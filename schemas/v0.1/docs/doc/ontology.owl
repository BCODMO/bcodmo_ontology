        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInstant"/>
        <rdfs:comment>The end of a temporal interval.</rdfs:comment>
        <rdfs:label>hasEnd</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasProgram -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasProgram">
