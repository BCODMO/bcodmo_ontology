    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/prov#wasAttributedTo -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasAttributedTo">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIStatus"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:comment>The person who set/attributed this DOI status (from PROV-O).</rdfs:comment>
        <rdfs:label>wasAttributedTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/affiliation -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/affiliation">
