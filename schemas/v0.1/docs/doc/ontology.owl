    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.wikidata.org/entity/Q5188229 -->


    <owl:NamedIndividual rdf:about="http://www.wikidata.org/entity/Q5188229">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/Organization"/>
        <label>Crossref</label>
    </owl:NamedIndividual>
    


    <!-- http://www.wikidata.org/entity/Q821542 -->


    <owl:NamedIndividual rdf:about="http://www.wikidata.org/entity/Q821542">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/Organization"/>
        <label>DataCite</label>
    </owl:NamedIndividual>
    


    <!-- https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm_MD5 -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm_MD5">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme"/>
        <owl:sameAs rdf:resource="urn:bcodmo:taxonomy:cryptographic-hash:190"/>
        <abbreviation>md5</abbreviation>
        <label>MD5</label>
    </owl:NamedIndividual>
    


    <!-- urn:bcodmo:taxonomy:cryptographic-hash:190 -->


    <rdf:Description rdf:about="urn:bcodmo:taxonomy:cryptographic-hash:190"/>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIStatus_Draft -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v0.1/DOIStatus_Draft">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/DOIStatus"/>
        <label>Draft</label>
        <rdfs:comment>The DOI record has been created locally but not yet registered.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIStatus_PublishFailed -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v0.1/DOIStatus_PublishFailed">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/DOIStatus"/>
        <label>Publish Failed</label>
        <rdfs:comment>DOI metadata publication failed after initiation.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIStatus_PublishInProgress -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v0.1/DOIStatus_PublishInProgress">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/DOIStatus"/>
        <label>Publish in Progress</label>
        <rdfs:comment>DOI metadata submission to the minter is in progress.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIStatus_PublishInitiateFailed -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v0.1/DOIStatus_PublishInitiateFailed">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/DOIStatus"/>
        <label>Publish Initiate Failed</label>
        <rdfs:comment>Initiating the DOI metadata publication failed.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIStatus_Published -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v0.1/DOIStatus_Published">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/DOIStatus"/>
        <label>Published</label>
        <rdfs:comment>The DOI is registered and publicly resolvable (Registered with DataCite).</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIStatus_Reserved -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v0.1/DOIStatus_Reserved">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v0.1/DOIStatus"/>
        <label>Reserved</label>
        <rdfs:comment>The DOI has been reserved/registered as Findable with DataCite.</rdfs:comment>
    </owl:NamedIndividual>
    


