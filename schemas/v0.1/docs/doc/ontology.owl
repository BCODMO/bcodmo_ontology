<?xml version="1.0"?>
<rdf:RDF xmlns="https://schema.bco-dmo.org/v0.1/"
     xml:base="https://schema.bco-dmo.org/v0.1/"
     xmlns:v0="https://schema.bco-dmo.org/v0.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#">
    <owl:Ontology rdf:about="https://schema.bco-dmo.org/v0.1/">
        <owl:versionIRI rdf:resource="https://schema.bco-dmo.org/v0.1/"/>
        <rdfs:comment>Ontology for the Biological and Chemical Oceanography Data Management Office (BCO-DMO).</rdfs:comment>
        <rdfs:label>BCO-DMO Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML -->


    <rdfs:Datatype rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#object -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#subject -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v0.1/hasBeginning"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasEnd -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasEnd">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v0.1/hasEnd"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/affiliation -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/affiliation">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Affiliation"/>
        <rdfs:comment>The institutional affiliation of a person.</rdfs:comment>
        <rdfs:label>affiliation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/author -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/author">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/AgentRole"/>
        <rdfs:comment>An author associated witha creative work. The Agent Role provides context as to how the agent contirbuted as an author to the work.</rdfs:comment>
        <rdfs:label>author</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/browseGraphic -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/browseGraphic">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Image"/>
        <rdfs:comment>An image that is representative of some thing. This could be a logo for a project or organization. It could also be an image that represents a creative work.</rdfs:comment>
        <rdfs:label>browseGraphic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/checksum -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/checksum">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v0.1/identifier"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/CryptographicHash"/>
        <rdfs:comment>A cryptographic hash for verifying file integrity.</rdfs:comment>
        <rdfs:label>checksum</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/conformsTo -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/conformsTo">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/MetadataProfile"/>
        <rdfs:comment>The metadata profile specification to which this dataset conforms.</rdfs:comment>
        <rdfs:label>conformsTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/contributor -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/contributor">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/AgentRole"/>
        <rdfs:comment>A contributor, not an author, associated with a creative work. The Agent Role provides context as to how the agent contributed to the work.</rdfs:comment>
        <rdfs:label>contributor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/createdDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/createdDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInstant"/>
        <rdfs:comment>The date on which a creative work was created.</rdfs:comment>
        <rdfs:label>createdDate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/currentState -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/currentState">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/CurrentState"/>
        <rdfs:comment>The editorial/curation state of the dataset.</rdfs:comment>
        <rdfs:label>currentState</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/dataFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/dataFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DataFile"/>
        <rdfs:comment>A primary or supplemental data file distributed with this dataset package.</rdfs:comment>
        <rdfs:label>dataFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/dataManagementPlan -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/dataManagementPlan">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/ResearchActivity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DataManagementPlan"/>
        <rdfs:comment>A file describing a research activities plan for managing their data.</rdfs:comment>
        <rdfs:label>dataManagementPlan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/dataType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/dataType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Datatype"/>
        <rdfs:comment>The data type of a dataset parameter.</rdfs:comment>
        <rdfs:label>dataType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/datasetType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/datasetType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetType"/>
        <rdfs:comment>A category or type classification for this dataset.</rdfs:comment>
        <rdfs:label>datasetType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/describesFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/describesFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/FileDescriptor"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
        <rdfs:comment>Links a file record to the File object describing its physical properties.</rdfs:comment>
        <rdfs:label>describesFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fileType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fileType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/FileType"/>
        <rdfs:comment>The format type of this file.</rdfs:comment>
        <rdfs:label>fileType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/forDataset -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/forDataset">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:comment>Links to a dataset.</rdfs:comment>
        <rdfs:label>forDataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fromDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fromDeployment">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetDeployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
        <rdfs:comment>Links a deployment and a dataset.</rdfs:comment>
        <rdfs:label>fromDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fromInstrument -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fromInstrument">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetInstrument"/>
        <rdfs:comment>Links a dataset to the instruments used to collect the data.</rdfs:comment>
        <rdfs:label>fromInstrument</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fundedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fundedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/FundingAgency"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/fundedByAward"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/provider"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>A funding organisation that supported the work resulting in this dataset.</rdfs:comment>
        <rdfs:label>fundedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fundedByAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fundedByAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Award"/>
        <rdfs:comment>the award that funded the creation, generation, etc of some creative work.</rdfs:comment>
        <rdfs:label>fundedByAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/geometry -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/geometry">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Geometry"/>
        <rdfs:comment>One or more geometries (centroid, bounding box) describing a geographical location.</rdfs:comment>
        <rdfs:label>geometry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/governedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/governedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Policy"/>
        <rdfs:comment>A policy (e.g. embargo) that governs access to this dataset.</rdfs:comment>
        <rdfs:label>governedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/grantedAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/grantedAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/FundingAgency"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Award"/>
        <rdfs:comment>An award (grant) issued by this funding organisation.</rdfs:comment>
        <rdfs:label>grantedAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasAgentWithRole -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasAgentWithRole">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/AgentRole"/>
        <rdfs:comment>Associates an agent with a qualified role on a dataset or deployment.</rdfs:comment>
        <rdfs:label>hasAgentWithRole</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasBeginning -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasBeginning">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInterval"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInstant"/>
        <rdfs:comment>The start of a temporal interval.</rdfs:comment>
        <rdfs:label>hasBeginning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasCoordinatedDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasCoordinatedDeployment">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
        <rdfs:comment>A disparate deployment that coordinated in conjuction with this subject for data collection</rdfs:comment>
        <rdfs:label>hasCoordinatedDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasCruiseTrajectory -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasCruiseTrajectory">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Cruise"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Geometry"/>
        <rdfs:comment>The set of ordered coordinates forming a geometry (usually MultiPoint) representing the path taken by a Cruise.</rdfs:comment>
        <rdfs:label>hasCruiseTrajectory</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasEnd -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasEnd">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInterval"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInstant"/>
        <rdfs:comment>The end of a temporal interval.</rdfs:comment>
        <rdfs:label>hasEnd</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasParameter -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasParameter">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v0.1/storesValuesFor"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
        <rdfs:comment xml:lang="en">A dataset collected this dataset-parameter</rdfs:comment>
        <rdfs:label xml:lang="en">hasParameter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasParameterAttribute -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasParameterAttribute">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameterAttribute"/>
        <rdfs:comment>An attribute of a particular DatasetParameter</rdfs:comment>
        <rdfs:label>hasParameterAttribute</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasParentProgram -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasParentProgram">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Project"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Program"/>
        <rdfs:comment>The Program that enabled a Project&apos;s existence</rdfs:comment>
        <rdfs:label>hasParentProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasProgram -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasProgram">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Program"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/hasProject"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/hasParentProgram"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>Associates a dataset with a scientific program.</rdfs:comment>
        <rdfs:label>hasProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasProject -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasProject">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Project"/>
        <rdfs:comment>Associates a dataset with a scientific project.</rdfs:comment>
        <rdfs:label>hasProject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasSynonym -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasSynonym">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Synonym"/>
        <rdfs:comment>An alternative name used for a deployment.</rdfs:comment>
        <rdfs:label>hasSynonym</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/identifier -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/identifier">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Identifier"/>
        <rdfs:comment>An identifier assigned to a resource.</rdfs:comment>
        <rdfs:label>identifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/identifierScheme -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/identifierScheme">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Identifier"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme"/>
        <rdfs:comment>The scheme (authority) that defines the identifier.</rdfs:comment>
        <rdfs:label>identifierScheme</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/inGroup -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/inGroup">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/ResourceRelation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/ResourceRelationGroup"/>
        <rdfs:comment>The group/category to which a resource relation type belongs.</rdfs:comment>
        <rdfs:label>inGroup</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/isTypeOf -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/isTypeOf">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DatasetInstrument"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Instrument"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Links a dataset-level parameter or instrument instance to its master (community vocabulary) definition.</rdfs:comment>
        <rdfs:label>isTypeOf</rdfs:label>
    </owl:ObjectProperty>
    


