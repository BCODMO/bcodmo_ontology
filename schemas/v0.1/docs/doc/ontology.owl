    <!-- https://schema.bco-dmo.org/v0.1/description -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/description">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of a resource.</rdfs:comment>
        <rdfs:label>description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/eastBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/eastBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The eastern longitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>eastBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/encoding -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/encoding">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The character encoding of a file (e.g. utf-8).</rdfs:comment>
        <rdfs:label>encoding</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/expirationDate -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/expirationDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/EmbargoPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which an embargo expires and the dataset becomes publicly accessible.</rdfs:comment>
        <rdfs:label>expirationDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/externalWebsite -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/externalWebsite">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>The external project or program website URL.</rdfs:comment>
        <rdfs:label>externalWebsite</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/familyName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/familyName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The family (last) name of a person.</rdfs:comment>
        <rdfs:label>familyName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/filename -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/filename">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The file name including extension.</rdfs:comment>
        <rdfs:label>filename</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/givenName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/givenName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The given (first) name of a person.</rdfs:comment>
        <rdfs:label>givenName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasReportURL -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasReportURL">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>A URL linking to the cruise/deployment report.</rdfs:comment>
        <rdfs:label>hasReportURL</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/honorific -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/honorific">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Honorific for a Person.</rdfs:comment>
        <rdfs:label>honorific</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/identifierValue -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/identifierValue">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The raw identifier string value (e.g. the DOI suffix, the ROR ID).</rdfs:comment>
        <rdfs:label>identifierValue</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/isPrimaryDataFile -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/isPrimaryDataFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DataFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether this is the primary data file of a dataset (true/false).</rdfs:comment>
        <rdfs:label>isPrimaryDataFile</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/label -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/label">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A human-readable label for any BCO-DMO resource.</rdfs:comment>
        <rdfs:label>label</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/middleName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/middleName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The middle name or initial of a person.</rdfs:comment>
        <rdfs:label>middleName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/mimeType -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/mimeType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/FileType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The MIME type associated with a file type.</rdfs:comment>
        <rdfs:label>mimeType</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/name -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A name property (used on Language and similar small vocabulary resources).</rdfs:comment>
        <rdfs:label>name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/nickname -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/nickname">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Nickname, or preferred name, of a Person</rdfs:comment>
        <rdfs:label>nickname</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/noDataValue -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/noDataValue">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The value to expect in a DatasetParameter when there was no data for the given record.</rdfs:comment>
        <rdfs:label>noDataValue</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/northBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/northBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The northern latitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>northBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/officialName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/officialName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Parameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official name for a master parameter.</rdfs:comment>
        <rdfs:label>officialName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/problemDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/problemDescription">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of known problems or caveats with the dataset.</rdfs:comment>
        <rdfs:label>problemDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/processingDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/processingDescription">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DatasetDeployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Deployment"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
        <rdfs:comment>An HTML description of data processing steps.</rdfs:comment>
        <rdfs:label>processingDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/requiresConversion -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/requiresConversion">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>The values in the dataset for this property need to be converted.</rdfs:comment>
        <rdfs:label>requiresConversion</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/resolvableUrl -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/resolvableUrl">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>A resolvable URL that dereferences the identifier.</rdfs:comment>
        <rdfs:label>resolvableUrl</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/restricted -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/restricted">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Is the dataset restricted for access by the public.</rdfs:comment>
        <rdfs:label>restricted</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/roleWeight -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/roleWeight">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Role"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment>Sort ordering of role types</rdfs:comment>
        <rdfs:label>roleWeight</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/shortDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/shortDescription">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
        <rdfs:comment>A brief HTML description of the dataset.</rdfs:comment>
        <rdfs:label>shortDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/shortName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/shortName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Parameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A short name for a master parameter.</rdfs:comment>
        <rdfs:label>shortName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/southBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/southBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The southern latitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>southBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/title -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/title">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The full title of the dataset.</rdfs:comment>
        <rdfs:label>title</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/url -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/url">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>A URL for a resource, such as its landing page.</rdfs:comment>
        <rdfs:label>url</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/validated -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/validated">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Has the dataset been validated by the PI.</rdfs:comment>
        <rdfs:label>validated</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/valueFormat -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/valueFormat">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The format string used to encode parameter values in the data file.</rdfs:comment>
        <rdfs:label>valueFormat</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/version -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/version">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The version label of the dataset (numeric or numeric + single lowercase letter).</rdfs:comment>
        <rdfs:label>version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/westBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v0.1/westBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The western longitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>westBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement -->


    <owl:Class rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    


    <!-- http://www.w3.org/2006/time#Instant -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#Instant"/>
    


    <!-- http://www.w3.org/2006/time#Interval -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#Interval"/>
    


    <!-- https://schema.bco-dmo.org/v0.1/Action -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Action">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>Some action that can be taken on an Entity. A Policy can restrict and allow actions</rdfs:comment>
        <rdfs:label>Action</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Affiliation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Affiliation">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Organization"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty>
                                    <rdf:Description>
                                        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/affiliation"/>
                                    </rdf:Description>
                                </owl:onProperty>
                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty>
                                    <rdf:Description>
                                        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/performedAt"/>
                                    </rdf:Description>
                                </owl:onProperty>
                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/AgentRole"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>An institutional affiliation of a person (university, research institute, etc.).</rdfs:comment>
        <rdfs:label>Affiliation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Agent -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Agent">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>An entity (person or organisation) that can perform roles.</rdfs:comment>
        <rdfs:label>Agent</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/AgentRole -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/AgentRole">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/performedBy"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Agent"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/role"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Role"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>A qualified association that links an Agent to a role and optionally an affiliation context.</rdfs:comment>
        <rdfs:label>Agent Role</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/ArchiveFileType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/ArchiveFileType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/FileType"/>
        <rdfs:comment>A file format  used to bundle multiple files and folders into a single file for easier storage or transfer.</rdfs:comment>
        <rdfs:label>ArchiveFileType</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Award -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Award">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/provider"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/FundingAgency"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/fundedByAward"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A funding award (grant) from a funder that supports data collection.</rdfs:comment>
        <rdfs:label>Award</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/BCODMOIdentifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/BCODMOIdentifier">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Identifier"/>
        <rdfs:comment>An internal BCO-DMO identifier (version 2 scheme).</rdfs:comment>
        <rdfs:label>BCO-DMO Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Geometry"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/eastBoundary"/>
                                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/northBoundary"/>
                                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/southBoundary"/>
                                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/westBoundary"/>
                                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>An axis-aligned bounding box geometry defined by west/south/east/north boundaries.</rdfs:comment>
        <rdfs:label>Bounding Box Geometry</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Category -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Category">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>A set of taxonomy</rdfs:comment>
        <rdfs:label>Category</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/CentroidGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/CentroidGeometry">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Geometry"/>
        <rdfs:comment>A point geometry representing the centroid of a spatial extent.</rdfs:comment>
        <rdfs:label>Centroid Geometry</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/ConsumeAction -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/ConsumeAction">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Action"/>
        <rdfs:comment>The act of consuming an Entity.</rdfs:comment>
        <rdfs:label>ConsumeAction</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/CreativeWork -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/CreativeWork">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>Any work that can be created by some Agent</rdfs:comment>
        <rdfs:label>Creative Work</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/CreativeWorkStatus -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/CreativeWorkStatus">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A state of for some createive work.</rdfs:comment>
        <rdfs:label>CreativeWorkStatus</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Cruise -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Cruise">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Deployment"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/onPlatform"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Vessel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A research vessel cruise, a specialisation of Platform for vessel-type platforms.</rdfs:comment>
        <rdfs:label>Cruise</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/CryptographicHash -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/CryptographicHash">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Identifier"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/identifierScheme"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A cryptographic hash (e.g. MD5) used as a file integrity checksum.</rdfs:comment>
        <rdfs:label>Cryptographic Hash</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme"/>
        <rdfs:comment>A mathematical function that transforms any arbitrary amount of input data into a fixed-length string of characters (identifierValue), acting as a secure &quot;digital fingerprint&quot; or &quot;digest&quot;</rdfs:comment>
        <rdfs:label>Cryptographic Hash Algorithm</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/CurrentState -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/CurrentState">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>The current editorial/curation state of a CreativeWork</rdfs:comment>
        <rdfs:label>Current State</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIDataset -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DOIDataset">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/identifier"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/identifierScheme"/>
                                <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme_DOI"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A versioned BCO-DMO dataset that has been assigned a DOI.</rdfs:comment>
        <rdfs:label>DOI Dataset</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIIdentifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DOIIdentifier">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Identifier"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/identifierScheme"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme_DOI"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A Digital Object Identifier.</rdfs:comment>
        <rdfs:label>DOI Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DOIStatus -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DOIStatus">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWorkStatus"/>
        <rdfs:comment>The lifecycle status of a DOI Dataset (Draft, Reserved, Published, etc.).</rdfs:comment>
        <rdfs:label>DOI Status</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DataFile -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DataFile">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/dataFile"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A primary or supplemental data file distributed as part of a dataset.</rdfs:comment>
        <rdfs:label>Data File</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DataManagementPlan -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DataManagementPlan">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/dataManagementPlan"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A plan describing how a research activity will manage and archive data products produced.</rdfs:comment>
        <rdfs:label>DataManagementPlan</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Dataset -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Dataset">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:comment>A dataset which may be internal or external to BCO-DMO.</rdfs:comment>
        <rdfs:label>Dataset</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DatasetAward -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DatasetAward">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/fundedByAward"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Award"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/forDataset"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>The connection between a dataset and the award the funded its generation</rdfs:comment>
        <rdfs:label>DatasetAward</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DatasetDeployment -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DatasetDeployment">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/fromDeployment"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/forDataset"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A deployment as referenced within a specific dataset, with dataset-specific properties.</rdfs:comment>
        <rdfs:label>Dataset Deployment</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DatasetInstrument -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DatasetInstrument">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/isTypeOf"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Instrument"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/forDataset"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>An instrument as referenced within a specific dataset, with dataset-specific properties.</rdfs:comment>
        <rdfs:label>Dataset Instrument</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DatasetParameter -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DatasetParameter">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/isTypeOf"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Parameter"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/forDataset"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A parameter as instantiated within a specific dataset column, with dataset-level name, description, units, and format.</rdfs:comment>
        <rdfs:label>Dataset Parameter</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DatasetParameterAttribute -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DatasetParameterAttribute">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>An attribute of a dataset parameter that provides more context as to how it could be used.</rdfs:comment>
        <rdfs:label>DatasetParameterAttribute</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DatasetType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DatasetType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A category describing the type of dataset (e.g. Cruise Data, Model Output).</rdfs:comment>
        <rdfs:label>Dataset Type</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Datatype -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Datatype">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>The data type of a dataset parameter column (e.g. string, integer, float).</rdfs:comment>
        <rdfs:label>Datatype</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Deployment -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Deployment">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/onPlatform"/>
                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Platform"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A scientific deployment (cruise, expedition, mooring deployment) during which data were collected.</rdfs:comment>
        <rdfs:label>Deployment</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/DeploymentEntityMatch -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/DeploymentEntityMatch">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/EntityMatch"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/EmailAddress -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/EmailAddress">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierString"/>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v0.1/Datatype_EmailAddress"/>
        <rdfs:label>Email Address</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/EmbargoPolicy -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/EmbargoPolicy">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Policy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/modifiesAction"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/ConsumeAction"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/target"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/expirationDate"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A policy that restricts access to a dataset until an expiration date.</rdfs:comment>
        <rdfs:label>Embargo Policy</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/EmbargoReleasePolicy -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/EmbargoReleasePolicy">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Policy"/>
        <rdfs:comment>A policy that allows access to a FileDescriptor when its overarching Dataset is under an embargo.</rdfs:comment>
        <rdfs:label>EmbargoReleasePolicy</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Entity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Entity">
        <rdfs:comment>A BCO-DMO specific concept</rdfs:comment>
        <rdfs:label>Entity</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/EntityMatch -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/EntityMatch">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A link between two entities that are related in some way as defined by rdf:predicate. This entity allows for annotating details of the match.</rdfs:comment>
        <rdfs:label>EntityMatch</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/File -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/File">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:comment>A physical file (byte stream) associated with a dataset or package.</rdfs:comment>
        <rdfs:label>File</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/FileDescriptor -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/FileDescriptor">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/describesFile"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A context-specific description of a file. The context could be data, metadata or supplemental documentation.</rdfs:comment>
        <rdfs:label>File Descriptor</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/FileType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/FileType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A file format type, characterised by a label and MIME type (e.g. CSV, XML, PDF).</rdfs:comment>
        <rdfs:label>File Type</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/FundingAgency -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/FundingAgency">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Organization"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/grantedAward"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Award"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>An Organization that has provided some funding award</rdfs:comment>
        <rdfs:label>Funding Agency</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/GeographicalLocation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/GeographicalLocation">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>A spatial extent or named location associated with a dataset, deployment, project, or program.</rdfs:comment>
        <rdfs:label>Geographical Location</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Geometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Geometry">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>An abstract spatial geometry.</rdfs:comment>
        <rdfs:label>Geometry</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Identifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Identifier">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>An identifier assigned to a resource by some scheme.</rdfs:comment>
        <rdfs:label>Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/IdentifierScheme -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/IdentifierScheme">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A named scheme or authority that mints identifiers (DOI, ROR, ORCID, etc.).</rdfs:comment>
        <rdfs:label>Identifier Scheme</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/IdentifierString -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/IdentifierString">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/String"/>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v0.1/Datatype_Identifier"/>
        <rdfs:label xml:lang="en">IdentifierString</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Image -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Image">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/File"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/fileType"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/ImageFileType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>An image file.</rdfs:comment>
        <rdfs:label>Image</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/ImageFileType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/ImageFileType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/FileType"/>
        <rdfs:comment>Representative of a type of image file.</rdfs:comment>
        <rdfs:label>ImageFileType</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Instrument -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Instrument">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A master (community-level) scientific instrument definition.</rdfs:comment>
        <rdfs:label>Instrument</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Keyword -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Keyword">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A subject keyword associated with a dataset.</rdfs:comment>
        <rdfs:label>Keyword</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Language -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Language">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A natural language used in the dataset metadata.</rdfs:comment>
        <rdfs:label>Language</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/License -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/License">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/license"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A  license applied to some creative work.</rdfs:comment>
        <rdfs:label>License</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Logo -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Logo">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Image"/>
        <rdfs:comment>An image that is representative of some thing</rdfs:comment>
        <rdfs:label>Logo</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/MetadataFile -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/MetadataFile">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/metadataFile"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A metadata file (e.g. ISO 19115-2 XML, dataset description PDF) describing a dataset.</rdfs:comment>
        <rdfs:label>Metadata File</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/MetadataProfile -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/MetadataProfile">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:comment>A formal metadata profile specification to which the datapackage conforms.</rdfs:comment>
        <rdfs:label>Metadata Profile</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/ORCIDIdentifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/ORCIDIdentifier">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Identifier"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/identifierScheme"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme_ROR"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>An Open Researcher and Contributor ID</rdfs:comment>
        <rdfs:label>ORCID Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Organization -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Organization">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Agent"/>
        <owl:disjointWith rdf:resource="https://schema.bco-dmo.org/v0.1/Person"/>
        <rdfs:comment>An organisational body such as a publisher, funder, or identifier authority.</rdfs:comment>
        <rdfs:label>Organization</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Parameter -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Parameter">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A master (community-level) scientific parameter definition.</rdfs:comment>
        <rdfs:label>Parameter</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Person -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Person">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Agent"/>
        <rdfs:comment>A human individual associated with some entity.</rdfs:comment>
        <rdfs:label>Person</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Platform -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Platform">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>A platform (vessel, buoy, glider, etc.) used for data collection.</rdfs:comment>
        <rdfs:label>Platform</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/PlatformTitle -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/PlatformTitle">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A named title/designation for a platform (e.g. the full name of a research vessel).</rdfs:comment>
        <rdfs:label>Platform Title</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/PlatformType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/PlatformType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A category of platform (e.g. vessel, mooring, glider).</rdfs:comment>
        <rdfs:label>Platform Type</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Policy -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Policy">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Entity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/modifiesAction"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/ConsumeAction"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/target"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>An access or governance policy applied to a resource.</rdfs:comment>
        <rdfs:label>Policy</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Program -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Program">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/ResearchActivity"/>
        <rdfs:comment>A scientific program (typically a grouping of related projects) associated with a dataset.</rdfs:comment>
        <rdfs:label>Program</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Project -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Project">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/ResearchActivity"/>
        <rdfs:comment>A funded scientific project under which data were collected.</rdfs:comment>
        <rdfs:label>Project</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Publication -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Publication">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:comment>A scholarly publication related to a dataset (journal article, report, etc.).</rdfs:comment>
        <rdfs:label>Publication</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/RORIdentifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/RORIdentifier">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Identifier"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/identifierScheme"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme_ROR"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A Research Organization Registry identifier.</rdfs:comment>
        <rdfs:label>ROR Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/ResearchActivity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/ResearchActivity">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>An activity that enables research. The research typically produces datasets.</rdfs:comment>
        <rdfs:label>Research Activity</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/ResourceRelation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/ResourceRelation">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A controlled-vocabulary term describing the relationship between two resources (aligned to Crossref and DataCite relation types).</rdfs:comment>
        <rdfs:label>Resource Relation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/ResourceRelationGroup -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/ResourceRelationGroup">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Category"/>
        <rdfs:comment>A grouping category for resource relation types.</rdfs:comment>
        <rdfs:label>Resource Relation Group</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Role -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Role">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Category"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v0.1/roleWeight"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A functional role performed by an agent (e.g. Principal Investigator, Co-Investigator).</rdfs:comment>
        <rdfs:label>Role</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/String -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/String">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Datatype"/>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v0.1/Datatype_String"/>
        <rdfs:label xml:lang="en">String</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://schema.org/Text"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/SupplementalDocument -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/SupplementalDocument">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v0.1/supplementalDocument"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A supplemental (non-primary) document file associated with a dataset.</rdfs:comment>
        <rdfs:label>Supplemental Document</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/Synonym -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/Synonym">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>An alternative name or synonym, e.g. for a deployment.</rdfs:comment>
        <rdfs:label>Synonym</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/TemporalEntity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/TemporalEntity">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/Entity"/>
        <rdfs:comment>A frame of reference for when something existed or occupied time — it is either a durationless point (an instant) or a thing with some extent in time (an interval).</rdfs:comment>
        <rdfs:label>TemporalEntity</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/TemporalInstant -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/TemporalInstant">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalEntity"/>
        <rdfs:comment>A single point in time associated with a dataset extent or event date.</rdfs:comment>
        <rdfs:label>Temporal Instant</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/TemporalInterval -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/TemporalInterval">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalEntity"/>
        <rdfs:comment>A time period with a beginning and an end, used to describe dataset temporal coverage.</rdfs:comment>
        <rdfs:label>Temporal Interval</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v0.1/URL -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v0.1/URL">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierString"/>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v0.1/Datatype_URL"/>
