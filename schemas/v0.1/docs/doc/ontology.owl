        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Affiliation"/>
        <rdfs:comment>The primary institutional affiliation of a person.</rdfs:comment>
        <rdfs:label>affiliation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/author -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/author">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/AgentRole"/>
        <rdfs:comment>An ordered list of authors associated with the dataset (via AgentRole).</rdfs:comment>
        <rdfs:label>author</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/checksum -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/checksum">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v0.1/identifier"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/CryptographicHash"/>
        <rdfs:comment>A cryptographic hash for verifying file integrity.</rdfs:comment>
        <rdfs:label>checksum</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/conformsTo -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/conformsTo">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/MetadataProfile"/>
        <rdfs:comment>The metadata profile specification to which this datapackage conforms.</rdfs:comment>
        <rdfs:label>conformsTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/contributor -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/contributor">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/AgentRole"/>
        <rdfs:comment>An ordered list of contributors associated with the dataset (via AgentRole).</rdfs:comment>
        <rdfs:label>contributor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/createdDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/createdDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInstant"/>
        <rdfs:comment>The date on which this datapackage record was created.</rdfs:comment>
        <rdfs:label>createdDate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/currentState -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/currentState">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/CurrentState"/>
        <rdfs:comment>The editorial/curation state of the dataset.</rdfs:comment>
        <rdfs:label>currentState</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/dataFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/dataFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DataFile"/>
        <rdfs:comment>A primary or supplemental data file distributed with this dataset package.</rdfs:comment>
        <rdfs:label>dataFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/dataType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/dataType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Datatype"/>
        <rdfs:comment>The data type of a dataset parameter.</rdfs:comment>
        <rdfs:label>dataType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/datasetType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/datasetType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetType"/>
        <rdfs:comment>A category or type classification for this dataset.</rdfs:comment>
        <rdfs:label>datasetType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/describesFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/describesFile">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DataFile"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/MetadataFile"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/SupplementalDocument"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
        <rdfs:comment>Links a file record to the File object describing its physical properties.</rdfs:comment>
        <rdfs:label>describesFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fileType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fileType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/FileType"/>
        <rdfs:comment>The format type of this file.</rdfs:comment>
        <rdfs:label>fileType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/forDataset -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/forDataset">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Dataset"/>
        <rdfs:comment>Links to a dataset.</rdfs:comment>
        <rdfs:label>forDataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fromDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fromDeployment">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetDeployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
        <rdfs:comment>Links a deployment and a dataset.</rdfs:comment>
        <rdfs:label>fromDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fromInstrument -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fromInstrument">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/DatasetInstrument"/>
        <rdfs:comment>Links a dataset to the instruments used to collect the data.</rdfs:comment>
        <rdfs:label>fromInstrument</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/fundedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/fundedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Organization"/>
        <rdfs:comment>A funding organisation that supported the work resulting in this dataset.</rdfs:comment>
        <rdfs:label>fundedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/geometry -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/geometry">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/GeographicalLocation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Geometry"/>
        <rdfs:comment>One or more geometries (centroid, bounding box) describing a geographical location.</rdfs:comment>
        <rdfs:label>geometry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/governedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/governedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Policy"/>
        <rdfs:comment>A policy (e.g. embargo) that governs access to this dataset.</rdfs:comment>
        <rdfs:label>governedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/grantedAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/grantedAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/FundingAgency"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Award"/>
        <rdfs:comment>An award (grant) issued by this funding organisation.</rdfs:comment>
        <rdfs:label>grantedAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasAgentWithRole -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasAgentWithRole">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/AgentRole"/>
        <rdfs:comment>Associates an agent with a qualified role on a dataset or deployment.</rdfs:comment>
        <rdfs:label>hasAgentWithRole</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasBeginning -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasBeginning">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInterval"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInstant"/>
        <rdfs:comment>The start of a temporal interval.</rdfs:comment>
        <rdfs:label>hasBeginning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasEnd -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasEnd">
