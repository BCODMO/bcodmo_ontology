        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Program"/>
        <rdfs:comment>Associates a dataset with a scientific program.</rdfs:comment>
        <rdfs:label>hasProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasProject -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasProject">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Project"/>
        <rdfs:comment>Associates a dataset with a scientific project.</rdfs:comment>
        <rdfs:label>hasProject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/hasSynonym -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/hasSynonym">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Synonym"/>
        <rdfs:comment>An alternative name used for a deployment.</rdfs:comment>
        <rdfs:label>hasSynonym</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/identifier -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/identifier">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Affiliation"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DataFile"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Organization"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Person"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Identifier"/>
        <rdfs:comment>An identifier assigned to a resource.</rdfs:comment>
        <rdfs:label>identifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/identifierScheme -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/identifierScheme">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/Identifier"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/IdentifierScheme"/>
        <rdfs:comment>The scheme (authority) that defines the identifier.</rdfs:comment>
        <rdfs:label>identifierScheme</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/inGroup -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/inGroup">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/ResourceRelation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/ResourceRelationGroup"/>
        <rdfs:comment>The group/category to which a resource relation type belongs.</rdfs:comment>
        <rdfs:label>inGroup</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/isTypeOf -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/isTypeOf">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DatasetInstrument"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/DatasetParameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Instrument"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Links a dataset-level parameter or instrument instance to its master (community vocabulary) definition.</rdfs:comment>
        <rdfs:label>isTypeOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/issuedDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/issuedDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/TemporalInstant"/>
        <rdfs:comment>The date on which the DOI was issued for this dataset.</rdfs:comment>
        <rdfs:label>issuedDate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/keywords -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/keywords">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Keyword"/>
        <rdfs:comment>Subject keywords associated with this dataset.</rdfs:comment>
        <rdfs:label>keywords</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/language -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/language">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/Language"/>
        <rdfs:comment>The natural language used in the dataset metadata.</rdfs:comment>
        <rdfs:label>language</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/license -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/license">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/License"/>
        <rdfs:comment>The data license applied to this dataset.</rdfs:comment>
        <rdfs:label>license</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/matches -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/matches">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Instrument"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/Parameter"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v0.1/ResourceRelation"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:comment>Aligns a BCO-DMO vocabulary term with an equivalent term from an external community vocabulary (e.g. SeaDataNet, NERC, Crossref, DataCite).</rdfs:comment>
        <rdfs:label>matches</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/metadataFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/metadataFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v0.1/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v0.1/MetadataFile"/>
        <rdfs:comment>A metadata file (ISO XML, description PDF) bundled in the dataset package.</rdfs:comment>
        <rdfs:label>metadataFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v0.1/obsoletes -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v0.1/obsoletes">
