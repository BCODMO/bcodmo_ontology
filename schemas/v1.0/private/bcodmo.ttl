@prefix : <https://schema.bco-dmo.org/internal/v1.0/> .
@prefix sf: <http://www.opengis.net/ont/sf#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix wgs84: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix bcodmo: <https://schema.bco-dmo.org/v1.0/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://schema.bco-dmo.org/internal/v1.0/> .

<https://schema.bco-dmo.org/internal/v1.0/> rdf:type owl:Ontology ;
                                             owl:versionIRI <https://schema.bco-dmo.org/internal/v1.0/> ;
                                             owl:imports bcodmo: ;
                                             rdfs:comment "The Private Ontology for the Biological and Chemical Oceanography Data Management Office (BCO-DMO)." ;
                                             rdfs:label "BCO-DMO Ontology (***PRIVATE***)" .

#################################################################
#    Object Properties
#################################################################

###  https://schema.bco-dmo.org/internal/v1.0/classifiedAs
:classifiedAs rdf:type owl:ObjectProperty ;
              rdfs:domain bcodmo:Event ;
              rdfs:range bcodmo:Action ;
              rdfs:comment "The Action that classifies some Event" ;
              rdfs:label "classifiedAs" .


###  https://schema.bco-dmo.org/internal/v1.0/containedInS3Bucket
:containedInS3Bucket rdf:type owl:ObjectProperty ;
                     owl:inverseOf :s3BucketContains ;
                     rdfs:domain :S3Object ;
                     rdfs:range :S3Bucket ;
                     rdfs:comment "The bucket containing this S3Object" ;
                     rdfs:label "containedInS3Bucket" .


###  https://schema.bco-dmo.org/internal/v1.0/eventDate
:eventDate rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain bcodmo:Event ;
           rdfs:range bcodmo:TemporalEntity ;
           rdfs:comment "The date of some Event" ;
           rdfs:label "eventDate" .


###  https://schema.bco-dmo.org/internal/v1.0/fileFromSubmission
:fileFromSubmission rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf bcodmo:situationInvolves ;
                    rdfs:domain :S3Object ;
                    rdfs:range :Submission ;
                    rdfs:comment "The Submission from which this file originated" ;
                    rdfs:label "fileFromSubmission" .


###  https://schema.bco-dmo.org/internal/v1.0/hasCategoryType
:hasCategoryType rdf:type owl:ObjectProperty ;
                 owl:equivalentProperty bcodmo:isDefinedAs ;
                 rdfs:comment "The Category for some Entity" ;
                 rdfs:label "hasCategoryType" .


###  https://schema.bco-dmo.org/internal/v1.0/hasEventMetrics
:hasEventMetrics rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf bcodmo:situationInvolves ;
                 rdfs:domain bcodmo:CreativeWork ;
                 rdfs:comment "The EventMetrics related to a CreativeWork" ;
                 rdfs:label "hasEventMetrics" .


###  https://schema.bco-dmo.org/internal/v1.0/s3BucketContains
:s3BucketContains rdf:type owl:ObjectProperty ;
                  rdfs:domain :S3Bucket ;
                  rdfs:range :S3Object ;
                  rdfs:label "An object contained within an S3Bucket" ,
                             "s3BucketContains" .


###  https://schema.bco-dmo.org/internal/v1.0/s3ObjectSource
:s3ObjectSource rdf:type owl:ObjectProperty ;
                rdfs:domain :S3Object ;
                rdfs:range :S3Object ;
                rdfs:comment "A representation of the source from which an S3Object originated" ;
                rdfs:label "s3ObjectSource" .


#################################################################
#    Data properties
#################################################################

###  https://schema.bco-dmo.org/internal/v1.0/awsJobId
:awsJobId rdf:type owl:DatatypeProperty ;
          rdfs:domain :S3Object ;
          rdfs:range xsd:token ;
          rdfs:comment "The AWS Job identifier relevent to some thing." ;
          rdfs:label "awsJobId" .


###  https://schema.bco-dmo.org/internal/v1.0/awsObjectId
:awsObjectId rdf:type owl:DatatypeProperty ;
             rdfs:domain :S3Object ;
             rdfs:range xsd:token ;
             rdfs:label "awsObjectId" .


###  https://schema.bco-dmo.org/internal/v1.0/awsSourcePath
:awsSourcePath rdf:type owl:DatatypeProperty ;
               rdfs:domain :S3Object ;
               rdfs:range xsd:token ;
               rdfs:comment "The source path of some S3 object" ;
               rdfs:label "awsSourcePath" .


###  https://schema.bco-dmo.org/internal/v1.0/executionFrequency
:executionFrequency rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :DatasetUsageMetricsHarvest ;
                    rdfs:range xsd:string ;
                    rdfs:comment "A label for how often a certain activity is run" ;
                    rdfs:label "executionFrequency" .


###  https://schema.bco-dmo.org/internal/v1.0/s3KeyPrefix
:s3KeyPrefix rdf:type owl:DatatypeProperty ;
             rdfs:domain :S3Object ;
             rdfs:range xsd:token ;
             rdfs:comment "The prefix path for an S3 object" ;
             rdfs:label "s3KeyPrefix" .


###  https://schema.bco-dmo.org/internal/v1.0/s3Url
:s3Url rdf:type owl:DatatypeProperty ;
       rdfs:domain :S3Object ;
       rdfs:range xsd:token ;
       rdfs:comment "The S3 URL in the form of s3://{bucket-name}/{prefix-path}/{filename}" ;
       rdfs:label "s3Url" .


###  https://schema.bco-dmo.org/internal/v1.0/totalCount
:totalCount rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :EventMetrics ;
            rdfs:range xsd:integer ;
            rdfs:comment "The number of occurences for some EventMetrics" ;
            rdfs:label "totalCount" .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/prov#Activity
prov:Activity rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
prov:Entity rdf:type owl:Class .


###  https://schema.bco-dmo.org/internal/v1.0/CurrentStateComment
:CurrentStateComment rdf:type owl:Class ;
                     rdfs:subClassOf bcodmo:Situation ;
                     rdfs:comment "To be a subclass of Annotation" ;
                     rdfs:label "CurrentStateComment" .


###  https://schema.bco-dmo.org/internal/v1.0/DatasetSubmission
:DatasetSubmission rdf:type owl:Class ;
                   rdfs:subClassOf :Submission ;
                   rdfs:comment "A submitted Dataset" ;
                   rdfs:label "DatasetSubmission" .


###  https://schema.bco-dmo.org/internal/v1.0/DatasetUsageMetricsHarvest
:DatasetUsageMetricsHarvest rdf:type owl:Class ;
                            rdfs:subClassOf prov:Activity ;
                            rdfs:comment "A harvest run looking for EventMetrics for a specific TemporalEntity" ;
                            rdfs:label "DatasetUsageMetricsHarvest" .


###  https://schema.bco-dmo.org/internal/v1.0/EventMetrics
:EventMetrics rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( bcodmo:Event
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :classifiedAs ;
                                                           owl:someValuesFrom bcodmo:ConsumeAction
                                                         ]
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :eventDate ;
                                                           owl:someValuesFrom bcodmo:TemporalInstant
                                                         ]
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty bcodmo:situationInvolves ;
                                                           owl:someValuesFrom bcodmo:Dataset
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf bcodmo:Event ;
              rdfs:comment "Metrics for a CreativeWorkas a result of some Event" ;
              rdfs:label "EventMetrics" .


###  https://schema.bco-dmo.org/internal/v1.0/MetricsCategory
:MetricsCategory rdf:type owl:Class ;
                 rdfs:subClassOf bcodmo:DefinedType ;
                 rdfs:comment "The type of metric that was inferred into counting toward some Action on an EventMetrics" ;
                 rdfs:label "MetricsCategory" .


###  https://schema.bco-dmo.org/internal/v1.0/NoDatasetDOIReason
:NoDatasetDOIReason rdf:type owl:Class ;
                    rdfs:subClassOf bcodmo:Category ;
                    rdfs:comment "A reason why a Dataset will not get a DOI." ;
                    rdfs:label "NoDatasetDOIReason" .


###  https://schema.bco-dmo.org/internal/v1.0/ProjectSubmission
:ProjectSubmission rdf:type owl:Class ;
                   rdfs:subClassOf :Submission ;
                   rdfs:comment "A submitted Project" ;
                   rdfs:label "ProjectSubmission" .


###  https://schema.bco-dmo.org/internal/v1.0/S3Bucket
:S3Bucket rdf:type owl:Class ;
          rdfs:subClassOf bcodmo:Entity ;
          rdfs:comment "An S3 bucket for storing objects" ;
          rdfs:label "S3Bucket" .


###  https://schema.bco-dmo.org/internal/v1.0/S3Object
:S3Object rdf:type owl:Class ;
          rdfs:subClassOf [ owl:intersectionOf ( bcodmo:FileDescriptor
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :containedInS3Bucket ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onClass :S3Bucket
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty bcodmo:filename ;
                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onDataRange xsd:string
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :s3KeyPrefix ;
                                                   owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                   owl:onDataRange xsd:string
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
          rdfs:comment "An S3 storage location." ;
          rdfs:label "S3Object" .


###  https://schema.bco-dmo.org/internal/v1.0/StoredReportedEvent
:StoredReportedEvent rdf:type owl:Class ;
                     rdfs:subClassOf prov:Entity ;
                     rdfs:comment "Raw event data that needs to be interpreted into EventMetrics" ;
                     rdfs:label "StoredReportedEvent" .


###  https://schema.bco-dmo.org/internal/v1.0/Submission
:Submission rdf:type owl:Class ;
            rdfs:subClassOf bcodmo:CreativeWork ;
            rdfs:comment "A PI-curated submission of project or dataset metadata and creativeworks" ;
            rdfs:label "Submission" .


###  https://schema.bco-dmo.org/v1.0/MetricsCategory
bcodmo:MetricsCategory rdf:type owl:Class .


