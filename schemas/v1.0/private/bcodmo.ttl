<http://schema.bco-dmo.org/datasource/ga4> a prov:Entity ;
        bcodmo:label "Google Analytics 4" .

<http://schema.bco-dmo.org/application#GA4HarvesterDatasetUsageMetrics> a bcodmo:SoftwareApplication ;
        rdfs:comment	"Software for extracting and processing GA4 metrics" ;
        rdfs:label "BCO-DMO GA4 ETL Pipeline" .