                                                        bcodmo:description "Has a parameter ( link_object, file_link, document_link) that links to files we control or other JGOFS objects" ;
                                                        bcodmo:label "Contains Data File Links Or JGOFS Objects" ;
                                                        rdfs:label "NoDatasetDOIReason: Contains Data File Links Or JGOFS Objects" .


###  https://schema.bco-dmo.org/internal/v1.0/NoDatasetDOIReason_DataInDeploymentDatasets
:NoDatasetDOIReason_DataInDeploymentDatasets rdf:type owl:NamedIndividual ,
                                                      :NoDatasetDOIReason ;
                                             bcodmo:description "These are typically old JGOFS datasets with no dataset URL but one or multiple dataset deployment URLs." ;
                                             bcodmo:label "Data In Deployment Datasets" ;
                                             rdfs:label "NoDatasetDOIReason: Data In Deployment Datasets" .


###  https://schema.bco-dmo.org/internal/v1.0/NoDatasetDOIReason_DataUrlNotAFile
:NoDatasetDOIReason_DataUrlNotAFile rdf:type owl:NamedIndividual ,
                                             :NoDatasetDOIReason ;
                                    bcodmo:description "If it goes to a file on our server we can DOI if the file is in an open format (.csv, but not PDF or Excel)" ;
                                    bcodmo:label "Data Url Not A File" ;
                                    rdfs:label "NoDatasetDOIReason: Data Url Not A File" .


