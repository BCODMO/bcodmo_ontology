                                        bcodmo:description "The dataset does not need a BCO-DMO DOI because the dataset has a pre-existing DOI and we are not altering the data." ;
                                        bcodmo:label "Existing External DOI" ;
                                        rdfs:label "NoDatasetDOIReason: Existing External DOI" .


