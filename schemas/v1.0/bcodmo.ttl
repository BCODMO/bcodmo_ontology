bcodmo:DatasetType_CruiseResults rdf:type owl:NamedIndividual ,
                                          bcodmo:DatasetType ;
                                 bcodmo:label "Cruise Results" ;
                                 rdfs:comment "Results from a research cruise" ;
                                 rdfs:label "Dataset Type: Cruise Results" .


