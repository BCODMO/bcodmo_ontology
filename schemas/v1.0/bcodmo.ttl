bcodmo:DatasetParameterAttribute_PrimaryLatitudeVariable rdf:type owl:NamedIndividual ,
                                                                  bcodmo:DatasetParameterAttribute ;
                                                         bcodmo:label "Primary Latitude Variable" ;
                                                         rdfs:label "Dataset Parameter Attribute: Primary Latitude Variable" .


