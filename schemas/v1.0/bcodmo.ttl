bcodmo:DatasetType_Code rdf:type owl:NamedIndividual ,
                                 bcodmo:DatasetType ;
                        bcodmo:label "Code" ;
                        rdfs:comment "Software/code as a product of some research project" ;
                        rdfs:label "Dataset Type: Code" .


