bcodmo:DatasetParameterAttribute_PrimaryLongitudeVariable rdf:type owl:NamedIndividual ,
                                                                   bcodmo:DatasetParameterAttribute ;
                                                          bcodmo:label "Primary Longitude Variable" ;
                                                          rdfs:label "Dataset Parameter Attribute: Primary Longtiude Variable" .


