bcodmo:DatasetType_Experimental rdf:type owl:NamedIndividual ,
                                         bcodmo:DatasetType ;
                                bcodmo:label "Experimental" ;
                                rdfs:comment "The dataset is experimental results." ;
                                rdfs:label "Dataset Type: Experimental" .


