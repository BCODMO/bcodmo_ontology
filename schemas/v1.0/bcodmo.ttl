bcodmo:DatasetType_Document rdf:type owl:NamedIndividual ,
                                     bcodmo:DatasetType ;
                            bcodmo:label "Document" ;
                            rdfs:comment "The dataset is some kind of document." ;
                            rdfs:label "Dataset Type: Document" .


