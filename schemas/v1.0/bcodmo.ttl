bcodmo:DatasetType_CruiseReport rdf:type owl:NamedIndividual ,
                                         bcodmo:DatasetType ;
                                bcodmo:label "Cruise Report" ;
                                rdfs:comment "The dataset is a cruise report" ;
                                rdfs:label "Dataset Type: Cruise Report" .


