bcodmo:DOIStatus_PublishFailed rdf:type owl:NamedIndividual ,
                                        bcodmo:DOIStatus ;
                               bcodmo:label "Publish Failed" ;
                               rdfs:comment "DOI metadata publication failed after initiation." .


