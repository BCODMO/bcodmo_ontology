@prefix : <https://schema.bco-dmo.org/v1.0/> .
@prefix sf: <http://www.opengis.net/ont/sf#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bcodmo: <https://schema.bco-dmo.org/v1.0/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@base <https://schema.bco-dmo.org/v1.0/> .

<https://schema.bco-dmo.org/v1.0/> rdf:type owl:Ontology ;
                                    owl:versionIRI <https://schema.bco-dmo.org/v1.0/> ;
                                    dcterms:contributor <https://orcid.org/0000-0001-9414-722X> ,
                                                        <https://orcid.org/0000-0003-2109-706X> ,
                                                        <https://orcid.org/0000-0003-3359-9120> ;
                                    dcterms:creator <https://orcid.org/0000-0003-4486-9448> ;
                                    dcterms:license "Creative Commons Zero 1.0 Universal" ,
                                                    "https://creativecommons.org/publicdomain/zero/1.0/" ;
                                    dcterms:title "BCO-DMO Ontology (Version 1.0)" ;
                                    rdfs:comment "Ontology for the Biological and Chemical Oceanography Data Management Office (BCO-DMO)." ;
                                    rdfs:label "BCO-DMO Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#qualifiedCardinality
owl:qualifiedCardinality rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broader
skos:broader rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#relatedMatch
skos:relatedMatch rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.opengis.net/ont/geosparql#geoJSONLiteral
geosparql:geoJSONLiteral rdf:type rdfs:Datatype .


###  http://www.opengis.net/ont/geosparql#wktLiteral
geosparql:wktLiteral rdf:type rdfs:Datatype .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML
rdf:HTML rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#first
rdf:first rdf:type owl:ObjectProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#object
rdf:object rdf:type owl:ObjectProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate
rdf:predicate rdf:type owl:ObjectProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#rest
rdf:rest rdf:type owl:ObjectProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#subject
rdf:subject rdf:type owl:ObjectProperty .


###  https://schema.bco-dmo.org/v1.0/actionType
bcodmo:actionType rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf bcodmo:categorizedBy ;
                  rdfs:domain bcodmo:Entity ;
                  rdfs:range bcodmo:Action ;
                  rdfs:comment "THe type of Action" ;
                  rdfs:label "actionType" .


###  https://schema.bco-dmo.org/v1.0/affiliation
bcodmo:affiliation rdf:type owl:ObjectProperty ;
                   rdfs:domain bcodmo:Person ;
                   rdfs:range bcodmo:Affiliation ;
                   rdfs:comment "The institutional affiliation of a person." ;
                   rdfs:label "affiliation" ;
                   skos:exactMatch <https://schema.org/affiliation> .


###  https://schema.bco-dmo.org/v1.0/annotates
bcodmo:annotates rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf bcodmo:situationInvolves ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain bcodmo:Annotation ;
                 rdfs:range [ rdf:type owl:Class ;
                              owl:unionOf ( rdf:Statement
                                            owl:Thing
                                            bcodmo:Entity
                                          )
                            ] ;
                 rdfs:comment "The thing being annotated" ;
                 rdfs:label "annotates" .


###  https://schema.bco-dmo.org/v1.0/annotator
bcodmo:annotator rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf bcodmo:situationInvolves ;
                 rdfs:domain bcodmo:Annotation ;
                 rdfs:range bcodmo:Agent ;
                 rdfs:comment "An agent that adds explanatory notes, metadata, or comments to enhance understanding of some thing." ;
                 rdfs:label "annotator" .


###  https://schema.bco-dmo.org/v1.0/archives
bcodmo:archives rdf:type owl:ObjectProperty ;
                owl:inverseOf bcodmo:isArchivedBy ;
                rdfs:domain bcodmo:DOIDataset ;
                rdfs:range bcodmo:Dataset ;
                rdfs:comment "The Dataset that was archvied by a specific DOIDataset." ;
                rdfs:label "archives" .


###  https://schema.bco-dmo.org/v1.0/audience
bcodmo:audience rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:CreativeWork ;
                rdfs:range bcodmo:Audience ;
                rdfs:comment "An intended audience, i.e. a group for whom a CreativeWork was created or offered to." ;
                rdfs:label "audience" .


###  https://schema.bco-dmo.org/v1.0/author
bcodmo:author rdf:type owl:ObjectProperty ;
              rdfs:domain bcodmo:CreativeWork ;
              rdfs:range bcodmo:AgentRole ;
              rdfs:comment "An author associated witha creative work. The Agent Role provides context as to how the agent contirbuted as an author to the work." ;
              rdfs:label "author" ;
              skos:closeMatch <https://schema.org/author> .


###  https://schema.bco-dmo.org/v1.0/authority
bcodmo:authority rdf:type owl:ObjectProperty ;
                 rdfs:domain bcodmo:Entity ;
                 rdfs:range bcodmo:Agent ;
                 rdfs:comment "The authoritative source for some piece of information or some physical thing." ;
                 rdfs:label "authority" .


###  https://schema.bco-dmo.org/v1.0/awardProducingData
bcodmo:awardProducingData rdf:type owl:ObjectProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain bcodmo:Award ;
                          rdfs:range bcodmo:Boolean .


###  https://schema.bco-dmo.org/v1.0/boundingBox
bcodmo:boundingBox rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf bcodmo:geometry ;
                   rdfs:domain bcodmo:GeographicalLocation ;
                   rdfs:range bcodmo:BoundingBoxGeometry ;
                   rdfs:comment "A bounding box" ;
                   rdfs:label "boundingBox" .


###  https://schema.bco-dmo.org/v1.0/browseGraphic
bcodmo:browseGraphic rdf:type owl:ObjectProperty ;
                     rdfs:domain bcodmo:Entity ;
                     rdfs:range bcodmo:Image ;
                     rdfs:comment "An image that is representative of some thing. This could be a logo for a project or organization. It could also be an image that represents a creative work." ;
                     rdfs:label "browseGraphic" .


###  https://schema.bco-dmo.org/v1.0/categorizedBy
bcodmo:categorizedBy rdf:type owl:ObjectProperty ;
                     rdfs:domain bcodmo:Entity ;
                     rdfs:range bcodmo:Category ;
                     rdfs:comment "A category for some Entity" ;
                     rdfs:label "categorizedBy" ;
                     skos:closeMatch <https://schema.org/category> .


###  https://schema.bco-dmo.org/v1.0/checksum
bcodmo:checksum rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf bcodmo:identifier ;
                rdfs:domain bcodmo:File ;
                rdfs:range bcodmo:CryptographicHash ;
                rdfs:comment "A cryptographic hash for verifying file integrity." ;
                rdfs:label "checksum" .


###  https://schema.bco-dmo.org/v1.0/collectionItem
bcodmo:collectionItem rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf bcodmo:situationInvolves ;
                      rdfs:domain bcodmo:CollectionItem ;
                      rdfs:range bcodmo:Entity ;
                      rdfs:comment "The actual item in the collection." ;
                      rdfs:label "collectionItem" .


###  https://schema.bco-dmo.org/v1.0/conformsTo
bcodmo:conformsTo rdf:type owl:ObjectProperty ;
                  rdfs:domain bcodmo:Dataset ;
                  rdfs:range bcodmo:MetadataProfile ;
                  rdfs:comment "The metadata profile specification to which this dataset conforms." ;
                  rdfs:label "conformsTo" ;
                  skos:exactMatch dcterms:conformsTo .


###  https://schema.bco-dmo.org/v1.0/contributor
bcodmo:contributor rdf:type owl:ObjectProperty ;
                   rdfs:domain bcodmo:CreativeWork ;
                   rdfs:range bcodmo:AgentRole ;
                   rdfs:comment "A contributor, not an author, associated with a creative work. The Agent Role provides context as to how the agent contributed to the work." ;
                   rdfs:label "contributor" ;
                   skos:closeMatch <https://schema.org/contributor> .


###  https://schema.bco-dmo.org/v1.0/coordinateReferenceSystem
bcodmo:coordinateReferenceSystem rdf:type owl:ObjectProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain bcodmo:Geometry ;
                                 rdfs:range bcodmo:CoordinateReferenceSystem ;
                                 rdfs:comment "the coordinate reference system for some representation of a Geographical Location" ;
                                 rdfs:label "coordinateReferenceSystem" ;
                                 skos:closeMatch geosparql:crs .


###  https://schema.bco-dmo.org/v1.0/coordinates
bcodmo:coordinates rdf:type owl:ObjectProperty ;
                   rdfs:domain bcodmo:Geometry ;
                   rdfs:range rdf:List ;
                   rdfs:comment "a list of 1 or more PointGeometry" ;
                   rdfs:label "coordinates" .


###  https://schema.bco-dmo.org/v1.0/createdDate
bcodmo:createdDate rdf:type owl:ObjectProperty ;
                   rdfs:domain bcodmo:CreativeWork ;
                   rdfs:range bcodmo:TemporalInstant ;
                   rdfs:comment "The date on which a creative work was created." ;
                   rdfs:label "createdDate" ;
                   skos:closeMatch <https://schema.org/dateCreated> .


###  https://schema.bco-dmo.org/v1.0/creativeWorkStatus
bcodmo:creativeWorkStatus rdf:type owl:ObjectProperty ;
                          owl:equivalentProperty bcodmo:status ;
                          rdfs:domain bcodmo:CreativeWork ;
                          rdfs:range bcodmo:CreativeWorkStatus ;
                          rdfs:comment "The status of a creative work in terms of its stage in a lifecycle. Example terms include Incomplete, Draft, Published, Obsolete. Some organizations define a set of terms for the stages of their publication lifecycle." ;
                          rdfs:label "creativeWorkStatus" ;
                          skos:exactMatch <https://schema.org/creativeWorkStatus> .


###  https://schema.bco-dmo.org/v1.0/currentState
bcodmo:currentState rdf:type owl:ObjectProperty ;
                    rdfs:domain bcodmo:CreativeWork ;
                    rdfs:range bcodmo:CurrentState ;
                    rdfs:comment "The editorial/curation state of the dataset." ;
                    rdfs:label "currentState" .


###  https://schema.bco-dmo.org/v1.0/dataFile
bcodmo:dataFile rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain bcodmo:Dataset ;
                rdfs:range bcodmo:DataFile ;
                rdfs:comment "A primary or supplemental data file distributed with this dataset package." ;
                rdfs:label "dataFile" .


###  https://schema.bco-dmo.org/v1.0/dataManagementPlan
bcodmo:dataManagementPlan rdf:type owl:ObjectProperty ;
                          rdfs:domain bcodmo:ResearchActivity ;
                          rdfs:range bcodmo:DataManagementPlan ;
                          rdfs:comment "A file describing a research activities plan for managing their data." ;
                          rdfs:label "dataManagementPlan" .


###  https://schema.bco-dmo.org/v1.0/dataType
bcodmo:dataType rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:DatasetParameter ;
                rdfs:range bcodmo:Datatype ;
                rdfs:comment "The data type of a dataset parameter." ;
                rdfs:label "dataType" .


###  https://schema.bco-dmo.org/v1.0/datasetInstrumentsNotUsed
bcodmo:datasetInstrumentsNotUsed rdf:type owl:ObjectProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain bcodmo:Dataset ;
                                 rdfs:range bcodmo:Boolean .


###  https://schema.bco-dmo.org/v1.0/datasetParametersNotRequired
bcodmo:datasetParametersNotRequired rdf:type owl:ObjectProperty ,
                                             owl:FunctionalProperty ;
                                    rdfs:domain bcodmo:Dataset ;
                                    rdfs:range bcodmo:Boolean .


###  https://schema.bco-dmo.org/v1.0/datasetType
bcodmo:datasetType rdf:type owl:ObjectProperty ;
                   rdfs:domain bcodmo:Dataset ;
                   rdfs:range bcodmo:DatasetType ;
                   rdfs:comment "A category or type classification for this dataset." ;
                   rdfs:label "datasetType" .


###  https://schema.bco-dmo.org/v1.0/deploymentDataset
bcodmo:deploymentDataset rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf bcodmo:hasPart ;
                         rdfs:domain bcodmo:Dataset ;
                         rdfs:range bcodmo:DatasetDeployment ;
                         rdfs:comment "a deployment-specific description of that deployment's aspects of a dataset." ;
                         rdfs:label "deploymentDataset" .


###  https://schema.bco-dmo.org/v1.0/describesFile
bcodmo:describesFile rdf:type owl:ObjectProperty ;
                     rdfs:domain bcodmo:FileDescriptor ;
                     rdfs:range bcodmo:File ;
                     rdfs:comment "Links a file record to the File object describing its physical properties." ;
                     rdfs:label "describesFile" .


###  https://schema.bco-dmo.org/v1.0/entityPublishingStatus
bcodmo:entityPublishingStatus rdf:type owl:ObjectProperty ;
                              rdfs:domain bcodmo:Entity ;
                              rdfs:range bcodmo:EntityPublishingStatus ;
                              rdfs:comment "the publishing status of some BCO-DMO Entity" ;
                              rdfs:label "entityPublishingStatus" .


###  https://schema.bco-dmo.org/v1.0/entryPoint
bcodmo:entryPoint rdf:type owl:ObjectProperty ;
                  rdfs:domain bcodmo:ServiceOffering ;
                  rdfs:range bcodmo:SoftwareService ;
                  rdfs:comment "The entryPoint into some SoftwareService" ;
                  rdfs:label "entryPoint" ;
                  skos:closeMatch <https://schema.org/target> .


###  https://schema.bco-dmo.org/v1.0/expirationDate
bcodmo:expirationDate rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf bcodmo:hasTime ;
                      rdfs:domain bcodmo:EmbargoPolicy ;
                      rdfs:range bcodmo:TemporalEntity ;
                      rdfs:comment "The date on which an embargo expires and the dataset becomes publicly accessible." ;
                      rdfs:label "expirationDate" ;
                      skos:closeMatch <https://schema.org/expires> .


###  https://schema.bco-dmo.org/v1.0/fileType
bcodmo:fileType rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:File ;
                rdfs:range bcodmo:FileType ;
                rdfs:comment "The format type of this file." ;
                rdfs:label "fileType" ;
                skos:closeMatch <http://www.w3.org/ns/dcat#mediaType> .


###  https://schema.bco-dmo.org/v1.0/fixesPreviousErrors
bcodmo:fixesPreviousErrors rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf bcodmo:obsoletes ;
                           rdfs:domain bcodmo:DOIDataset ;
                           rdfs:range bcodmo:DOIDataset ;
                           rdfs:comment "The DOIDataset from the past that this DOIDataset fixes errors." ;
                           rdfs:label "fixesPreviousErrors" .


###  https://schema.bco-dmo.org/v1.0/forCreativeWork
bcodmo:forCreativeWork rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf bcodmo:situationInvolves ;
                       rdfs:domain bcodmo:Situation ;
                       rdfs:range bcodmo:CreativeWork ;
                       rdfs:comment "Links to a CreativeWork" ;
                       rdfs:label "forCreativeWork" .


###  https://schema.bco-dmo.org/v1.0/forDataset
bcodmo:forDataset rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf bcodmo:forCreativeWork ;
                  rdfs:domain bcodmo:Situation ;
                  rdfs:range bcodmo:Dataset ;
                  rdfs:comment "Links to a dataset." ;
                  rdfs:label "forDataset" .


###  https://schema.bco-dmo.org/v1.0/fromDeployment
bcodmo:fromDeployment rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf bcodmo:situationInvolves ;
                      rdfs:domain bcodmo:DatasetDeployment ;
                      rdfs:range bcodmo:Deployment ;
                      rdfs:comment "Links a deployment and a dataset." ;
                      rdfs:label "fromDeployment" .


###  https://schema.bco-dmo.org/v1.0/fromInstrument
bcodmo:fromInstrument rdf:type owl:ObjectProperty ;
                      rdfs:domain bcodmo:Dataset ;
                      rdfs:range bcodmo:DatasetInstrument ;
                      rdfs:comment "Links a dataset to the instruments used to collect the data." ;
                      rdfs:label "fromInstrument" .


###  https://schema.bco-dmo.org/v1.0/fundedBy
bcodmo:fundedBy rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:Dataset ;
                rdfs:range bcodmo:FundingAgency ;
                owl:propertyChainAxiom ( bcodmo:fundedByAward
                                         bcodmo:provider
                                       ) ;
                rdfs:comment "A funding organisation that supported the work resulting in this dataset." ;
                rdfs:label "fundedBy" ;
                skos:closeMatch <https://schema.org/funder> .


###  https://schema.bco-dmo.org/v1.0/fundedByAward
bcodmo:fundedByAward rdf:type owl:ObjectProperty ;
                     rdfs:domain bcodmo:CreativeWork ;
                     rdfs:range bcodmo:Award ;
                     rdfs:comment "the award that funded the creation, generation, etc of some creative work." ;
                     rdfs:label "fundedByAward" ;
                     skos:closeMatch <https://schema.org/funding> .


###  https://schema.bco-dmo.org/v1.0/funder
bcodmo:funder rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain bcodmo:Award ;
              rdfs:range bcodmo:Agent ;
              rdfs:label "funder" .


###  https://schema.bco-dmo.org/v1.0/geometry
bcodmo:geometry rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:Entity ;
                rdfs:range bcodmo:Geometry ;
                rdfs:comment "One or more geometries (centroid, bounding box) describing a geographical location." ;
                rdfs:label "geometry" ;
                skos:closeMatch <https://schema.org/geo> ;
                skos:exactMatch geosparql:hasGeometry .


###  https://schema.bco-dmo.org/v1.0/governedBy
bcodmo:governedBy rdf:type owl:ObjectProperty ;
                  rdfs:domain bcodmo:CreativeWork ;
                  rdfs:range bcodmo:Policy ;
                  rdfs:comment "A policy (e.g. embargo) that governs access to this dataset." ;
                  rdfs:label "governedBy" .


###  https://schema.bco-dmo.org/v1.0/grantedAward
bcodmo:grantedAward rdf:type owl:ObjectProperty ;
                    rdfs:domain bcodmo:FundingAgency ;
                    rdfs:range bcodmo:Award ;
                    rdfs:comment "An award (grant) issued by this funding organisation." ;
                    rdfs:label "grantedAward" ;
                    skos:closeMatch <https://schema.org/funder> .


###  https://schema.bco-dmo.org/v1.0/hasAgentWithRole
bcodmo:hasAgentWithRole rdf:type owl:ObjectProperty ;
                        owl:inverseOf bcodmo:isRoleFor ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( bcodmo:CreativeWork
                                                    bcodmo:Deployment
                                                    bcodmo:ResearchActivity
                                                  )
                                    ] ;
                        rdfs:range bcodmo:AgentRole ;
                        rdfs:comment "Associates an agent with a qualified role on a dataset or deployment." ;
                        rdfs:label "hasAgentWithRole" .


###  https://schema.bco-dmo.org/v1.0/hasBeginning
bcodmo:hasBeginning rdf:type owl:ObjectProperty ;
                    rdfs:domain bcodmo:TemporalInterval ;
                    rdfs:range bcodmo:TemporalInstant ;
                    rdfs:comment "The start of a temporal interval." ;
                    rdfs:label "hasBeginning" ;
                    skos:exactMatch time:hasBeginning .


###  https://schema.bco-dmo.org/v1.0/hasCollection
bcodmo:hasCollection rdf:type owl:ObjectProperty ;
                     rdfs:domain bcodmo:Entity ;
                     rdfs:range bcodmo:Collection ;
                     rdfs:comment "A collection related to some Thing" ;
                     rdfs:label "hasCollection" .


###  https://schema.bco-dmo.org/v1.0/hasCollectionItem
bcodmo:hasCollectionItem rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty ;
                         owl:inverseOf bcodmo:inCollection ;
                         rdfs:domain bcodmo:Collection ;
                         rdfs:range bcodmo:CollectionItem ;
                         rdfs:comment "An CollectionItem in a Collection" ;
                         rdfs:label "hasCollectionItem" ;
                         skos:exactMatch <https://schema.org/item> .


###  https://schema.bco-dmo.org/v1.0/hasContent
bcodmo:hasContent rdf:type owl:ObjectProperty ;
                  rdfs:domain bcodmo:Annotation ;
                  rdfs:range bcodmo:CreativeWork ;
                  rdfs:comment "The content or text of some Annotation. the annotation could be an image or publication, but it is the main idea of the annotation." ;
                  rdfs:label "hasContent" ;
                  skos:exactMatch <https://schema.org/text> .


###  https://schema.bco-dmo.org/v1.0/hasCoordinatedDeployment
bcodmo:hasCoordinatedDeployment rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf bcodmo:situationInvolves ;
                                rdfs:domain bcodmo:Deployment ;
                                rdfs:range bcodmo:Deployment ;
                                rdfs:comment "A disparate deployment that coordinated in conjuction with this subject for data collection" ;
                                rdfs:label "hasCoordinatedDeployment" .


###  https://schema.bco-dmo.org/v1.0/hasCruiseTrajectory
bcodmo:hasCruiseTrajectory rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf bcodmo:geometry ;
                           rdfs:domain bcodmo:Cruise ;
                           rdfs:range bcodmo:Geometry ;
                           rdfs:comment "The set of ordered coordinates forming a geometry (usually MultiPoint) representing the path taken by a Cruise." ;
                           rdfs:label "hasCruiseTrajectory" ;
                           skos:exactMatch <https://schema.org/geo> .


###  https://schema.bco-dmo.org/v1.0/hasDeployment
bcodmo:hasDeployment rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf bcodmo:situationInvolves ;
                     rdfs:domain bcodmo:TimeSeries ;
                     rdfs:range bcodmo:Deployment ;
                     rdfs:comment "Links a deployment to a TimeSeries" ;
                     rdfs:label "hasDeployment" .


###  https://schema.bco-dmo.org/v1.0/hasDistribution
bcodmo:hasDistribution rdf:type owl:ObjectProperty ;
                       rdfs:domain bcodmo:CreativeWork ;
                       rdfs:range bcodmo:MediaService ;
                       rdfs:comment "A services distributing all or part of some CreativeWork or FileDescriptor" ;
                       rdfs:label "hasDistribution" ;
                       skos:closeMatch <https://schema.org/distribution> .


###  https://schema.bco-dmo.org/v1.0/hasEnd
bcodmo:hasEnd rdf:type owl:ObjectProperty ;
              rdfs:domain bcodmo:TemporalInterval ;
              rdfs:range bcodmo:TemporalInstant ;
              rdfs:comment "The end of a temporal interval." ;
              rdfs:label "hasEnd" ;
              skos:exactMatch time:hasEnd .


###  https://schema.bco-dmo.org/v1.0/hasLeadAwardOf
bcodmo:hasLeadAwardOf rdf:type owl:ObjectProperty ;
                      rdfs:domain bcodmo:Award ;
                      rdfs:range bcodmo:Award ;
                      rdfs:comment "The lead award in a group of collaborative awards" ;
                      rdfs:label "hasLeadAwardOf" .


###  https://schema.bco-dmo.org/v1.0/hasParameter
bcodmo:hasParameter rdf:type owl:ObjectProperty ;
                    owl:equivalentProperty bcodmo:storesValuesFor ;
                    rdfs:domain bcodmo:Dataset ;
                    rdfs:range bcodmo:DatasetParameter ;
                    rdfs:comment "A dataset collected this dataset-parameter"@en ;
                    rdfs:label "hasParameter"@en ;
                    skos:closeMatch <http://www.w3.org/ns/sosa/observedProperty> ,
                                    <https://schema.org/variableMeasured> .


###  https://schema.bco-dmo.org/v1.0/hasParameterAttribute
bcodmo:hasParameterAttribute rdf:type owl:ObjectProperty ;
                             rdfs:domain bcodmo:DatasetParameter ;
                             rdfs:range bcodmo:DatasetParameterAttribute ;
                             rdfs:comment "An attribute of a particular DatasetParameter" ;
                             rdfs:label "hasParameterAttribute" .


###  https://schema.bco-dmo.org/v1.0/hasParentProgram
bcodmo:hasParentProgram rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf bcodmo:situationInvolves ;
                        rdfs:domain bcodmo:Project ;
                        rdfs:range bcodmo:Program ;
                        rdfs:comment "The Program that enabled a Project's existence" ;
                        rdfs:label "hasParentProgram" .


###  https://schema.bco-dmo.org/v1.0/hasPart
bcodmo:hasPart rdf:type owl:ObjectProperty ;
               owl:inverseOf bcodmo:isPartOf ;
               rdfs:domain bcodmo:Entity ;
               rdfs:range bcodmo:Entity ;
               rdfs:comment "A related entity that is included either physically or logically in the described entity." .


###  https://schema.bco-dmo.org/v1.0/hasProgram
bcodmo:hasProgram rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf bcodmo:situationInvolves ;
                  rdfs:domain bcodmo:Dataset ;
                  rdfs:range bcodmo:Program ;
                  owl:propertyChainAxiom ( bcodmo:hasProject
                                           bcodmo:hasParentProgram
                                         ) ,
                                         ( bcodmo:hasProject
                                           bcodmo:hasProject
                                           bcodmo:hasParentProgram
                                         ) ;
                  rdfs:comment "Associates a dataset with a scientific program." ;
                  rdfs:label "hasProgram" .


###  https://schema.bco-dmo.org/v1.0/hasProject
bcodmo:hasProject rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf bcodmo:situationInvolves ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( bcodmo:Dataset
                                              bcodmo:DatasetProject
                                              bcodmo:DatasetsInOtherCatalog
                                            )
                              ] ;
                  rdfs:range bcodmo:Project ;
                  rdfs:comment "Associates a dataset with a scientific project." ;
                  rdfs:label "hasProject" .


###  https://schema.bco-dmo.org/v1.0/hasSynonym
bcodmo:hasSynonym rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf bcodmo:situationInvolves ;
                  rdfs:domain bcodmo:Deployment ;
                  rdfs:range bcodmo:Synonym ;
                  rdfs:comment "An alternative name used for a deployment." ;
                  rdfs:label "hasSynonym" .


###  https://schema.bco-dmo.org/v1.0/hasTime
bcodmo:hasTime rdf:type owl:ObjectProperty ;
               rdfs:domain bcodmo:Entity ;
               rdfs:range bcodmo:TemporalEntity ;
               rdfs:comment "Connects a temporal entity to some thing" ;
               rdfs:label "hasTime" ;
               skos:exactMatch time:hasTime .


###  https://schema.bco-dmo.org/v1.0/identifier
bcodmo:identifier rdf:type owl:ObjectProperty ;
                  rdfs:domain bcodmo:Entity ;
                  rdfs:range bcodmo:Identifier ;
                  rdfs:comment "An identifier assigned to a resource." ;
                  rdfs:label "identifier" ;
                  skos:closeMatch <https://schema.org/identifier> .


###  https://schema.bco-dmo.org/v1.0/identifierScheme
bcodmo:identifierScheme rdf:type owl:ObjectProperty ;
                        rdfs:domain bcodmo:Identifier ;
                        rdfs:range bcodmo:IdentifierScheme ;
                        rdfs:comment "The scheme (authority) that defines the identifier." ;
                        rdfs:label "identifierScheme" .


###  https://schema.bco-dmo.org/v1.0/inCollection
bcodmo:inCollection rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf bcodmo:situationInvolves ;
                    rdfs:domain bcodmo:CollectionItem ;
                    rdfs:range bcodmo:Collection ;
                    rdfs:comment "The collection to which this item belongs" ;
                    rdfs:label "inCollection" .


###  https://schema.bco-dmo.org/v1.0/inControlledVocabulary
bcodmo:inControlledVocabulary rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf bcodmo:isPartOf ;
                              rdf:type owl:FunctionalProperty ;
                              rdfs:domain bcodmo:Keyword ;
                              rdfs:range bcodmo:ControlledVocabulary ;
                              rdfs:comment "The ControlledVocabulary to which a term belongs" ;
                              rdfs:label "inControlledVocabulary" .


###  https://schema.bco-dmo.org/v1.0/inGroup
bcodmo:inGroup rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf bcodmo:categorizedBy ;
               rdfs:domain bcodmo:ResourceRelation ;
               rdfs:range bcodmo:ResourceRelationGroup ;
               rdfs:comment "The group/category to which a resource relation type belongs." ;
               rdfs:label "inGroup" .


###  https://schema.bco-dmo.org/v1.0/inverseRelationship
bcodmo:inverseRelationship rdf:type owl:ObjectProperty ;
                           rdfs:domain bcodmo:ResourceRelation ;
                           rdfs:range bcodmo:ResourceRelation ;
                           rdfs:comment "The inverse relationship to another relationship type" ;
                           rdfs:label "inverseRelationship" .


###  https://schema.bco-dmo.org/v1.0/isArchivedBy
bcodmo:isArchivedBy rdf:type owl:ObjectProperty ;
                    rdfs:domain bcodmo:Dataset ;
                    rdfs:range bcodmo:DOIDataset ;
                    rdfs:comment "An ArchiveDataset that arvhies a specific version of a Dataset." ;
                    rdfs:label "isArchivedBy" .


###  https://schema.bco-dmo.org/v1.0/isContinuingAwardOf
bcodmo:isContinuingAwardOf rdf:type owl:ObjectProperty ;
                           rdfs:domain bcodmo:Award ;
                           rdfs:range bcodmo:Award ;
                           rdfs:comment "The award that preceded this Award for continuing some work" ;
                           rdfs:label "isContinuingAwardOf" .


###  https://schema.bco-dmo.org/v1.0/isDefinedAs
bcodmo:isDefinedAs rdf:type owl:ObjectProperty ;
                   owl:equivalentProperty bcodmo:isTypeOf ;
                   rdfs:subPropertyOf bcodmo:categorizedBy ;
                   rdfs:domain bcodmo:Entity ;
                   rdfs:range bcodmo:DefinedTerm ;
                   rdfs:comment "A thing is defined to be something more specific or colloquial than this more standardized cateogrization or community term." ;
                   rdfs:label "isDefinedAs" .


###  https://schema.bco-dmo.org/v1.0/isPartOf
bcodmo:isPartOf rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:Entity ;
                rdfs:range bcodmo:Entity ;
                rdfs:comment "A related entity in which the described entity is physically or logically included." ;
                rdfs:label "isPartOf" .


###  https://schema.bco-dmo.org/v1.0/isRoleFor
bcodmo:isRoleFor rdf:type owl:ObjectProperty ;
                 rdfs:domain bcodmo:AgentRole ;
                 rdfs:range [ rdf:type owl:Class ;
                              owl:unionOf ( bcodmo:CreativeWork
                                            bcodmo:Deployment
                                            bcodmo:ResearchActivity
                                          )
                            ] ;
                 rdfs:comment "Associates a dataset or deployment with an a qualified role of an agent." ;
                 rdfs:label "hasAgentWithRole" .


###  https://schema.bco-dmo.org/v1.0/isTypeOf
bcodmo:isTypeOf rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:Entity ;
                rdfs:range bcodmo:DefinedTerm ;
                rdfs:comment "Categorizes some thing." ;
                rdfs:label "isTypeOf" ;
                owl:deprecated "true"^^xsd:boolean .


###  https://schema.bco-dmo.org/v1.0/issuedDate
bcodmo:issuedDate rdf:type owl:ObjectProperty ;
                  rdfs:domain bcodmo:DOIDataset ;
                  rdfs:range bcodmo:TemporalInstant ;
                  rdfs:comment "The date on which the DOI was issued for this dataset." ;
                  rdfs:label "issuedDate" ;
                  skos:closeMatch <https://schema.org/dateIssued> .


###  https://schema.bco-dmo.org/v1.0/keywords
bcodmo:keywords rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:CreativeWork ;
                rdfs:range bcodmo:Keyword ;
                rdfs:comment "Subject keywords associated with this dataset." ;
                rdfs:label "keywords" ;
                skos:closeMatch <https://schema.org/keywords> .


###  https://schema.bco-dmo.org/v1.0/language
bcodmo:language rdf:type owl:ObjectProperty ;
                rdfs:domain bcodmo:CreativeWork ;
                rdfs:range bcodmo:Language ;
                rdfs:comment "The natural language used in the dataset metadata." ;
                rdfs:label "language" ;
                skos:closeMatch <https://schema.org/language> .


###  https://schema.bco-dmo.org/v1.0/license
bcodmo:license rdf:type owl:ObjectProperty ;
               rdfs:domain bcodmo:CreativeWork ;
               rdfs:range bcodmo:License ;
               rdfs:comment "The data license applied to this dataset." ;
               rdfs:label "license" ;
               skos:exactMatch <https://schema.org/license> .


###  https://schema.bco-dmo.org/v1.0/logo
bcodmo:logo rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf bcodmo:browseGraphic ;
            rdfs:domain bcodmo:Entity ;
            rdfs:range bcodmo:Logo ;
            rdfs:comment "A logo for some thing" ;
            rdfs:label "logo" ;
            skos:closeMatch <https://schema.org/logo> .


###  https://schema.bco-dmo.org/v1.0/matches
bcodmo:matches rdf:type owl:ObjectProperty ;
               owl:inverseOf bcodmo:matchesToEntity ;
               rdfs:domain bcodmo:Entity ;
               rdfs:range bcodmo:EntityMatch ;
               rdfs:comment "Aligns a BCO-DMO vocabulary term with an equivalent term from an external community vocabulary (e.g. SeaDataNet, NERC, Crossref, DataCite)." ;
               rdfs:label "matches" ;
               skos:exactMatch skos:exactMatch .


###  https://schema.bco-dmo.org/v1.0/matchesToEntity
bcodmo:matchesToEntity rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf bcodmo:situationInvolves ;
                       rdfs:domain bcodmo:EntityMatch ;
                       rdfs:range bcodmo:Entity ;
                       rdfs:comment "The entity to which this match belongs. The entity would be rdf:subject and the EntityMatch defines the rdf:predicate and rdf:object." ;
                       rdfs:label "matchesToEntity" .


###  https://schema.bco-dmo.org/v1.0/metadataFile
bcodmo:metadataFile rdf:type owl:ObjectProperty ;
                    rdfs:domain bcodmo:Dataset ;
                    rdfs:range bcodmo:MetadataFile ;
                    rdfs:comment "A metadata file (ISO XML, description PDF) bundled in the dataset package." ;
                    rdfs:label "metadataFile" .


###  https://schema.bco-dmo.org/v1.0/modifiesAction
bcodmo:modifiesAction rdf:type owl:ObjectProperty ;
                      rdfs:domain bcodmo:Policy ;
                      rdfs:range bcodmo:Action ;
                      rdfs:comment "The action being modified by some Policy" ;
                      rdfs:label "modifiesAction" .


###  https://schema.bco-dmo.org/v1.0/nodcTopicCategory
bcodmo:nodcTopicCategory rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty ;
                         rdfs:domain bcodmo:Dataset ;
                         rdfs:range bcodmo:NODCTopic ;
                         rdfs:comment "THe NODC Topic Category to which a Dataset belongs" ;
                         rdfs:label "nodcTopicCategory" .


###  https://schema.bco-dmo.org/v1.0/obsoletes
bcodmo:obsoletes rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain bcodmo:DOIDataset ;
                 rdfs:range bcodmo:DOIDataset ;
                 rdfs:comment "A previous version of this dataset that is superseded by the current one." ;
                 rdfs:label "obsoletes" .


###  https://schema.bco-dmo.org/v1.0/offers
bcodmo:offers rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf bcodmo:hasCollection ;
              rdfs:domain bcodmo:MediaService ;
              rdfs:range bcodmo:OfferCatalog ;
              rdfs:comment "The offering made by some MediaService" ;
              rdfs:label "offers" ;
              skos:closeMatch <https://schema.org/hasOfferCatalog> .


###  https://schema.bco-dmo.org/v1.0/onPlatform
bcodmo:onPlatform rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf bcodmo:situationInvolves ;
                  rdfs:domain bcodmo:Deployment ;
                  rdfs:range bcodmo:Platform ;
                  rdfs:comment "The platform (vessel, buoy, etc.) on which a deployment took place." ;
                  rdfs:label "onPlatform" .


###  https://schema.bco-dmo.org/v1.0/orcidIdentifier
bcodmo:orcidIdentifier rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf bcodmo:identifier ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain bcodmo:Person ;
                       rdfs:range bcodmo:ORCIDIdentifier ;
                       rdfs:comment "The ORCID Identifier for some person" ;
                       rdfs:label "orcidIdentifier" .


###  https://schema.bco-dmo.org/v1.0/performedAt
bcodmo:performedAt rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf bcodmo:situationInvolves ;
                   rdfs:domain bcodmo:AgentRole ;
                   rdfs:range bcodmo:Organization ;
                   rdfs:comment "The institutional affiliation at which the role was performed." ;
                   rdfs:label "performedAt" .


###  https://schema.bco-dmo.org/v1.0/performedBy
bcodmo:performedBy rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf bcodmo:situationInvolves ;
                   owl:inverseOf bcodmo:performedRole ;
                   rdfs:domain bcodmo:AgentRole ;
                   rdfs:range bcodmo:Agent ;
                   rdfs:comment "The person who performed or holds this role." ;
                   rdfs:label "performedBy" .


###  https://schema.bco-dmo.org/v1.0/performedRole
bcodmo:performedRole rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf bcodmo:situationInvolves ;
                     rdfs:domain bcodmo:Agent ;
                     rdfs:range bcodmo:AgentRole ;
                     rdfs:comment "An Agent Role performed by some Agent." ;
                     rdfs:label "performedRole" .


###  https://schema.bco-dmo.org/v1.0/piInstitutionChangedForPreviousAward
bcodmo:piInstitutionChangedForPreviousAward rdf:type owl:ObjectProperty ;
                                            rdfs:domain bcodmo:Award ;
                                            rdfs:range bcodmo:Award ;
                                            rdfs:comment "The Award that preceded this Award because the PI changed institutions." ;
                                            rdfs:label "piInstitutionChangedForPreviousAward" .


###  https://schema.bco-dmo.org/v1.0/platformTitle
bcodmo:platformTitle rdf:type owl:ObjectProperty ;
                     rdfs:domain bcodmo:Platform ;
                     rdfs:range bcodmo:PlatformTitle ;
                     rdfs:comment "The official or common title of the platform." ;
                     rdfs:label "platformTitle" .


###  https://schema.bco-dmo.org/v1.0/platformType
bcodmo:platformType rdf:type owl:ObjectProperty ;
                    rdfs:domain bcodmo:Platform ;
                    rdfs:range bcodmo:PlatformType ;
                    rdfs:comment "The type/category of the platform." ;
                    rdfs:label "platformType" .


###  https://schema.bco-dmo.org/v1.0/postalAddress
bcodmo:postalAddress rdf:type owl:ObjectProperty ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( bcodmo:Organization
                                                 bcodmo:Person
                                               )
                                 ] ;
                     rdfs:range bcodmo:PostalAddress ;
                     rdfs:comment "Postal address of some Agent." ;
                     rdfs:label "postalAddress" ;
                     skos:closeMatch <https://schema.org/address> .


###  https://schema.bco-dmo.org/v1.0/preferredDOI
bcodmo:preferredDOI rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf bcodmo:identifier ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( bcodmo:CreativeWork
                                                bcodmo:Dataset
                                                bcodmo:Deployment
                                                bcodmo:ResearchActivity
                                              )
                                ] ;
                    rdfs:range bcodmo:DOIIdentifier ;
                    rdfs:comment "The DOI that should be presented publicly for this resource. In most cases this is the most recent DOI, but the value is determined by curatorial judgment and must be asserted explicitly." ;
                    rdfs:label "preferredDOI" .


###  https://schema.bco-dmo.org/v1.0/producedWork
bcodmo:producedWork rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf bcodmo:situationInvolves ;
                    rdfs:domain bcodmo:ResearchActivity ;
                    rdfs:range bcodmo:CreativeWork ;
                    rdfs:comment "The research activity produced the research product." ;
                    rdfs:label "producedWork" ;
                    skos:exactMatch prov:generated .


###  https://schema.bco-dmo.org/v1.0/programManager
bcodmo:programManager rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty ;
                      rdfs:domain bcodmo:Award ;
                      rdfs:range bcodmo:Person ;
                      rdfs:comment "The program manager at the funding agency responsible for this award." ;
                      rdfs:label "programManager" .


###  https://schema.bco-dmo.org/v1.0/projectActedOnWork
bcodmo:projectActedOnWork rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf bcodmo:situationInvolves ;
                          rdfs:domain bcodmo:DatasetProject ;
                          rdfs:range bcodmo:Action ;
                          rdfs:comment "Defines the relationship between a Project and a Dataset." ;
                          rdfs:label "projectActedOnWork" .


###  https://schema.bco-dmo.org/v1.0/projectExternalDatasetList
bcodmo:projectExternalDatasetList rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf bcodmo:hasCollection ;
                                  rdfs:domain bcodmo:Project ;
                                  rdfs:range bcodmo:DatasetList ;
                                  rdfs:comment "a Collection of external Datasets related to a Project" ;
                                  rdfs:label "projectExternalDatasetList" .


###  https://schema.bco-dmo.org/v1.0/provider
bcodmo:provider rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( bcodmo:CreativeWork
                                            bcodmo:SoftwareApplication
                                          )
                            ] ;
                rdfs:range bcodmo:Agent ;
                rdfs:comment "The provider of some CreativeWork" ,
                             "The service provider that hosts/distributes the resource." ;
                rdfs:label "provider" ;
                skos:exactMatch <https://schema.org/provider> .


###  https://schema.bco-dmo.org/v1.0/publishedDate
bcodmo:publishedDate rdf:type owl:ObjectProperty ;
                     rdfs:domain bcodmo:CreativeWork ;
                     rdfs:range bcodmo:TemporalInstant ;
                     rdfs:comment "The date on which this dataset version was published." ;
                     rdfs:label "publishedDate" ;
                     skos:closeMatch <https://schema.org/datePublished> .


###  https://schema.bco-dmo.org/v1.0/publisher
bcodmo:publisher rdf:type owl:ObjectProperty ;
                 rdfs:domain bcodmo:Entity ;
                 rdfs:range bcodmo:Organization ;
                 rdfs:comment "The agent responsible for publishing a resource." ;
                 rdfs:label "publisher" ;
                 skos:closeMatch <https://schema.org/publisher> .


###  https://schema.bco-dmo.org/v1.0/relatedAward
bcodmo:relatedAward rdf:type owl:ObjectProperty ;
                    rdfs:domain bcodmo:Award ;
                    rdfs:range bcodmo:Award ;
                    rdfs:comment "A related award becuase it funded the same ResearchActivity" ;
                    rdfs:label "relatedAward" .


###  https://schema.bco-dmo.org/v1.0/relatedDataset
bcodmo:relatedDataset rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf bcodmo:relations ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( bcodmo:CreativeWork
                                                  bcodmo:RelatedWork
                                                )
                                  ] ;
                      rdfs:range bcodmo:Dataset ;
                      rdfs:comment "Related Datasets to some CreativeWork" ;
                      rdfs:label "relatedDataset" .


###  https://schema.bco-dmo.org/v1.0/relatedPublication
bcodmo:relatedPublication rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf bcodmo:relations ;
                          rdfs:domain [ rdf:type owl:Class ;
                                        owl:unionOf ( bcodmo:CreativeWork
                                                      bcodmo:RelatedWork
                                                    )
                                      ] ;
                          rdfs:range bcodmo:Publication ;
                          rdfs:comment "Related Publication to some CreativeWork" ;
                          rdfs:label "relatedPublication" .


###  https://schema.bco-dmo.org/v1.0/relations
bcodmo:relations rdf:type owl:ObjectProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( bcodmo:CreativeWork
                                             bcodmo:RelatedWork
                                           )
                             ] ;
                 rdfs:range bcodmo:CreativeWork ;
                 rdfs:comment "Related creative work associated with this creative work." ;
                 rdfs:label "relations" ;
                 skos:relatedMatch <https://schema.org/citation> .


###  https://schema.bco-dmo.org/v1.0/relationship
bcodmo:relationship rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( bcodmo:Dataset
                                                bcodmo:RelatedWork
                                              )
                                ] ;
                    rdfs:range bcodmo:ResourceRelation ;
                    rdfs:comment "A controlled-vocabulary relation type between two resources." ;
                    rdfs:label "relationship" .


###  https://schema.bco-dmo.org/v1.0/releaseDate
bcodmo:releaseDate rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf bcodmo:hasTime ;
                   rdfs:domain bcodmo:EmbargoReleasePolicy ;
                   rdfs:range bcodmo:TemporalEntity ;
                   rdfs:comment "The date on which an embargo releases and the dataset becomes publicly accessible." ;
                   rdfs:label "releaseDate" ;
                   skos:closeMatch <https://schema.org/expires> .


###  https://schema.bco-dmo.org/v1.0/replacedBy
bcodmo:replacedBy rdf:type owl:ObjectProperty ;
                  rdfs:domain bcodmo:DeprecatedEntity ;
                  rdfs:range bcodmo:Entity ;
                  rdfs:comment "An entity that replaces a deprecated Entity." ;
                  rdfs:label "replacedBy" .


###  https://schema.bco-dmo.org/v1.0/resolution
bcodmo:resolution rdf:type owl:ObjectProperty ;
                  owl:equivalentProperty bcodmo:temporalResolution ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( bcodmo:TemporalInstant
                                              bcodmo:TemporalInterval
                                            )
                              ] ;
                  rdfs:range time:TemporalUnit ;
                  rdfs:comment "The temporal resolution of a temporal extent (e.g. time:unitDay)." ;
                  rdfs:label "resolution" ;
                  owl:deprecated "true"^^xsd:boolean ;
                  skos:closeMatch time:unitType .


###  https://schema.bco-dmo.org/v1.0/role
bcodmo:role rdf:type owl:ObjectProperty ;
            rdfs:domain bcodmo:AgentRole ;
            rdfs:range bcodmo:Role ;
            rdfs:comment "The role type performed by the agent." ;
            rdfs:label "role" .


###  https://schema.bco-dmo.org/v1.0/situationInvolves
bcodmo:situationInvolves rdf:type owl:ObjectProperty ;
                         rdfs:domain bcodmo:Situation ;
                         rdfs:range owl:Thing ;
                         rdfs:comment "Some thing involved in a situation or event. A super property for more specific relationships in some Event." ;
                         rdfs:label "situationInvolves" ;
                         skos:relatedMatch <https://schema.org/about> .


###  https://schema.bco-dmo.org/v1.0/smallLogo
bcodmo:smallLogo rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf bcodmo:logo ;
                 rdfs:domain bcodmo:Entity ;
                 rdfs:range bcodmo:Logo ;
                 rdfs:comment "A smaller logo of some thing" ;
                 rdfs:label "smallLogo" .


###  https://schema.bco-dmo.org/v1.0/spatialCenter
bcodmo:spatialCenter rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf bcodmo:geometry ;
                     rdfs:domain bcodmo:GeographicalLocation ;
                     rdfs:range bcodmo:CentroidGeometry ;
                     rdfs:comment "The spatial centroid for a Geographical Location" ;
                     rdfs:label "spatialCenter" .


###  https://schema.bco-dmo.org/v1.0/spatialExtent
bcodmo:spatialExtent rdf:type owl:ObjectProperty ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( bcodmo:Dataset
                                                 bcodmo:Deployment
                                                 bcodmo:ResearchActivity
                                               )
                                 ] ;
                     rdfs:range bcodmo:GeographicalLocation ;
                     rdfs:comment "The spatial coverage of the dataset, deployment, project, or program." ;
                     rdfs:label "spatialExtent" ;
                     skos:closeMatch <https://schema.org/spatialCoverage> .


###  https://schema.bco-dmo.org/v1.0/status
bcodmo:status rdf:type owl:ObjectProperty ;
              rdfs:domain bcodmo:CreativeWork ;
              rdfs:range bcodmo:CreativeWorkStatus ;
              rdfs:comment "The current DOI lifecycle status of the dataset package." ;
              rdfs:label "status" ;
              owl:deprecated "true"^^xsd:boolean ;
              skos:closeMatch <https://schema.org/creativeWorkStatus> .


###  https://schema.bco-dmo.org/v1.0/storesValuesFor
bcodmo:storesValuesFor rdf:type owl:ObjectProperty ;
                       rdfs:domain bcodmo:Dataset ;
                       rdfs:range bcodmo:DatasetParameter ;
                       rdfs:comment "Links a dataset to the parameters whose values it records." ;
                       rdfs:label "storesValuesFor" ;
                       skos:closeMatch <https://schema.org/variableMeasured> .


###  https://schema.bco-dmo.org/v1.0/supplementalDocument
bcodmo:supplementalDocument rdf:type owl:ObjectProperty ;
                            rdfs:domain bcodmo:Dataset ;
                            rdfs:range bcodmo:SupplementalDocument ;
                            rdfs:comment "A supplemental document distributed with this dataset package." ;
                            rdfs:label "supplementalDocument" .


###  https://schema.bco-dmo.org/v1.0/target
bcodmo:target rdf:type owl:ObjectProperty ;
              rdfs:domain bcodmo:Policy ;
              rdfs:range bcodmo:CreativeWork ;
              rdfs:comment "The resource to which this policy applies." ;
              rdfs:label "target" .


###  https://schema.bco-dmo.org/v1.0/temporalExtent
bcodmo:temporalExtent rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf bcodmo:hasTime ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( bcodmo:AgentRole
                                                  bcodmo:Dataset
                                                  bcodmo:Deployment
                                                  bcodmo:ResearchActivity
                                                )
                                  ] ;
                      rdfs:range bcodmo:TemporalEntity ;
                      rdfs:comment "The temporal coverage of an agent role, dataset, deployment or research activity." ;
                      rdfs:label "temporalExtent" ;
                      skos:closeMatch time:hasTime .


###  https://schema.bco-dmo.org/v1.0/temporalResolution
bcodmo:temporalResolution rdf:type owl:ObjectProperty ;
                          rdfs:domain [ rdf:type owl:Class ;
                                        owl:unionOf ( bcodmo:TemporalInstant
                                                      bcodmo:TemporalInterval
                                                    )
                                      ] ;
                          rdfs:range time:TemporalUnit ;
                          rdfs:comment "The temporal resolution of a temporal extent (e.g. time:unitDay)." ;
                          rdfs:label "temporalResolution" ;
                          skos:closeMatch time:unitType .


###  https://schema.bco-dmo.org/v1.0/units
bcodmo:units rdf:type owl:ObjectProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( bcodmo:DatasetParameter
                                         bcodmo:Parameter
                                       )
                         ] ;
             rdfs:range bcodmo:UnitOfMeasure ;
             rdfs:comment "The unit of measure for a dataset parameter." ;
             rdfs:label "units" ;
             skos:relatedMatch <https://schema.org/unitCode> .


###  https://schema.bco-dmo.org/v1.0/usedWork
bcodmo:usedWork rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf bcodmo:situationInvolves ;
                rdfs:domain bcodmo:ResearchActivity ;
                rdfs:range bcodmo:CreativeWork ;
                rdfs:comment "A CreativeWork that was used in some ResearchActivity" ,
                             "The CreativeWork was used in a ResearchActivity" ;
                rdfs:label "usedWork" ;
                skos:exactMatch prov:used .


#################################################################
#    Data properties
#################################################################

###  https://schema.bco-dmo.org/v1.0/abbreviation
bcodmo:abbreviation rdf:type owl:DatatypeProperty ;
                    rdfs:domain bcodmo:Entity ;
                    rdfs:range xsd:string ;
                    rdfs:comment "A short abbreviation for a scheme, language, or licence." ;
                    rdfs:label "abbreviation" .


###  https://schema.bco-dmo.org/v1.0/abstract
bcodmo:abstract rdf:type owl:DatatypeProperty ;
                rdfs:domain bcodmo:CreativeWork ;
                rdfs:range xsd:string ;
                rdfs:comment "A plain-text abstract describing the dataset." ;
                rdfs:label "abstract" ;
                skos:closeMatch <https://schema.org/abstract> .


###  https://schema.bco-dmo.org/v1.0/acquisitionDescription
bcodmo:acquisitionDescription rdf:type owl:DatatypeProperty ;
                              rdfs:domain [ rdf:type owl:Class ;
                                            owl:unionOf ( bcodmo:Dataset
                                                          bcodmo:DatasetDeployment
                                                          bcodmo:Deployment
                                                        )
                                          ] ;
                              rdfs:range rdf:HTML ;
                              rdfs:comment "An HTML description of data acquisition methods." ;
                              rdfs:label "acquisitionDescription" .


###  https://schema.bco-dmo.org/v1.0/acronym
bcodmo:acronym rdf:type owl:DatatypeProperty ;
               rdfs:domain bcodmo:Entity ;
               rdfs:range xsd:token ;
               rdfs:comment "An acronym or abbreviation for an organisation, affiliation, project, or program." ;
               rdfs:label "acronym" .


###  https://schema.bco-dmo.org/v1.0/addressCountry
bcodmo:addressCountry rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain bcodmo:PostalAddress ;
                      rdfs:range xsd:string ;
                      rdfs:comment "The country for some physical address." ;
                      rdfs:label "addressCountry" ;
                      skos:exactMatch <https://schema.org/addressCountry> .


###  https://schema.bco-dmo.org/v1.0/addressLocality
bcodmo:addressLocality rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain bcodmo:PostalAddress ;
                       rdfs:range xsd:string ;
                       rdfs:comment "The region in which the locality is, and which is in the country. For example, California or another appropriate first-level Administrative division such as the Province in Italy or Region in Germany." ;
                       rdfs:label "addressLocality" ;
                       skos:exactMatch <https://schema.org/addressLocality> .


###  https://schema.bco-dmo.org/v1.0/addressRegion
bcodmo:addressRegion rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain bcodmo:PostalAddress ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The region in which the locality is, and which is in the country. For the US, this would be the name of the state, the province in Italy, or region in Germany." ;
                     rdfs:label "addressRegion" .


###  https://schema.bco-dmo.org/v1.0/affiliationName
bcodmo:affiliationName rdf:type owl:DatatypeProperty ;
                       rdfs:domain bcodmo:Affiliation ;
                       rdfs:range xsd:string ;
                       rdfs:comment "The primary name of the affiliated institution." ;
                       rdfs:label "affiliationName" .


###  https://schema.bco-dmo.org/v1.0/affiliationSubName
bcodmo:affiliationSubName rdf:type owl:DatatypeProperty ;
                          rdfs:domain bcodmo:Affiliation ;
                          rdfs:range xsd:string ;
                          rdfs:comment "A sub-unit or department name within an affiliated institution." ;
                          rdfs:label "affiliationSubName" .


###  https://schema.bco-dmo.org/v1.0/archiveComment
bcodmo:archiveComment rdf:type owl:DatatypeProperty ;
                      rdfs:domain bcodmo:DOIDataset ;
                      rdfs:range xsd:string ;
                      rdfs:comment "An internal comment about this particular DOIDataset" ;
                      rdfs:label "archiveComment" .


###  https://schema.bco-dmo.org/v1.0/asGeoJSON
bcodmo:asGeoJSON rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain bcodmo:Geometry ;
                 rdfs:range geosparql:geoJSONLiteral ;
                 rdfs:label "asGeoJSON" ;
                 skos:exactMatch geosparql:asGeoJSON .


###  https://schema.bco-dmo.org/v1.0/asWKT
bcodmo:asWKT rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain bcodmo:Geometry ;
             rdfs:range geosparql:wktLiteral ;
             rdfs:label "asWKT" ;
             skos:exactMatch geosparql:asWKT .


###  https://schema.bco-dmo.org/v1.0/bibliographicCitation
bcodmo:bibliographicCitation rdf:type owl:DatatypeProperty ;
                             rdfs:domain bcodmo:CreativeWork ;
                             rdfs:range rdf:HTML ;
                             rdfs:comment "The full bibliographic citation for a related publication or dataset." ;
                             rdfs:label "bibliographicCitation" .


###  https://schema.bco-dmo.org/v1.0/bytesize
bcodmo:bytesize rdf:type owl:DatatypeProperty ;
                rdfs:domain bcodmo:File ;
                rdfs:range xsd:long ;
                rdfs:comment "The size of the file in bytes." ;
                rdfs:label "bytesize" ;
                skos:closeMatch <https://schema.org/contentSize> .


###  https://schema.bco-dmo.org/v1.0/codeValue
bcodmo:codeValue rdf:type owl:DatatypeProperty ;
                 rdfs:domain bcodmo:Entity ;
                 rdfs:range xsd:token ;
                 rdfs:comment "A specific code value but not quite an Identifier." ;
                 rdfs:label "codeValue" ;
                 skos:exactMatch <https://schema.org/codeValue> .


###  https://schema.bco-dmo.org/v1.0/commonFileExtension
bcodmo:commonFileExtension rdf:type owl:DatatypeProperty ;
                           rdfs:domain bcodmo:FileType ;
                           rdfs:range xsd:token ;
                           rdfs:comment "A commonly used file extension for a particular FileType" ;
                           rdfs:label "commonFileExtension" .


###  https://schema.bco-dmo.org/v1.0/content
bcodmo:content rdf:type owl:DatatypeProperty ;
               rdfs:domain bcodmo:CreativeWork ;
               rdfs:range xsd:string ;
               rdfs:comment "The intellectual content for some CreativeWork" ;
               rdfs:label "content" ;
               skos:exactMatch <https://schema.org/text> .


###  https://schema.bco-dmo.org/v1.0/conversionDescription
bcodmo:conversionDescription rdf:type owl:DatatypeProperty ;
                             rdfs:domain bcodmo:DatasetParameter ;
                             rdfs:range xsd:string ;
                             rdfs:comment "Describes how the values can be converted." ;
                             rdfs:label "conversionDescription" .


###  https://schema.bco-dmo.org/v1.0/dataManagementProcessingDescription
bcodmo:dataManagementProcessingDescription rdf:type owl:DatatypeProperty ;
                                           rdfs:domain bcodmo:Dataset ;
                                           rdfs:range xsd:string ;
                                           rdfs:comment "A description of data management and processing applied by BCO-DMO." ;
                                           rdfs:label "dataManagementProcessingDescription" .


###  https://schema.bco-dmo.org/v1.0/dataURL
bcodmo:dataURL rdf:type owl:DatatypeProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( bcodmo:Dataset
                                           bcodmo:DatasetDeployment
                                           bcodmo:ResearchActivity
                                         )
                           ] ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "A URL where the data can be found for some thing, typically a Dataset or ResearchActivity" ;
               rdfs:label "dataURL" ;
               skos:closeMatch <http://www.w3.org/ns/dcat#accessURL> .


###  https://schema.bco-dmo.org/v1.0/description
bcodmo:description rdf:type owl:DatatypeProperty ;
                   rdfs:domain bcodmo:Entity ;
                   rdfs:range xsd:string ;
                   rdfs:comment "A description of a resource." ;
                   rdfs:label "description" ;
                   skos:exactMatch <https://schema.org/description> .


###  https://schema.bco-dmo.org/v1.0/disclaimer
bcodmo:disclaimer rdf:type owl:DatatypeProperty ;
                  rdfs:domain bcodmo:DatasetList ;
                  rdfs:range xsd:string ;
                  rdfs:comment "A disclaimer statement" ;
                  rdfs:label "disclaimer" .


###  https://schema.bco-dmo.org/v1.0/eastBoundary
bcodmo:eastBoundary rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain bcodmo:BoundingBoxGeometry ;
                    rdfs:range xsd:float ;
                    rdfs:comment "The eastern longitude boundary of a bounding box (decimal degrees)." ;
                    rdfs:label "eastBoundary" .


###  https://schema.bco-dmo.org/v1.0/email
bcodmo:email rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain bcodmo:Agent ;
             rdfs:range xsd:token ;
             rdfs:comment "Email address" ;
             rdfs:label "email" ;
             rdfs:seeAlso bcodmo:Datatype_EmailAddress ;
             skos:exactMatch <https://schema.org/email> .


###  https://schema.bco-dmo.org/v1.0/encoding
bcodmo:encoding rdf:type owl:DatatypeProperty ;
                rdfs:domain bcodmo:File ;
                rdfs:range xsd:string ;
                rdfs:comment "The character encoding of a file (e.g. utf-8)." ;
                rdfs:label "encoding" .


###  https://schema.bco-dmo.org/v1.0/expectingPublication
bcodmo:expectingPublication rdf:type owl:DatatypeProperty ;
                            rdfs:domain bcodmo:CreativeWork ;
                            rdfs:range xsd:boolean ;
                            rdfs:comment "Is the publication expecting publication?" ;
                            rdfs:label "expectingPublication" .


###  https://schema.bco-dmo.org/v1.0/externalWebsite
bcodmo:externalWebsite rdf:type owl:DatatypeProperty ;
                       rdfs:domain bcodmo:Entity ;
                       rdfs:range xsd:anyURI ;
                       rdfs:comment "The external project or program website URL." ;
                       rdfs:label "externalWebsite" ;
                       skos:relatedMatch <https://schema.org/url> .


###  https://schema.bco-dmo.org/v1.0/familyName
bcodmo:familyName rdf:type owl:DatatypeProperty ;
                  rdfs:domain bcodmo:Person ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The family (last) name of a person." ;
                  rdfs:label "familyName" ;
                  skos:exactMatch <https://schema.org/familyName> .


###  https://schema.bco-dmo.org/v1.0/faxNumber
bcodmo:faxNumber rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain bcodmo:Agent ;
                 rdfs:range xsd:token ;
                 rdfs:comment "The fax number." ;
                 rdfs:label "faxNumber" .


###  https://schema.bco-dmo.org/v1.0/filename
bcodmo:filename rdf:type owl:DatatypeProperty ;
                rdfs:domain bcodmo:File ;
                rdfs:range xsd:token ;
                rdfs:comment "The file name including extension." ;
                rdfs:label "filename" .


###  https://schema.bco-dmo.org/v1.0/firstNameSynonyms
bcodmo:firstNameSynonyms rdf:type owl:DatatypeProperty ;
                         rdfs:domain bcodmo:Person ;
                         rdfs:range xsd:string ;
                         rdfs:comment "A list of synonyms for the perons's first name" ;
                         rdfs:label "firstNameSynonyms" .


###  https://schema.bco-dmo.org/v1.0/givenName
bcodmo:givenName rdf:type owl:DatatypeProperty ;
                 rdfs:domain bcodmo:Person ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The given (first) name of a person." ;
                 rdfs:label "givenName" ;
                 skos:exactMatch <https://schema.org/givenName> .


###  https://schema.bco-dmo.org/v1.0/hasReportURL
bcodmo:hasReportURL rdf:type owl:DatatypeProperty ;
                    rdfs:domain bcodmo:Deployment ;
                    rdfs:range xsd:anyURI ;
                    rdfs:comment "A URL linking to the cruise/deployment report." ;
                    rdfs:label "hasReportURL" .


###  https://schema.bco-dmo.org/v1.0/honorific
bcodmo:honorific rdf:type owl:DatatypeProperty ;
                 rdfs:domain bcodmo:Person ;
                 rdfs:range xsd:string ;
                 rdfs:comment "An honorific prefix preceding a Person's name such as Dr/Mrs/Mr." ;
                 rdfs:label "honorific" ;
                 skos:closeMatch <https://schema.org/honorificPrefix> .


###  https://schema.bco-dmo.org/v1.0/honorificSuffix
bcodmo:honorificSuffix rdf:type owl:DatatypeProperty ;
                       rdfs:domain bcodmo:Person ;
                       rdfs:range xsd:string ;
                       rdfs:comment "An honorific suffix following a Person's name such as M.D./PhD/MSCSW." ;
                       rdfs:label "honorificSuffix" ;
                       skos:exactMatch "https://schema.org/honorificSuffix" .


###  https://schema.bco-dmo.org/v1.0/identifierValue
bcodmo:identifierValue rdf:type owl:DatatypeProperty ;
                       rdfs:domain bcodmo:Identifier ;
                       rdfs:range xsd:token ;
                       rdfs:comment "The raw identifier string value (e.g. the DOI suffix, the ROR ID)." ;
                       rdfs:label "identifierValue" ;
                       skos:closeMatch "https://schema.org/identifier" .


###  https://schema.bco-dmo.org/v1.0/inverseDescription
bcodmo:inverseDescription rdf:type owl:DatatypeProperty ;
                          rdfs:domain bcodmo:RelatedWork ;
                          rdfs:range xsd:string ;
                          rdfs:comment "The description of a bi-directional relationship (like a RelatedWork) to describe the relationship from object to subject direction. The `description` property describes the erlationship from subject to object." ;
                          rdfs:label "inverseDescription" .


###  https://schema.bco-dmo.org/v1.0/inverseLabel
bcodmo:inverseLabel rdf:type owl:DatatypeProperty ;
                    rdfs:domain bcodmo:ResourceRelation ;
                    rdfs:range xsd:string ;
                    rdfs:comment "A label describing some relationship beween from the perspective of the object." ;
                    rdfs:label "inverseLabel" .


###  https://schema.bco-dmo.org/v1.0/inverseSymmetricalRelationship
bcodmo:inverseSymmetricalRelationship rdf:type owl:DatatypeProperty ,
                                               owl:FunctionalProperty ;
                                      rdfs:domain bcodmo:ResourceRelation ;
                                      rdfs:range xsd:boolean ;
                                      rdfs:comment "Is the relationship symmetrical?" ;
                                      rdfs:label "inverseSymmetricalRelationship" .


###  https://schema.bco-dmo.org/v1.0/isDeprecated
bcodmo:isDeprecated rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain bcodmo:Entity ;
                    rdfs:range xsd:boolean ;
                    rdfs:comment "A way to mark an Entity as deprecated from use." ;
                    rdfs:label "isDeprecated" .


###  https://schema.bco-dmo.org/v1.0/isPrimary
bcodmo:isPrimary rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain bcodmo:Entity ;
                 rdfs:range xsd:boolean ;
                 rdfs:comment "In a multi-valued set of Things, this one is the primary" ;
                 rdfs:label "isPrimary" .


###  https://schema.bco-dmo.org/v1.0/isPrimaryDataFile
bcodmo:isPrimaryDataFile rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf bcodmo:isPrimary ;
                         rdfs:domain bcodmo:DataFile ;
                         rdfs:range xsd:boolean ;
                         rdfs:comment "Indicates whether this is the primary data file of a dataset (true/false)." ;
                         rdfs:label "isPrimaryDataFile" .


###  https://schema.bco-dmo.org/v1.0/label
bcodmo:label rdf:type owl:DatatypeProperty ;
             owl:equivalentProperty bcodmo:name ;
             rdfs:domain bcodmo:Entity ;
             rdfs:range xsd:string ;
             rdfs:comment "A human-readable label for any BCO-DMO resource." ;
             rdfs:label "label" ;
             skos:closeMatch <https://schema.org/name> .


###  https://schema.bco-dmo.org/v1.0/lastNameSynonyms
bcodmo:lastNameSynonyms rdf:type owl:DatatypeProperty ;
                        rdfs:domain bcodmo:Person ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Last name that a person may have or be known as" ;
                        rdfs:label "lastNameSynonyms" .


###  https://schema.bco-dmo.org/v1.0/latitude
bcodmo:latitude rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain sf:Point ;
                rdfs:range xsd:float ;
                rdfs:comment "Latitude is the angular measure of a point's position along the primary axis of a CRS, perpendicular to the reference surface's axis of symmetry." ;
                rdfs:label "latitude" .


###  https://schema.bco-dmo.org/v1.0/listPosition
bcodmo:listPosition rdf:type owl:DatatypeProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( bcodmo:CollectionItem
                                                bcodmo:DatasetParameter
                                              )
                                ] ;
                    rdfs:range xsd:integer ;
                    rdfs:comment "A integer representing a position of some Thing in a list of things. Can be used to rank, sort and order a list of things." ;
                    rdfs:label "listPosition" ;
                    skos:closeMatch <https://schema.org/position> .


###  https://schema.bco-dmo.org/v1.0/longitude
bcodmo:longitude rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain sf:Point ;
                 rdfs:range xsd:float ;
                 rdfs:comment "Longitude is the angular measure of a point's position around the secondary axis of a CRS, relative to an arbitrarily defined reference meridian." ;
                 rdfs:label "longitude" .


###  https://schema.bco-dmo.org/v1.0/middleName
bcodmo:middleName rdf:type owl:DatatypeProperty ;
                  rdfs:domain bcodmo:Person ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The middle name or initial of a person." ;
                  rdfs:label "middleName" ;
                  skos:relatedMatch <https://schema.org/additionalName> .


###  https://schema.bco-dmo.org/v1.0/middleNameSynonyms
bcodmo:middleNameSynonyms rdf:type owl:DatatypeProperty ;
                          rdfs:domain bcodmo:Person ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Other middle names a person may have or be known as" ;
                          rdfs:label "middleNameSynonyms" .


###  https://schema.bco-dmo.org/v1.0/mimeType
bcodmo:mimeType rdf:type owl:DatatypeProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( bcodmo:FileType
                                            bcodmo:SoftwareService
                                          )
                            ] ;
                rdfs:range xsd:token ;
                rdfs:comment "The MIME type associated with a file type." ;
                rdfs:label "mimeType" ;
                skos:closeMatch <http://www.w3.org/ns/dcat#mediaType> ,
                                <https://schema.org/encodingFormat> .


###  https://schema.bco-dmo.org/v1.0/name
bcodmo:name rdf:type owl:DatatypeProperty ;
            rdfs:domain bcodmo:Entity ;
            rdfs:range xsd:string ;
            rdfs:comment "The name of the item. Synonymous with the label property." ;
            rdfs:label "name" ;
            skos:closeMatch <https://schema.org/name> .


###  https://schema.bco-dmo.org/v1.0/nickname
bcodmo:nickname rdf:type owl:DatatypeProperty ;
                rdfs:domain bcodmo:Person ;
                rdfs:range xsd:string ;
                rdfs:comment "Nickname, or preferred name, of a Person" ;
                rdfs:label "nickname" ;
                skos:closeMatch <https://schema.org/additionalName> .


###  https://schema.bco-dmo.org/v1.0/noDataValue
bcodmo:noDataValue rdf:type owl:DatatypeProperty ;
                   rdfs:domain bcodmo:DatasetParameter ;
                   rdfs:range xsd:token ;
                   rdfs:comment "The value to expect in a DatasetParameter when there was no data for the given record." ;
                   rdfs:label "noDataValue" .


###  https://schema.bco-dmo.org/v1.0/northBoundary
bcodmo:northBoundary rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain bcodmo:BoundingBoxGeometry ;
                     rdfs:range xsd:float ;
                     rdfs:comment "The northern latitude boundary of a bounding box (decimal degrees)." ;
                     rdfs:label "northBoundary" .


###  https://schema.bco-dmo.org/v1.0/officialName
bcodmo:officialName rdf:type owl:DatatypeProperty ;
                    rdfs:domain bcodmo:Parameter ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The official name for a master parameter." ;
                    rdfs:label "officialName" ;
                    skos:relatedMatch <https://schema.org/name> .


###  https://schema.bco-dmo.org/v1.0/postalCode
bcodmo:postalCode rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain bcodmo:PostalAddress ;
                  rdfs:range xsd:token ;
                  rdfs:comment "The postal code" ;
                  rdfs:label "postalCode" .


###  https://schema.bco-dmo.org/v1.0/problemDescription
bcodmo:problemDescription rdf:type owl:DatatypeProperty ;
                          rdfs:domain bcodmo:Dataset ;
                          rdfs:range xsd:string ;
                          rdfs:comment "A description of known problems or caveats with the dataset." ;
                          rdfs:label "problemDescription" .


###  https://schema.bco-dmo.org/v1.0/processingDescription
bcodmo:processingDescription rdf:type owl:DatatypeProperty ;
                             rdfs:domain [ rdf:type owl:Class ;
                                           owl:unionOf ( bcodmo:Dataset
                                                         bcodmo:DatasetDeployment
                                                         bcodmo:Deployment
                                                       )
                                         ] ;
                             rdfs:range rdf:HTML ;
                             rdfs:comment "An HTML description of data processing steps." ;
                             rdfs:label "processingDescription" .


###  https://schema.bco-dmo.org/v1.0/requiresConversion
bcodmo:requiresConversion rdf:type owl:DatatypeProperty ;
                          rdfs:domain bcodmo:DatasetParameter ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "The values in the dataset for this property need to be converted." ;
                          rdfs:label "requiresConversion" .


###  https://schema.bco-dmo.org/v1.0/resolvableUrl
bcodmo:resolvableUrl rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf bcodmo:url ;
                     rdfs:domain bcodmo:Identifier ;
                     rdfs:range xsd:anyURI ;
                     rdfs:comment "A resolvable URL that dereferences the identifier." ;
                     rdfs:label "resolvableUrl" ;
                     skos:closeMatch <https://schema.org/url> .


###  https://schema.bco-dmo.org/v1.0/roleWeight
bcodmo:roleWeight rdf:type owl:DatatypeProperty ;
                  rdfs:domain bcodmo:Role ;
                  rdfs:range xsd:int ;
                  rdfs:comment "Sort ordering of role types" ;
                  rdfs:label "roleWeight" .


###  https://schema.bco-dmo.org/v1.0/shortDescription
bcodmo:shortDescription rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf bcodmo:description ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( bcodmo:Dataset
                                                    bcodmo:Parameter
                                                  )
                                    ] ;
                        rdfs:range rdf:HTML ;
                        rdfs:comment "A brief HTML description of the dataset or parameter" ;
                        rdfs:label "shortDescription" ;
                        skos:closeMatch <https://schema.org/disambiguatingDescription> .


###  https://schema.bco-dmo.org/v1.0/shortName
bcodmo:shortName rdf:type owl:DatatypeProperty ;
                 rdfs:domain bcodmo:Parameter ;
                 rdfs:range xsd:string ;
                 rdfs:comment "A short name for a master parameter." ;
                 rdfs:label "shortName" ;
                 skos:relatedMatch <https://schema.org/name> .


###  https://schema.bco-dmo.org/v1.0/showTable
bcodmo:showTable rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain bcodmo:FileDescriptor ;
                 rdfs:range xsd:boolean ;
                 rdfs:comment "Whether to allow a tabular file to be viewed in the table data viewer" ;
                 rdfs:label "showTable" .


###  https://schema.bco-dmo.org/v1.0/southBoundary
bcodmo:southBoundary rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain bcodmo:BoundingBoxGeometry ;
                     rdfs:range xsd:float ;
                     rdfs:comment "The southern latitude boundary of a bounding box (decimal degrees)." ;
                     rdfs:label "southBoundary" .


###  https://schema.bco-dmo.org/v1.0/streetAddress
bcodmo:streetAddress rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain bcodmo:PostalAddress ;
                     rdfs:range xsd:string ;
                     rdfs:comment "The street address. For example, 1600 Amphitheatre Pkwy. Can be multi-line to include APT or other street informaion. It typically comes after the addressee's name but before the addressLocality" ;
                     rdfs:label "streetAddress" ;
                     skos:closeMatch <https://schema.org/streetAddress> .


###  https://schema.bco-dmo.org/v1.0/telephone
bcodmo:telephone rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain bcodmo:Agent ;
                 rdfs:range xsd:token ;
                 rdfs:comment "The telephone number." ;
                 rdfs:label "telephone" ;
                 skos:exactMatch <https://schema.org/telephone> .


###  https://schema.bco-dmo.org/v1.0/title
bcodmo:title rdf:type owl:DatatypeProperty ;
             rdfs:domain bcodmo:Dataset ;
             rdfs:range xsd:string ;
             rdfs:comment "The full title of the dataset." ;
             rdfs:label "title" ;
             skos:closeMatch <https://schema.org/name> .


###  https://schema.bco-dmo.org/v1.0/url
bcodmo:url rdf:type owl:DatatypeProperty ;
           rdfs:domain bcodmo:Entity ;
           rdfs:range xsd:anyURI ;
           rdfs:comment "A URL for a resource, such as its landing page." ;
           rdfs:label "url" ;
           skos:exactMatch <https://schema.org/url> .


###  https://schema.bco-dmo.org/v1.0/urlTemplate
bcodmo:urlTemplate rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain bcodmo:SoftwareService ;
                   rdfs:range xsd:anyURI ;
                   rdfs:comment "An url template (RFC6570) that will be used to construct the target of the execution of the action." ;
                   rdfs:label "urlTemplate" ;
                   skos:exactMatch <https://schema.org/urlTemplate> .


###  https://schema.bco-dmo.org/v1.0/useFullMiddleNameInCitationText
bcodmo:useFullMiddleNameInCitationText rdf:type owl:DatatypeProperty ,
                                                owl:FunctionalProperty ;
                                       rdfs:domain [ rdf:type owl:Class ;
                                                     owl:unionOf ( bcodmo:AgentRole
                                                                   bcodmo:Person
                                                                 )
                                                   ] ;
                                       rdfs:range xsd:boolean ;
                                       rdfs:comment "Whether the Person prefers to use their full middle name in citations. Can be overriden by using at teh AgentRole for authors and contributors." ;
                                       rdfs:label "useFullMiddleNameInCitationText" .


###  https://schema.bco-dmo.org/v1.0/validated
bcodmo:validated rdf:type owl:DatatypeProperty ;
                 rdfs:domain bcodmo:Dataset ;
                 rdfs:range xsd:boolean ;
                 rdfs:comment "Has the dataset been validated by the PI." ;
                 rdfs:label "validated" .


###  https://schema.bco-dmo.org/v1.0/valueFormat
bcodmo:valueFormat rdf:type owl:DatatypeProperty ;
                   rdfs:domain bcodmo:DatasetParameter ;
                   rdfs:range xsd:token ;
                   rdfs:comment "The format string used to encode parameter values in the data file." ;
                   rdfs:label "valueFormat" .


###  https://schema.bco-dmo.org/v1.0/version
bcodmo:version rdf:type owl:DatatypeProperty ;
               rdfs:domain bcodmo:Dataset ;
               rdfs:range xsd:token ;
               rdfs:comment "The version label of the dataset (numeric or numeric + single lowercase letter)." ;
               rdfs:label "version" ;
               skos:exactMatch <https://schema.org/version> .


###  https://schema.bco-dmo.org/v1.0/westBoundary
bcodmo:westBoundary rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain bcodmo:BoundingBoxGeometry ;
                    rdfs:range xsd:float ;
                    rdfs:comment "The western longitude boundary of a bounding box (decimal degrees)." ;
                    rdfs:label "westBoundary" .


#################################################################
#    Classes
#################################################################

###  http://www.opengis.net/ont/sf#LineString
sf:LineString rdf:type owl:Class ;
              rdfs:subClassOf bcodmo:Geometry .


###  http://www.opengis.net/ont/sf#MultiLineString
sf:MultiLineString rdf:type owl:Class ;
                   rdfs:subClassOf bcodmo:Geometry .


###  http://www.opengis.net/ont/sf#MultiPoint
sf:MultiPoint rdf:type owl:Class ;
              rdfs:subClassOf bcodmo:Geometry .


###  http://www.opengis.net/ont/sf#Point
sf:Point rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( bcodmo:Geometry
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty bcodmo:latitude ;
                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onDataRange xsd:float
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty bcodmo:longitude ;
                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onDataRange xsd:float
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf bcodmo:Geometry .


###  http://www.opengis.net/ont/sf#Polygon
sf:Polygon rdf:type owl:Class ;
           rdfs:subClassOf bcodmo:Geometry .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#List
rdf:List rdf:type owl:Class .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement
rdf:Statement rdf:type owl:Class .


###  http://www.w3.org/2006/time#TemporalUnit
time:TemporalUnit rdf:type owl:Class .


###  https://schema.bco-dmo.org/v1.0/Action
bcodmo:Action rdf:type owl:Class ;
              rdfs:subClassOf bcodmo:Category ;
              rdfs:comment "Some action that can be taken on an Entity. A Policy can restrict and allow actions" ;
              rdfs:label "Action" ;
              skos:closeMatch <https://schema.org/Action> .


###  https://schema.bco-dmo.org/v1.0/Affiliation
bcodmo:Affiliation rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( bcodmo:Organization
                                                              [ rdf:type owl:Class ;
                                                                owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                owl:onProperty [ owl:inverseOf bcodmo:affiliation
                                                                                               ] ;
                                                                                owl:someValuesFrom bcodmo:Person
                                                                              ]
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty [ owl:inverseOf bcodmo:performedAt
                                                                                               ] ;
                                                                                owl:someValuesFrom bcodmo:AgentRole
                                                                              ]
                                                                            )
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf bcodmo:Organization ;
                   rdfs:comment "An institutional affiliation of a person (university, research institute, etc.)." ;
                   rdfs:label "Affiliation" .


###  https://schema.bco-dmo.org/v1.0/Agent
bcodmo:Agent rdf:type owl:Class ;
             rdfs:subClassOf bcodmo:Entity ;
             owl:disjointWith bcodmo:Award ,
                              bcodmo:Category ,
                              bcodmo:CreativeWork ,
                              bcodmo:GeographicalLocation ,
                              bcodmo:Geometry ,
                              bcodmo:Identifier ,
                              bcodmo:Platform ,
                              bcodmo:Situation ,
                              bcodmo:TemporalEntity ;
             rdfs:comment "An entity (person or organisation) that can perform roles." ;
             rdfs:label "Agent" ;
             skos:exactMatch prov:Agent .


###  https://schema.bco-dmo.org/v1.0/AgentRole
bcodmo:AgentRole rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty bcodmo:performedBy ;
                                                              owl:someValuesFrom bcodmo:Agent
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty bcodmo:role ;
                                                              owl:someValuesFrom bcodmo:Role
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf bcodmo:hasAgentWithRole
                                                                             ] ;
                                                              owl:someValuesFrom bcodmo:Entity
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf bcodmo:Situation ;
                 rdfs:comment "A qualified association that links an Agent to a role and optionally an affiliation context." ;
                 rdfs:label "Agent Role" ;
                 skos:closeMatch <https://schema.org/Role> ,
                                 <https://www.w3.org/ns/prov#Role> .


###  https://schema.bco-dmo.org/v1.0/Annotation
bcodmo:Annotation rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:annotator ;
                                                               owl:someValuesFrom bcodmo:Agent
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:annotates ;
                                                               owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:hasContent ;
                                                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass bcodmo:CreativeWork
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf bcodmo:Situation ;
                  rdfs:comment "A comment or some other piece of content that annotates for some specific purpose some Thing" ;
                  rdfs:label "Annotation" .


###  https://schema.bco-dmo.org/v1.0/AnnotationAction
bcodmo:AnnotationAction rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:Action ;
                        rdfs:comment "The motivation for annotating some thing." ;
                        rdfs:label "AnnotationAction" .


###  https://schema.bco-dmo.org/v1.0/ArchiveFileType
bcodmo:ArchiveFileType rdf:type owl:Class ;
                       rdfs:subClassOf bcodmo:FileType ;
                       rdfs:comment "A file format  used to bundle multiple files and folders into a single file for easier storage or transfer." ;
                       rdfs:label "ArchiveFileType" .


###  https://schema.bco-dmo.org/v1.0/ArchivedDataset
bcodmo:ArchivedDataset rdf:type owl:Class ;
                       rdfs:subClassOf bcodmo:Dataset ;
                       rdfs:comment "A specific version of a Dataset that has been stored  in an archive that typcially provides access" ;
                       rdfs:label "ArchivedDataset" .


###  https://schema.bco-dmo.org/v1.0/Audience
bcodmo:Audience rdf:type owl:Class ;
                rdfs:subClassOf bcodmo:Category ;
                rdfs:comment "Intended audience for an item, i.e. the group for whom the item was created or is being offered to." ;
                rdfs:label "Audience" ;
                skos:closeMatch <https://schema.org/Audience> .


###  https://schema.bco-dmo.org/v1.0/Award
bcodmo:Award rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( bcodmo:Entity
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty bcodmo:funder ;
                                                          owl:someValuesFrom bcodmo:FundingAgency
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty [ owl:inverseOf bcodmo:fundedByAward
                                                                         ] ;
                                                          owl:someValuesFrom bcodmo:CreativeWork
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf bcodmo:Entity ;
             owl:disjointWith bcodmo:Category ,
                              bcodmo:CreativeWork ,
                              bcodmo:GeographicalLocation ,
                              bcodmo:Geometry ,
                              bcodmo:Identifier ,
                              bcodmo:Platform ,
                              bcodmo:Situation ,
                              bcodmo:TemporalEntity ;
             rdfs:comment "A funding award (grant) from a funder that supports data collection." ;
             rdfs:label "Award" ;
             skos:closeMatch <https://schema.org/Grant> .


###  https://schema.bco-dmo.org/v1.0/AwardNoDataAnnotation
bcodmo:AwardNoDataAnnotation rdf:type owl:Class ;
                             owl:equivalentClass [ owl:intersectionOf ( bcodmo:Annotation
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty bcodmo:annotates ;
                                                                          owl:someValuesFrom [ owl:intersectionOf ( rdf:Statement
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty rdf:subject ;
                                                                                                                      owl:someValuesFrom bcodmo:Award
                                                                                                                    ]
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty rdf:object ;
                                                                                                                      owl:hasValue bcodmo:Boolean_True
                                                                                                                    ]
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty rdf:predicate ;
                                                                                                                      owl:hasValue bcodmo:awardProducingData
                                                                                                                    ]
                                                                                                                  ) ;
                                                                                               rdf:type owl:Class
                                                                                             ]
                                                                        ]
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty bcodmo:hasContent ;
                                                                          owl:someValuesFrom [ owl:intersectionOf ( bcodmo:Comment
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty bcodmo:content ;
                                                                                                                      owl:someValuesFrom xsd:string
                                                                                                                    ]
                                                                                                                  ) ;
                                                                                               rdf:type owl:Class
                                                                                             ]
                                                                        ]
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty bcodmo:annotator ;
                                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                          owl:onClass bcodmo:Agent
                                                                        ]
                                                                      ) ;
                                                   rdf:type owl:Class
                                                 ] ;
                             rdfs:subClassOf bcodmo:Annotation ;
                             rdfs:comment "A reason why an award will not produce datasets" ;
                             rdfs:label "AwardNoDataAnnotation" .


###  https://schema.bco-dmo.org/v1.0/BCODMOIdentifier
bcodmo:BCODMOIdentifier rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:Identifier ;
                        rdfs:comment "An internal BCO-DMO identifier (version 2 scheme)." ;
                        rdfs:label "BCO-DMO Identifier" .


###  https://schema.bco-dmo.org/v1.0/Boolean
bcodmo:Boolean rdf:type owl:Class ;
               rdfs:subClassOf bcodmo:Datatype ;
               rdfs:comment "A boolean value like True or False, Yes or No, 1 or 0." ;
               rdfs:isDefinedBy bcodmo:Datatype_Boolean ;
               rdfs:label "Boolean" ;
               skos:exactMatch <https://schema.org/Boolean> .


###  https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry
bcodmo:BoundingBoxGeometry rdf:type owl:Class ;
                           rdfs:subClassOf sf:Polygon ;
                           rdfs:comment "An axis-aligned bounding box geometry defined by west/south/east/north boundaries. A set of Point geometries where the first Point and the last point are the same Point." ;
                           rdfs:label "Bounding Box Geometry" ;
                           skos:exactMatch sf:Envelope .


###  https://schema.bco-dmo.org/v1.0/Category
bcodmo:Category rdf:type owl:Class ;
                rdfs:subClassOf bcodmo:Entity ;
                owl:disjointWith bcodmo:CreativeWork ,
                                 bcodmo:GeographicalLocation ,
                                 bcodmo:Geometry ,
                                 bcodmo:Identifier ,
                                 bcodmo:Platform ,
                                 bcodmo:Situation ,
                                 bcodmo:TemporalEntity ;
                rdfs:comment "A set of taxonomy" ;
                rdfs:label "Category" ;
                skos:closeMatch <https://schema.org/DefinedTerm> .


###  https://schema.bco-dmo.org/v1.0/CentroidGeometry
bcodmo:CentroidGeometry rdf:type owl:Class ;
                        rdfs:subClassOf sf:Point ;
                        rdfs:comment "A point geometry representing the centroid of a spatial extent." ;
                        rdfs:label "Centroid Geometry" ;
                        skos:closeMatch sf:Point .


###  https://schema.bco-dmo.org/v1.0/Collection
bcodmo:Collection rdf:type owl:Class ;
                  rdfs:subClassOf bcodmo:CreativeWork ;
                  rdfs:comment "A curated collection, set, or list of some Things." ;
                  rdfs:label "Collection" ;
                  skos:closeMatch <https://schema.org/Collection> .


###  https://schema.bco-dmo.org/v1.0/CollectionItem
bcodmo:CollectionItem rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty bcodmo:inCollection ;
                                                                   owl:someValuesFrom bcodmo:Collection
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf bcodmo:Situation ;
                      rdfs:comment "An item in a collection" ;
                      rdfs:label "CollectionItem" ;
                      skos:exactMatch <https://schema.org/ListItem> .


###  https://schema.bco-dmo.org/v1.0/Comment
bcodmo:Comment rdf:type owl:Class ;
               rdfs:subClassOf bcodmo:CreativeWork ;
               rdfs:comment "A note or piece of text typically used for Annotations" ;
               rdfs:label "Comment" ;
               skos:closeMatch <https://schema.org/Comment> .


###  https://schema.bco-dmo.org/v1.0/ComputerLanguage
bcodmo:ComputerLanguage rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:Language ;
                        owl:disjointWith bcodmo:NaturalLanguage ;
                        rdfs:comment "Programming languages such as Python, Go, Rust and Java." ;
                        rdfs:label "ComputerLanguage" ;
                        skos:closeMatch <https://schema.org/ComputerLanguage> .


###  https://schema.bco-dmo.org/v1.0/ConsumeAction
bcodmo:ConsumeAction rdf:type owl:Class ;
                     rdfs:subClassOf bcodmo:Action ;
                     rdfs:comment "The act of consuming an Entity." ;
                     rdfs:label "ConsumeAction" ;
                     skos:closeMatch "https://schema.org/ConsumeAction" .


###  https://schema.bco-dmo.org/v1.0/ControlledVocabulary
bcodmo:ControlledVocabulary rdf:type owl:Class ;
                            rdfs:subClassOf bcodmo:CreativeWork ;
                            rdfs:comment "A vocabulary of terms or phrases used to describe concepts in a specific domain" ;
                            rdfs:label "ControlledVocabulary" .


###  https://schema.bco-dmo.org/v1.0/CoordinateReferenceSystem
bcodmo:CoordinateReferenceSystem rdf:type owl:Class ;
                                 rdfs:subClassOf bcodmo:IdentifierScheme ;
                                 rdfs:comment "A coordinate reference system" ;
                                 rdfs:label "CoordinateReferenceSystem" .


###  https://schema.bco-dmo.org/v1.0/CreativeWork
bcodmo:CreativeWork rdf:type owl:Class ;
                    rdfs:subClassOf bcodmo:Entity ;
                    owl:disjointWith bcodmo:GeographicalLocation ,
                                     bcodmo:Geometry ,
                                     bcodmo:Identifier ,
                                     bcodmo:Platform ,
                                     bcodmo:Situation ,
                                     bcodmo:TemporalEntity ;
                    rdfs:comment "Any work that can be created by some Agent" ;
                    rdfs:label "Creative Work" ;
                    skos:exactMatch <https://schema.org/CreativeWork> .


###  https://schema.bco-dmo.org/v1.0/CreativeWorkStatus
bcodmo:CreativeWorkStatus rdf:type owl:Class ;
                          rdfs:subClassOf bcodmo:Category ;
                          rdfs:comment "A state of for some creative work." ;
                          rdfs:label "CreativeWorkStatus" .


###  https://schema.bco-dmo.org/v1.0/Cruise
bcodmo:Cruise rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( bcodmo:Deployment
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty bcodmo:onPlatform ;
                                                           owl:someValuesFrom bcodmo:Vessel
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf bcodmo:Deployment ;
              rdfs:comment "A research vessel cruise, a specialisation of Platform for vessel-type platforms." ;
              rdfs:label "Cruise" .


###  https://schema.bco-dmo.org/v1.0/CryptographicHash
bcodmo:CryptographicHash rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( bcodmo:Identifier
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty bcodmo:identifierScheme ;
                                                                      owl:someValuesFrom bcodmo:CryptographicHashAlgorithm
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf bcodmo:Identifier ;
                         rdfs:comment "A cryptographic hash (e.g. MD5) used as a file integrity checksum." ;
                         rdfs:label "Cryptographic Hash" .


###  https://schema.bco-dmo.org/v1.0/CryptographicHashAlgorithm
bcodmo:CryptographicHashAlgorithm rdf:type owl:Class ;
                                  rdfs:subClassOf bcodmo:IdentifierScheme ;
                                  rdfs:comment "A mathematical function that transforms any arbitrary amount of input data into a fixed-length string of characters (identifierValue), acting as a secure \"digital fingerprint\" or \"digest\"" ;
                                  rdfs:label "Cryptographic Hash Algorithm" .


###  https://schema.bco-dmo.org/v1.0/CurrentState
bcodmo:CurrentState rdf:type owl:Class ;
                    rdfs:subClassOf bcodmo:Category ;
                    rdfs:comment "The current editorial/curation state of a CreativeWork" ;
                    rdfs:label "Current State" .


###  https://schema.bco-dmo.org/v1.0/DOIDataset
bcodmo:DOIDataset rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( bcodmo:ArchivedDataset
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:identifier ;
                                                               owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty bcodmo:identifierScheme ;
                                                                                    owl:hasValue bcodmo:IdentifierScheme_DOI
                                                                                  ]
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf bcodmo:ArchivedDataset ;
                  rdfs:comment "A versioned BCO-DMO dataset that has been assigned a DOI." ;
                  rdfs:label "DOI Dataset" .


###  https://schema.bco-dmo.org/v1.0/DOIIdentifier
bcodmo:DOIIdentifier rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( bcodmo:Identifier
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty bcodmo:identifierScheme ;
                                                                  owl:hasValue bcodmo:IdentifierScheme_DOI
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf bcodmo:Identifier ;
                     rdfs:comment "A Digital Object Identifier." ;
                     rdfs:label "DOI Identifier" .


###  https://schema.bco-dmo.org/v1.0/DOIStatus
bcodmo:DOIStatus rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( bcodmo:CreativeWorkStatus
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf bcodmo:status
                                                                             ] ;
                                                              owl:someValuesFrom bcodmo:DOIDataset
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf bcodmo:CreativeWorkStatus ;
                 rdfs:comment "The lifecycle status of a DOI Dataset (Draft, Reserved, Published, etc.)." ;
                 rdfs:label "DOI Status" .


###  https://schema.bco-dmo.org/v1.0/DataFile
bcodmo:DataFile rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( bcodmo:FileDescriptor
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty [ owl:inverseOf bcodmo:dataFile
                                                                            ] ;
                                                             owl:someValuesFrom bcodmo:CreativeWork
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf bcodmo:FileDescriptor ;
                rdfs:comment "A primary or supplemental data file distributed as part of a dataset." ;
                rdfs:label "Data File" ;
                skos:closeMatch <https://schema.org/DataDownload> .


###  https://schema.bco-dmo.org/v1.0/DataManagementPlan
bcodmo:DataManagementPlan rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( bcodmo:FileDescriptor
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty [ owl:inverseOf bcodmo:dataManagementPlan
                                                                                      ] ;
                                                                       owl:someValuesFrom bcodmo:CreativeWork
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf bcodmo:FileDescriptor ;
                          rdfs:comment "A plan describing how a research activity will manage and archive data products produced." ;
                          rdfs:label "DataManagementPlan" .


###  https://schema.bco-dmo.org/v1.0/Dataset
bcodmo:Dataset rdf:type owl:Class ;
               rdfs:subClassOf bcodmo:CreativeWork ;
               rdfs:comment "A dataset which may be internal or external to BCO-DMO." ;
               rdfs:label "Dataset" ;
               skos:exactMatch <https://schema.org/Dataset> .


###  https://schema.bco-dmo.org/v1.0/DatasetAward
bcodmo:DatasetAward rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty bcodmo:fundedByAward ;
                                                                 owl:someValuesFrom bcodmo:Award
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty [ owl:inverseOf bcodmo:forDataset
                                                                                ] ;
                                                                 owl:someValuesFrom bcodmo:Dataset
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf bcodmo:Situation ;
                    rdfs:comment "The connection between a dataset and the award the funded its generation" ;
                    rdfs:label "DatasetAward" .


###  https://schema.bco-dmo.org/v1.0/DatasetDeployment
bcodmo:DatasetDeployment rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty bcodmo:forDataset ;
                                                                      owl:someValuesFrom bcodmo:Dataset
                                                                    ]
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty bcodmo:fromDeployment ;
                                                                      owl:someValuesFrom bcodmo:Deployment
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf bcodmo:Situation ,
                                         [ owl:intersectionOf ( bcodmo:Situation
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty bcodmo:forDataset ;
                                                                  owl:someValuesFrom bcodmo:Dataset
                                                                ]
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty bcodmo:fromDeployment ;
                                                                  owl:someValuesFrom bcodmo:Deployment
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                         rdfs:comment "A deployment as referenced within a specific dataset, with dataset-specific properties." ;
                         rdfs:label "Dataset Deployment" .


###  https://schema.bco-dmo.org/v1.0/DatasetInstrument
bcodmo:DatasetInstrument rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty bcodmo:forDataset ;
                                                                      owl:someValuesFrom bcodmo:Dataset
                                                                    ]
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty bcodmo:isDefinedAs ;
                                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                      owl:onClass bcodmo:Instrument
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf bcodmo:Situation ;
                         rdfs:comment "An instrument as referenced within a specific dataset, with dataset-specific properties." ;
                         rdfs:label "Dataset Instrument" .


###  https://schema.bco-dmo.org/v1.0/DatasetList
bcodmo:DatasetList rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( bcodmo:Collection
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty bcodmo:hasCollectionItem ;
                                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass [ owl:intersectionOf ( bcodmo:CollectionItem
                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                     owl:onProperty bcodmo:collectionItem ;
                                                                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                     owl:onClass bcodmo:Dataset
                                                                                                   ]
                                                                                                 ) ;
                                                                              rdf:type owl:Class
                                                                            ]
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf bcodmo:Collection ;
                   rdfs:comment "A list of Datasets" ;
                   rdfs:label "DatasetList" .


###  https://schema.bco-dmo.org/v1.0/DatasetNoInstrumentsAnnotation
bcodmo:DatasetNoInstrumentsAnnotation rdf:type owl:Class ;
                                      owl:equivalentClass [ owl:intersectionOf ( bcodmo:Annotation
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty bcodmo:annotates ;
                                                                                   owl:someValuesFrom [ owl:intersectionOf ( rdf:Statement
                                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                                               owl:onProperty rdf:subject ;
                                                                                                                               owl:someValuesFrom bcodmo:Dataset
                                                                                                                             ]
                                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                                               owl:onProperty rdf:object ;
                                                                                                                               owl:hasValue bcodmo:Boolean_True
                                                                                                                             ]
                                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                                               owl:onProperty rdf:predicate ;
                                                                                                                               owl:hasValue bcodmo:datasetInstrumentsNotUsed
                                                                                                                             ]
                                                                                                                           ) ;
                                                                                                        rdf:type owl:Class
                                                                                                      ]
                                                                                 ]
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty bcodmo:hasContent ;
                                                                                   owl:someValuesFrom [ owl:intersectionOf ( bcodmo:Comment
                                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                                               owl:onProperty bcodmo:content ;
                                                                                                                               owl:someValuesFrom xsd:string
                                                                                                                             ]
                                                                                                                           ) ;
                                                                                                        rdf:type owl:Class
                                                                                                      ]
                                                                                 ]
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty bcodmo:annotator ;
                                                                                   owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                   owl:onClass bcodmo:Agent
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ] ;
                                      rdfs:subClassOf bcodmo:Annotation ;
                                      rdfs:comment "A reason as to why no instruments were used in the generation of this Dataset." ;
                                      rdfs:label "DatasetNoInstrumentsAnnotation" .


###  https://schema.bco-dmo.org/v1.0/DatasetNoParametersAnnotation
bcodmo:DatasetNoParametersAnnotation rdf:type owl:Class ;
                                     owl:equivalentClass [ owl:intersectionOf ( bcodmo:Annotation
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty bcodmo:annotates ;
                                                                                  owl:someValuesFrom [ owl:intersectionOf ( rdf:Statement
                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                              owl:onProperty rdf:subject ;
                                                                                                                              owl:someValuesFrom bcodmo:Dataset
                                                                                                                            ]
                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                              owl:onProperty rdf:object ;
                                                                                                                              owl:hasValue bcodmo:Boolean_True
                                                                                                                            ]
                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                              owl:onProperty rdf:predicate ;
                                                                                                                              owl:hasValue bcodmo:datasetParametersNotRequired
                                                                                                                            ]
                                                                                                                          ) ;
                                                                                                       rdf:type owl:Class
                                                                                                     ]
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty bcodmo:hasContent ;
                                                                                  owl:someValuesFrom [ owl:intersectionOf ( bcodmo:Comment
                                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                                              owl:onProperty bcodmo:content ;
                                                                                                                              owl:someValuesFrom xsd:string
                                                                                                                            ]
                                                                                                                          ) ;
                                                                                                       rdf:type owl:Class
                                                                                                     ]
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty bcodmo:annotator ;
                                                                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                  owl:onClass bcodmo:Agent
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                     rdfs:subClassOf bcodmo:Annotation ;
                                     rdfs:comment "A reason as to why a Dataset has no parameters defined." ;
                                     rdfs:label "DatasetNoParametersAnnotation" .


###  https://schema.bco-dmo.org/v1.0/DatasetParameter
bcodmo:DatasetParameter rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty bcodmo:forDataset ;
                                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                     owl:onClass bcodmo:Dataset
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty bcodmo:isDefinedAs ;
                                                                     owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                     owl:onClass bcodmo:Parameter
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf bcodmo:Situation ;
                        rdfs:comment "A parameter as instantiated within a specific dataset column, with dataset-level name, description, units, and format." ;
                        rdfs:label "Dataset Parameter" ;
                        skos:closeMatch <http://www.w3.org/ns/sosa/ObservableProperty> .


###  https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute
bcodmo:DatasetParameterAttribute rdf:type owl:Class ;
                                 rdfs:subClassOf bcodmo:Category ;
                                 rdfs:comment "An attribute of a dataset parameter that provides more context as to how it could be used." ;
                                 rdfs:label "DatasetParameterAttribute" .


###  https://schema.bco-dmo.org/v1.0/DatasetProject
bcodmo:DatasetProject rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty bcodmo:forDataset ;
                                                                   owl:someValuesFrom bcodmo:Dataset
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty bcodmo:hasProject ;
                                                                   owl:someValuesFrom bcodmo:Project
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty bcodmo:projectActedOnWork ;
                                                                   owl:someValuesFrom bcodmo:Action
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf bcodmo:Situation ;
                      rdfs:comment "A situation in which a Project has some influence on the creation of a Dataset." ;
                      rdfs:label "DatasetProject" .


###  https://schema.bco-dmo.org/v1.0/DatasetType
bcodmo:DatasetType rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty [ owl:inverseOf bcodmo:datasetType
                                                                               ] ;
                                                                owl:someValuesFrom bcodmo:Dataset
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf bcodmo:Category ;
                   rdfs:comment "A category describing the type of dataset (e.g. Cruise Data, Model Output)." ;
                   rdfs:label "Dataset Type" .


###  https://schema.bco-dmo.org/v1.0/DatasetsInOtherCatalog
bcodmo:DatasetsInOtherCatalog rdf:type owl:Class ;
                              owl:equivalentClass [ owl:intersectionOf ( bcodmo:DatasetList
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty bcodmo:hasProject ;
                                                                           owl:someValuesFrom bcodmo:Project
                                                                         ]
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty bcodmo:publisher ;
                                                                           owl:someValuesFrom bcodmo:Agent
                                                                         ]
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty bcodmo:disclaimer ;
                                                                           owl:someValuesFrom xsd:string
                                                                         ]
                                                                       ) ;
                                                    rdf:type owl:Class
                                                  ] ;
                              rdfs:subClassOf bcodmo:DatasetList ;
                              rdfs:comment "A list of datasets in a catalog that isn't BCO-DMO" ;
                              rdfs:label "DatasetsInOtherCatalog" .


###  https://schema.bco-dmo.org/v1.0/Datatype
bcodmo:Datatype rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty [ owl:inverseOf bcodmo:dataType
                                                                            ] ;
                                                             owl:someValuesFrom bcodmo:DatasetParameter
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf bcodmo:Category ;
                rdfs:comment "The data type of a dataset parameter column (e.g. string, integer, float)." ;
                rdfs:label "Datatype" ;
                skos:exactMatch <https://schema.org/DataType> .


###  https://schema.bco-dmo.org/v1.0/DefinedTerm
bcodmo:DefinedTerm rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty bcodmo:inControlledVocabulary ;
                                                                owl:someValuesFrom bcodmo:ControlledVocabulary
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf bcodmo:Category ;
                   rdfs:comment "A term in some ControlledVocabulary with a community-agreed definition" ;
                   rdfs:label "DefinedTerm" ;
                   skos:exactMatch <https://schema.org/DefinedTerm> .


###  https://schema.bco-dmo.org/v1.0/Deployment
bcodmo:Deployment rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( bcodmo:Event
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:onPlatform ;
                                                               owl:someValuesFrom bcodmo:Platform
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf bcodmo:Event ;
                  rdfs:comment "A scientific deployment (cruise, expedition, mooring deployment) during which data were collected." ;
                  rdfs:label "Deployment" ;
                  skos:closeMatch <http://www.w3.org/ns/ssn/Deployment> .


###  https://schema.bco-dmo.org/v1.0/DeploymentActivity
bcodmo:DeploymentActivity rdf:type owl:Class ;
                          rdfs:subClassOf bcodmo:Category ;
                          rdfs:comment "The type of activity a specific deployment was operating under." ;
                          rdfs:label "DeploymentActivity" .


###  https://schema.bco-dmo.org/v1.0/DeploymentEntityMatch
bcodmo:DeploymentEntityMatch rdf:type owl:Class ;
                             owl:equivalentClass [ owl:intersectionOf ( bcodmo:EntityMatch
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty rdf:object ;
                                                                          owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                        ]
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty rdf:subject ;
                                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                          owl:onClass bcodmo:Deployment
                                                                        ]
                                                                      ) ;
                                                   rdf:type owl:Class
                                                 ] ;
                             rdfs:subClassOf bcodmo:EntityMatch ;
                             rdfs:label "DeploymentEntityMatch" .


###  https://schema.bco-dmo.org/v1.0/DeprecatedEntity
bcodmo:DeprecatedEntity rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( bcodmo:Entity
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty bcodmo:isDeprecated ;
                                                                     owl:hasValue "true"^^xsd:boolean
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf bcodmo:Entity ;
                        rdfs:comment "An entity that should no longer be used." ;
                        rdfs:label "DeprecatedEntity" .


###  https://schema.bco-dmo.org/v1.0/EmailAddress
bcodmo:EmailAddress rdf:type owl:Class ;
                    rdfs:subClassOf bcodmo:IdentifierString ;
                    rdfs:comment "An email address." ;
                    rdfs:isDefinedBy bcodmo:Datatype_EmailAddress ;
                    rdfs:label "Email Address" .


###  https://schema.bco-dmo.org/v1.0/EmbargoPolicy
bcodmo:EmbargoPolicy rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( bcodmo:Policy
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty bcodmo:expirationDate ;
                                                                  owl:someValuesFrom bcodmo:TemporalEntity
                                                                ]
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty bcodmo:modifiesAction ;
                                                                  owl:someValuesFrom bcodmo:ConsumeAction
                                                                ]
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty bcodmo:target ;
                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass bcodmo:CreativeWork
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf bcodmo:Policy ;
                     rdfs:comment "A policy that restricts access to a dataset until an expiration date." ;
                     rdfs:label "Embargo Policy" .


###  https://schema.bco-dmo.org/v1.0/EmbargoReleasePolicy
bcodmo:EmbargoReleasePolicy rdf:type owl:Class ;
                            owl:equivalentClass [ owl:intersectionOf ( bcodmo:Policy
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty bcodmo:modifiesAction ;
                                                                         owl:someValuesFrom bcodmo:ConsumeAction
                                                                       ]
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty bcodmo:releaseDate ;
                                                                         owl:someValuesFrom bcodmo:TemporalEntity
                                                                       ]
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty bcodmo:target ;
                                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                         owl:onClass bcodmo:CreativeWork
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ] ;
                            rdfs:subClassOf bcodmo:Policy ;
                            rdfs:comment "A policy that allows access to a FileDescriptor when its overarching Dataset is under an embargo." ;
                            rdfs:label "EmbargoReleasePolicy" .


###  https://schema.bco-dmo.org/v1.0/Entity
bcodmo:Entity rdf:type owl:Class ;
              rdfs:comment "A BCO-DMO specific concept" ;
              rdfs:label "Entity" .


###  https://schema.bco-dmo.org/v1.0/EntityMatch
bcodmo:EntityMatch rdf:type owl:Class ;
                   rdfs:subClassOf bcodmo:Situation ;
                   rdfs:comment "A link between two entities that are related in some way as defined by rdf:predicate. This entity allows for annotating details of the match." ;
                   rdfs:label "EntityMatch" .


###  https://schema.bco-dmo.org/v1.0/EntityPublishingStatus
bcodmo:EntityPublishingStatus rdf:type owl:Class ;
                              rdfs:subClassOf bcodmo:Category ;
                              rdfs:comment "One or more statuses of a BCO-DMO Entity. This is primarily used to determine where an entity appears - not at all while it's being contructed, in draft review for a submitter, published, deprecated or unpublished." ;
                              rdfs:label "EntityPublishingStatus" .


###  https://schema.bco-dmo.org/v1.0/Event
bcodmo:Event rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty bcodmo:hasTime ;
                                                          owl:someValuesFrom bcodmo:TemporalEntity
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf bcodmo:Situation ;
             rdfs:comment "A dynamic situation in which something unique or impotant happened." ;
             rdfs:label "Event" ;
             skos:closeMatch <https://schema.org/Event> .


###  https://schema.bco-dmo.org/v1.0/File
bcodmo:File rdf:type owl:Class ;
            rdfs:subClassOf bcodmo:CreativeWork ;
            rdfs:comment "A physical file (byte stream) associated with a dataset or package." ;
            rdfs:label "File" ;
            skos:closeMatch <https://schema.org/MediaObject> .


###  https://schema.bco-dmo.org/v1.0/FileDescriptor
bcodmo:FileDescriptor rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( bcodmo:CreativeWork
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty bcodmo:describesFile ;
                                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                   owl:onClass bcodmo:File
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf bcodmo:CreativeWork ;
                      rdfs:comment "A context-specific description of a file. The context could be data, metadata or supplemental documentation." ;
                      rdfs:label "File Descriptor" ;
                      skos:closeMatch <https://schema.org/DigitalDocument> .


###  https://schema.bco-dmo.org/v1.0/FileType
bcodmo:FileType rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty [ owl:inverseOf bcodmo:fileType
                                                                            ] ;
                                                             owl:someValuesFrom bcodmo:File
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf bcodmo:Category ;
                rdfs:comment "A file format type, characterised by a label and MIME type (e.g. CSV, XML, PDF)." ;
                rdfs:label "File Type" .


###  https://schema.bco-dmo.org/v1.0/FundingAgency
bcodmo:FundingAgency rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( bcodmo:Organization
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty [ owl:inverseOf bcodmo:funder
                                                                                 ] ;
                                                                  owl:someValuesFrom bcodmo:Award
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf bcodmo:Organization ;
                     rdfs:comment "An Organization that has provided some funding award" ;
                     rdfs:label "Funding Agency" ;
                     skos:exactMatch <https://schema.org/FundingAgency> .


###  https://schema.bco-dmo.org/v1.0/GCMDPlatformType
bcodmo:GCMDPlatformType rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:DefinedTerm ;
                        rdfs:comment "A platform type defined by GCMD" ;
                        rdfs:isDefinedBy bcodmo:ControlledVocabulary_GCMDPlatformTypes ;
                        rdfs:label "GCMDPlatformType" .


###  https://schema.bco-dmo.org/v1.0/GeographicalLocation
bcodmo:GeographicalLocation rdf:type owl:Class ;
                            rdfs:subClassOf bcodmo:Entity ;
                            owl:disjointWith bcodmo:Geometry ,
                                             bcodmo:Identifier ,
                                             bcodmo:Platform ,
                                             bcodmo:Situation ,
                                             bcodmo:TemporalEntity ;
                            rdfs:comment "A spatial extent or named location associated with a dataset, deployment, project, or program." ;
                            rdfs:label "Geographical Location" ;
                            skos:exactMatch <https://schema.org/Place> ;
                            skos:relatedMatch <http://www.w3.org/ns/sosa/FeatureOfInterest> .


###  https://schema.bco-dmo.org/v1.0/Geometry
bcodmo:Geometry rdf:type owl:Class ;
                rdfs:subClassOf bcodmo:Entity ;
                owl:disjointWith bcodmo:Identifier ,
                                 bcodmo:Platform ,
                                 bcodmo:Situation ,
                                 bcodmo:TemporalEntity ;
                rdfs:comment "An abstract spatial geometry." ;
                rdfs:label "Geometry" ;
                skos:closeMatch <https://schema.org/GeospatialGeometry> ;
                skos:exactMatch sf:Geometry .


###  https://schema.bco-dmo.org/v1.0/Identifier
bcodmo:Identifier rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( bcodmo:Entity
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:identifierScheme ;
                                                               owl:someValuesFrom bcodmo:IdentifierScheme
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:identifierValue ;
                                                               owl:someValuesFrom xsd:token
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf bcodmo:Entity ;
                  owl:disjointWith bcodmo:Platform ,
                                   bcodmo:Situation ,
                                   bcodmo:TemporalEntity ;
                  rdfs:comment "An identifier assigned to a resource by some scheme." ;
                  rdfs:label "Identifier" .


###  https://schema.bco-dmo.org/v1.0/IdentifierScheme
bcodmo:IdentifierScheme rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:Category ;
                        rdfs:comment "A named scheme or authority that mints identifiers (DOI, ROR, ORCID, etc.)." ;
                        rdfs:label "Identifier Scheme" .


###  https://schema.bco-dmo.org/v1.0/IdentifierString
bcodmo:IdentifierString rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:String ;
                        rdfs:comment "A string that is used as an identifier" ;
                        rdfs:isDefinedBy bcodmo:Datatype_Identifier ;
                        rdfs:label "IdentifierString"@en .


###  https://schema.bco-dmo.org/v1.0/Image
bcodmo:Image rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( bcodmo:File
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty bcodmo:fileType ;
                                                          owl:someValuesFrom bcodmo:ImageFileType
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf bcodmo:File ;
             rdfs:comment "An image file." ;
             rdfs:label "Image" ;
             skos:closeMatch <https://schema.org/ImageObject> .


###  https://schema.bco-dmo.org/v1.0/ImageFileType
bcodmo:ImageFileType rdf:type owl:Class ;
                     rdfs:subClassOf bcodmo:FileType ;
                     rdfs:comment "Representative of a type of image file." ;
                     rdfs:label "ImageFileType" .


###  https://schema.bco-dmo.org/v1.0/Instrument
bcodmo:Instrument rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( bcodmo:DefinedTerm
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty [ owl:inverseOf bcodmo:isDefinedAs
                                                                              ] ;
                                                               owl:someValuesFrom bcodmo:DatasetInstrument
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ,
                                      [ owl:intersectionOf ( bcodmo:DefinedTerm
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty bcodmo:inControlledVocabulary ;
                                                               owl:hasValue bcodmo:ControlledVocabulary_BCODMO_Instruments
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf bcodmo:DefinedTerm ;
                  rdfs:comment "A master (community-level) scientific instrument definition." ;
                  rdfs:label "Instrument" ;
                  skos:closeMatch <http://www.w3.org/ns/sosa/Sensor> ;
                  skos:relatedMatch <https://www.w3.org/TR/vocab-ssn/#SSNSystem> .


###  https://schema.bco-dmo.org/v1.0/Keyword
bcodmo:Keyword rdf:type owl:Class ;
               rdfs:subClassOf bcodmo:Category ;
               rdfs:comment "A subject keyword associated with a CreativeWork." ;
               rdfs:label "Keyword" .


###  https://schema.bco-dmo.org/v1.0/Language
bcodmo:Language rdf:type owl:Class ;
                rdfs:subClassOf bcodmo:Category ;
                rdfs:comment "A natural language used in the dataset metadata." ;
                rdfs:label "Language" .


###  https://schema.bco-dmo.org/v1.0/License
bcodmo:License rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( bcodmo:CreativeWork
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty [ owl:inverseOf bcodmo:license
                                                                           ] ;
                                                            owl:someValuesFrom bcodmo:CreativeWork
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf bcodmo:CreativeWork ;
               rdfs:comment "A  license applied to some creative work." ;
               rdfs:label "License" .


###  https://schema.bco-dmo.org/v1.0/Logo
bcodmo:Logo rdf:type owl:Class ;
            rdfs:subClassOf bcodmo:Image ;
            rdfs:comment "An image that is representative of some thing" ;
            rdfs:label "Logo" .


###  https://schema.bco-dmo.org/v1.0/MediaService
bcodmo:MediaService rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( bcodmo:CreativeWork
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty bcodmo:categorizedBy ;
                                                                 owl:someValuesFrom bcodmo:MediaServiceType
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf bcodmo:CreativeWork ;
                    rdfs:comment "An affordance made to some audience by a provider to access all or part of some CreativeWork. Often times it is an interpretation of the whole work - a metadata record, a visualization, a file in a specific format, etc." ;
                    rdfs:label "MediaService" ;
                    skos:relatedMatch <http://www.w3.org/ns/dcat#DataService> ,
                                      <https://schema.org/DataDownload> ,
                                      <https://schema.org/MediaObject> ,
                                      <https://schema.org/WebAPI> .


###  https://schema.bco-dmo.org/v1.0/MediaServiceType
bcodmo:MediaServiceType rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:Category ;
                        rdfs:comment "A way of grouping multiple MediaService offerings on the same CreativeWork" ;
                        rdfs:label "MediaServiceType" .


###  https://schema.bco-dmo.org/v1.0/MetadataFile
bcodmo:MetadataFile rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( bcodmo:FileDescriptor
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty [ owl:inverseOf bcodmo:metadataFile
                                                                                ] ;
                                                                 owl:someValuesFrom bcodmo:CreativeWork
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf bcodmo:FileDescriptor ;
                    rdfs:comment "A metadata file (e.g. ISO 19115-2 XML, dataset description PDF) describing a dataset." ;
                    rdfs:label "Metadata File" ;
                    skos:closeMatch <https://schema.org/DataDownload> .


###  https://schema.bco-dmo.org/v1.0/MetadataProfile
bcodmo:MetadataProfile rdf:type owl:Class ;
                       rdfs:subClassOf bcodmo:CreativeWork ;
                       rdfs:comment "A formal metadata profile specification to which the datapackage conforms." ;
                       rdfs:label "Metadata Profile" .


###  https://schema.bco-dmo.org/v1.0/MultiPolygon
bcodmo:MultiPolygon rdf:type owl:Class ;
                    rdfs:subClassOf bcodmo:Geometry .


###  https://schema.bco-dmo.org/v1.0/NODCTopic
bcodmo:NODCTopic rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( bcodmo:DefinedTerm
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf bcodmo:nodcTopicCategory
                                                                             ] ;
                                                              owl:someValuesFrom bcodmo:Dataset
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ,
                                     [ owl:intersectionOf ( bcodmo:DefinedTerm
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty bcodmo:inControlledVocabulary ;
                                                              owl:hasValue bcodmo:ControlledVocabulary_NODC_ISO19115-2_MD_TopicCategoryCode
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf bcodmo:DefinedTerm ;
                 rdfs:comment "A NODC topic category for Datases." ;
                 rdfs:isDefinedBy bcodmo:ControlledVocabulary_NODC_ISO19115-2_MD_TopicCategoryCode ;
                 rdfs:label "NODCTopic" .


###  https://schema.bco-dmo.org/v1.0/NaturalLanguage
bcodmo:NaturalLanguage rdf:type owl:Class ;
                       rdfs:subClassOf bcodmo:Language ;
                       rdfs:comment "Natural languages such as Spanish, Tamil, Hindi, English, etc." ;
                       rdfs:label "NaturalLanguage" ;
                       skos:closeMatch <https://schema.org/Language> .


###  https://schema.bco-dmo.org/v1.0/ORCIDIdentifier
bcodmo:ORCIDIdentifier rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( bcodmo:Identifier
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty bcodmo:identifierScheme ;
                                                                    owl:hasValue bcodmo:IdentifierScheme_ORCID
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf bcodmo:Identifier ;
                       rdfs:comment "An Open Researcher and Contributor ID" ;
                       rdfs:label "ORCID Identifier" .


###  https://schema.bco-dmo.org/v1.0/OfferCatalog
bcodmo:OfferCatalog rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( bcodmo:Collection
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty bcodmo:hasCollectionItem ;
                                                                 owl:someValuesFrom bcodmo:ServiceOffering
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty [ owl:inverseOf bcodmo:offers
                                                                                ] ;
                                                                 owl:someValuesFrom [ owl:intersectionOf ( bcodmo:MediaService
                                                                                                           [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty bcodmo:categorizedBy ;
                                                                                                             owl:someValuesFrom bcodmo:MediaServiceType
                                                                                                           ]
                                                                                                         ) ;
                                                                                      rdf:type owl:Class
                                                                                    ]
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf bcodmo:Collection ;
                    rdfs:comment "A list of offerings for some MediaService" ;
                    rdfs:label "OfferCatalog" ;
                    skos:exactMatch <https://schema.org/OfferCatalog> .


###  https://schema.bco-dmo.org/v1.0/Organization
bcodmo:Organization rdf:type owl:Class ;
                    rdfs:subClassOf bcodmo:Agent ;
                    owl:disjointWith bcodmo:Person ,
                                     bcodmo:SoftwareApplication ;
                    rdfs:comment "An organisational body such as a publisher, funder, or identifier authority." ;
                    rdfs:label "Organization" ;
                    skos:exactMatch <https://schema.org/Organization> ,
                                    <https://www.w3.org/ns/prov#Organization> .


###  https://schema.bco-dmo.org/v1.0/Parameter
bcodmo:Parameter rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( bcodmo:DefinedTerm
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty [ owl:inverseOf bcodmo:isDefinedAs
                                                                             ] ;
                                                              owl:someValuesFrom bcodmo:DatasetParameter
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ,
                                     [ owl:intersectionOf ( bcodmo:DefinedTerm
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty bcodmo:inControlledVocabulary ;
                                                              owl:hasValue bcodmo:ControlledVocabulary_BCODMO_Parameters
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf bcodmo:DefinedTerm ;
                 rdfs:comment "A master (community-level) scientific parameter definition." ;
                 rdfs:label "Parameter" .


###  https://schema.bco-dmo.org/v1.0/Person
bcodmo:Person rdf:type owl:Class ;
              rdfs:subClassOf bcodmo:Agent ;
              owl:disjointWith bcodmo:SoftwareApplication ;
              rdfs:comment "A human individual associated with some entity." ;
              rdfs:label "Person" ;
              skos:exactMatch <https://schema.org/Person> ,
                              <https://www.w3.org/ns/prov#Person> .


###  https://schema.bco-dmo.org/v1.0/Platform
bcodmo:Platform rdf:type owl:Class ;
                rdfs:subClassOf bcodmo:Entity ;
                owl:disjointWith bcodmo:Situation ,
                                 bcodmo:TemporalEntity ;
                rdfs:comment "A platform (vessel, buoy, glider, etc.) used for data collection." ;
                rdfs:label "Platform" ;
                skos:closeMatch <http://www.w3.org/ns/sosa/Platform> .


###  https://schema.bco-dmo.org/v1.0/PlatformTitle
bcodmo:PlatformTitle rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty [ owl:inverseOf bcodmo:platformTitle
                                                                                 ] ;
                                                                  owl:someValuesFrom bcodmo:Platform
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf bcodmo:Category ;
                     rdfs:comment "A named title/designation for a platform (e.g. the full name of a research vessel)." ;
                     rdfs:label "Platform Title" .


###  https://schema.bco-dmo.org/v1.0/PlatformType
bcodmo:PlatformType rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty [ owl:inverseOf bcodmo:platformType
                                                                                ] ;
                                                                 owl:someValuesFrom bcodmo:Platform
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf bcodmo:Category ;
                    rdfs:comment "A category of platform (e.g. vessel, mooring, glider)." ;
                    rdfs:label "Platform Type" .


###  https://schema.bco-dmo.org/v1.0/Policy
bcodmo:Policy rdf:type owl:Class ;
              rdfs:subClassOf bcodmo:CreativeWork ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                       owl:onProperty bcodmo:modifiesAction ;
                                                       owl:someValuesFrom bcodmo:ConsumeAction
                                                     ]
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty bcodmo:target ;
                                                       owl:someValuesFrom bcodmo:Entity
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
              rdfs:comment "An access or governance policy applied to a resource." ;
              rdfs:label "Policy" .


###  https://schema.bco-dmo.org/v1.0/PostalAddress
bcodmo:PostalAddress rdf:type owl:Class ;
                     rdfs:subClassOf bcodmo:GeographicalLocation ;
                     rdfs:comment "The mailing address." ;
                     rdfs:label "PostalAddress" ;
                     skos:exactMatch <https://schema.org/PostalAddress> .


###  https://schema.bco-dmo.org/v1.0/Program
bcodmo:Program rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( bcodmo:ResearchActivity
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty [ owl:inverseOf bcodmo:hasParentProgram
                                                                           ] ;
                                                            owl:someValuesFrom bcodmo:Project
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf bcodmo:ResearchActivity ;
               owl:disjointWith bcodmo:Project ;
               rdfs:comment "A scientific program (typically a grouping of related projects) associated with a dataset." ;
               rdfs:label "Program" .


###  https://schema.bco-dmo.org/v1.0/Project
bcodmo:Project rdf:type owl:Class ;
               rdfs:subClassOf bcodmo:ResearchActivity ;
               rdfs:comment "A funded scientific project under which data were collected." ;
               rdfs:label "Project" .


###  https://schema.bco-dmo.org/v1.0/Publication
bcodmo:Publication rdf:type owl:Class ;
                   rdfs:subClassOf bcodmo:CreativeWork ;
                   rdfs:comment "A scholarly publication related to a dataset (journal article, report, etc.)." ;
                   rdfs:label "Publication" ;
                   skos:closeMatch <https://schema.org/Article> .


###  https://schema.bco-dmo.org/v1.0/RORIdentifier
bcodmo:RORIdentifier rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( bcodmo:Identifier
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty bcodmo:identifierScheme ;
                                                                  owl:hasValue bcodmo:IdentifierScheme_ROR
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf bcodmo:Identifier ;
                     rdfs:comment "A Research Organization Registry identifier." ;
                     rdfs:label "ROR Identifier" .


###  https://schema.bco-dmo.org/v1.0/RelatedDataset
bcodmo:RelatedDataset rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( bcodmo:RelatedWork
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty bcodmo:relations ;
                                                                   owl:someValuesFrom bcodmo:Dataset
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf bcodmo:RelatedWork ;
                      rdfs:label "RelatedDataset" .


###  https://schema.bco-dmo.org/v1.0/RelatedPublication
bcodmo:RelatedPublication rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( bcodmo:RelatedWork
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty bcodmo:relations ;
                                                                       owl:someValuesFrom bcodmo:Publication
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf bcodmo:RelatedWork .


###  https://schema.bco-dmo.org/v1.0/RelatedWork
bcodmo:RelatedWork rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( bcodmo:Situation
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty bcodmo:forCreativeWork ;
                                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass bcodmo:CreativeWork
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty bcodmo:relations ;
                                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass bcodmo:CreativeWork
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty bcodmo:relationship ;
                                                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass bcodmo:ResourceRelation
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf bcodmo:Situation ;
                   rdfs:comment "A related CreativeWork to some other CreativeWork. This describes the situation surrounding this relationship." ;
                   rdfs:label "RelatedWork" .


###  https://schema.bco-dmo.org/v1.0/ResearchActivity
bcodmo:ResearchActivity rdf:type owl:Class ;
                        rdfs:subClassOf bcodmo:Event ;
                        rdfs:comment "An activity that enables research. The research typically produces datasets." ;
                        rdfs:label "Research Activity" ;
                        skos:relatedMatch <https://schema.org/ResearchProject> .


###  https://schema.bco-dmo.org/v1.0/ResourceRelation
bcodmo:ResourceRelation rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty [ owl:inverseOf bcodmo:relationship
                                                                                    ] ;
                                                                     owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                          owl:unionOf ( bcodmo:Dataset
                                                                                                        bcodmo:RelatedWork
                                                                                                      )
                                                                                        ]
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf bcodmo:DefinedTerm ;
                        rdfs:comment "A controlled-vocabulary term describing the relationship between two resources (aligned to Crossref and DataCite relation types)." ;
                        rdfs:label "Resource Relation" .


###  https://schema.bco-dmo.org/v1.0/ResourceRelationGroup
bcodmo:ResourceRelationGroup rdf:type owl:Class ;
                             owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty [ owl:inverseOf bcodmo:inGroup
                                                                                         ] ;
                                                                          owl:someValuesFrom bcodmo:ResourceRelation
                                                                        ]
                                                                      ) ;
                                                   rdf:type owl:Class
                                                 ] ;
                             rdfs:subClassOf bcodmo:Category ;
                             rdfs:comment "A grouping category for resource relation types." ;
                             rdfs:label "Resource Relation Group" .


###  https://schema.bco-dmo.org/v1.0/Role
bcodmo:Role rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( bcodmo:Category
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty bcodmo:roleWeight ;
                                                         owl:someValuesFrom xsd:int
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf bcodmo:Category ;
            rdfs:comment "A functional role performed by an agent (e.g. Principal Investigator, Co-Investigator)." ;
            rdfs:label "Role" .


###  https://schema.bco-dmo.org/v1.0/ServiceOffering
bcodmo:ServiceOffering rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( bcodmo:CollectionItem
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty bcodmo:actionType ;
                                                                    owl:someValuesFrom bcodmo:ConsumeAction
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf bcodmo:CollectionItem ;
                       rdfs:comment "An offered entry pointoffered by a MediaService to perform some Action." ;
                       rdfs:label "ServiceOffering" ;
                       skos:relatedMatch <https://schema.org/EntryPoint> .


###  https://schema.bco-dmo.org/v1.0/Situation
bcodmo:Situation rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( bcodmo:Entity
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty bcodmo:situationInvolves ;
                                                              owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf bcodmo:Entity ;
                 owl:disjointWith bcodmo:TemporalEntity ;
                 rdfs:comment "A static or dynamic scenario. A state of affairs that describes some configuration of the world. Most often a situation describes the interaction of 2 or more entities. In some cases these interactions are time bounded and can be labeled as significant events." ;
                 rdfs:label "Situation" .


###  https://schema.bco-dmo.org/v1.0/SoftwareApplication
bcodmo:SoftwareApplication rdf:type owl:Class ;
                           owl:equivalentClass [ owl:intersectionOf ( bcodmo:Agent
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty bcodmo:provider ;
                                                                        owl:someValuesFrom bcodmo:Agent
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                           rdfs:subClassOf bcodmo:Agent ;
                           rdfs:comment "A piece of software that is deployed and executable." ;
                           rdfs:label "SoftwareApplication" ;
                           skos:exactMatch <https://schema.org/SoftwareApplication> ,
                                           <https://www.w3.org/ns/prov#SoftwareAgent> .


###  https://schema.bco-dmo.org/v1.0/SoftwareService
bcodmo:SoftwareService rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( bcodmo:CreativeWork
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty bcodmo:provider ;
                                                                    owl:someValuesFrom bcodmo:SoftwareApplication
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf bcodmo:CreativeWork ;
                       rdfs:comment "A service offered by some SoftwareApplication" ;
                       rdfs:label "SoftwareService" ;
                       skos:relatedMatch <http://www.w3.org/ns/dcat#DataService> ,
                                         <https://schema.org/EntryPoint> .


###  https://schema.bco-dmo.org/v1.0/String
bcodmo:String rdf:type owl:Class ;
              rdfs:subClassOf bcodmo:Datatype ;
              rdfs:comment "A string value" ;
              rdfs:isDefinedBy bcodmo:Datatype_String ;
              rdfs:label "String"@en ;
              skos:closeMatch <https://schema.org/Text> .


###  https://schema.bco-dmo.org/v1.0/SupplementalDocument
bcodmo:SupplementalDocument rdf:type owl:Class ;
                            owl:equivalentClass [ owl:intersectionOf ( bcodmo:FileDescriptor
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty [ owl:inverseOf bcodmo:supplementalDocument
                                                                                        ] ;
                                                                         owl:someValuesFrom bcodmo:CreativeWork
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ] ;
                            rdfs:subClassOf bcodmo:FileDescriptor ;
                            rdfs:comment "A supplemental (non-primary) document file associated with a dataset." ;
                            rdfs:label "Supplemental Document" .


###  https://schema.bco-dmo.org/v1.0/Synonym
bcodmo:Synonym rdf:type owl:Class ;
               rdfs:subClassOf bcodmo:Situation ;
               rdfs:comment "An alternative name or synonym, e.g. for a deployment." ;
               rdfs:label "Synonym" .


###  https://schema.bco-dmo.org/v1.0/TabularFile
bcodmo:TabularFile rdf:type owl:Class ;
                   rdfs:subClassOf bcodmo:FileType .


###  https://schema.bco-dmo.org/v1.0/TemporalEntity
bcodmo:TemporalEntity rdf:type owl:Class ;
                      rdfs:subClassOf bcodmo:Entity ;
                      rdfs:comment "A frame of reference for when something existed or occupied time — it is either a durationless point (an instant) or a thing with some extent in time (an interval)." ;
                      rdfs:label "TemporalEntity" ;
                      skos:exactMatch time:TemporalEntity .


###  https://schema.bco-dmo.org/v1.0/TemporalInstant
bcodmo:TemporalInstant rdf:type owl:Class ;
                       rdfs:subClassOf bcodmo:TemporalEntity ;
                       rdfs:comment "A single point in time associated with a dataset extent or event date." ;
                       rdfs:label "Temporal Instant" ;
                       skos:exactMatch time:Instant .


###  https://schema.bco-dmo.org/v1.0/TemporalInterval
bcodmo:TemporalInterval rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( bcodmo:TemporalEntity
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty bcodmo:hasBeginning ;
                                                                     owl:someValuesFrom bcodmo:TemporalInstant
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty bcodmo:hasEnd ;
                                                                     owl:someValuesFrom bcodmo:TemporalInstant
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf bcodmo:TemporalEntity ;
                        rdfs:comment "A time period with a beginning and an end, used to describe dataset temporal coverage." ;
                        rdfs:label "Temporal Interval" ;
                        skos:exactMatch time:Interval .


###  https://schema.bco-dmo.org/v1.0/TimeSeries
bcodmo:TimeSeries rdf:type owl:Class ;
                  rdfs:subClassOf bcodmo:Event ;
                  rdfs:comment "an ordered collection of observations indexed by time, representing the temporal evolution of one or more properties of a feature, system, or phenomenon." ;
                  rdfs:label "Time Series" ;
                  skos:closeMatch <https://schema.org/EventSeries> .


###  https://schema.bco-dmo.org/v1.0/URL
bcodmo:URL rdf:type owl:Class ;
           rdfs:subClassOf bcodmo:IdentifierString ;
           rdfs:comment "A URL" ;
           rdfs:isDefinedBy bcodmo:Datatype_URL ;
           rdfs:label "URL"@en ;
           skos:exactMatch <https://schema.org/URL> .


###  https://schema.bco-dmo.org/v1.0/UnitOfMeasure
bcodmo:UnitOfMeasure rdf:type owl:Class ;
                     rdfs:subClassOf bcodmo:Category ;
                     rdfs:comment "A unit of measure associated with a dataset parameter." ;
                     rdfs:label "Unit of Measure" ;
                     skos:closeMatch <http://purl.obolibrary.org/obo/UO_0000000> ,
                                     <http://www.ontology-of-units-of-measure.org/resource/om-2/Unit> .


###  https://schema.bco-dmo.org/v1.0/Vessel
bcodmo:Vessel rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( bcodmo:Platform
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty bcodmo:platformType ;
                                                           owl:hasValue bcodmo:PlatformType_Vessel
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf bcodmo:Platform ;
              rdfs:comment "A ship or boat." ;
              rdfs:label "Vessel" .


###  https://schema.bco-dmo.org/v1.0/WebPage
bcodmo:WebPage rdf:type owl:Class ;
               rdfs:subClassOf bcodmo:CreativeWork ;
               rdfs:comment "A web page" ;
               rdfs:label "WebPage" ;
               skos:exactMatch <https://schema.org/WebPage> .


