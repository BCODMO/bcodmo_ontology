        <rdfs:comment>The fax number.</rdfs:comment>
        <rdfs:label>faxNumber</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/filename -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/filename">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The file name including extension.</rdfs:comment>
        <rdfs:label>filename</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/firstNameSynonyms -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/firstNameSynonyms">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A list of synonyms for the perons&apos;s first name</rdfs:comment>
        <rdfs:label>firstNameSynonyms</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/givenName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/givenName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The given (first) name of a person.</rdfs:comment>
        <rdfs:label>givenName</rdfs:label>
