<?xml version="1.0"?>
<rdf:RDF xmlns="https://schema.bco-dmo.org/v1.0/"
     xml:base="https://schema.bco-dmo.org/v1.0/"
     xmlns:v1="https://schema.bco-dmo.org/v1.0/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://schema.bco-dmo.org/v1.0/">
        <owl:versionIRI rdf:resource="https://schema.bco-dmo.org/v1.0/"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9414-722X"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-2109-706X"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-3359-9120"/>
        <terms:creator rdf:resource="https://orcid.org/0000-0003-4486-9448"/>
        <terms:license>Creative Commons Zero 1.0 Universal</terms:license>
        <terms:license>https://creativecommons.org/publicdomain/zero/1.0/</terms:license>
        <terms:title>BCO-DMO Ontology (Version 1.0)</terms:title>
        <rdfs:comment>Ontology for the Biological and Chemical Oceanography Data Management Office (BCO-DMO).</rdfs:comment>
        <rdfs:label>BCO-DMO Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.w3.org/2002/07/owl#qualifiedCardinality -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#qualifiedCardinality"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#relatedMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#relatedMatch"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML -->


    <rdfs:Datatype rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#first -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#first"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#object -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#rest -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#rest"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#subject -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
    


    <!-- https://schema.bco-dmo.org/v1.0/actionType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/actionType">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Action"/>
        <rdfs:comment>THe type of Action</rdfs:comment>
        <rdfs:label>actionType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/affiliation -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/affiliation">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Affiliation"/>
        <rdfs:comment>The institutional affiliation of a person.</rdfs:comment>
        <rdfs:label>affiliation</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/affiliation"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/annotates -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/annotates">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Annotation"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
                    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Entity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>The thing being annotated</rdfs:comment>
        <rdfs:label>annotates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/annotator -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/annotator">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Annotation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:comment>An agent that adds explanatory notes, metadata, or comments to enhance understanding of some thing.</rdfs:comment>
        <rdfs:label>annotator</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/archives -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/archives">
        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/isArchivedBy"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:comment>The Dataset that was archvied by a specific DOIDataset.</rdfs:comment>
        <rdfs:label>archives</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/audience -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/audience">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Audience"/>
        <rdfs:comment>An intended audience, i.e. a group for whom a CreativeWork was created or offered to.</rdfs:comment>
        <rdfs:label>audience</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/author -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/author">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:comment>An author associated witha creative work. The Agent Role provides context as to how the agent contirbuted as an author to the work.</rdfs:comment>
        <rdfs:label>author</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/author"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/authority -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/authority">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:comment>The authoritative source for some piece of information or some physical thing.</rdfs:comment>
        <rdfs:label>authority</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/awardProducingData -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/awardProducingData">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Boolean"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/boundingBox -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/boundingBox">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/geometry"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/GeographicalLocation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry"/>
        <rdfs:comment>A bounding box</rdfs:comment>
        <rdfs:label>boundingBox</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/browseGraphic -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/browseGraphic">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Image"/>
        <rdfs:comment>An image that is representative of some thing. This could be a logo for a project or organization. It could also be an image that represents a creative work.</rdfs:comment>
        <rdfs:label>browseGraphic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/categorizedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/categorizedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A category for some Entity</rdfs:comment>
        <rdfs:label>categorizedBy</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/category"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/checksum -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/checksum">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/identifier"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CryptographicHash"/>
        <rdfs:comment>A cryptographic hash for verifying file integrity.</rdfs:comment>
        <rdfs:label>checksum</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/collectionItem -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/collectionItem">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CollectionItem"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>The actual item in the collection.</rdfs:comment>
        <rdfs:label>collectionItem</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/conformsTo -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/conformsTo">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/MetadataProfile"/>
        <rdfs:comment>The metadata profile specification to which this dataset conforms.</rdfs:comment>
        <rdfs:label>conformsTo</rdfs:label>
        <skos:exactMatch rdf:resource="http://purl.org/dc/terms/conformsTo"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/contributor -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/contributor">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:comment>A contributor, not an author, associated with a creative work. The Agent Role provides context as to how the agent contributed to the work.</rdfs:comment>
        <rdfs:label>contributor</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/contributor"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/coordinateReferenceSystem -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/coordinateReferenceSystem">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/GeographicalLocation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CoordinateReferenceSystem"/>
        <rdfs:comment>the coordinate reference system for some representation of a Geographical Location</rdfs:comment>
        <rdfs:label>coordinateReferenceSystem</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.opengis.net/ont/geosparql#crs"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/coordinates -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/coordinates">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
        <rdfs:comment>a list of 1 or more PointGeometry</rdfs:comment>
        <rdfs:label>coordinates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/createdDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/createdDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The date on which a creative work was created.</rdfs:comment>
        <rdfs:label>createdDate</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/dateCreated"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/creativeWorkStatus -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/creativeWorkStatus">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/status"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWorkStatus"/>
        <rdfs:comment>The status of a creative work in terms of its stage in a lifecycle. Example terms include Incomplete, Draft, Published, Obsolete. Some organizations define a set of terms for the stages of their publication lifecycle.</rdfs:comment>
        <rdfs:label>creativeWorkStatus</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/creativeWorkStatus"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/currentState -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/currentState">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CurrentState"/>
        <rdfs:comment>The editorial/curation state of the dataset.</rdfs:comment>
        <rdfs:label>currentState</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataFile">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DataFile"/>
        <rdfs:comment>A primary or supplemental data file distributed with this dataset package.</rdfs:comment>
        <rdfs:label>dataFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataManagementPlan -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataManagementPlan">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DataManagementPlan"/>
        <rdfs:comment>A file describing a research activities plan for managing their data.</rdfs:comment>
        <rdfs:label>dataManagementPlan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype"/>
        <rdfs:comment>The data type of a dataset parameter.</rdfs:comment>
        <rdfs:label>dataType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/datasetInstrumentsNotUsed -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/datasetInstrumentsNotUsed">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Boolean"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/datasetParametersNotRequired -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/datasetParametersNotRequired">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Boolean"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/datasetType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/datasetType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetType"/>
        <rdfs:comment>A category or type classification for this dataset.</rdfs:comment>
        <rdfs:label>datasetType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/deploymentDataset -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/deploymentDataset">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasPart"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetDeployment"/>
        <rdfs:comment>a deployment-specific description of that deployment&apos;s aspects of a dataset.</rdfs:comment>
        <rdfs:label>deploymentDataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/describesFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/describesFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:comment>Links a file record to the File object describing its physical properties.</rdfs:comment>
        <rdfs:label>describesFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/entityPublishingStatus -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/entityPublishingStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/EntityStatus"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/EntityPublishingStatus"/>
        <rdfs:comment>The publishing status of some BCO-DMO Entity</rdfs:comment>
        <rdfs:label>entityPublishingStatus</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/entityStatus -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/entityStatus">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/EntityStatus"/>
        <rdfs:comment>the status of some BCO-DMO Entity</rdfs:comment>
        <rdfs:label>entityStatus</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/entryPoint -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/entryPoint">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ServiceOffering"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/SoftwareService"/>
        <rdfs:comment>The entryPoint into some SoftwareService</rdfs:comment>
        <rdfs:label>entryPoint</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/target"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/expirationDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/expirationDate">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasTime"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/EmbargoPolicy"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
        <rdfs:comment>The date on which an embargo expires and the dataset becomes publicly accessible.</rdfs:comment>
        <rdfs:label>expirationDate</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/expires"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fileType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fileType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/FileType"/>
        <rdfs:comment>The format type of this file.</rdfs:comment>
        <rdfs:label>fileType</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/dcat#mediaType"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fixesPreviousErrors -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fixesPreviousErrors">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/obsoletes"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:comment>The DOIDataset from the past that this DOIDataset fixes errors.</rdfs:comment>
        <rdfs:label>fixesPreviousErrors</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/forCreativeWork -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/forCreativeWork">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>Links to a CreativeWork</rdfs:comment>
        <rdfs:label>forCreativeWork</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/forDataset -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/forDataset">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/forCreativeWork"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:comment>Links to a dataset.</rdfs:comment>
        <rdfs:label>forDataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fromDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fromDeployment">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetDeployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:comment>Links a deployment and a dataset.</rdfs:comment>
        <rdfs:label>fromDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fromInstrument -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fromInstrument">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetInstrument"/>
        <rdfs:comment>Links a dataset to the instruments used to collect the data.</rdfs:comment>
        <rdfs:label>fromInstrument</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fundedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fundedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/FundingAgency"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/fundedByAward"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/provider"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>A funding organisation that supported the work resulting in this dataset.</rdfs:comment>
        <rdfs:label>fundedBy</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/funder"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fundedByAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fundedByAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>the award that funded the creation, generation, etc of some creative work.</rdfs:comment>
        <rdfs:label>fundedByAward</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/funding"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/funder -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/funder">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/provider"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:label>funder</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/geometry -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/geometry">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>One or more geometries (centroid, bounding box) describing a geographical location.</rdfs:comment>
        <rdfs:label>geometry</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/geo"/>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/governedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/governedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Policy"/>
        <rdfs:comment>A policy (e.g. embargo) that governs access to this dataset.</rdfs:comment>
        <rdfs:label>governedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/grantedAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/grantedAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/FundingAgency"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>An award (grant) issued by this funding organisation.</rdfs:comment>
        <rdfs:label>grantedAward</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/funder"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasAgentWithRole -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasAgentWithRole">
        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/isRoleFor"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:comment>Associates an agent with a qualified role on a dataset or deployment.</rdfs:comment>
        <rdfs:label>hasAgentWithRole</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasBeginning -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasBeginning">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInterval"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The start of a temporal interval.</rdfs:comment>
        <rdfs:label>hasBeginning</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/2006/time#hasBeginning"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasCollection -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasCollection">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Collection"/>
        <rdfs:comment>A collection related to some Thing</rdfs:comment>
        <rdfs:label>hasCollection</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasCollectionItem -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasCollectionItem">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/inCollection"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Collection"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CollectionItem"/>
        <rdfs:comment>An CollectionItem in a Collection</rdfs:comment>
        <rdfs:label>hasCollectionItem</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/item"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasContent -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasContent">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Annotation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>The content or text of some Annotation. the annotation could be an image or publication, but it is the main idea of the annotation.</rdfs:comment>
        <rdfs:label>hasContent</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/text"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasCoordinatedDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasCoordinatedDeployment">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:comment>A disparate deployment that coordinated in conjuction with this subject for data collection</rdfs:comment>
        <rdfs:label>hasCoordinatedDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasCruiseTrajectory -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasCruiseTrajectory">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/geometry"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Cruise"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>The set of ordered coordinates forming a geometry (usually MultiPoint) representing the path taken by a Cruise.</rdfs:comment>
        <rdfs:label>hasCruiseTrajectory</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/geo"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasDeployment">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/TimeSeries"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:comment>Links a deployment to a TimeSeries</rdfs:comment>
        <rdfs:label>hasDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasDistribution -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasDistribution">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/MediaService"/>
        <rdfs:comment>A services distributing all or part of some CreativeWork or FileDescriptor</rdfs:comment>
        <rdfs:label>hasDistribution</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/distribution"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasEnd -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasEnd">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInterval"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The end of a temporal interval.</rdfs:comment>
        <rdfs:label>hasEnd</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/2006/time#hasEnd"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasLeadAwardOf -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasLeadAwardOf">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>The lead award in a group of collaborative awards</rdfs:comment>
        <rdfs:label>hasLeadAwardOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasParameter -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasParameter">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/storesValuesFor"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:comment xml:lang="en">A dataset collected this dataset-parameter</rdfs:comment>
        <rdfs:label xml:lang="en">hasParameter</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/sosa/observedProperty"/>
        <skos:closeMatch rdf:resource="https://schema.org/variableMeasured"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasParameterAttribute -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasParameterAttribute">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute"/>
        <rdfs:comment>An attribute of a particular DatasetParameter</rdfs:comment>
        <rdfs:label>hasParameterAttribute</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasParentProgram -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasParentProgram">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Program"/>
        <rdfs:comment>The Program that enabled a Project&apos;s existence</rdfs:comment>
        <rdfs:label>hasParentProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasPart -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasPart">
        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/isPartOf"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A related entity that is included either physically or logically in the described entity.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasProgram -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasProgram">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Program"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/hasProject"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/hasParentProgram"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/hasProject"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/hasProject"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/hasParentProgram"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>Associates a dataset with a scientific program.</rdfs:comment>
        <rdfs:label>hasProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasProject -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasProject">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetProject"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetsInOtherCatalog"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
        <rdfs:comment>Associates a dataset with a scientific project.</rdfs:comment>
        <rdfs:label>hasProject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasSynonym -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasSynonym">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Synonym"/>
        <rdfs:comment>An alternative name used for a deployment.</rdfs:comment>
        <rdfs:label>hasSynonym</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasTime -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasTime">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
        <rdfs:comment>Connects a temporal entity to some thing</rdfs:comment>
        <rdfs:label>hasTime</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/2006/time#hasTime"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/identifier -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/identifier">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:comment>An identifier assigned to a resource.</rdfs:comment>
        <rdfs:label>identifier</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/identifier"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/identifierScheme -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/identifierScheme">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme"/>
        <rdfs:comment>The scheme (authority) that defines the identifier.</rdfs:comment>
        <rdfs:label>identifierScheme</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inCollection -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/inCollection">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CollectionItem"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Collection"/>
        <rdfs:comment>The collection to which this item belongs</rdfs:comment>
        <rdfs:label>inCollection</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inControlledVocabulary -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/inControlledVocabulary">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/isPartOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Keyword"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/ControlledVocabulary"/>
        <rdfs:comment>The ControlledVocabulary to which a term belongs</rdfs:comment>
        <rdfs:label>inControlledVocabulary</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inGroup -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/inGroup">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelationGroup"/>
        <rdfs:comment>The group/category to which a resource relation type belongs.</rdfs:comment>
        <rdfs:label>inGroup</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inverseRelationship -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/inverseRelationship">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
        <rdfs:comment>The inverse relationship to another relationship type</rdfs:comment>
        <rdfs:label>inverseRelationship</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isArchivedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/isArchivedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:comment>An ArchiveDataset that arvhies a specific version of a Dataset.</rdfs:comment>
        <rdfs:label>isArchivedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isContinuingAwardOf -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/isContinuingAwardOf">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>The award that preceded this Award for continuing some work</rdfs:comment>
        <rdfs:label>isContinuingAwardOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isDefinedAs -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/isDefinedAs">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/isTypeOf"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
        <rdfs:comment>A thing is defined to be something more specific or colloquial than this more standardized cateogrization or community term.</rdfs:comment>
        <rdfs:label>isDefinedAs</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isPartOf -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/isPartOf">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A related entity in which the described entity is physically or logically included.</rdfs:comment>
        <rdfs:label>isPartOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isRoleFor -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/isRoleFor">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Associates a dataset or deployment with an a qualified role of an agent.</rdfs:comment>
        <rdfs:label>hasAgentWithRole</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isTypeOf -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/isTypeOf">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
        <rdfs:comment>Categorizes some thing.</rdfs:comment>
        <rdfs:label>isTypeOf</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/issuedDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/issuedDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The date on which the DOI was issued for this dataset.</rdfs:comment>
        <rdfs:label>issuedDate</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/dateIssued"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/keywords -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/keywords">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Keyword"/>
        <rdfs:comment>Subject keywords associated with this dataset.</rdfs:comment>
        <rdfs:label>keywords</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/keywords"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/language -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/language">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Language"/>
        <rdfs:comment>The natural language used in the dataset metadata.</rdfs:comment>
        <rdfs:label>language</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/language"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/license -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/license">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/License"/>
        <rdfs:comment>The data license applied to this dataset.</rdfs:comment>
        <rdfs:label>license</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/license"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/logo -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/logo">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/browseGraphic"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Logo"/>
        <rdfs:comment>A logo for some thing</rdfs:comment>
        <rdfs:label>logo</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/logo"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/matches -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/matches">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>Aligns a BCO-DMO vocabulary term with an equivalent term from an external community vocabulary (e.g. SeaDataNet, NERC, Crossref, DataCite).</rdfs:comment>
        <rdfs:label>matches</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/metadataFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/metadataFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/MetadataFile"/>
        <rdfs:comment>A metadata file (ISO XML, description PDF) bundled in the dataset package.</rdfs:comment>
        <rdfs:label>metadataFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/modifiesAction -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/modifiesAction">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Policy"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Action"/>
        <rdfs:comment>The action being modified by some Policy</rdfs:comment>
        <rdfs:label>modifiesAction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/nodcTopicCategory -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/nodcTopicCategory">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/NODCTopic"/>
        <rdfs:comment>THe NODC Topic Category to which a Dataset belongs</rdfs:comment>
        <rdfs:label>nodcTopicCategory</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/obsoletes -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/obsoletes">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:comment>A previous version of this dataset that is superseded by the current one.</rdfs:comment>
        <rdfs:label>obsoletes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/offers -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/offers">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasCollection"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/MediaService"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/OfferCatalog"/>
        <rdfs:comment>The offering made by some MediaService</rdfs:comment>
        <rdfs:label>offers</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/hasOfferCatalog"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/onPlatform -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/onPlatform">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Platform"/>
        <rdfs:comment>The platform (vessel, buoy, etc.) on which a deployment took place.</rdfs:comment>
        <rdfs:label>onPlatform</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/orcidIdentifier -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/orcidIdentifier">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/ORCIDIdentifier"/>
        <rdfs:comment>The ORCID Identifier for some person</rdfs:comment>
        <rdfs:label>orcidIdentifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/performedAt -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/performedAt">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Organization"/>
        <rdfs:comment>The institutional affiliation at which the role was performed.</rdfs:comment>
        <rdfs:label>performedAt</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/performedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/performedBy">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/performedRole"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:comment>The person who performed or holds this role.</rdfs:comment>
        <rdfs:label>performedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/performedRole -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/performedRole">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:comment>An Agent Role performed by some Agent.</rdfs:comment>
        <rdfs:label>performedRole</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/piInstitutionChangedForPreviousAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/piInstitutionChangedForPreviousAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>The Award that preceded this Award because the PI changed institutions.</rdfs:comment>
        <rdfs:label>piInstitutionChangedForPreviousAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/platformTitle -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/platformTitle">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Platform"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/PlatformTitle"/>
        <rdfs:comment>The official or common title of the platform.</rdfs:comment>
        <rdfs:label>platformTitle</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/platformType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/platformType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Platform"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/PlatformType"/>
        <rdfs:comment>The type/category of the platform.</rdfs:comment>
        <rdfs:label>platformType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/postalAddress -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/postalAddress">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Organization"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Person"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/PostalAddress"/>
        <rdfs:comment>Postal address of some Agent.</rdfs:comment>
        <rdfs:label>postalAddress</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/address"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/preferredDOI -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/preferredDOI">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/identifier"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DOIIdentifier"/>
        <rdfs:comment>The DOI that should be presented publicly for this resource. In most cases this is the most recent DOI, but the value is determined by curatorial judgment and must be asserted explicitly.</rdfs:comment>
        <rdfs:label>preferredDOI</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/producedWork -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/producedWork">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>The research activity produced the research product.</rdfs:comment>
        <rdfs:label>producedWork</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/ns/prov#generated"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/programManager -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/programManager">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:comment>The program manager at the funding agency responsible for this award.</rdfs:comment>
        <rdfs:label>programManager</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/projectActedOnWork -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/projectActedOnWork">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetProject"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Action"/>
        <rdfs:comment>Defines the relationship between a Project and a Dataset.</rdfs:comment>
        <rdfs:label>projectActedOnWork</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/projectExternalDatasetList -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/projectExternalDatasetList">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasCollection"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetList"/>
        <rdfs:comment>a Collection of external Datasets related to a Project</rdfs:comment>
        <rdfs:label>projectExternalDatasetList</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/provider -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/provider">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:comment>The provider of some Award</rdfs:comment>
        <rdfs:comment>The service provider that hosts/distributes the resource.</rdfs:comment>
        <rdfs:label>provider</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/provider"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/publishedDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/publishedDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The date on which this dataset version was published.</rdfs:comment>
        <rdfs:label>publishedDate</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/datePublished"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/publisher -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/publisher">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Organization"/>
        <rdfs:comment>The agent responsible for publishing a resource.</rdfs:comment>
        <rdfs:label>publisher</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/publisher"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/relatedAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/relatedAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>A related award becuase it funded the same ResearchActivity</rdfs:comment>
        <rdfs:label>relatedAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/relatedDataset -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/relatedDataset">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/relations"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:comment>Related Datasets to some CreativeWork</rdfs:comment>
        <rdfs:label>relatedDataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/relatedPublication -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/relatedPublication">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/relations"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Publication"/>
        <rdfs:comment>Related Publication to some CreativeWork</rdfs:comment>
        <rdfs:label>relatedPublication</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/relations -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/relations">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>Related creative work associated with this creative work.</rdfs:comment>
        <rdfs:label>relations</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/citation"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/relationship -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/relationship">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
        <rdfs:comment>A controlled-vocabulary relation type between two resources.</rdfs:comment>
        <rdfs:label>relationship</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/releaseDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/releaseDate">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasTime"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/EmbargoReleasePolicy"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
        <rdfs:comment>The date on which an embargo releases and the dataset becomes publicly accessible.</rdfs:comment>
        <rdfs:label>releaseDate</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/expires"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/replacedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/replacedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DeprecatedEntity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>An entity that replaces a deprecated Entity.</rdfs:comment>
        <rdfs:label>replacedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/resolution -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/resolution">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/temporalResolution"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/TemporalInterval"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalUnit"/>
        <rdfs:comment>The temporal resolution of a temporal extent (e.g. time:unitDay).</rdfs:comment>
        <rdfs:label>resolution</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:closeMatch rdf:resource="http://www.w3.org/2006/time#unitType"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/role -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/role">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Role"/>
        <rdfs:comment>The role type performed by the agent.</rdfs:comment>
        <rdfs:label>role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/situationInvolves -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/situationInvolves">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>Some thing involved in a situation or event. A super property for more specific relationships in some Event.</rdfs:comment>
        <rdfs:label>situationInvolves</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/about"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/smallLogo -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/smallLogo">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/logo"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Logo"/>
        <rdfs:comment>A smaller logo of some thing</rdfs:comment>
        <rdfs:label>smallLogo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/spatialCenter -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/spatialCenter">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/geometry"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/GeographicalLocation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CentroidGeometry"/>
        <rdfs:comment>The spatial centroid for a Geographical Location</rdfs:comment>
        <rdfs:label>spatialCenter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/spatialExtent -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/spatialExtent">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/GeographicalLocation"/>
        <rdfs:comment>The spatial coverage of the dataset, deployment, project, or program.</rdfs:comment>
        <rdfs:label>spatialExtent</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/spatialCoverage"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/status -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/status">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWorkStatus"/>
        <rdfs:comment>The current DOI lifecycle status of the dataset package.</rdfs:comment>
        <rdfs:label>status</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:closeMatch rdf:resource="https://schema.org/creativeWorkStatus"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/storesValuesFor -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/storesValuesFor">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:comment>Links a dataset to the parameters whose values it records.</rdfs:comment>
        <rdfs:label>storesValuesFor</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/variableMeasured"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/supplementalDocument -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/supplementalDocument">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/SupplementalDocument"/>
        <rdfs:comment>A supplemental document distributed with this dataset package.</rdfs:comment>
        <rdfs:label>supplementalDocument</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/target -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/target">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Policy"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>The resource to which this policy applies.</rdfs:comment>
        <rdfs:label>target</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/temporalExtent -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/temporalExtent">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasTime"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/AgentRole"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
        <rdfs:comment>The temporal coverage of an agent role, dataset, deployment or research activity.</rdfs:comment>
        <rdfs:label>temporalExtent</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/2006/time#hasTime"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/temporalResolution -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/temporalResolution">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/TemporalInterval"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalUnit"/>
        <rdfs:comment>The temporal resolution of a temporal extent (e.g. time:unitDay).</rdfs:comment>
        <rdfs:label>temporalResolution</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/2006/time#unitType"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/units -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/units">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/UnitOfMeasure"/>
        <rdfs:comment>The unit of measure for a dataset parameter.</rdfs:comment>
        <rdfs:label>units</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/unitCode"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/usedWork -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/usedWork">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A CreativeWork that was used in some ResearchActivity</rdfs:comment>
        <rdfs:comment>The CreativeWork was used in a ResearchActivity</rdfs:comment>
        <rdfs:label>usedWork</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/ns/prov#used"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://schema.bco-dmo.org/v1.0/abbreviation -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/abbreviation">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A short abbreviation for a scheme, language, or licence.</rdfs:comment>
        <rdfs:label>abbreviation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/abstract -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/abstract">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A plain-text abstract describing the dataset.</rdfs:comment>
        <rdfs:label>abstract</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/abstract"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/acquisitionDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/acquisitionDescription">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetDeployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
        <rdfs:comment>An HTML description of data acquisition methods.</rdfs:comment>
        <rdfs:label>acquisitionDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/acronym -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/acronym">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>An acronym or abbreviation for an organisation, affiliation, project, or program.</rdfs:comment>
        <rdfs:label>acronym</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/addressCountry -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/addressCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/PostalAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The country for some physical address.</rdfs:comment>
        <rdfs:label>addressCountry</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/addressCountry"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/addressLocality -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/addressLocality">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/PostalAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The region in which the locality is, and which is in the country. For example, California or another appropriate first-level Administrative division such as the Province in Italy or Region in Germany.</rdfs:comment>
        <rdfs:label>addressLocality</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/addressLocality"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/addressRegion -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/addressRegion">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/PostalAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The region in which the locality is, and which is in the country. For the US, this would be the name of the state, the province in Italy, or region in Germany.</rdfs:comment>
        <rdfs:label>addressRegion</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/affiliationName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/affiliationName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Affiliation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The primary name of the affiliated institution.</rdfs:comment>
        <rdfs:label>affiliationName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/affiliationSubName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/affiliationSubName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Affiliation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A sub-unit or department name within an affiliated institution.</rdfs:comment>
        <rdfs:label>affiliationSubName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/archiveComment -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/archiveComment">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>An internal comment about this particular DOIDataset</rdfs:comment>
        <rdfs:label>archiveComment</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/bibliographicCitation -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/bibliographicCitation">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
        <rdfs:comment>The full bibliographic citation for a related publication or dataset.</rdfs:comment>
        <rdfs:label>bibliographicCitation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/bytesize -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/bytesize">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <rdfs:comment>The size of the file in bytes.</rdfs:comment>
        <rdfs:label>bytesize</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/contentSize"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/codeValue -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/codeValue">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>A specific code value but not quite an Identifier.</rdfs:comment>
        <rdfs:label>codeValue</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/codeValue"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/commonFileExtension -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/commonFileExtension">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/FileType"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>A commonly used file extension for a particular FileType</rdfs:comment>
        <rdfs:label>commonFileExtension</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/content -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/content">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The intellectual content for some CreativeWork</rdfs:comment>
        <rdfs:label>content</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/text"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/conversionDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/conversionDescription">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describes how the values can be converted.</rdfs:comment>
        <rdfs:label>conversionDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataManagementProcessingDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataManagementProcessingDescription">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of data management and processing applied by BCO-DMO.</rdfs:comment>
        <rdfs:label>dataManagementProcessingDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataURL -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataURL">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetDeployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>A URL where the data can be found for some thing, typically a Dataset or ResearchActivity</rdfs:comment>
        <rdfs:label>dataURL</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/dcat#accessURL"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/description -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/description">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of a resource.</rdfs:comment>
        <rdfs:label>description</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/description"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/disclaimer -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/disclaimer">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetList"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A disclaimer statement</rdfs:comment>
        <rdfs:label>disclaimer</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/eastBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/eastBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
