        <rdfs:label>honorificSuffix</rdfs:label>
        <skos:exactMatch>https://schema.org/honorificSuffix</skos:exactMatch>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/identifierValue -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/identifierValue">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The raw identifier string value (e.g. the DOI suffix, the ROR ID).</rdfs:comment>
        <rdfs:label>identifierValue</rdfs:label>
        <skos:closeMatch>https://schema.org/identifier</skos:closeMatch>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inverseDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/inverseDescription">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The description of a bi-directional relationship (like a RelatedWork) to describe the relationship from object to subject direction. The `description` property describes the erlationship from subject to object.</rdfs:comment>
        <rdfs:label>inverseDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inverseLabel -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/inverseLabel">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A label describing some relationship beween from the perspective of the object.</rdfs:comment>
        <rdfs:label>inverseLabel</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inverseSymmetricalRelationship -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/inverseSymmetricalRelationship">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Is the relationship symmetrical?</rdfs:comment>
        <rdfs:label>inverseSymmetricalRelationship</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isPrimary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/isPrimary">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>In a multi-valued set of Things, this one is the primary</rdfs:comment>
        <rdfs:label>isPrimary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/isPrimaryDataFile -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/isPrimaryDataFile">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/isPrimary"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DataFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether this is the primary data file of a dataset (true/false).</rdfs:comment>
        <rdfs:label>isPrimaryDataFile</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/label -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/label">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/name"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A human-readable label for any BCO-DMO resource.</rdfs:comment>
        <rdfs:label>label</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/name"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/lastNameSynonyms -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/lastNameSynonyms">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Last name that a person may have or be known as</rdfs:comment>
        <rdfs:label>lastNameSynonyms</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/latitude -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/latitude">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/PointGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>Latitude is the angular measure of a point&apos;s position along the primary axis of a CRS, perpendicular to the reference surface&apos;s axis of symmetry.</rdfs:comment>
        <rdfs:label>latitude</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/listPosition -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/listPosition">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CollectionItem"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>A integer representing a position of some Thing in a list of things. Can be used to rank, sort and order a list of things.</rdfs:comment>
        <rdfs:label>listPosition</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/position"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/longitude -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/longitude">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/PointGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>Longitude is the angular measure of a point&apos;s position around the secondary axis of a CRS, relative to an arbitrarily defined reference meridian.</rdfs:comment>
        <rdfs:label>longitude</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/middleName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/middleName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The middle name or initial of a person.</rdfs:comment>
        <rdfs:label>middleName</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/additionalName"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/middleNameSynonyms -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/middleNameSynonyms">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Other middle names a person may have or be known as</rdfs:comment>
        <rdfs:label>middleNameSynonyms</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/mimeType -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/mimeType">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/FileType"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/SoftwareService"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The MIME type associated with a file type.</rdfs:comment>
        <rdfs:label>mimeType</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/dcat#mediaType"/>
        <skos:closeMatch rdf:resource="https://schema.org/encodingFormat"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/name -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/name">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The name of the item. Synonymous with the label property.</rdfs:comment>
        <rdfs:label>name</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/name"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/nickname -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/nickname">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Nickname, or preferred name, of a Person</rdfs:comment>
        <rdfs:label>nickname</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/additionalName"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/noDataValue -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/noDataValue">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The value to expect in a DatasetParameter when there was no data for the given record.</rdfs:comment>
        <rdfs:label>noDataValue</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/northBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/northBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The northern latitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>northBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/officialName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/officialName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Parameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official name for a master parameter.</rdfs:comment>
        <rdfs:label>officialName</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/name"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/postalCode -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/postalCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/PostalAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The postal code</rdfs:comment>
        <rdfs:label>postalCode</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/problemDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/problemDescription">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of known problems or caveats with the dataset.</rdfs:comment>
        <rdfs:label>problemDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/processingDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/processingDescription">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetDeployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
        <rdfs:comment>An HTML description of data processing steps.</rdfs:comment>
        <rdfs:label>processingDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/requiresConversion -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/requiresConversion">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>The values in the dataset for this property need to be converted.</rdfs:comment>
        <rdfs:label>requiresConversion</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/resolvableUrl -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/resolvableUrl">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/url"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>A resolvable URL that dereferences the identifier.</rdfs:comment>
        <rdfs:label>resolvableUrl</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/url"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/roleWeight -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/roleWeight">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Role"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <rdfs:comment>Sort ordering of role types</rdfs:comment>
        <rdfs:label>roleWeight</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/shortDescription -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/shortDescription">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/description"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Parameter"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
        <rdfs:comment>A brief HTML description of the dataset or parameter</rdfs:comment>
        <rdfs:label>shortDescription</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/disambiguatingDescription"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/shortName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/shortName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Parameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A short name for a master parameter.</rdfs:comment>
        <rdfs:label>shortName</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/name"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/showTable -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/showTable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Whether to allow a tabular file to be viewed in the table data viewer</rdfs:comment>
        <rdfs:label>showTable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/southBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/southBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The southern latitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>southBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/streetAddress -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/streetAddress">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/PostalAddress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The street address. For example, 1600 Amphitheatre Pkwy. Can be multi-line to include APT or other street informaion. It typically comes after the addressee&apos;s name but before the addressLocality</rdfs:comment>
        <rdfs:label>streetAddress</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/streetAddress"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/telephone -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/telephone">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The telephone number.</rdfs:comment>
        <rdfs:label>telephone</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/telephone"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/title -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/title">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The full title of the dataset.</rdfs:comment>
        <rdfs:label>title</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/name"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/url -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/url">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>A URL for a resource, such as its landing page.</rdfs:comment>
        <rdfs:label>url</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/url"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/urlTemplate -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/urlTemplate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/SoftwareService"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>An url template (RFC6570) that will be used to construct the target of the execution of the action.</rdfs:comment>
        <rdfs:label>urlTemplate</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/urlTemplate"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/useFullMiddleNameInCitationText -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/useFullMiddleNameInCitationText">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/AgentRole"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Person"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Whether the Person prefers to use their full middle name in citations. Can be overriden by using at teh AgentRole for authors and contributors.</rdfs:comment>
        <rdfs:label>useFullMiddleNameInCitationText</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/validated -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/validated">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Has the dataset been validated by the PI.</rdfs:comment>
        <rdfs:label>validated</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/valueFormat -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/valueFormat">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The format string used to encode parameter values in the data file.</rdfs:comment>
        <rdfs:label>valueFormat</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/version -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/version">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The version label of the dataset (numeric or numeric + single lowercase letter).</rdfs:comment>
        <rdfs:label>version</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/version"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/westBoundary -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/westBoundary">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The western longitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>westBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#List -->


    <owl:Class rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement -->


    <owl:Class rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    


    <!-- http://www.w3.org/2006/time#TemporalUnit -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporalUnit"/>
    


    <!-- https://schema.bco-dmo.org/v1.0/Action -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Action">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>Some action that can be taken on an Entity. A Policy can restrict and allow actions</rdfs:comment>
        <rdfs:label>Action</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Action"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Affiliation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Affiliation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Organization"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty>
                                    <rdf:Description>
                                        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/affiliation"/>
                                    </rdf:Description>
                                </owl:onProperty>
                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty>
                                    <rdf:Description>
                                        <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/performedAt"/>
                                    </rdf:Description>
                                </owl:onProperty>
                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Organization"/>
        <rdfs:comment>An institutional affiliation of a person (university, research institute, etc.).</rdfs:comment>
        <rdfs:label>Affiliation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Agent -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Agent">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>An entity (person or organisation) that can perform roles.</rdfs:comment>
        <rdfs:label>Agent</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/ns/prov#Agent"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/AgentRole -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/AgentRole">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/performedBy"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/role"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Role"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasAgentWithRole"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>A qualified association that links an Agent to a role and optionally an affiliation context.</rdfs:comment>
        <rdfs:label>Agent Role</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Role"/>
        <skos:closeMatch rdf:resource="https://www.w3.org/ns/prov#Role"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Annotation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Annotation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotator"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotates"/>
                        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasContent"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>A comment or some other piece of content that annotates for some specific purpose some Thing</rdfs:comment>
        <rdfs:label>Annotation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/AnnotationAction -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/AnnotationAction">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Action"/>
        <rdfs:comment>The motivation for annotating some thing.</rdfs:comment>
        <rdfs:label>AnnotationAction</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ArchiveFileType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ArchiveFileType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/FileType"/>
        <rdfs:comment>A file format  used to bundle multiple files and folders into a single file for easier storage or transfer.</rdfs:comment>
        <rdfs:label>ArchiveFileType</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ArchivedDataset -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ArchivedDataset">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:comment>A specific version of a Dataset that has been stored  in an archive that typcially provides access</rdfs:comment>
        <rdfs:label>ArchivedDataset</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Audience -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Audience">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>Intended audience for an item, i.e. the group for whom the item was created or is being offered to.</rdfs:comment>
        <rdfs:label>Audience</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Audience"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Award -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Award">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Entity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/funder"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/FundingAgency"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/fundedByAward"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A funding award (grant) from a funder that supports data collection.</rdfs:comment>
        <rdfs:label>Award</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Grant"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/AwardNoDataAnnotation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/AwardNoDataAnnotation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Annotation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotates"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
                                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
                                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/Boolean_True"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
                                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/awardProducingData"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasContent"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Comment"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/content"/>
                                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotator"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Annotation"/>
        <rdfs:comment>A reason why an award will not produce datasets</rdfs:comment>
        <rdfs:label>AwardNoDataAnnotation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/BCODMOIdentifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/BCODMOIdentifier">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:comment>An internal BCO-DMO identifier (version 2 scheme).</rdfs:comment>
        <rdfs:label>BCO-DMO Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Boolean -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Boolean">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype"/>
        <rdfs:comment>A boolean value like True or False, Yes or No, 1 or 0.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype_Boolean"/>
        <rdfs:label>Boolean</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/Boolean"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/PolygonGeometry"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/eastBoundary"/>
                                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/northBoundary"/>
                                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/southBoundary"/>
                                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/westBoundary"/>
                                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/coordinates"/>
                                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">5</owl:qualifiedCardinality>
                                <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/PointGeometry"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/PolygonGeometry"/>
        <rdfs:comment>An axis-aligned bounding box geometry defined by west/south/east/north boundaries.</rdfs:comment>
        <rdfs:label>Bounding Box Geometry</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/sf#Envelope"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Category -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Category">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A set of taxonomy</rdfs:comment>
        <rdfs:label>Category</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/DefinedTerm"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CentroidGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CentroidGeometry">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/PointGeometry"/>
        <rdfs:comment>A point geometry representing the centroid of a spatial extent.</rdfs:comment>
        <rdfs:label>Centroid Geometry</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.opengis.net/ont/sf#Point"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Collection -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Collection">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A curated collection, set, or list of some Things.</rdfs:comment>
        <rdfs:label>Collection</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Collection"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CollectionItem -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CollectionItem">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/inCollection"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Collection"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>An item in a collection</rdfs:comment>
        <rdfs:label>CollectionItem</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/ListItem"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Comment -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Comment">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A note or piece of text typically used for Annotations</rdfs:comment>
        <rdfs:label>Comment</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Comment"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ComputerLanguage -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ComputerLanguage">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Language"/>
        <owl:disjointWith rdf:resource="https://schema.bco-dmo.org/v1.0/NaturalLanguage"/>
        <rdfs:comment>Programming languages such as Python, Go, Rust and Java.</rdfs:comment>
        <rdfs:label>ComputerLanguage</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/ComputerLanguage"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ConsumeAction -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ConsumeAction">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Action"/>
        <rdfs:comment>The act of consuming an Entity.</rdfs:comment>
        <rdfs:label>ConsumeAction</rdfs:label>
        <skos:closeMatch>https://schema.org/ConsumeAction</skos:closeMatch>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ControlledVocabulary -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ControlledVocabulary">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A vocabulary of terms or phrases used to describe concepts in a specific domain</rdfs:comment>
        <rdfs:label>ControlledVocabulary</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CoordinateReferenceSystem -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CoordinateReferenceSystem">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme"/>
        <rdfs:comment>A coordinate reference system</rdfs:comment>
        <rdfs:label>CoordinateReferenceSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CreativeWork -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>Any work that can be created by some Agent</rdfs:comment>
        <rdfs:label>Creative Work</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/CreativeWork"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CreativeWorkStatus -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWorkStatus">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A state of for some createive work.</rdfs:comment>
        <rdfs:label>CreativeWorkStatus</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Cruise -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Cruise">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/onPlatform"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Vessel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:comment>A research vessel cruise, a specialisation of Platform for vessel-type platforms.</rdfs:comment>
        <rdfs:label>Cruise</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CryptographicHash -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CryptographicHash">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Identifier"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/identifierScheme"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/CryptographicHashAlgorithm"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:comment>A cryptographic hash (e.g. MD5) used as a file integrity checksum.</rdfs:comment>
        <rdfs:label>Cryptographic Hash</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CryptographicHashAlgorithm -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CryptographicHashAlgorithm">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme"/>
        <rdfs:comment>A mathematical function that transforms any arbitrary amount of input data into a fixed-length string of characters (identifierValue), acting as a secure &quot;digital fingerprint&quot; or &quot;digest&quot;</rdfs:comment>
        <rdfs:label>Cryptographic Hash Algorithm</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/CurrentState -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/CurrentState">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>The current editorial/curation state of a CreativeWork</rdfs:comment>
        <rdfs:label>Current State</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DOIDataset -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DOIDataset">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ArchivedDataset"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/identifier"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/identifierScheme"/>
                                <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme_DOI"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/ArchivedDataset"/>
        <rdfs:comment>A versioned BCO-DMO dataset that has been assigned a DOI.</rdfs:comment>
        <rdfs:label>DOI Dataset</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DOIIdentifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DOIIdentifier">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Identifier"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/identifierScheme"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme_DOI"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:comment>A Digital Object Identifier.</rdfs:comment>
        <rdfs:label>DOI Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DOIStatus -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DOIStatus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWorkStatus"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/status"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/DOIDataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWorkStatus"/>
        <rdfs:comment>The lifecycle status of a DOI Dataset (Draft, Reserved, Published, etc.).</rdfs:comment>
        <rdfs:label>DOI Status</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DataFile -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DataFile">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/dataFile"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
        <rdfs:comment>A primary or supplemental data file distributed as part of a dataset.</rdfs:comment>
        <rdfs:label>Data File</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/DataDownload"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DataManagementPlan -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DataManagementPlan">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/dataManagementPlan"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
        <rdfs:comment>A plan describing how a research activity will manage and archive data products produced.</rdfs:comment>
        <rdfs:label>DataManagementPlan</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Dataset -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Dataset">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A dataset which may be internal or external to BCO-DMO.</rdfs:comment>
        <rdfs:label>Dataset</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/Dataset"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetAward -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetAward">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/fundedByAward"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/forDataset"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>The connection between a dataset and the award the funded its generation</rdfs:comment>
        <rdfs:label>DatasetAward</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetDeployment -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetDeployment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/forDataset"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/fromDeployment"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/forDataset"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/fromDeployment"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment>A deployment as referenced within a specific dataset, with dataset-specific properties.</rdfs:comment>
        <rdfs:label>Dataset Deployment</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetInstrument -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetInstrument">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/forDataset"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/isDefinedAs"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Instrument"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>An instrument as referenced within a specific dataset, with dataset-specific properties.</rdfs:comment>
        <rdfs:label>Dataset Instrument</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetList -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetList">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Collection"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasCollectionItem"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CollectionItem"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/collectionItem"/>
                                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:onClass>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Collection"/>
        <rdfs:comment>A list of Datasets</rdfs:comment>
        <rdfs:label>DatasetList</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetNoInstrumentsAnnotation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetNoInstrumentsAnnotation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Annotation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotates"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
                                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
                                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/Boolean_True"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
                                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/datasetInstrumentsNotUsed"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasContent"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Comment"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/content"/>
                                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotator"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Annotation"/>
        <rdfs:comment>A reason as to why no instruments were used in the generation of this Dataset.</rdfs:comment>
        <rdfs:label>DatasetNoInstrumentsAnnotation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetNoParametersAnnotation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetNoParametersAnnotation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Annotation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotates"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
                                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
                                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/Boolean_True"/>
                                    </owl:Restriction>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
                                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/datasetParametersNotRequired"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasContent"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Comment"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/content"/>
                                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/annotator"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Annotation"/>
        <rdfs:comment>A reason as to why a Dataset has no parameters defined.</rdfs:comment>
        <rdfs:label>DatasetNoParametersAnnotation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetParameter -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetParameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/forDataset"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/isDefinedAs"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Parameter"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>A parameter as instantiated within a specific dataset column, with dataset-level name, description, units, and format.</rdfs:comment>
        <rdfs:label>Dataset Parameter</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>An attribute of a dataset parameter that provides more context as to how it could be used.</rdfs:comment>
        <rdfs:label>DatasetParameterAttribute</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetProject -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetProject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/forDataset"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasProject"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/projectActedOnWork"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Action"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>A situation in which a Project has some influence on the creation of a Dataset.</rdfs:comment>
        <rdfs:label>DatasetProject</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/datasetType"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A category describing the type of dataset (e.g. Cruise Data, Model Output).</rdfs:comment>
        <rdfs:label>Dataset Type</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DatasetsInOtherCatalog -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DatasetsInOtherCatalog">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DatasetList"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasProject"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/publisher"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/disclaimer"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetList"/>
        <rdfs:comment>A list of datasets in a catalog that isn&apos;t BCO-DMO</rdfs:comment>
        <rdfs:label>DatasetsInOtherCatalog</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Datatype -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Datatype">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/dataType"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>The data type of a dataset parameter column (e.g. string, integer, float).</rdfs:comment>
        <rdfs:label>Datatype</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/DataType"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DefinedTerm -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DefinedTerm">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/inControlledVocabulary"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ControlledVocabulary"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A term in some ControlledVocabulary with a community-agreed definition</rdfs:comment>
        <rdfs:label>DefinedTerm</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/DefinedTerm"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Deployment -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Deployment">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Event"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/onPlatform"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Platform"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Event"/>
        <rdfs:comment>A scientific deployment (cruise, expedition, mooring deployment) during which data were collected.</rdfs:comment>
        <rdfs:label>Deployment</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/ssn/Deployment"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DeploymentActivity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DeploymentActivity">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>The type of activity a specific deployment was operating under.</rdfs:comment>
        <rdfs:label>DeploymentActivity</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DeploymentEntityMatch -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DeploymentEntityMatch">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/EntityMatch"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
                        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/EntityMatch"/>
        <rdfs:label>DeploymentEntityMatch</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/DeprecatedEntity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/DeprecatedEntity">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Entity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/entityStatus"/>
                        <owl:someValuesFrom>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/entityPublishingStatus"/>
                                <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/EntityPublishingStatus_Deprecated"/>
                            </owl:Restriction>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>An entity that should no longer be used.</rdfs:comment>
        <rdfs:label>DeprecatedEntity</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/EmailAddress -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/EmailAddress">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierString"/>
        <rdfs:comment>An email address.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype_EmailAddress"/>
        <rdfs:label>Email Address</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/EmbargoPolicy -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/EmbargoPolicy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Policy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/expirationDate"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/modifiesAction"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ConsumeAction"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/target"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Policy"/>
        <rdfs:comment>A policy that restricts access to a dataset until an expiration date.</rdfs:comment>
        <rdfs:label>Embargo Policy</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/EmbargoReleasePolicy -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/EmbargoReleasePolicy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Policy"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/modifiesAction"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ConsumeAction"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/releaseDate"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/target"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Policy"/>
        <rdfs:comment>A policy that allows access to a FileDescriptor when its overarching Dataset is under an embargo.</rdfs:comment>
        <rdfs:label>EmbargoReleasePolicy</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Entity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Entity">
        <rdfs:comment>A BCO-DMO specific concept</rdfs:comment>
        <rdfs:label>Entity</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/EntityMatch -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/EntityMatch">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>A link between two entities that are related in some way as defined by rdf:predicate. This entity allows for annotating details of the match.</rdfs:comment>
        <rdfs:label>EntityMatch</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/EntityPublishingStatus -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/EntityPublishingStatus">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>One or more statuses of a BCO-DMO Entity. This is primarily used to determine where an entity appears - not at all while it&apos;s being contructed, in draft review for a submitter, published, deprecated or unpublished.</rdfs:comment>
        <rdfs:label>EntityPublishingStatus</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/EntityStatus -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/EntityStatus">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/entityPublishingStatus"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/EntityPublishingStatus"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasTime"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>The status of some BCO-DMO Entity</rdfs:comment>
        <rdfs:label>EntityStatus</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Event -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Event">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasTime"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>A dynamic situation in which something unique or impotant happened.</rdfs:comment>
        <rdfs:label>Event</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Event"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/File -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/File">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A physical file (byte stream) associated with a dataset or package.</rdfs:comment>
        <rdfs:label>File</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/MediaObject"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/FileDescriptor -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/FileDescriptor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/describesFile"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A context-specific description of a file. The context could be data, metadata or supplemental documentation.</rdfs:comment>
        <rdfs:label>File Descriptor</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/DigitalDocument"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/FileType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/FileType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/fileType"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A file format type, characterised by a label and MIME type (e.g. CSV, XML, PDF).</rdfs:comment>
        <rdfs:label>File Type</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/FundingAgency -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/FundingAgency">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Organization"/>
        <rdfs:comment>An Organization that has provided some funding award</rdfs:comment>
        <rdfs:label>Funding Agency</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/FundingAgency"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/GCMDPlatformType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/GCMDPlatformType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
        <rdfs:comment>A platform type defined by GCMD</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v1.0/ControlledVocabulary_GCMDPlatformTypes"/>
        <rdfs:label>GCMDPlatformType</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/GeographicalLocation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/GeographicalLocation">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A spatial extent or named location associated with a dataset, deployment, project, or program.</rdfs:comment>
        <rdfs:label>Geographical Location</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/Place"/>
        <skos:relatedMatch rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Geometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Geometry">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Entity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>An abstract spatial geometry.</rdfs:comment>
        <rdfs:label>Geometry</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/GeospatialGeometry"/>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/sf#Geometry"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/GeometryShape -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/GeometryShape">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>The shape of various geometries.</rdfs:comment>
        <rdfs:label>GeometryShape</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Identifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Identifier">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/identifierScheme"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/identifierValue"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>An identifier assigned to a resource by some scheme.</rdfs:comment>
        <rdfs:label>Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/IdentifierScheme -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/IdentifierScheme">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A named scheme or authority that mints identifiers (DOI, ROR, ORCID, etc.).</rdfs:comment>
        <rdfs:label>Identifier Scheme</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/IdentifierString -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/IdentifierString">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/String"/>
        <rdfs:comment>A string that is used as an identifier</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype_Identifier"/>
        <rdfs:label xml:lang="en">IdentifierString</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Image -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Image">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/File"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/fileType"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ImageFileType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:comment>An image file.</rdfs:comment>
        <rdfs:label>Image</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/ImageObject"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ImageFileType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ImageFileType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/FileType"/>
        <rdfs:comment>Representative of a type of image file.</rdfs:comment>
        <rdfs:label>ImageFileType</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Instrument -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Instrument">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/isDefinedAs"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetInstrument"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
        <rdfs:comment>A master (community-level) scientific instrument definition.</rdfs:comment>
        <rdfs:label>Instrument</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <skos:relatedMatch rdf:resource="https://www.w3.org/TR/vocab-ssn/#SSNSystem"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Keyword -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Keyword">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A subject keyword associated with a CreativeWork.</rdfs:comment>
        <rdfs:label>Keyword</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Language -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Language">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A natural language used in the dataset metadata.</rdfs:comment>
        <rdfs:label>Language</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/License -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/License">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/license"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A  license applied to some creative work.</rdfs:comment>
        <rdfs:label>License</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/LineStringGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/LineStringGeometry">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Geometry"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/coordinates"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#rest"/>
                                                <owl:someValuesFrom rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                            </owl:Restriction>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#rest"/>
                                                <owl:hasValue rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </owl:Restriction>
                                        </owl:unionOf>
                                    </owl:Class>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#first"/>
                                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/PointGeometry"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape_Linestring"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>Two or more PointGeometry that when connected form lines between between adjacent points.</rdfs:comment>
        <rdfs:label>LineStringGeometry</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/sf#LineString"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Logo -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Logo">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Image"/>
        <rdfs:comment>An image that is representative of some thing</rdfs:comment>
        <rdfs:label>Logo</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/MediaService -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/MediaService">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/MediaServiceType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>An affordance made to some audience by a provider to access all or part of some CreativeWork. Often times it is an interpretation of the whole work - a metadata record, a visualization, a file in a specific format, etc.</rdfs:comment>
        <rdfs:label>MediaService</rdfs:label>
        <skos:relatedMatch rdf:resource="http://www.w3.org/ns/dcat#DataService"/>
        <skos:relatedMatch rdf:resource="https://schema.org/DataDownload"/>
        <skos:relatedMatch rdf:resource="https://schema.org/MediaObject"/>
        <skos:relatedMatch rdf:resource="https://schema.org/WebAPI"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/MediaServiceType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/MediaServiceType">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A way of grouping multiple MediaService offerings on the same CreativeWork</rdfs:comment>
        <rdfs:label>MediaServiceType</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/MetadataFile -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/MetadataFile">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/metadataFile"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
        <rdfs:comment>A metadata file (e.g. ISO 19115-2 XML, dataset description PDF) describing a dataset.</rdfs:comment>
        <rdfs:label>Metadata File</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/DataDownload"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/MetadataProfile -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/MetadataProfile">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A formal metadata profile specification to which the datapackage conforms.</rdfs:comment>
        <rdfs:label>Metadata Profile</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/MultiLineStringGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/MultiLineStringGeometry">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Geometry"/>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#rest"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#first"/>
                                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/LineStringGeometry"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/coordinates"/>
                                <owl:someValuesFrom>
                                    <owl:Class>
                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#first"/>
                                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/LineStringGeometry"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape_MultiLinestring"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>A geometry whose coordinates member is an array of LineString coordinate arrays</rdfs:comment>
        <rdfs:label>MultiLineStringGeometry</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/sf#MultiLineString"/>
    </owl:Class>
    


