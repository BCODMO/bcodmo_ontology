    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/encoding -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/encoding">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The character encoding of a file (e.g. utf-8).</rdfs:comment>
        <rdfs:label>encoding</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/expirationDate -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/expirationDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/EmbargoPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which an embargo expires and the dataset becomes publicly accessible.</rdfs:comment>
        <rdfs:label>expirationDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/externalWebsite -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/externalWebsite">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment>The external project or program website URL.</rdfs:comment>
        <rdfs:label>externalWebsite</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/familyName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/familyName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The family (last) name of a person.</rdfs:comment>
        <rdfs:label>familyName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/filename -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/filename">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>The file name including extension.</rdfs:comment>
        <rdfs:label>filename</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/givenName -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/givenName">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The given (first) name of a person.</rdfs:comment>
        <rdfs:label>givenName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasReportURL -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasReportURL">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
