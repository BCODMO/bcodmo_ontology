                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#first"/>
                                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/PointGeometry"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
                                    </owl:Class>
                                </owl:someValuesFrom>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape_MultiPoint"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>A geometry whose coordinates member is an array of point coordinate arrays</rdfs:comment>
        <rdfs:label>MultiPointGeometry</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/sf#MultiPoint"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/MultiPolygonGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/MultiPolygonGeometry">
