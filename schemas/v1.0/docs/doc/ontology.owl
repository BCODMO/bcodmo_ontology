        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of data management and processing applied by BCO-DMO.</rdfs:comment>
        <rdfs:label>dataManagementProcessingDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/description -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/description">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of a resource.</rdfs:comment>
        <rdfs:label>description</rdfs:label>
    </owl:DatatypeProperty>
    


