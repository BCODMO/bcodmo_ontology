        <rdf:type rdf:resource="https://schema.bco-dmo.org/v1.0/CoordinateReferenceSystem"/>
        <label>CRS84</label>
        <url rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.opengis.net/def/crs/OGC/1.3/CRS84</url>
        <rdfs:label>CRS84</rdfs:label>
    </owl:NamedIndividual>
    


