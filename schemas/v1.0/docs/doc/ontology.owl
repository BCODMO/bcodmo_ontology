    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/honorific -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/honorific">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>An honorific prefix preceding a Person&apos;s name such as Dr/Mrs/Mr.</rdfs:comment>
        <rdfs:label>honorific</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/honorificPrefix"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/honorificSuffix -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/honorificSuffix">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
