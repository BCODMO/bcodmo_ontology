    <owl:NamedIndividual rdf:about="http://www.wikidata.org/entity/Q5188229">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v1.0/Organization"/>
        <label>Crossref</label>
    </owl:NamedIndividual>
    


    <!-- http://www.wikidata.org/entity/Q821542 -->


    <owl:NamedIndividual rdf:about="http://www.wikidata.org/entity/Q821542">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v1.0/Organization"/>
        <label>DataCite</label>
    </owl:NamedIndividual>
    


    <!-- https://creativecommons.org/licenses/by-nc/4.0/ -->


    <owl:NamedIndividual rdf:about="https://creativecommons.org/licenses/by-nc/4.0/">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v1.0/License"/>
        <label>CC-BY-NC-4</label>
        <rdfs:label>License: CC-BY-NC-4</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://creativecommons.org/licenses/by/4.0/ -->


    <owl:NamedIndividual rdf:about="https://creativecommons.org/licenses/by/4.0/">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v1.0/License"/>
        <label>CC-BY-4</label>
        <rdfs:label>License: CC-BY-4</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://creativecommons.org/publicdomain/zero/1.0/ -->


    <owl:NamedIndividual rdf:about="https://creativecommons.org/publicdomain/zero/1.0/">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v1.0/License"/>
        <label>CC-Zero-1</label>
        <rdfs:label>License: CC-Zero-1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://schema.bco-dmo.org/v1.0/Action_Assess -->


    <owl:NamedIndividual rdf:about="https://schema.bco-dmo.org/v1.0/Action_Assess">
        <rdf:type rdf:resource="https://schema.bco-dmo.org/v1.0/AnnotationAction"/>
        <label>Assess</label>
        <rdfs:label>Action: Assess</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/oa#assessing"/>
