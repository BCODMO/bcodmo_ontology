                                        <owl:intersectionOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#first"/>
                                                <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/PolygonGeometry"/>
                                            </owl:Restriction>
                                        </owl:intersectionOf>
