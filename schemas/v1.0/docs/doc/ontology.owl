        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>The eastern longitude boundary of a bounding box (decimal degrees).</rdfs:comment>
        <rdfs:label>eastBoundary</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/email -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/email">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>Email address</rdfs:comment>
        <rdfs:label>email</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype_EmailAddress"/>
        <skos:exactMatch rdf:resource="https://schema.org/email"/>
    </owl:DatatypeProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/encoding -->


    <owl:DatatypeProperty rdf:about="https://schema.bco-dmo.org/v1.0/encoding">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The character encoding of a file (e.g. utf-8).</rdfs:comment>
        <rdfs:label>encoding</rdfs:label>
    </owl:DatatypeProperty>
    


