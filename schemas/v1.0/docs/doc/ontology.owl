    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/OfferCatalog -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/OfferCatalog">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Collection"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasCollectionItem"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ServiceOffering"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/offers"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/MediaService"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/MediaServiceType"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Collection"/>
        <rdfs:comment>A list of offerings for some MediaService</rdfs:comment>
        <rdfs:label>OfferCatalog</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/OfferCatalog"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Organization -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Organization">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <owl:disjointWith rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <owl:disjointWith rdf:resource="https://schema.bco-dmo.org/v1.0/SoftwareApplication"/>
        <rdfs:comment>An organisational body such as a publisher, funder, or identifier authority.</rdfs:comment>
        <rdfs:label>Organization</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/Organization"/>
        <skos:exactMatch rdf:resource="https://www.w3.org/ns/prov#Organization"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Parameter -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Parameter">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/isDefinedAs"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
        <rdfs:comment>A master (community-level) scientific parameter definition.</rdfs:comment>
        <rdfs:label>Parameter</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Person -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Person">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <owl:disjointWith rdf:resource="https://schema.bco-dmo.org/v1.0/SoftwareApplication"/>
        <rdfs:comment>A human individual associated with some entity.</rdfs:comment>
        <rdfs:label>Person</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/Person"/>
        <skos:exactMatch rdf:resource="https://www.w3.org/ns/prov#Person"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Platform -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Platform">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A platform (vessel, buoy, glider, etc.) used for data collection.</rdfs:comment>
        <rdfs:label>Platform</rdfs:label>
        <skos:closeMatch rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/PlatformTitle -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/PlatformTitle">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/platformTitle"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Platform"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A named title/designation for a platform (e.g. the full name of a research vessel).</rdfs:comment>
        <rdfs:label>Platform Title</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/PlatformType -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/PlatformType">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/platformType"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Platform"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A category of platform (e.g. vessel, mooring, glider).</rdfs:comment>
        <rdfs:label>Platform Type</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/PointGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/PointGeometry">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Geometry"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape_Point"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/latitude"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/longitude"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>A single coordinate</rdfs:comment>
        <rdfs:label>PointGeometry</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape_Point"/>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/sf#Point"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Policy -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Policy">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Entity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/modifiesAction"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ConsumeAction"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/target"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>An access or governance policy applied to a resource.</rdfs:comment>
        <rdfs:label>Policy</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/PolygonGeometry -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/PolygonGeometry">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Geometry"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/coordinates"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                    <owl:Class>
                                        <owl:unionOf rdf:parseType="Collection">
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#rest"/>
                                                <owl:someValuesFrom rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                            </owl:Restriction>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#rest"/>
                                                <owl:hasValue rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </owl:Restriction>
                                        </owl:unionOf>
                                    </owl:Class>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#first"/>
                                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/PointGeometry"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/categorizedBy"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape_Polygon"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>A collection of points where the first and last are equal in irder to close the shape.</rdfs:comment>
        <rdfs:label>PolygonGeometry</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://schema.bco-dmo.org/v1.0/GeometryShape_Polygon"/>
        <skos:exactMatch rdf:resource="http://www.opengis.net/ont/sf#Polygon"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/PostalAddress -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/PostalAddress">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/GeographicalLocation"/>
        <rdfs:comment>The mailing address.</rdfs:comment>
        <rdfs:label>PostalAddress</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/PostalAddress"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Program -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Program">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/hasParentProgram"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
        <owl:disjointWith rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
        <rdfs:comment>A scientific program (typically a grouping of related projects) associated with a dataset.</rdfs:comment>
        <rdfs:label>Program</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Project -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Project">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
        <rdfs:comment>A funded scientific project under which data were collected.</rdfs:comment>
        <rdfs:label>Project</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Publication -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Publication">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A scholarly publication related to a dataset (journal article, report, etc.).</rdfs:comment>
        <rdfs:label>Publication</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Article"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/RORIdentifier -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/RORIdentifier">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Identifier"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/identifierScheme"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme_ROR"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:comment>A Research Organization Registry identifier.</rdfs:comment>
        <rdfs:label>ROR Identifier</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/RelatedDataset -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/RelatedDataset">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/relations"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
        <rdfs:label>RelatedDataset</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/RelatedPublication -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/RelatedPublication">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/relations"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Publication"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/RelatedWork -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/RelatedWork">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Situation"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/forCreativeWork"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/relations"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/relationship"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>A related CreativeWork to some other CreativeWork. This describes the situation surrounding this relationship.</rdfs:comment>
        <rdfs:label>RelatedWork</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ResearchActivity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Event"/>
        <rdfs:comment>An activity that enables research. The research typically produces datasets.</rdfs:comment>
        <rdfs:label>Research Activity</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/ResearchProject"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ResourceRelation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ResourceRelation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/relationship"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Dataset"/>
                                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/RelatedWork"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/DefinedTerm"/>
        <rdfs:comment>A controlled-vocabulary term describing the relationship between two resources (aligned to Crossref and DataCite relation types).</rdfs:comment>
        <rdfs:label>Resource Relation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ResourceRelationGroup -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ResourceRelationGroup">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/inGroup"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A grouping category for resource relation types.</rdfs:comment>
        <rdfs:label>Resource Relation Group</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Role -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Role">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Category"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/roleWeight"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Category"/>
        <rdfs:comment>A functional role performed by an agent (e.g. Principal Investigator, Co-Investigator).</rdfs:comment>
        <rdfs:label>Role</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/ServiceOffering -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/ServiceOffering">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CollectionItem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/actionType"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/ConsumeAction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CollectionItem"/>
        <rdfs:comment>An offered entry pointoffered by a MediaService to perform some Action.</rdfs:comment>
        <rdfs:label>ServiceOffering</rdfs:label>
        <skos:relatedMatch rdf:resource="https://schema.org/EntryPoint"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Situation -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Situation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Entity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
                        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A static or dynamic scenario. A state of affairs that describes some configuration of the world. Most often a situation describes the interaction of 2 or more entities. In some cases these interactions are time bounded and can be labeled as significant events.</rdfs:comment>
        <rdfs:label>Situation</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/SoftwareApplication -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/SoftwareApplication">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Agent"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/provider"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Agent"/>
        <rdfs:comment>A piece of software that is deployed and executable.</rdfs:comment>
        <rdfs:label>SoftwareApplication</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/SoftwareApplication"/>
        <skos:exactMatch rdf:resource="https://www.w3.org/ns/prov#SoftwareAgent"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/SoftwareService -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/SoftwareService">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/provider"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/SoftwareApplication"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A service offered by some SoftwareApplication</rdfs:comment>
        <rdfs:label>SoftwareService</rdfs:label>
        <skos:relatedMatch rdf:resource="http://www.w3.org/ns/dcat#DataService"/>
        <skos:relatedMatch rdf:resource="https://schema.org/EntryPoint"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/String -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/String">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype"/>
        <rdfs:comment>A string value</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype_String"/>
        <rdfs:label xml:lang="en">String</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/Text"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/SupplementalDocument -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/SupplementalDocument">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://schema.bco-dmo.org/v1.0/supplementalDocument"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
        <rdfs:comment>A supplemental (non-primary) document file associated with a dataset.</rdfs:comment>
        <rdfs:label>Supplemental Document</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Synonym -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Synonym">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:comment>An alternative name or synonym, e.g. for a deployment.</rdfs:comment>
        <rdfs:label>Synonym</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/TabularFile -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/TabularFile">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/FileType"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/TemporalEntity -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/TemporalEntity">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A frame of reference for when something existed or occupied time — it is either a durationless point (an instant) or a thing with some extent in time (an interval).</rdfs:comment>
        <rdfs:label>TemporalEntity</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/TemporalInstant -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/TemporalInstant">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
        <rdfs:comment>A single point in time associated with a dataset extent or event date.</rdfs:comment>
        <rdfs:label>Temporal Instant</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/2006/time#Instant"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/TemporalInterval -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/TemporalInterval">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasBeginning"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasEnd"/>
                        <owl:someValuesFrom rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
        <rdfs:comment>A time period with a beginning and an end, used to describe dataset temporal coverage.</rdfs:comment>
        <rdfs:label>Temporal Interval</rdfs:label>
        <skos:exactMatch rdf:resource="http://www.w3.org/2006/time#Interval"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/TimeSeries -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/TimeSeries">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Event"/>
        <rdfs:comment>an ordered collection of observations indexed by time, representing the temporal evolution of one or more properties of a feature, system, or phenomenon.</rdfs:comment>
        <rdfs:label>Time Series</rdfs:label>
        <skos:closeMatch rdf:resource="https://schema.org/EventSeries"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/URL -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/URL">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierString"/>
        <rdfs:comment>A URL</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype_URL"/>
        <rdfs:label xml:lang="en">URL</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/URL"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/UnitOfMeasure -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/UnitOfMeasure">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Entity"/>
        <rdfs:comment>A unit of measure associated with a dataset parameter.</rdfs:comment>
        <rdfs:label>Unit of Measure</rdfs:label>
        <skos:closeMatch rdf:resource="http://purl.obolibrary.org/obo/UO_0000000"/>
        <skos:closeMatch rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Unit"/>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/Vessel -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/Vessel">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Platform"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://schema.bco-dmo.org/v1.0/platformType"/>
                        <owl:hasValue rdf:resource="https://schema.bco-dmo.org/v1.0/PlatformType_Vessel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/Platform"/>
        <rdfs:comment>A ship or boat.</rdfs:comment>
        <rdfs:label>Vessel</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.bco-dmo.org/v1.0/WebPage -->


    <owl:Class rdf:about="https://schema.bco-dmo.org/v1.0/WebPage">
        <rdfs:subClassOf rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:comment>A web page</rdfs:comment>
        <rdfs:label>WebPage</rdfs:label>
        <skos:exactMatch rdf:resource="https://schema.org/WebPage"/>
    </owl:Class>
    


