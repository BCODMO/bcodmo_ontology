<?xml version="1.0"?>
<rdf:RDF xmlns="https://schema.bco-dmo.org/v1.0/"
     xml:base="https://schema.bco-dmo.org/v1.0/"
     xmlns:v1="https://schema.bco-dmo.org/v1.0/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#">
    <owl:Ontology rdf:about="https://schema.bco-dmo.org/v1.0/">
        <owl:versionIRI rdf:resource="https://schema.bco-dmo.org/v1.0/"/>
        <rdfs:comment>Ontology for the Biological and Chemical Oceanography Data Management Office (BCO-DMO).</rdfs:comment>
        <rdfs:label>BCO-DMO Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML -->


    <rdfs:Datatype rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#object -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#object"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate"/>
    


    <!-- http://www.w3.org/1999/02/22-rdf-syntax-ns#subject -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/1999/02/22-rdf-syntax-ns#subject"/>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasBeginning"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasEnd -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasEnd">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/hasEnd"/>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/affiliation -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/affiliation">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Person"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Affiliation"/>
        <rdfs:comment>The institutional affiliation of a person.</rdfs:comment>
        <rdfs:label>affiliation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/author -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/author">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:comment>An author associated witha creative work. The Agent Role provides context as to how the agent contirbuted as an author to the work.</rdfs:comment>
        <rdfs:label>author</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/browseGraphic -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/browseGraphic">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Image"/>
        <rdfs:comment>An image that is representative of some thing. This could be a logo for a project or organization. It could also be an image that represents a creative work.</rdfs:comment>
        <rdfs:label>browseGraphic</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/checksum -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/checksum">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/identifier"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CryptographicHash"/>
        <rdfs:comment>A cryptographic hash for verifying file integrity.</rdfs:comment>
        <rdfs:label>checksum</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/conformsTo -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/conformsTo">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/MetadataProfile"/>
        <rdfs:comment>The metadata profile specification to which this dataset conforms.</rdfs:comment>
        <rdfs:label>conformsTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/contributor -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/contributor">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:comment>A contributor, not an author, associated with a creative work. The Agent Role provides context as to how the agent contributed to the work.</rdfs:comment>
        <rdfs:label>contributor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/createdDate -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/createdDate">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The date on which a creative work was created.</rdfs:comment>
        <rdfs:label>createdDate</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/currentState -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/currentState">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/CurrentState"/>
        <rdfs:comment>The editorial/curation state of the dataset.</rdfs:comment>
        <rdfs:label>currentState</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataFile">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DataFile"/>
        <rdfs:comment>A primary or supplemental data file distributed with this dataset package.</rdfs:comment>
        <rdfs:label>dataFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataManagementPlan -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataManagementPlan">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DataManagementPlan"/>
        <rdfs:comment>A file describing a research activities plan for managing their data.</rdfs:comment>
        <rdfs:label>dataManagementPlan</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/dataType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/dataType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Datatype"/>
        <rdfs:comment>The data type of a dataset parameter.</rdfs:comment>
        <rdfs:label>dataType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/datasetType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/datasetType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetType"/>
        <rdfs:comment>A category or type classification for this dataset.</rdfs:comment>
        <rdfs:label>datasetType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/describesFile -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/describesFile">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/FileDescriptor"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:comment>Links a file record to the File object describing its physical properties.</rdfs:comment>
        <rdfs:label>describesFile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fileType -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fileType">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/File"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/FileType"/>
        <rdfs:comment>The format type of this file.</rdfs:comment>
        <rdfs:label>fileType</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/forDataset -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/forDataset">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Situation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:comment>Links to a dataset.</rdfs:comment>
        <rdfs:label>forDataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fromDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fromDeployment">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetDeployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:comment>Links a deployment and a dataset.</rdfs:comment>
        <rdfs:label>fromDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fromInstrument -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fromInstrument">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetInstrument"/>
        <rdfs:comment>Links a dataset to the instruments used to collect the data.</rdfs:comment>
        <rdfs:label>fromInstrument</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fundedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fundedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/FundingAgency"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/fundedByAward"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/provider"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>A funding organisation that supported the work resulting in this dataset.</rdfs:comment>
        <rdfs:label>fundedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/fundedByAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/fundedByAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>the award that funded the creation, generation, etc of some creative work.</rdfs:comment>
        <rdfs:label>fundedByAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/geometry -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/geometry">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>One or more geometries (centroid, bounding box) describing a geographical location.</rdfs:comment>
        <rdfs:label>geometry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/governedBy -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/governedBy">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Policy"/>
        <rdfs:comment>A policy (e.g. embargo) that governs access to this dataset.</rdfs:comment>
        <rdfs:label>governedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/grantedAward -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/grantedAward">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/FundingAgency"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Award"/>
        <rdfs:comment>An award (grant) issued by this funding organisation.</rdfs:comment>
        <rdfs:label>grantedAward</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasAgentWithRole -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasAgentWithRole">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/CreativeWork"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/Deployment"/>
                    <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/ResearchActivity"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/AgentRole"/>
        <rdfs:comment>Associates an agent with a qualified role on a dataset or deployment.</rdfs:comment>
        <rdfs:label>hasAgentWithRole</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasBeginning -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasBeginning">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInterval"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The start of a temporal interval.</rdfs:comment>
        <rdfs:label>hasBeginning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasCoordinatedDeployment -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasCoordinatedDeployment">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:comment>A disparate deployment that coordinated in conjuction with this subject for data collection</rdfs:comment>
        <rdfs:label>hasCoordinatedDeployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasCruiseTrajectory -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasCruiseTrajectory">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Cruise"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Geometry"/>
        <rdfs:comment>The set of ordered coordinates forming a geometry (usually MultiPoint) representing the path taken by a Cruise.</rdfs:comment>
        <rdfs:label>hasCruiseTrajectory</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasEnd -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasEnd">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInterval"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalInstant"/>
        <rdfs:comment>The end of a temporal interval.</rdfs:comment>
        <rdfs:label>hasEnd</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasParameter -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasParameter">
        <owl:equivalentProperty rdf:resource="https://schema.bco-dmo.org/v1.0/storesValuesFor"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:comment xml:lang="en">A dataset collected this dataset-parameter</rdfs:comment>
        <rdfs:label xml:lang="en">hasParameter</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasParameterAttribute -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasParameterAttribute">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameter"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute"/>
        <rdfs:comment>An attribute of a particular DatasetParameter</rdfs:comment>
        <rdfs:label>hasParameterAttribute</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasParentProgram -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasParentProgram">
        <rdfs:subPropertyOf rdf:resource="https://schema.bco-dmo.org/v1.0/situationInvolves"/>
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Program"/>
        <rdfs:comment>The Program that enabled a Project&apos;s existence</rdfs:comment>
        <rdfs:label>hasParentProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasProgram -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasProgram">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Program"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/hasProject"/>
            <rdf:Description rdf:about="https://schema.bco-dmo.org/v1.0/hasParentProgram"/>
        </owl:propertyChainAxiom>
        <rdfs:comment>Associates a dataset with a scientific program.</rdfs:comment>
        <rdfs:label>hasProgram</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasProject -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasProject">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Dataset"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Project"/>
        <rdfs:comment>Associates a dataset with a scientific project.</rdfs:comment>
        <rdfs:label>hasProject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasSynonym -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasSynonym">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Deployment"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Synonym"/>
        <rdfs:comment>An alternative name used for a deployment.</rdfs:comment>
        <rdfs:label>hasSynonym</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/hasTime -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/hasTime">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/TemporalEntity"/>
        <rdfs:comment>Connects a temporal entity to some thing</rdfs:comment>
        <rdfs:label>hasTime</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/identifier -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/identifier">
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:comment>An identifier assigned to a resource.</rdfs:comment>
        <rdfs:label>identifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/identifierScheme -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/identifierScheme">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/Identifier"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/IdentifierScheme"/>
        <rdfs:comment>The scheme (authority) that defines the identifier.</rdfs:comment>
        <rdfs:label>identifierScheme</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://schema.bco-dmo.org/v1.0/inGroup -->


    <owl:ObjectProperty rdf:about="https://schema.bco-dmo.org/v1.0/inGroup">
        <rdfs:domain rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelation"/>
        <rdfs:range rdf:resource="https://schema.bco-dmo.org/v1.0/ResourceRelationGroup"/>
        <rdfs:comment>The group/category to which a resource relation type belongs.</rdfs:comment>
        <rdfs:label>inGroup</rdfs:label>
    </owl:ObjectProperty>
    


