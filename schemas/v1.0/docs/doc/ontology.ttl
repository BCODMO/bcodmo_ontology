:Action_Assess rdf:type owl:NamedIndividual ,
                        :AnnotationAction ;
               :label "Assess" ;
               rdfs:label "Action: Assess" ;
               <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/oa#assessing> .


###  https://schema.bco-dmo.org/v1.0/Action_Comment
:Action_Comment rdf:type owl:NamedIndividual ,
                         :AnnotationAction ;
                :label "Comment" ;
                rdfs:label "Action: Comment" ;
                <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/oa#commenting> .


###  https://schema.bco-dmo.org/v1.0/Action_Download
:Action_Download rdf:type owl:NamedIndividual ,
                          :ConsumeAction ;
                 :label "Download" ;
                 rdfs:label "Action: Download" .


###  https://schema.bco-dmo.org/v1.0/Action_Question
:Action_Question rdf:type owl:NamedIndividual ,
                          :AnnotationAction ;
                 :label "Question" ;
                 rdfs:label "Action: Question" ;
                 <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/oa#questioning> .


###  https://schema.bco-dmo.org/v1.0/Action_Rationalize
:Action_Rationalize rdf:type owl:NamedIndividual ,
                             :AnnotationAction ;
                    :label "Rationalize" ;
                    rdfs:label "Action: Rationalize" ;
                    <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/oa#questioning> .


###  https://schema.bco-dmo.org/v1.0/Action_View
:Action_View rdf:type owl:NamedIndividual ,
                      :ConsumeAction ;
             :label "View" ;
             rdfs:label "Action: View" .


###  https://schema.bco-dmo.org/v1.0/Boolean_False
:Boolean_False rdf:type owl:NamedIndividual ,
                        :Boolean ;
               :label "false"^^xsd:boolean ;
               rdfs:label "Boolean: False" .


###  https://schema.bco-dmo.org/v1.0/Boolean_True
:Boolean_True rdf:type owl:NamedIndividual ,
                       :Boolean ;
              :label "true"^^xsd:boolean ;
              rdfs:label "Boolean: True" .


###  https://schema.bco-dmo.org/v1.0/CryptographicHashAlgorithm_MD5
:CryptographicHashAlgorithm_MD5 rdf:type owl:NamedIndividual ,
                                         :CryptographicHashAlgorithm ;
                                owl:sameAs <urn:bcodmo:taxonomy:cryptographic-hash:190> ;
                                :abbreviation "md5" ;
                                :label "MD5" .


