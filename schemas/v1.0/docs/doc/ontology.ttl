               <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/streetAddress> .


###  https://schema.bco-dmo.org/v1.0/telephone
:telephone rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Agent ;
           rdfs:range xsd:token ;
           rdfs:comment "The telephone number." ;
           rdfs:label "telephone" ;
           <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/telephone> .


###  https://schema.bco-dmo.org/v1.0/title
:title rdf:type owl:DatatypeProperty ;
       rdfs:domain :Dataset ;
       rdfs:range xsd:string ;
       rdfs:comment "The full title of the dataset." ;
       rdfs:label "title" ;
       <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/name> .


###  https://schema.bco-dmo.org/v1.0/url
:url rdf:type owl:DatatypeProperty ;
     rdfs:domain :Entity ;
     rdfs:range xsd:anyURI ;
     rdfs:comment "A URL for a resource, such as its landing page." ;
     rdfs:label "url" ;
     <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/url> .


###  https://schema.bco-dmo.org/v1.0/urlTemplate
:urlTemplate rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :SoftwareService ;
             rdfs:range xsd:anyURI ;
             rdfs:comment "An url template (RFC6570) that will be used to construct the target of the execution of the action." ;
             rdfs:label "urlTemplate" ;
             <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/urlTemplate> .


###  https://schema.bco-dmo.org/v1.0/useFullMiddleNameInCitationText
:useFullMiddleNameInCitationText rdf:type owl:DatatypeProperty ,
                                          owl:FunctionalProperty ;
                                 rdfs:domain [ rdf:type owl:Class ;
                                               owl:unionOf ( :AgentRole
                                                             :Person
                                                           )
                                             ] ;
                                 rdfs:range xsd:boolean ;
                                 rdfs:comment "Whether the Person prefers to use their full middle name in citations. Can be overriden by using at teh AgentRole for authors and contributors." ;
                                 rdfs:label "useFullMiddleNameInCitationText" .


###  https://schema.bco-dmo.org/v1.0/validated
:validated rdf:type owl:DatatypeProperty ;
           rdfs:domain :Dataset ;
           rdfs:range xsd:boolean ;
           rdfs:comment "Has the dataset been validated by the PI." ;
           rdfs:label "validated" .


###  https://schema.bco-dmo.org/v1.0/valueFormat
:valueFormat rdf:type owl:DatatypeProperty ;
             rdfs:domain :DatasetParameter ;
             rdfs:range xsd:token ;
             rdfs:comment "The format string used to encode parameter values in the data file." ;
             rdfs:label "valueFormat" .


###  https://schema.bco-dmo.org/v1.0/version
:version rdf:type owl:DatatypeProperty ;
         rdfs:domain :Dataset ;
         rdfs:range xsd:token ;
         rdfs:comment "The version label of the dataset (numeric or numeric + single lowercase letter)." ;
         rdfs:label "version" ;
         <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/version> .


###  https://schema.bco-dmo.org/v1.0/westBoundary
:westBoundary rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :BoundingBoxGeometry ;
              rdfs:range xsd:float ;
              rdfs:comment "The western longitude boundary of a bounding box (decimal degrees)." ;
              rdfs:label "westBoundary" .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#List
rdf:List rdf:type owl:Class .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement
rdf:Statement rdf:type owl:Class .


###  http://www.w3.org/2006/time#TemporalUnit
<http://www.w3.org/2006/time#TemporalUnit> rdf:type owl:Class .


###  https://schema.bco-dmo.org/v1.0/Action
:Action rdf:type owl:Class ;
        rdfs:subClassOf :Category ;
        rdfs:comment "Some action that can be taken on an Entity. A Policy can restrict and allow actions" ;
        rdfs:label "Action" ;
        <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Action> .


###  https://schema.bco-dmo.org/v1.0/Affiliation
:Affiliation rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Organization
                                                        [ rdf:type owl:Class ;
                                                          owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                          owl:onProperty [ owl:inverseOf :affiliation
                                                                                         ] ;
                                                                          owl:someValuesFrom :Person
                                                                        ]
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty [ owl:inverseOf :performedAt
                                                                                         ] ;
                                                                          owl:someValuesFrom :AgentRole
                                                                        ]
                                                                      )
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf :Organization ;
             rdfs:comment "An institutional affiliation of a person (university, research institute, etc.)." ;
             rdfs:label "Affiliation" .


###  https://schema.bco-dmo.org/v1.0/Agent
:Agent rdf:type owl:Class ;
       rdfs:subClassOf :Entity ;
       rdfs:comment "An entity (person or organisation) that can perform roles." ;
       rdfs:label "Agent" ;
       <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.w3.org/ns/prov#Agent> .


###  https://schema.bco-dmo.org/v1.0/AgentRole
:AgentRole rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :performedBy ;
                                                        owl:someValuesFrom :Agent
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :role ;
                                                        owl:someValuesFrom :Role
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty [ owl:inverseOf :hasAgentWithRole
                                                                       ] ;
                                                        owl:someValuesFrom :Entity
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf :Situation ;
           rdfs:comment "A qualified association that links an Agent to a role and optionally an affiliation context." ;
           rdfs:label "Agent Role" ;
           <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Role> ,
                                                            <https://www.w3.org/ns/prov#Role> .


###  https://schema.bco-dmo.org/v1.0/Annotation
:Annotation rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :annotator ;
                                                         owl:someValuesFrom :Agent
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :annotates ;
                                                         owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :hasContent ;
                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass :CreativeWork
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf :Situation ;
            rdfs:comment "A comment or some other piece of content that annotates for some specific purpose some Thing" ;
            rdfs:label "Annotation" .


###  https://schema.bco-dmo.org/v1.0/AnnotationAction
:AnnotationAction rdf:type owl:Class ;
                  rdfs:subClassOf :Action ;
                  rdfs:comment "The motivation for annotating some thing." ;
                  rdfs:label "AnnotationAction" .


###  https://schema.bco-dmo.org/v1.0/ArchiveFileType
:ArchiveFileType rdf:type owl:Class ;
                 rdfs:subClassOf :FileType ;
                 rdfs:comment "A file format  used to bundle multiple files and folders into a single file for easier storage or transfer." ;
                 rdfs:label "ArchiveFileType" .


###  https://schema.bco-dmo.org/v1.0/ArchivedDataset
:ArchivedDataset rdf:type owl:Class ;
                 rdfs:subClassOf :Dataset ;
                 rdfs:comment "A specific version of a Dataset that has been stored  in an archive that typcially provides access" ;
                 rdfs:label "ArchivedDataset" .


###  https://schema.bco-dmo.org/v1.0/Audience
:Audience rdf:type owl:Class ;
          rdfs:subClassOf :Category ;
          rdfs:comment "Intended audience for an item, i.e. the group for whom the item was created or is being offered to." ;
          rdfs:label "Audience" ;
          <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Audience> .


###  https://schema.bco-dmo.org/v1.0/Award
:Award rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :Entity
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :funder ;
                                                    owl:someValuesFrom :FundingAgency
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty [ owl:inverseOf :fundedByAward
                                                                   ] ;
                                                    owl:someValuesFrom :CreativeWork
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf :Entity ;
       rdfs:comment "A funding award (grant) from a funder that supports data collection." ;
       rdfs:label "Award" ;
       <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Grant> .


###  https://schema.bco-dmo.org/v1.0/AwardNoDataAnnotation
:AwardNoDataAnnotation rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :Annotation
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :annotates ;
                                                                    owl:someValuesFrom [ owl:intersectionOf ( rdf:Statement
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty rdf:subject ;
                                                                                                                owl:someValuesFrom :Award
                                                                                                              ]
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty rdf:object ;
                                                                                                                owl:hasValue :Boolean_True
                                                                                                              ]
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty rdf:predicate ;
                                                                                                                owl:hasValue :awardProducingData
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ]
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasContent ;
                                                                    owl:someValuesFrom [ owl:intersectionOf ( :Comment
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty :content ;
                                                                                                                owl:someValuesFrom xsd:string
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ]
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :annotator ;
                                                                    owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                    owl:onClass :Agent
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :Annotation ;
                       rdfs:comment "A reason why an award will not produce datasets" ;
                       rdfs:label "AwardNoDataAnnotation" .


###  https://schema.bco-dmo.org/v1.0/BCODMOIdentifier
:BCODMOIdentifier rdf:type owl:Class ;
                  rdfs:subClassOf :Identifier ;
                  rdfs:comment "An internal BCO-DMO identifier (version 2 scheme)." ;
                  rdfs:label "BCO-DMO Identifier" .


###  https://schema.bco-dmo.org/v1.0/Boolean
:Boolean rdf:type owl:Class ;
         rdfs:subClassOf :Datatype ;
         rdfs:comment "A boolean value like True or False, Yes or No, 1 or 0." ;
         rdfs:isDefinedBy :Datatype_Boolean ;
         rdfs:label "Boolean" ;
         <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Boolean> .


###  https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry
:BoundingBoxGeometry rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :PolygonGeometry
                                                                [ rdf:type owl:Class ;
                                                                  owl:unionOf ( [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty :eastBoundary ;
                                                                                                         owl:someValuesFrom xsd:float
                                                                                                       ]
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty :northBoundary ;
                                                                                                         owl:someValuesFrom xsd:float
                                                                                                       ]
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty :southBoundary ;
                                                                                                         owl:someValuesFrom xsd:float
                                                                                                       ]
                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                         owl:onProperty :westBoundary ;
                                                                                                         owl:someValuesFrom xsd:float
                                                                                                       ]
                                                                                                     ) ;
                                                                                  rdf:type owl:Class
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty :coordinates ;
                                                                                  owl:qualifiedCardinality "5"^^xsd:nonNegativeInteger ;
                                                                                  owl:onClass :PointGeometry
                                                                                ]
                                                                              )
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf :PolygonGeometry ;
                     rdfs:comment "An axis-aligned bounding box geometry defined by west/south/east/north boundaries." ;
                     rdfs:label "Bounding Box Geometry" ;
                     <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#Envelope> .


###  https://schema.bco-dmo.org/v1.0/Category
:Category rdf:type owl:Class ;
          rdfs:subClassOf :Entity ;
          rdfs:comment "A set of taxonomy" ;
          rdfs:label "Category" ;
          <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/DefinedTerm> .


###  https://schema.bco-dmo.org/v1.0/CentroidGeometry
:CentroidGeometry rdf:type owl:Class ;
                  rdfs:subClassOf :PointGeometry ;
                  rdfs:comment "A point geometry representing the centroid of a spatial extent." ;
                  rdfs:label "Centroid Geometry" ;
                  <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.opengis.net/ont/sf#Point> .


###  https://schema.bco-dmo.org/v1.0/Collection
:Collection rdf:type owl:Class ;
            rdfs:subClassOf :CreativeWork ;
            rdfs:comment "A curated collection, set, or list of some Things." ;
            rdfs:label "Collection" ;
            <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Collection> .


###  https://schema.bco-dmo.org/v1.0/CollectionItem
:CollectionItem rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :inCollection ;
                                                             owl:someValuesFrom :Collection
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :Situation ;
                rdfs:comment "An item in a collection" ;
                rdfs:label "CollectionItem" ;
                <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/ListItem> .


###  https://schema.bco-dmo.org/v1.0/Comment
:Comment rdf:type owl:Class ;
         rdfs:subClassOf :CreativeWork ;
         rdfs:comment "A note or piece of text typically used for Annotations" ;
         rdfs:label "Comment" ;
         <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Comment> .


###  https://schema.bco-dmo.org/v1.0/ComputerLanguage
:ComputerLanguage rdf:type owl:Class ;
                  rdfs:subClassOf :Language ;
                  owl:disjointWith :NaturalLanguage ;
                  rdfs:comment "Programming languages such as Python, Go, Rust and Java." ;
                  rdfs:label "ComputerLanguage" ;
                  <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/ComputerLanguage> .


###  https://schema.bco-dmo.org/v1.0/ConsumeAction
:ConsumeAction rdf:type owl:Class ;
               rdfs:subClassOf :Action ;
               rdfs:comment "The act of consuming an Entity." ;
               rdfs:label "ConsumeAction" ;
               <http://www.w3.org/2004/02/skos/core#closeMatch> "https://schema.org/ConsumeAction" .


###  https://schema.bco-dmo.org/v1.0/ControlledVocabulary
:ControlledVocabulary rdf:type owl:Class ;
                      rdfs:subClassOf :CreativeWork ;
                      rdfs:comment "A vocabulary of terms or phrases used to describe concepts in a specific domain" ;
                      rdfs:label "ControlledVocabulary" .


###  https://schema.bco-dmo.org/v1.0/CoordinateReferenceSystem
:CoordinateReferenceSystem rdf:type owl:Class ;
                           rdfs:subClassOf :IdentifierScheme ;
                           rdfs:comment "A coordinate reference system" ;
                           rdfs:label "CoordinateReferenceSystem" .


###  https://schema.bco-dmo.org/v1.0/CreativeWork
:CreativeWork rdf:type owl:Class ;
              rdfs:subClassOf :Entity ;
              rdfs:comment "Any work that can be created by some Agent" ;
              rdfs:label "Creative Work" ;
              <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/CreativeWork> .


###  https://schema.bco-dmo.org/v1.0/CreativeWorkStatus
:CreativeWorkStatus rdf:type owl:Class ;
                    rdfs:subClassOf :Category ;
                    rdfs:comment "A state of for some createive work." ;
                    rdfs:label "CreativeWorkStatus" .


###  https://schema.bco-dmo.org/v1.0/Cruise
:Cruise rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Deployment
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :onPlatform ;
                                                     owl:someValuesFrom :Vessel
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:subClassOf :Deployment ;
        rdfs:comment "A research vessel cruise, a specialisation of Platform for vessel-type platforms." ;
        rdfs:label "Cruise" .


###  https://schema.bco-dmo.org/v1.0/CryptographicHash
:CryptographicHash rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :Identifier
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :identifierScheme ;
                                                                owl:someValuesFrom :CryptographicHashAlgorithm
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :Identifier ;
                   rdfs:comment "A cryptographic hash (e.g. MD5) used as a file integrity checksum." ;
                   rdfs:label "Cryptographic Hash" .


###  https://schema.bco-dmo.org/v1.0/CryptographicHashAlgorithm
:CryptographicHashAlgorithm rdf:type owl:Class ;
                            rdfs:subClassOf :IdentifierScheme ;
                            rdfs:comment "A mathematical function that transforms any arbitrary amount of input data into a fixed-length string of characters (identifierValue), acting as a secure \"digital fingerprint\" or \"digest\"" ;
                            rdfs:label "Cryptographic Hash Algorithm" .


###  https://schema.bco-dmo.org/v1.0/CurrentState
:CurrentState rdf:type owl:Class ;
              rdfs:subClassOf :Category ;
              rdfs:comment "The current editorial/curation state of a CreativeWork" ;
              rdfs:label "Current State" .


###  https://schema.bco-dmo.org/v1.0/DOIDataset
:DOIDataset rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( :ArchivedDataset
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :identifier ;
                                                         owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                              owl:onProperty :identifierScheme ;
                                                                              owl:hasValue :IdentifierScheme_DOI
                                                                            ]
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf :ArchivedDataset ;
            rdfs:comment "A versioned BCO-DMO dataset that has been assigned a DOI." ;
            rdfs:label "DOI Dataset" .


###  https://schema.bco-dmo.org/v1.0/DOIIdentifier
:DOIIdentifier rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Identifier
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :identifierScheme ;
                                                            owl:hasValue :IdentifierScheme_DOI
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Identifier ;
               rdfs:comment "A Digital Object Identifier." ;
               rdfs:label "DOI Identifier" .


###  https://schema.bco-dmo.org/v1.0/DOIStatus
:DOIStatus rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :CreativeWorkStatus
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty [ owl:inverseOf :status
                                                                       ] ;
                                                        owl:someValuesFrom :DOIDataset
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf :CreativeWorkStatus ;
           rdfs:comment "The lifecycle status of a DOI Dataset (Draft, Reserved, Published, etc.)." ;
           rdfs:label "DOI Status" .


###  https://schema.bco-dmo.org/v1.0/DataFile
:DataFile rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( :FileDescriptor
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf :dataFile
                                                                      ] ;
                                                       owl:someValuesFrom :CreativeWork
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
          rdfs:subClassOf :FileDescriptor ;
          rdfs:comment "A primary or supplemental data file distributed as part of a dataset." ;
          rdfs:label "Data File" ;
          <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/DataDownload> .


###  https://schema.bco-dmo.org/v1.0/DataManagementPlan
:DataManagementPlan rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( :FileDescriptor
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty [ owl:inverseOf :dataManagementPlan
                                                                                ] ;
                                                                 owl:someValuesFrom :CreativeWork
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf :FileDescriptor ;
                    rdfs:comment "A plan describing how a research activity will manage and archive data products produced." ;
                    rdfs:label "DataManagementPlan" .


###  https://schema.bco-dmo.org/v1.0/Dataset
:Dataset rdf:type owl:Class ;
         rdfs:subClassOf :CreativeWork ;
         rdfs:comment "A dataset which may be internal or external to BCO-DMO." ;
         rdfs:label "Dataset" ;
         <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Dataset> .


###  https://schema.bco-dmo.org/v1.0/DatasetAward
:DatasetAward rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :fundedByAward ;
                                                           owl:someValuesFrom :Award
                                                         ]
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty [ owl:inverseOf :forDataset
                                                                          ] ;
                                                           owl:someValuesFrom :Dataset
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf :Situation ;
              rdfs:comment "The connection between a dataset and the award the funded its generation" ;
              rdfs:label "DatasetAward" .


###  https://schema.bco-dmo.org/v1.0/DatasetDeployment
:DatasetDeployment rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :forDataset ;
                                                                owl:someValuesFrom :Dataset
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :fromDeployment ;
                                                                owl:someValuesFrom :Deployment
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :Situation ,
                                   [ owl:intersectionOf ( :Situation
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :forDataset ;
                                                            owl:someValuesFrom :Dataset
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :fromDeployment ;
                                                            owl:someValuesFrom :Deployment
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
                   rdfs:comment "A deployment as referenced within a specific dataset, with dataset-specific properties." ;
                   rdfs:label "Dataset Deployment" .


###  https://schema.bco-dmo.org/v1.0/DatasetInstrument
:DatasetInstrument rdf:type owl:Class ;
                   owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :forDataset ;
                                                                owl:someValuesFrom :Dataset
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty :isDefinedAs ;
                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass :Instrument
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                   rdfs:subClassOf :Situation ;
                   rdfs:comment "An instrument as referenced within a specific dataset, with dataset-specific properties." ;
                   rdfs:label "Dataset Instrument" .


###  https://schema.bco-dmo.org/v1.0/DatasetList
:DatasetList rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Collection
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :hasCollectionItem ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass [ owl:intersectionOf ( :CollectionItem
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty :collectionItem ;
                                                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                               owl:onClass :Dataset
                                                                                             ]
                                                                                           ) ;
                                                                        rdf:type owl:Class
                                                                      ]
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf :Collection ;
             rdfs:comment "A list of Datasets" ;
             rdfs:label "DatasetList" .


###  https://schema.bco-dmo.org/v1.0/DatasetNoInstrumentsAnnotation
:DatasetNoInstrumentsAnnotation rdf:type owl:Class ;
                                owl:equivalentClass [ owl:intersectionOf ( :Annotation
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty :annotates ;
                                                                             owl:someValuesFrom [ owl:intersectionOf ( rdf:Statement
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty rdf:subject ;
                                                                                                                         owl:someValuesFrom :Dataset
                                                                                                                       ]
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty rdf:object ;
                                                                                                                         owl:hasValue :Boolean_True
                                                                                                                       ]
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty rdf:predicate ;
                                                                                                                         owl:hasValue :datasetInstrumentsNotUsed
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ]
                                                                           ]
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty :hasContent ;
                                                                             owl:someValuesFrom [ owl:intersectionOf ( :Comment
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty :content ;
                                                                                                                         owl:someValuesFrom xsd:string
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ]
                                                                           ]
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty :annotator ;
                                                                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                             owl:onClass :Agent
                                                                           ]
                                                                         ) ;
                                                      rdf:type owl:Class
                                                    ] ;
                                rdfs:subClassOf :Annotation ;
                                rdfs:comment "A reason as to why no instruments were used in the generation of this Dataset." ;
                                rdfs:label "DatasetNoInstrumentsAnnotation" .


###  https://schema.bco-dmo.org/v1.0/DatasetNoParametersAnnotation
:DatasetNoParametersAnnotation rdf:type owl:Class ;
                               owl:equivalentClass [ owl:intersectionOf ( :Annotation
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :annotates ;
                                                                            owl:someValuesFrom [ owl:intersectionOf ( rdf:Statement
                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                        owl:onProperty rdf:subject ;
                                                                                                                        owl:someValuesFrom :Dataset
                                                                                                                      ]
                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                        owl:onProperty rdf:object ;
                                                                                                                        owl:hasValue :Boolean_True
                                                                                                                      ]
                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                        owl:onProperty rdf:predicate ;
                                                                                                                        owl:hasValue :datasetParametersNotRequired
                                                                                                                      ]
                                                                                                                    ) ;
                                                                                                 rdf:type owl:Class
                                                                                               ]
                                                                          ]
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :hasContent ;
                                                                            owl:someValuesFrom [ owl:intersectionOf ( :Comment
                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                        owl:onProperty :content ;
                                                                                                                        owl:someValuesFrom xsd:string
                                                                                                                      ]
                                                                                                                    ) ;
                                                                                                 rdf:type owl:Class
                                                                                               ]
                                                                          ]
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty :annotator ;
                                                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                            owl:onClass :Agent
                                                                          ]
                                                                        ) ;
                                                     rdf:type owl:Class
                                                   ] ;
                               rdfs:subClassOf :Annotation ;
                               rdfs:comment "A reason as to why a Dataset has no parameters defined." ;
                               rdfs:label "DatasetNoParametersAnnotation" .


###  https://schema.bco-dmo.org/v1.0/DatasetParameter
:DatasetParameter rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :forDataset ;
                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass :Dataset
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :isDefinedAs ;
                                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass :Parameter
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :Situation ;
                  rdfs:comment "A parameter as instantiated within a specific dataset column, with dataset-level name, description, units, and format." ;
                  rdfs:label "Dataset Parameter" ;
                  <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/sosa/ObservableProperty> .


###  https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute
:DatasetParameterAttribute rdf:type owl:Class ;
                           rdfs:subClassOf :Category ;
                           rdfs:comment "An attribute of a dataset parameter that provides more context as to how it could be used." ;
                           rdfs:label "DatasetParameterAttribute" .


###  https://schema.bco-dmo.org/v1.0/DatasetProject
:DatasetProject rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :forDataset ;
                                                             owl:someValuesFrom :Dataset
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :hasProject ;
                                                             owl:someValuesFrom :Project
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :projectActedOnWork ;
                                                             owl:someValuesFrom :Action
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :Situation ;
                rdfs:comment "A situation in which a Project has some influence on the creation of a Dataset." ;
                rdfs:label "DatasetProject" .


###  https://schema.bco-dmo.org/v1.0/DatasetType
:DatasetType rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Category
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty [ owl:inverseOf :datasetType
                                                                         ] ;
                                                          owl:someValuesFrom :Dataset
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf :Category ;
             rdfs:comment "A category describing the type of dataset (e.g. Cruise Data, Model Output)." ;
             rdfs:label "Dataset Type" .


###  https://schema.bco-dmo.org/v1.0/DatasetsInOtherCatalog
:DatasetsInOtherCatalog rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :DatasetList
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasProject ;
                                                                     owl:someValuesFrom :Project
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :publisher ;
                                                                     owl:someValuesFrom :Agent
                                                                   ]
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :disclaimer ;
                                                                     owl:someValuesFrom xsd:string
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :DatasetList ;
                        rdfs:comment "A list of datasets in a catalog that isn't BCO-DMO" ;
                        rdfs:label "DatasetsInOtherCatalog" .


###  https://schema.bco-dmo.org/v1.0/Datatype
:Datatype rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( :Category
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf :dataType
                                                                      ] ;
                                                       owl:someValuesFrom :DatasetParameter
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
          rdfs:subClassOf :Category ;
          rdfs:comment "The data type of a dataset parameter column (e.g. string, integer, float)." ;
          rdfs:label "Datatype" ;
          <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/DataType> .


###  https://schema.bco-dmo.org/v1.0/DefinedTerm
:DefinedTerm rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Category
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :inControlledVocabulary ;
                                                          owl:someValuesFrom :ControlledVocabulary
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf :Category ;
             rdfs:comment "A term in some ControlledVocabulary with a community-agreed definition" ;
             rdfs:label "DefinedTerm" ;
             <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/DefinedTerm> .


###  https://schema.bco-dmo.org/v1.0/Deployment
:Deployment rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( :Event
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :onPlatform ;
                                                         owl:someValuesFrom :Platform
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf :Event ;
            rdfs:comment "A scientific deployment (cruise, expedition, mooring deployment) during which data were collected." ;
            rdfs:label "Deployment" ;
            <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/ssn/Deployment> .


###  https://schema.bco-dmo.org/v1.0/DeploymentActivity
:DeploymentActivity rdf:type owl:Class ;
                    rdfs:subClassOf :Category ;
                    rdfs:comment "The type of activity a specific deployment was operating under." ;
                    rdfs:label "DeploymentActivity" .


###  https://schema.bco-dmo.org/v1.0/DeploymentEntityMatch
:DeploymentEntityMatch rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :EntityMatch
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty rdf:object ;
                                                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty rdf:subject ;
                                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                    owl:onClass :Deployment
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :EntityMatch ;
                       rdfs:label "DeploymentEntityMatch" .


###  https://schema.bco-dmo.org/v1.0/DeprecatedEntity
:DeprecatedEntity rdf:type owl:Class ;
                  rdfs:subClassOf :Entity ;
                  rdfs:comment "An entity that should no longer be used." ;
                  rdfs:label "DeprecatedEntity" .


###  https://schema.bco-dmo.org/v1.0/EmailAddress
:EmailAddress rdf:type owl:Class ;
              rdfs:subClassOf :IdentifierString ;
              rdfs:comment "An email address." ;
              rdfs:isDefinedBy :Datatype_EmailAddress ;
              rdfs:label "Email Address" .


###  https://schema.bco-dmo.org/v1.0/EmbargoPolicy
:EmbargoPolicy rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Policy
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :expirationDate ;
                                                            owl:someValuesFrom :TemporalEntity
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :modifiesAction ;
                                                            owl:someValuesFrom :ConsumeAction
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :target ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass :CreativeWork
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Policy ;
               rdfs:comment "A policy that restricts access to a dataset until an expiration date." ;
               rdfs:label "Embargo Policy" .


###  https://schema.bco-dmo.org/v1.0/EmbargoReleasePolicy
:EmbargoReleasePolicy rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( :Policy
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :modifiesAction ;
                                                                   owl:someValuesFrom :ConsumeAction
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :releaseDate ;
                                                                   owl:someValuesFrom :TemporalEntity
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :target ;
                                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                   owl:onClass :CreativeWork
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf :Policy ;
                      rdfs:comment "A policy that allows access to a FileDescriptor when its overarching Dataset is under an embargo." ;
                      rdfs:label "EmbargoReleasePolicy" .


###  https://schema.bco-dmo.org/v1.0/Entity
:Entity rdf:type owl:Class ;
        rdfs:comment "A BCO-DMO specific concept" ;
        rdfs:label "Entity" .


###  https://schema.bco-dmo.org/v1.0/EntityMatch
:EntityMatch rdf:type owl:Class ;
             rdfs:subClassOf :Situation ;
             rdfs:comment "A link between two entities that are related in some way as defined by rdf:predicate. This entity allows for annotating details of the match." ;
             rdfs:label "EntityMatch" .


###  https://schema.bco-dmo.org/v1.0/EntityPublishingStatus
:EntityPublishingStatus rdf:type owl:Class ;
                        rdfs:subClassOf :Category ;
                        rdfs:comment "One or more statuses of a BCO-DMO Entity. This is primarily used to determine where an entity appears - not at all while it's being contructed, in draft review for a submitter, published, deprecated or unpublished." ;
                        rdfs:label "EntityPublishingStatus" .


###  https://schema.bco-dmo.org/v1.0/Event
:Event rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasTime ;
                                                    owl:someValuesFrom :TemporalEntity
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf :Situation ;
       rdfs:comment "A dynamic situation in which something unique or impotant happened." ;
       rdfs:label "Event" ;
       <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Event> .


###  https://schema.bco-dmo.org/v1.0/File
:File rdf:type owl:Class ;
      rdfs:subClassOf :CreativeWork ;
      rdfs:comment "A physical file (byte stream) associated with a dataset or package." ;
      rdfs:label "File" ;
      <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/MediaObject> .


###  https://schema.bco-dmo.org/v1.0/FileDescriptor
:FileDescriptor rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :CreativeWork
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :describesFile ;
                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                             owl:onClass :File
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :CreativeWork ;
                rdfs:comment "A context-specific description of a file. The context could be data, metadata or supplemental documentation." ;
                rdfs:label "File Descriptor" ;
                <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/DigitalDocument> .


###  https://schema.bco-dmo.org/v1.0/FileType
:FileType rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( :Category
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf :fileType
                                                                      ] ;
                                                       owl:someValuesFrom :File
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
          rdfs:subClassOf :Category ;
          rdfs:comment "A file format type, characterised by a label and MIME type (e.g. CSV, XML, PDF)." ;
          rdfs:label "File Type" .


###  https://schema.bco-dmo.org/v1.0/FundingAgency
:FundingAgency rdf:type owl:Class ;
               rdfs:subClassOf :Organization ;
               rdfs:comment "An Organization that has provided some funding award" ;
               rdfs:label "Funding Agency" ;
               <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/FundingAgency> .


###  https://schema.bco-dmo.org/v1.0/GCMDPlatformType
:GCMDPlatformType rdf:type owl:Class ;
                  rdfs:subClassOf :DefinedTerm ;
                  rdfs:comment "A platform type defined by GCMD" ;
                  rdfs:isDefinedBy :ControlledVocabulary_GCMDPlatformTypes ;
                  rdfs:label "GCMDPlatformType" .


###  https://schema.bco-dmo.org/v1.0/GeographicalLocation
:GeographicalLocation rdf:type owl:Class ;
                      rdfs:subClassOf :Entity ;
                      rdfs:comment "A spatial extent or named location associated with a dataset, deployment, project, or program." ;
                      rdfs:label "Geographical Location" ;
                      <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Place> ;
                      <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.w3.org/ns/sosa/FeatureOfInterest> .


###  https://schema.bco-dmo.org/v1.0/Geometry
:Geometry rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( :Entity
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :categorizedBy ;
                                                       owl:someValuesFrom :GeometryShape
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
          rdfs:subClassOf :Entity ;
          rdfs:comment "An abstract spatial geometry." ;
          rdfs:label "Geometry" ;
          <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/GeospatialGeometry> ;
          <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#Geometry> .


###  https://schema.bco-dmo.org/v1.0/GeometryShape
:GeometryShape rdf:type owl:Class ;
               rdfs:subClassOf :Category ;
               rdfs:comment "The shape of various geometries." ;
               rdfs:label "GeometryShape" .


###  https://schema.bco-dmo.org/v1.0/Identifier
:Identifier rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                         owl:onProperty :identifierScheme ;
                                                         owl:someValuesFrom :IdentifierScheme
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :identifierValue ;
                                                         owl:someValuesFrom xsd:token
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf :Entity ;
            rdfs:comment "An identifier assigned to a resource by some scheme." ;
            rdfs:label "Identifier" .


###  https://schema.bco-dmo.org/v1.0/IdentifierScheme
:IdentifierScheme rdf:type owl:Class ;
                  rdfs:subClassOf :Category ;
                  rdfs:comment "A named scheme or authority that mints identifiers (DOI, ROR, ORCID, etc.)." ;
                  rdfs:label "Identifier Scheme" .


###  https://schema.bco-dmo.org/v1.0/IdentifierString
:IdentifierString rdf:type owl:Class ;
                  rdfs:subClassOf :String ;
                  rdfs:comment "A string that is used as an identifier" ;
                  rdfs:isDefinedBy :Datatype_Identifier ;
                  rdfs:label "IdentifierString"@en .


###  https://schema.bco-dmo.org/v1.0/Image
:Image rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :File
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :fileType ;
                                                    owl:someValuesFrom :ImageFileType
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf :File ;
       rdfs:comment "An image file." ;
       rdfs:label "Image" ;
       <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/ImageObject> .


###  https://schema.bco-dmo.org/v1.0/ImageFileType
:ImageFileType rdf:type owl:Class ;
               rdfs:subClassOf :FileType ;
               rdfs:comment "Representative of a type of image file." ;
               rdfs:label "ImageFileType" .


###  https://schema.bco-dmo.org/v1.0/Instrument
:Instrument rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( :DefinedTerm
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty [ owl:inverseOf :isDefinedAs
                                                                        ] ;
                                                         owl:someValuesFrom :DatasetInstrument
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ,
                                [ owl:intersectionOf ( :DefinedTerm
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :inControlledVocabulary ;
                                                         owl:hasValue :ControlledVocabulary_BCODMO_Instruments
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf :DefinedTerm ;
            rdfs:comment "A master (community-level) scientific instrument definition." ;
            rdfs:label "Instrument" ;
            <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/sosa/Sensor> ;
            <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://www.w3.org/TR/vocab-ssn/#SSNSystem> .


###  https://schema.bco-dmo.org/v1.0/Keyword
:Keyword rdf:type owl:Class ;
         rdfs:subClassOf :Category ;
         rdfs:comment "A subject keyword associated with a CreativeWork." ;
         rdfs:label "Keyword" .


###  https://schema.bco-dmo.org/v1.0/Language
:Language rdf:type owl:Class ;
          rdfs:subClassOf :Category ;
          rdfs:comment "A natural language used in the dataset metadata." ;
          rdfs:label "Language" .


###  https://schema.bco-dmo.org/v1.0/License
:License rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( :CreativeWork
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty [ owl:inverseOf :license
                                                                     ] ;
                                                      owl:someValuesFrom :CreativeWork
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf :CreativeWork ;
         rdfs:comment "A  license applied to some creative work." ;
         rdfs:label "License" .


###  https://schema.bco-dmo.org/v1.0/LineStringGeometry
:LineStringGeometry rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( :Geometry
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :coordinates ;
                                                                 owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                           [ rdf:type owl:Class ;
                                                                                                             owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                                             owl:onProperty rdf:rest ;
                                                                                                                             owl:someValuesFrom rdf:List
                                                                                                                           ]
                                                                                                                           [ rdf:type owl:Restriction ;
                                                                                                                             owl:onProperty rdf:rest ;
                                                                                                                             owl:hasValue rdf:nil
                                                                                                                           ]
                                                                                                                         )
                                                                                                           ]
                                                                                                           [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty rdf:first ;
                                                                                                             owl:someValuesFrom :PointGeometry
                                                                                                           ]
                                                                                                         ) ;
                                                                                      rdf:type owl:Class
                                                                                    ]
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :categorizedBy ;
                                                                 owl:hasValue :GeometryShape_Linestring
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf :Geometry ;
                    rdfs:comment "Two or more PointGeometry that when connected form lines between between adjacent points." ;
                    rdfs:label "LineStringGeometry" ;
                    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#LineString> .


###  https://schema.bco-dmo.org/v1.0/Logo
:Logo rdf:type owl:Class ;
      rdfs:subClassOf :Image ;
      rdfs:comment "An image that is representative of some thing" ;
      rdfs:label "Logo" .


###  https://schema.bco-dmo.org/v1.0/MediaService
:MediaService rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :CreativeWork
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :categorizedBy ;
                                                           owl:someValuesFrom :MediaServiceType
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf :CreativeWork ;
              rdfs:comment "An affordance made to some audience by a provider to access all or part of some CreativeWork. Often times it is an interpretation of the whole work - a metadata record, a visualization, a file in a specific format, etc." ;
              rdfs:label "MediaService" ;
              <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.w3.org/ns/dcat#DataService> ,
                                                                 <https://schema.org/DataDownload> ,
                                                                 <https://schema.org/MediaObject> ,
                                                                 <https://schema.org/WebAPI> .


###  https://schema.bco-dmo.org/v1.0/MediaServiceType
:MediaServiceType rdf:type owl:Class ;
                  rdfs:subClassOf :Category ;
                  rdfs:comment "A way of grouping multiple MediaService offerings on the same CreativeWork" ;
                  rdfs:label "MediaServiceType" .


###  https://schema.bco-dmo.org/v1.0/MetadataFile
:MetadataFile rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :FileDescriptor
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty [ owl:inverseOf :metadataFile
                                                                          ] ;
                                                           owl:someValuesFrom :CreativeWork
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf :FileDescriptor ;
              rdfs:comment "A metadata file (e.g. ISO 19115-2 XML, dataset description PDF) describing a dataset." ;
              rdfs:label "Metadata File" ;
              <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/DataDownload> .


###  https://schema.bco-dmo.org/v1.0/MetadataProfile
:MetadataProfile rdf:type owl:Class ;
                 rdfs:subClassOf :CreativeWork ;
                 rdfs:comment "A formal metadata profile specification to which the datapackage conforms." ;
                 rdfs:label "Metadata Profile" .


###  https://schema.bco-dmo.org/v1.0/MultiLineStringGeometry
:MultiLineStringGeometry rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( :Geometry
                                                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty rdf:rest ;
                                                                                             owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty rdf:first ;
                                                                                                                                         owl:someValuesFrom :LineStringGeometry
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                           ]
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty :coordinates ;
                                                                                             owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty rdf:first ;
                                                                                                                                         owl:someValuesFrom :LineStringGeometry
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ]
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :categorizedBy ;
                                                                      owl:hasValue :GeometryShape_MultiLinestring
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf :Geometry ;
                         rdfs:comment "A geometry whose coordinates member is an array of LineString coordinate arrays" ;
                         rdfs:label "MultiLineStringGeometry" ;
                         <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#MultiLineString> .


###  https://schema.bco-dmo.org/v1.0/MultiPointGeometry
:MultiPointGeometry rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( :Geometry
                                                               [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty rdf:rest ;
                                                                                        owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                                    owl:onProperty rdf:first ;
                                                                                                                                    owl:someValuesFrom :PointGeometry
                                                                                                                                  ]
                                                                                                                                ) ;
                                                                                                             rdf:type owl:Class
                                                                                                           ]
                                                                                      ]
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty :coordinates ;
                                                                                        owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                                    owl:onProperty rdf:first ;
                                                                                                                                    owl:someValuesFrom :PointGeometry
                                                                                                                                  ]
                                                                                                                                ) ;
                                                                                                             rdf:type owl:Class
                                                                                                           ]
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :categorizedBy ;
                                                                 owl:hasValue :GeometryShape_MultiPoint
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf :Geometry ;
                    rdfs:comment "A geometry whose coordinates member is an array of point coordinate arrays" ;
                    rdfs:label "MultiPointGeometry" ;
                    <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#MultiPoint> .


###  https://schema.bco-dmo.org/v1.0/MultiPolygonGeometry
:MultiPolygonGeometry rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( :Geometry
                                                                 [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty rdf:rest ;
                                                                                          owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                                      owl:onProperty rdf:first ;
                                                                                                                                      owl:someValuesFrom :PolygonGeometry
                                                                                                                                    ]
                                                                                                                                  ) ;
                                                                                                               rdf:type owl:Class
                                                                                                             ]
                                                                                        ]
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty :coordinates ;
                                                                                          owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                                      owl:onProperty rdf:first ;
                                                                                                                                      owl:someValuesFrom :PolygonGeometry
                                                                                                                                    ]
                                                                                                                                  ) ;
                                                                                                               rdf:type owl:Class
                                                                                                             ]
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :categorizedBy ;
                                                                   owl:hasValue :GeometryShape_MultiPolygon
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf :Geometry ;
                      rdfs:comment "A geometry whose coordinates member is an array of Polygon coordinate arrays" ;
                      rdfs:label "MultiPolygonGeometry" ;
                      <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#MultiPolygon> .


###  https://schema.bco-dmo.org/v1.0/NODCTopic
:NODCTopic rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :DefinedTerm
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty [ owl:inverseOf :nodcTopicCategory
                                                                       ] ;
                                                        owl:someValuesFrom :Dataset
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ,
                               [ owl:intersectionOf ( :DefinedTerm
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :inControlledVocabulary ;
                                                        owl:hasValue :ControlledVocabulary_NODC_ISO19115-2_MD_TopicCategoryCode
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf :DefinedTerm ;
           rdfs:comment "A NODC topic category for Datases." ;
           rdfs:isDefinedBy :ControlledVocabulary_NODC_ISO19115-2_MD_TopicCategoryCode ;
           rdfs:label "NODCTopic" .


###  https://schema.bco-dmo.org/v1.0/NaturalLanguage
:NaturalLanguage rdf:type owl:Class ;
                 rdfs:subClassOf :Language ;
                 rdfs:comment "Natural languages such as Spanish, Tamil, Hindi, English, etc." ;
                 rdfs:label "NaturalLanguage" ;
                 <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Language> .


###  https://schema.bco-dmo.org/v1.0/ORCIDIdentifier
:ORCIDIdentifier rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :Identifier
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :identifierScheme ;
                                                              owl:hasValue :IdentifierScheme_ORCID
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf :Identifier ;
                 rdfs:comment "An Open Researcher and Contributor ID" ;
                 rdfs:label "ORCID Identifier" .


###  https://schema.bco-dmo.org/v1.0/OfferCatalog
:OfferCatalog rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :Collection
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :hasCollectionItem ;
                                                           owl:someValuesFrom :ServiceOffering
                                                         ]
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty [ owl:inverseOf :offers
                                                                          ] ;
                                                           owl:someValuesFrom [ owl:intersectionOf ( :MediaService
                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                       owl:onProperty :categorizedBy ;
                                                                                                       owl:someValuesFrom :MediaServiceType
                                                                                                     ]
                                                                                                   ) ;
                                                                                rdf:type owl:Class
                                                                              ]
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf :Collection ;
              rdfs:comment "A list of offerings for some MediaService" ;
              rdfs:label "OfferCatalog" ;
              <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/OfferCatalog> .


###  https://schema.bco-dmo.org/v1.0/Organization
:Organization rdf:type owl:Class ;
              rdfs:subClassOf :Agent ;
              owl:disjointWith :Person ,
                               :SoftwareApplication ;
              rdfs:comment "An organisational body such as a publisher, funder, or identifier authority." ;
              rdfs:label "Organization" ;
              <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Organization> ,
                                                               <https://www.w3.org/ns/prov#Organization> .


###  https://schema.bco-dmo.org/v1.0/Parameter
:Parameter rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :DefinedTerm
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty [ owl:inverseOf :isDefinedAs
                                                                       ] ;
                                                        owl:someValuesFrom :DatasetParameter
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ,
                               [ owl:intersectionOf ( :DefinedTerm
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :inControlledVocabulary ;
                                                        owl:hasValue :ControlledVocabulary_BCODMO_Parameters
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf :DefinedTerm ;
           rdfs:comment "A master (community-level) scientific parameter definition." ;
           rdfs:label "Parameter" .


###  https://schema.bco-dmo.org/v1.0/Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf :Agent ;
        owl:disjointWith :SoftwareApplication ;
        rdfs:comment "A human individual associated with some entity." ;
        rdfs:label "Person" ;
        <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Person> ,
                                                         <https://www.w3.org/ns/prov#Person> .


###  https://schema.bco-dmo.org/v1.0/Platform
:Platform rdf:type owl:Class ;
          rdfs:subClassOf :Entity ;
          rdfs:comment "A platform (vessel, buoy, glider, etc.) used for data collection." ;
          rdfs:label "Platform" ;
          <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.w3.org/ns/sosa/Platform> .


###  https://schema.bco-dmo.org/v1.0/PlatformTitle
:PlatformTitle rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Category
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty [ owl:inverseOf :platformTitle
                                                                           ] ;
                                                            owl:someValuesFrom :Platform
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Category ;
               rdfs:comment "A named title/designation for a platform (e.g. the full name of a research vessel)." ;
               rdfs:label "Platform Title" .


###  https://schema.bco-dmo.org/v1.0/PlatformType
:PlatformType rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :Category
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty [ owl:inverseOf :platformType
                                                                          ] ;
                                                           owl:someValuesFrom :Platform
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf :Category ;
              rdfs:comment "A category of platform (e.g. vessel, mooring, glider)." ;
              rdfs:label "Platform Type" .


###  https://schema.bco-dmo.org/v1.0/PointGeometry
:PointGeometry rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Geometry
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :categorizedBy ;
                                                            owl:hasValue :GeometryShape_Point
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :latitude ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onDataRange xsd:float
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :longitude ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onDataRange xsd:float
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Geometry ;
               rdfs:comment "A single coordinate" ;
               rdfs:label "PointGeometry" ;
               rdfs:seeAlso :GeometryShape_Point ;
               <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#Point> .


###  https://schema.bco-dmo.org/v1.0/Policy
:Policy rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Entity
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :modifiesAction ;
                                                     owl:someValuesFrom :ConsumeAction
                                                   ]
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :target ;
                                                     owl:someValuesFrom :Entity
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:subClassOf :Entity ;
        rdfs:comment "An access or governance policy applied to a resource." ;
        rdfs:label "Policy" .


###  https://schema.bco-dmo.org/v1.0/PolygonGeometry
:PolygonGeometry rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :Geometry
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :coordinates ;
                                                              owl:someValuesFrom [ owl:intersectionOf ( rdf:List
                                                                                                        [ rdf:type owl:Class ;
                                                                                                          owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                                          owl:onProperty rdf:rest ;
                                                                                                                          owl:someValuesFrom rdf:List
                                                                                                                        ]
                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                          owl:onProperty rdf:rest ;
                                                                                                                          owl:hasValue rdf:nil
                                                                                                                        ]
                                                                                                                      )
                                                                                                        ]
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty rdf:first ;
                                                                                                          owl:someValuesFrom :PointGeometry
                                                                                                        ]
                                                                                                      ) ;
                                                                                   rdf:type owl:Class
                                                                                 ]
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :categorizedBy ;
                                                              owl:hasValue :GeometryShape_Polygon
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf :Geometry ;
                 rdfs:comment "A collection of points where the first and last are equal in irder to close the shape." ;
                 rdfs:label "PolygonGeometry" ;
                 rdfs:seeAlso :GeometryShape_Polygon ;
                 <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#Polygon> .


###  https://schema.bco-dmo.org/v1.0/PostalAddress
:PostalAddress rdf:type owl:Class ;
               rdfs:subClassOf :GeographicalLocation ;
               rdfs:comment "The mailing address." ;
               rdfs:label "PostalAddress" ;
               <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/PostalAddress> .


###  https://schema.bco-dmo.org/v1.0/Program
:Program rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( :ResearchActivity
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty [ owl:inverseOf :hasParentProgram
                                                                     ] ;
                                                      owl:someValuesFrom :Project
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf :ResearchActivity ;
         owl:disjointWith :Project ;
         rdfs:comment "A scientific program (typically a grouping of related projects) associated with a dataset." ;
         rdfs:label "Program" .


###  https://schema.bco-dmo.org/v1.0/Project
:Project rdf:type owl:Class ;
         rdfs:subClassOf :ResearchActivity ;
         rdfs:comment "A funded scientific project under which data were collected." ;
         rdfs:label "Project" .


###  https://schema.bco-dmo.org/v1.0/Publication
:Publication rdf:type owl:Class ;
             rdfs:subClassOf :CreativeWork ;
             rdfs:comment "A scholarly publication related to a dataset (journal article, report, etc.)." ;
             rdfs:label "Publication" ;
             <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Article> .


###  https://schema.bco-dmo.org/v1.0/RORIdentifier
:RORIdentifier rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Identifier
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :identifierScheme ;
                                                            owl:hasValue :IdentifierScheme_ROR
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Identifier ;
               rdfs:comment "A Research Organization Registry identifier." ;
               rdfs:label "ROR Identifier" .


###  https://schema.bco-dmo.org/v1.0/RelatedDataset
:RelatedDataset rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :RelatedWork
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :relations ;
                                                             owl:someValuesFrom :Dataset
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                rdfs:subClassOf :RelatedWork ;
                rdfs:label "RelatedDataset" .


###  https://schema.bco-dmo.org/v1.0/RelatedPublication
:RelatedPublication rdf:type owl:Class ;
                    owl:equivalentClass [ owl:intersectionOf ( :RelatedWork
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty :relations ;
                                                                 owl:someValuesFrom :Publication
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                    rdfs:subClassOf :RelatedWork .


###  https://schema.bco-dmo.org/v1.0/RelatedWork
:RelatedWork rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Situation
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :forCreativeWork ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass :CreativeWork
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :relations ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass :CreativeWork
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :relationship ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass :ResourceRelation
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf :Situation ;
             rdfs:comment "A related CreativeWork to some other CreativeWork. This describes the situation surrounding this relationship." ;
             rdfs:label "RelatedWork" .


###  https://schema.bco-dmo.org/v1.0/ResearchActivity
:ResearchActivity rdf:type owl:Class ;
                  rdfs:subClassOf :Event ;
                  rdfs:comment "An activity that enables research. The research typically produces datasets." ;
                  rdfs:label "Research Activity" ;
                  <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://schema.org/ResearchProject> .


###  https://schema.bco-dmo.org/v1.0/ResourceRelation
:ResourceRelation rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Category
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty [ owl:inverseOf :relationship
                                                                              ] ;
                                                               owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( :Dataset
                                                                                                  :RelatedWork
                                                                                                )
                                                                                  ]
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :DefinedTerm ;
                  rdfs:comment "A controlled-vocabulary term describing the relationship between two resources (aligned to Crossref and DataCite relation types)." ;
                  rdfs:label "Resource Relation" .


###  https://schema.bco-dmo.org/v1.0/ResourceRelationGroup
:ResourceRelationGroup rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( :Category
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty [ owl:inverseOf :inGroup
                                                                                   ] ;
                                                                    owl:someValuesFrom :ResourceRelation
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf :Category ;
                       rdfs:comment "A grouping category for resource relation types." ;
                       rdfs:label "Resource Relation Group" .


###  https://schema.bco-dmo.org/v1.0/Role
:Role rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Category
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :roleWeight ;
                                                   owl:someValuesFrom xsd:int
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf :Category ;
      rdfs:comment "A functional role performed by an agent (e.g. Principal Investigator, Co-Investigator)." ;
      rdfs:label "Role" .


###  https://schema.bco-dmo.org/v1.0/ServiceOffering
:ServiceOffering rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :CollectionItem
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :actionType ;
                                                              owl:someValuesFrom :ConsumeAction
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf :CollectionItem ;
                 rdfs:comment "An offered entry pointoffered by a MediaService to perform some Action." ;
                 rdfs:label "ServiceOffering" ;
                 <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://schema.org/EntryPoint> .


###  https://schema.bco-dmo.org/v1.0/Situation
:Situation rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :Entity
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :situationInvolves ;
                                                        owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf :Entity ;
           rdfs:comment "A static or dynamic scenario. A state of affairs that describes some configuration of the world. Most often a situation describes the interaction of 2 or more entities. In some cases these interactions are time bounded and can be labeled as significant events." ;
           rdfs:label "Situation" .


###  https://schema.bco-dmo.org/v1.0/SoftwareApplication
:SoftwareApplication rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :Agent
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :provider ;
                                                                  owl:someValuesFrom :Agent
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf :Agent ;
                     rdfs:comment "A piece of software that is deployed and executable." ;
                     rdfs:label "SoftwareApplication" ;
                     <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/SoftwareApplication> ,
                                                                      <https://www.w3.org/ns/prov#SoftwareAgent> .


###  https://schema.bco-dmo.org/v1.0/SoftwareService
:SoftwareService rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :CreativeWork
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :provider ;
                                                              owl:someValuesFrom :SoftwareApplication
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                 rdfs:subClassOf :CreativeWork ;
                 rdfs:comment "A service offered by some SoftwareApplication" ;
                 rdfs:label "SoftwareService" ;
                 <http://www.w3.org/2004/02/skos/core#relatedMatch> <http://www.w3.org/ns/dcat#DataService> ,
                                                                    <https://schema.org/EntryPoint> .


###  https://schema.bco-dmo.org/v1.0/String
:String rdf:type owl:Class ;
        rdfs:subClassOf :Datatype ;
        rdfs:comment "A string value" ;
        rdfs:isDefinedBy :Datatype_String ;
        rdfs:label "String"@en ;
        <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Text> .


###  https://schema.bco-dmo.org/v1.0/SupplementalDocument
:SupplementalDocument rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( :FileDescriptor
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty [ owl:inverseOf :supplementalDocument
                                                                                  ] ;
                                                                   owl:someValuesFrom :CreativeWork
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf :FileDescriptor ;
                      rdfs:comment "A supplemental (non-primary) document file associated with a dataset." ;
                      rdfs:label "Supplemental Document" .


###  https://schema.bco-dmo.org/v1.0/Synonym
:Synonym rdf:type owl:Class ;
         rdfs:subClassOf :Situation ;
         rdfs:comment "An alternative name or synonym, e.g. for a deployment." ;
         rdfs:label "Synonym" .


###  https://schema.bco-dmo.org/v1.0/TabularFile
:TabularFile rdf:type owl:Class ;
             rdfs:subClassOf :FileType .


###  https://schema.bco-dmo.org/v1.0/TemporalEntity
:TemporalEntity rdf:type owl:Class ;
                rdfs:subClassOf :Entity ;
                rdfs:comment "A frame of reference for when something existed or occupied time — it is either a durationless point (an instant) or a thing with some extent in time (an interval)." ;
                rdfs:label "TemporalEntity" ;
                <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.w3.org/2006/time#TemporalEntity> .


###  https://schema.bco-dmo.org/v1.0/TemporalInstant
:TemporalInstant rdf:type owl:Class ;
                 rdfs:subClassOf :TemporalEntity ;
                 rdfs:comment "A single point in time associated with a dataset extent or event date." ;
                 rdfs:label "Temporal Instant" ;
                 <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.w3.org/2006/time#Instant> .


###  https://schema.bco-dmo.org/v1.0/TemporalInterval
:TemporalInterval rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :TemporalEntity
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :hasBeginning ;
                                                               owl:someValuesFrom :TemporalInstant
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :hasEnd ;
                                                               owl:someValuesFrom :TemporalInstant
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :TemporalEntity ;
                  rdfs:comment "A time period with a beginning and an end, used to describe dataset temporal coverage." ;
                  rdfs:label "Temporal Interval" ;
                  <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.w3.org/2006/time#Interval> .


###  https://schema.bco-dmo.org/v1.0/TimeSeries
:TimeSeries rdf:type owl:Class ;
            rdfs:subClassOf :Event ;
            rdfs:comment "an ordered collection of observations indexed by time, representing the temporal evolution of one or more properties of a feature, system, or phenomenon." ;
            rdfs:label "Time Series" ;
            <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/EventSeries> .


###  https://schema.bco-dmo.org/v1.0/URL
:URL rdf:type owl:Class ;
     rdfs:subClassOf :IdentifierString ;
     rdfs:comment "A URL" ;
     rdfs:isDefinedBy :Datatype_URL ;
     rdfs:label "URL"@en ;
     <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/URL> .


###  https://schema.bco-dmo.org/v1.0/UnitOfMeasure
:UnitOfMeasure rdf:type owl:Class ;
               rdfs:subClassOf :Entity ;
               rdfs:comment "A unit of measure associated with a dataset parameter." ;
               rdfs:label "Unit of Measure" ;
               <http://www.w3.org/2004/02/skos/core#closeMatch> <http://purl.obolibrary.org/obo/UO_0000000> ,
                                                                <http://www.ontology-of-units-of-measure.org/resource/om-2/Unit> .


###  https://schema.bco-dmo.org/v1.0/Vessel
:Vessel rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Platform
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :platformType ;
                                                     owl:hasValue :PlatformType_Vessel
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:subClassOf :Platform ;
        rdfs:comment "A ship or boat." ;
        rdfs:label "Vessel" .


###  https://schema.bco-dmo.org/v1.0/WebPage
:WebPage rdf:type owl:Class ;
         rdfs:subClassOf :CreativeWork ;
         rdfs:comment "A web page" ;
         rdfs:label "WebPage" ;
         <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/WebPage> .


