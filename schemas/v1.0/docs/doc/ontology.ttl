:DatasetParameterAttribute_PrimaryISODateTimeVariable rdf:type owl:NamedIndividual ,
                                                               :DatasetParameterAttribute ;
                                                      :label "Primary ISODateTime Variable" ;
                                                      rdfs:label "Dataset Parameter Attribute: Primary ISODateTime Variable" .


