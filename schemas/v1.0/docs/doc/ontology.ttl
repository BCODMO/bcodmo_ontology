@prefix : <https://schema.bco-dmo.org/v1.0/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://schema.bco-dmo.org/v1.0/> .

<https://schema.bco-dmo.org/v1.0/> rdf:type owl:Ontology ;
                                    owl:versionIRI <https://schema.bco-dmo.org/v1.0/> ;
                                    rdfs:comment "Ontology for the Biological and Chemical Oceanography Data Management Office (BCO-DMO)." ;
                                    rdfs:label "BCO-DMO Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#exactMatch
<http://www.w3.org/2004/02/skos/core#exactMatch> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML
rdf:HTML rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#object
rdf:object rdf:type owl:ObjectProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate
rdf:predicate rdf:type owl:ObjectProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#subject
rdf:subject rdf:type owl:ObjectProperty .


###  http://www.w3.org/2006/time#hasBeginning
<http://www.w3.org/2006/time#hasBeginning> rdf:type owl:ObjectProperty ;
                                           owl:equivalentProperty :hasBeginning .


###  http://www.w3.org/2006/time#hasEnd
<http://www.w3.org/2006/time#hasEnd> rdf:type owl:ObjectProperty ;
                                     owl:equivalentProperty :hasEnd .


###  https://schema.bco-dmo.org/v1.0/affiliation
:affiliation rdf:type owl:ObjectProperty ;
             rdfs:domain :Person ;
             rdfs:range :Affiliation ;
             rdfs:comment "The institutional affiliation of a person." ;
             rdfs:label "affiliation" .


###  https://schema.bco-dmo.org/v1.0/author
:author rdf:type owl:ObjectProperty ;
        rdfs:domain :CreativeWork ;
        rdfs:range :AgentRole ;
        rdfs:comment "An author associated witha creative work. The Agent Role provides context as to how the agent contirbuted as an author to the work." ;
        rdfs:label "author" .


###  https://schema.bco-dmo.org/v1.0/browseGraphic
:browseGraphic rdf:type owl:ObjectProperty ;
               rdfs:range :Image ;
               rdfs:comment "An image that is representative of some thing. This could be a logo for a project or organization. It could also be an image that represents a creative work." ;
               rdfs:label "browseGraphic" .


###  https://schema.bco-dmo.org/v1.0/checksum
:checksum rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :identifier ;
          rdfs:domain :File ;
          rdfs:range :CryptographicHash ;
          rdfs:comment "A cryptographic hash for verifying file integrity." ;
          rdfs:label "checksum" .


###  https://schema.bco-dmo.org/v1.0/conformsTo
:conformsTo rdf:type owl:ObjectProperty ;
            rdfs:domain :Dataset ;
            rdfs:range :MetadataProfile ;
            rdfs:comment "The metadata profile specification to which this dataset conforms." ;
            rdfs:label "conformsTo" .


###  https://schema.bco-dmo.org/v1.0/contributor
:contributor rdf:type owl:ObjectProperty ;
             rdfs:domain :CreativeWork ;
             rdfs:range :AgentRole ;
             rdfs:comment "A contributor, not an author, associated with a creative work. The Agent Role provides context as to how the agent contributed to the work." ;
             rdfs:label "contributor" .


###  https://schema.bco-dmo.org/v1.0/createdDate
:createdDate rdf:type owl:ObjectProperty ;
             rdfs:domain :CreativeWork ;
             rdfs:range :TemporalInstant ;
             rdfs:comment "The date on which a creative work was created." ;
             rdfs:label "createdDate" .


###  https://schema.bco-dmo.org/v1.0/currentState
:currentState rdf:type owl:ObjectProperty ;
              rdfs:domain :CreativeWork ;
              rdfs:range :CurrentState ;
              rdfs:comment "The editorial/curation state of the dataset." ;
              rdfs:label "currentState" .


###  https://schema.bco-dmo.org/v1.0/dataFile
:dataFile rdf:type owl:ObjectProperty ;
          rdfs:domain :Dataset ;
          rdfs:range :DataFile ;
          rdfs:comment "A primary or supplemental data file distributed with this dataset package." ;
          rdfs:label "dataFile" .


###  https://schema.bco-dmo.org/v1.0/dataManagementPlan
:dataManagementPlan rdf:type owl:ObjectProperty ;
                    rdfs:domain :ResearchActivity ;
                    rdfs:range :DataManagementPlan ;
                    rdfs:comment "A file describing a research activities plan for managing their data." ;
                    rdfs:label "dataManagementPlan" .


###  https://schema.bco-dmo.org/v1.0/dataType
:dataType rdf:type owl:ObjectProperty ;
          rdfs:domain :DatasetParameter ;
          rdfs:range :Datatype ;
          rdfs:comment "The data type of a dataset parameter." ;
          rdfs:label "dataType" .


###  https://schema.bco-dmo.org/v1.0/datasetType
:datasetType rdf:type owl:ObjectProperty ;
             rdfs:domain :Dataset ;
             rdfs:range :DatasetType ;
             rdfs:comment "A category or type classification for this dataset." ;
             rdfs:label "datasetType" .


###  https://schema.bco-dmo.org/v1.0/describesFile
:describesFile rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :situationInvolves ;
               rdfs:domain :FileDescriptor ;
               rdfs:range :File ;
               rdfs:comment "Links a file record to the File object describing its physical properties." ;
               rdfs:label "describesFile" .


###  https://schema.bco-dmo.org/v1.0/fileType
:fileType rdf:type owl:ObjectProperty ;
          rdfs:domain :File ;
          rdfs:range :FileType ;
          rdfs:comment "The format type of this file." ;
          rdfs:label "fileType" .


###  https://schema.bco-dmo.org/v1.0/forDataset
:forDataset rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :situationInvolves ;
            rdfs:domain :Situation ;
            rdfs:range :Dataset ;
            rdfs:comment "Links to a dataset." ;
            rdfs:label "forDataset" .


###  https://schema.bco-dmo.org/v1.0/fromDeployment
:fromDeployment rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :situationInvolves ;
                rdfs:domain :DatasetDeployment ;
                rdfs:range :Deployment ;
                rdfs:comment "Links a deployment and a dataset." ;
                rdfs:label "fromDeployment" .


###  https://schema.bco-dmo.org/v1.0/fromInstrument
:fromInstrument rdf:type owl:ObjectProperty ;
                rdfs:domain :Dataset ;
                rdfs:range :DatasetInstrument ;
                rdfs:comment "Links a dataset to the instruments used to collect the data." ;
                rdfs:label "fromInstrument" .


###  https://schema.bco-dmo.org/v1.0/fundedBy
:fundedBy rdf:type owl:ObjectProperty ;
          rdfs:domain :Dataset ;
          rdfs:range :FundingAgency ;
          owl:propertyChainAxiom ( :fundedByAward
                                   :provider
                                 ) ;
          rdfs:comment "A funding organisation that supported the work resulting in this dataset." ;
          rdfs:label "fundedBy" .


###  https://schema.bco-dmo.org/v1.0/fundedByAward
:fundedByAward rdf:type owl:ObjectProperty ;
               rdfs:domain :CreativeWork ;
               rdfs:range :Award ;
               rdfs:comment "the award that funded the creation, generation, etc of some creative work." ;
               rdfs:label "fundedByAward" .


###  https://schema.bco-dmo.org/v1.0/geometry
:geometry rdf:type owl:ObjectProperty ;
          rdfs:range :Geometry ;
          rdfs:comment "One or more geometries (centroid, bounding box) describing a geographical location." ;
          rdfs:label "geometry" .


###  https://schema.bco-dmo.org/v1.0/governedBy
:governedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :CreativeWork ;
            rdfs:range :Policy ;
            rdfs:comment "A policy (e.g. embargo) that governs access to this dataset." ;
            rdfs:label "governedBy" .


###  https://schema.bco-dmo.org/v1.0/grantedAward
:grantedAward rdf:type owl:ObjectProperty ;
              rdfs:domain :FundingAgency ;
              rdfs:range :Award ;
              rdfs:comment "An award (grant) issued by this funding organisation." ;
              rdfs:label "grantedAward" .


###  https://schema.bco-dmo.org/v1.0/hasAgentWithRole
:hasAgentWithRole rdf:type owl:ObjectProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :CreativeWork
                                              :Deployment
                                              :ResearchActivity
                                            )
                              ] ;
                  rdfs:range :AgentRole ;
                  rdfs:comment "Associates an agent with a qualified role on a dataset or deployment." ;
                  rdfs:label "hasAgentWithRole" .


###  https://schema.bco-dmo.org/v1.0/hasBeginning
:hasBeginning rdf:type owl:ObjectProperty ;
              rdfs:domain :TemporalInterval ;
              rdfs:range :TemporalInstant ;
              rdfs:comment "The start of a temporal interval." ;
              rdfs:label "hasBeginning" .


###  https://schema.bco-dmo.org/v1.0/hasCoordinatedDeployment
:hasCoordinatedDeployment rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf :situationInvolves ;
                          rdfs:domain :Deployment ;
                          rdfs:range :Deployment ;
                          rdfs:comment "A disparate deployment that coordinated in conjuction with this subject for data collection" ;
                          rdfs:label "hasCoordinatedDeployment" .


###  https://schema.bco-dmo.org/v1.0/hasCruiseTrajectory
:hasCruiseTrajectory rdf:type owl:ObjectProperty ;
                     rdfs:domain :Cruise ;
                     rdfs:range :Geometry ;
                     rdfs:comment "The set of ordered coordinates forming a geometry (usually MultiPoint) representing the path taken by a Cruise." ;
                     rdfs:label "hasCruiseTrajectory" .


###  https://schema.bco-dmo.org/v1.0/hasEnd
:hasEnd rdf:type owl:ObjectProperty ;
        rdfs:domain :TemporalInterval ;
        rdfs:range :TemporalInstant ;
        rdfs:comment "The end of a temporal interval." ;
        rdfs:label "hasEnd" .


###  https://schema.bco-dmo.org/v1.0/hasParameter
:hasParameter rdf:type owl:ObjectProperty ;
              owl:equivalentProperty :storesValuesFor ;
              rdfs:domain :Dataset ;
              rdfs:range :DatasetParameter ;
              rdfs:comment "A dataset collected this dataset-parameter"@en ;
              rdfs:label "hasParameter"@en .


###  https://schema.bco-dmo.org/v1.0/hasParameterAttribute
:hasParameterAttribute rdf:type owl:ObjectProperty ;
                       rdfs:domain :DatasetParameter ;
                       rdfs:range :DatasetParameterAttribute ;
                       rdfs:comment "An attribute of a particular DatasetParameter" ;
                       rdfs:label "hasParameterAttribute" .


###  https://schema.bco-dmo.org/v1.0/hasParentProgram
:hasParentProgram rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :situationInvolves ;
                  rdfs:domain :Project ;
                  rdfs:range :Program ;
                  rdfs:comment "The Program that enabled a Project's existence" ;
                  rdfs:label "hasParentProgram" .


###  https://schema.bco-dmo.org/v1.0/hasProgram
:hasProgram rdf:type owl:ObjectProperty ;
            rdfs:domain :Dataset ;
            rdfs:range :Program ;
            owl:propertyChainAxiom ( :hasProject
                                     :hasParentProgram
                                   ) ;
            rdfs:comment "Associates a dataset with a scientific program." ;
            rdfs:label "hasProgram" .


###  https://schema.bco-dmo.org/v1.0/hasProject
:hasProject rdf:type owl:ObjectProperty ;
            rdfs:domain :Dataset ;
            rdfs:range :Project ;
            rdfs:comment "Associates a dataset with a scientific project." ;
            rdfs:label "hasProject" .


###  https://schema.bco-dmo.org/v1.0/hasSynonym
:hasSynonym rdf:type owl:ObjectProperty ;
            rdfs:domain :Deployment ;
            rdfs:range :Synonym ;
            rdfs:comment "An alternative name used for a deployment." ;
            rdfs:label "hasSynonym" .


###  https://schema.bco-dmo.org/v1.0/hasTime
:hasTime rdf:type owl:ObjectProperty ;
         rdfs:range :TemporalEntity ;
         rdfs:comment "Connects a temporal entity to some thing" ;
         rdfs:label "hasTime" .


###  https://schema.bco-dmo.org/v1.0/identifier
:identifier rdf:type owl:ObjectProperty ;
            rdfs:range :Identifier ;
            rdfs:comment "An identifier assigned to a resource." ;
            rdfs:label "identifier" .


###  https://schema.bco-dmo.org/v1.0/identifierScheme
:identifierScheme rdf:type owl:ObjectProperty ;
                  rdfs:domain :Identifier ;
                  rdfs:range :IdentifierScheme ;
                  rdfs:comment "The scheme (authority) that defines the identifier." ;
                  rdfs:label "identifierScheme" .


###  https://schema.bco-dmo.org/v1.0/inGroup
:inGroup rdf:type owl:ObjectProperty ;
         rdfs:domain :ResourceRelation ;
         rdfs:range :ResourceRelationGroup ;
         rdfs:comment "The group/category to which a resource relation type belongs." ;
         rdfs:label "inGroup" .


###  https://schema.bco-dmo.org/v1.0/isDefinedAs
:isDefinedAs rdf:type owl:ObjectProperty ;
             owl:equivalentProperty :isTypeOf ;
             rdfs:domain :Entity ;
             rdfs:range :DefinedType ;
             rdfs:comment "A thing is defined to be something more specific or colloquial than this more standardized cateogrization or community term." ;
             rdfs:label "isDefinedAs" .


###  https://schema.bco-dmo.org/v1.0/isTypeOf
:isTypeOf rdf:type owl:ObjectProperty ;
          rdfs:domain :Entity ;
          rdfs:range :Category ;
          rdfs:comment "Categorizes some thing." ;
          rdfs:label "isTypeOf" ;
          owl:deprecated "true"^^xsd:boolean .


###  https://schema.bco-dmo.org/v1.0/issuedDate
:issuedDate rdf:type owl:ObjectProperty ;
            rdfs:domain :DOIDataset ;
            rdfs:range :TemporalInstant ;
            rdfs:comment "The date on which the DOI was issued for this dataset." ;
            rdfs:label "issuedDate" .


###  https://schema.bco-dmo.org/v1.0/keywords
:keywords rdf:type owl:ObjectProperty ;
          rdfs:domain :CreativeWork ;
          rdfs:range :Keyword ;
          rdfs:comment "Subject keywords associated with this dataset." ;
          rdfs:label "keywords" .


###  https://schema.bco-dmo.org/v1.0/language
:language rdf:type owl:ObjectProperty ;
          rdfs:domain :CreativeWork ;
          rdfs:range :Language ;
          rdfs:comment "The natural language used in the dataset metadata." ;
          rdfs:label "language" .


###  https://schema.bco-dmo.org/v1.0/license
:license rdf:type owl:ObjectProperty ;
         rdfs:domain :CreativeWork ;
         rdfs:range :License ;
         rdfs:comment "The data license applied to this dataset." ;
         rdfs:label "license" .


###  https://schema.bco-dmo.org/v1.0/logo
:logo rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :browseGraphic ;
      rdfs:range :Logo ;
      rdfs:comment "A logo for some thing" ;
      rdfs:label "logo" .


###  https://schema.bco-dmo.org/v1.0/matches
:matches rdf:type owl:ObjectProperty ;
         rdfs:domain :Entity ;
         rdfs:comment "Aligns a BCO-DMO vocabulary term with an equivalent term from an external community vocabulary (e.g. SeaDataNet, NERC, Crossref, DataCite)." ;
         rdfs:label "matches" ;
         rdfs:seeAlso <http://www.w3.org/2004/02/skos/core#exactMatch> .


###  https://schema.bco-dmo.org/v1.0/metadataFile
:metadataFile rdf:type owl:ObjectProperty ;
              rdfs:domain :Dataset ;
              rdfs:range :MetadataFile ;
              rdfs:comment "A metadata file (ISO XML, description PDF) bundled in the dataset package." ;
              rdfs:label "metadataFile" .


###  https://schema.bco-dmo.org/v1.0/modifiesAction
:modifiesAction rdf:type owl:ObjectProperty ;
                rdfs:domain :Policy ;
                rdfs:range :Action ;
                rdfs:comment "The action being modified by some Policy" ;
                rdfs:label "modifiesAction" .


###  https://schema.bco-dmo.org/v1.0/obsoletes
:obsoletes rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :DOIDataset ;
           rdfs:range :DOIDataset ;
           rdfs:comment "A previous version of this dataset that is superseded by the current one." ;
           rdfs:label "obsoletes" .


###  https://schema.bco-dmo.org/v1.0/onPlatform
:onPlatform rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :situationInvolves ;
            rdfs:domain :Deployment ;
            rdfs:range :Platform ;
            rdfs:comment "The platform (vessel, buoy, etc.) on which a deployment took place." ;
            rdfs:label "onPlatform" .


###  https://schema.bco-dmo.org/v1.0/performedAt
:performedAt rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :situationInvolves ;
             rdfs:domain :AgentRole ;
             rdfs:range :Organization ;
             rdfs:comment "The institutional affiliation at which the role was performed." ;
             rdfs:label "performedAt" .


###  https://schema.bco-dmo.org/v1.0/performedBy
:performedBy rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :situationInvolves ;
             rdfs:domain :AgentRole ;
             rdfs:range :Agent ;
             rdfs:comment "The person who performed or holds this role." ;
             rdfs:label "performedBy" .


###  https://schema.bco-dmo.org/v1.0/platformTitle
:platformTitle rdf:type owl:ObjectProperty ;
               rdfs:domain :Platform ;
               rdfs:range :PlatformTitle ;
               rdfs:comment "The official or common title of the platform." ;
               rdfs:label "platformTitle" .


###  https://schema.bco-dmo.org/v1.0/platformType
:platformType rdf:type owl:ObjectProperty ;
              rdfs:domain :Platform ;
              rdfs:range :PlatformType ;
              rdfs:comment "The type/category of the platform." ;
              rdfs:label "platformType" .


###  https://schema.bco-dmo.org/v1.0/producedWork
:producedWork rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :situationInvolves ;
              rdfs:domain :ResearchActivity ;
              rdfs:range :CreativeWork ;
              rdfs:comment "The research activity produced the research product." ;
              rdfs:label "producedWork" .


###  https://schema.bco-dmo.org/v1.0/programManager
:programManager rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain :Award ;
                rdfs:range :Person ;
                rdfs:comment "The program manager at the funding agency responsible for this award." ;
                rdfs:label "programManager" .


###  https://schema.bco-dmo.org/v1.0/provider
:provider rdf:type owl:ObjectProperty ;
          rdfs:range :Agent ;
          rdfs:comment "The service provider that hosts/distributes the resource." ;
          rdfs:label "provider" .


###  https://schema.bco-dmo.org/v1.0/publishedDate
:publishedDate rdf:type owl:ObjectProperty ;
               rdfs:domain :DOIDataset ;
               rdfs:range :TemporalInstant ;
               rdfs:comment "The date on which this dataset version was published." ;
               rdfs:label "publishedDate" .


###  https://schema.bco-dmo.org/v1.0/publisher
:publisher rdf:type owl:ObjectProperty ;
           rdfs:range :Organization ;
           rdfs:comment "The organisation responsible for publishing a resource." ;
           rdfs:label "publisher" .


###  https://schema.bco-dmo.org/v1.0/relations
:relations rdf:type owl:ObjectProperty ;
           rdfs:domain :CreativeWork ;
           rdfs:range :CreativeWork ;
           rdfs:comment "Related creative work associated with this creative work." ;
           rdfs:label "relations" .


###  https://schema.bco-dmo.org/v1.0/relationship
:relationship rdf:type owl:ObjectProperty ;
              rdfs:domain :CreativeWork ;
              rdfs:range :ResourceRelation ;
              rdfs:comment "A controlled-vocabulary relation type between two resources." ;
              rdfs:label "relationship" .


###  https://schema.bco-dmo.org/v1.0/resolution
:resolution rdf:type owl:ObjectProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( :TemporalInstant
                                        :TemporalInterval
                                      )
                        ] ;
            rdfs:comment "The temporal resolution of a temporal extent (e.g. time:unitDay)." ;
            rdfs:label "resolution" .


###  https://schema.bco-dmo.org/v1.0/role
:role rdf:type owl:ObjectProperty ;
      rdfs:domain :AgentRole ;
      rdfs:range :Role ;
      rdfs:comment "The role type performed by the agent." ;
      rdfs:label "role" .


###  https://schema.bco-dmo.org/v1.0/situationInvolves
:situationInvolves rdf:type owl:ObjectProperty ;
                   rdfs:domain :Event ;
                   rdfs:comment "Some thing involved in a situation or event. A super property for more specific relationships in some Event." ;
                   rdfs:label "situationInvolves" .


###  https://schema.bco-dmo.org/v1.0/smallLogo
:smallLogo rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :logo ;
           rdfs:range :Logo ;
           rdfs:comment "A smaller logo of some thing" ;
           rdfs:label "smallLogo" .


###  https://schema.bco-dmo.org/v1.0/spatialExtent
:spatialExtent rdf:type owl:ObjectProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :Dataset
                                           :Deployment
                                           :ResearchActivity
                                         )
                           ] ;
               rdfs:range :GeographicalLocation ;
               rdfs:comment "The spatial coverage of the dataset, deployment, project, or program." ;
               rdfs:label "spatialExtent" .


###  https://schema.bco-dmo.org/v1.0/status
:status rdf:type owl:ObjectProperty ;
        rdfs:domain :CreativeWork ;
        rdfs:range :CreativeWorkStatus ;
        rdfs:comment "The current DOI lifecycle status of the dataset package." ;
        rdfs:label "status" .


###  https://schema.bco-dmo.org/v1.0/storesValuesFor
:storesValuesFor rdf:type owl:ObjectProperty ;
                 rdfs:domain :Dataset ;
                 rdfs:range :DatasetParameter ;
                 rdfs:comment "Links a dataset to the parameters whose values it records." ;
                 rdfs:label "storesValuesFor" .


###  https://schema.bco-dmo.org/v1.0/supplementalDocument
:supplementalDocument rdf:type owl:ObjectProperty ;
                      rdfs:domain :Dataset ;
                      rdfs:range :SupplementalDocument ;
                      rdfs:comment "A supplemental document distributed with this dataset package." ;
                      rdfs:label "supplementalDocument" .


###  https://schema.bco-dmo.org/v1.0/target
:target rdf:type owl:ObjectProperty ;
        rdfs:domain :Policy ;
        rdfs:range :CreativeWork ;
        rdfs:comment "The resource to which this policy applies." ;
        rdfs:label "target" .


###  https://schema.bco-dmo.org/v1.0/temporalExtent
:temporalExtent rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasTime ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :AgentRole
                                            :Dataset
                                            :Deployment
                                            :ResearchActivity
                                          )
                            ] ;
                rdfs:range :TemporalEntity ;
                rdfs:comment "The temporal coverage of an agent role, dataset, deployment or research activity." ;
                rdfs:label "temporalExtent" .


###  https://schema.bco-dmo.org/v1.0/units
:units rdf:type owl:ObjectProperty ;
       rdfs:domain [ rdf:type owl:Class ;
                     owl:unionOf ( :DatasetParameter
                                   :Parameter
                                 )
                   ] ;
       rdfs:range :UnitOfMeasure ;
       rdfs:comment "The unit of measure for a dataset parameter." ;
       rdfs:label "units" .


#################################################################
#    Data properties
#################################################################

###  https://schema.bco-dmo.org/v1.0/abbreviation
:abbreviation rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string ;
              rdfs:comment "A short abbreviation for a scheme, language, or licence." ;
              rdfs:label "abbreviation" .


###  https://schema.bco-dmo.org/v1.0/abstract
:abstract rdf:type owl:DatatypeProperty ;
          rdfs:domain :CreativeWork ;
          rdfs:range xsd:string ;
          rdfs:comment "A plain-text abstract describing the dataset." ;
          rdfs:label "abstract" .


###  https://schema.bco-dmo.org/v1.0/acquisitionDescription
:acquisitionDescription rdf:type owl:DatatypeProperty ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( :Dataset
                                                    :DatasetDeployment
                                                    :Deployment
                                                  )
                                    ] ;
                        rdfs:range rdf:HTML ;
                        rdfs:comment "An HTML description of data acquisition methods." ;
                        rdfs:label "acquisitionDescription" .


###  https://schema.bco-dmo.org/v1.0/acronym
:acronym rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:token ;
         rdfs:comment "An acronym or abbreviation for an organisation, affiliation, project, or program." ;
         rdfs:label "acronym" .


###  https://schema.bco-dmo.org/v1.0/affiliationName
:affiliationName rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Affiliation ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The primary name of the affiliated institution." ;
                 rdfs:label "affiliationName" .


###  https://schema.bco-dmo.org/v1.0/affiliationSubName
:affiliationSubName rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Affiliation ;
                    rdfs:range xsd:string ;
                    rdfs:comment "A sub-unit or department name within an affiliated institution." ;
                    rdfs:label "affiliationSubName" .


###  https://schema.bco-dmo.org/v1.0/bibliographicCitation
:bibliographicCitation rdf:type owl:DatatypeProperty ;
                       rdfs:domain :CreativeWork ;
                       rdfs:range rdf:HTML ;
                       rdfs:comment "The full bibliographic citation for a related publication or dataset." ;
                       rdfs:label "bibliographicCitation" .


###  https://schema.bco-dmo.org/v1.0/bytesize
:bytesize rdf:type owl:DatatypeProperty ;
          rdfs:domain :File ;
          rdfs:range xsd:long ;
          rdfs:comment "The size of the file in bytes." ;
          rdfs:label "bytesize" .


###  https://schema.bco-dmo.org/v1.0/commonFileExtension
:commonFileExtension rdf:type owl:DatatypeProperty ;
                     rdfs:domain :FileType ;
                     rdfs:range xsd:token ;
                     rdfs:comment "A commonly used file extension for a particular FileType" ;
                     rdfs:label "commonFileExtension" .


###  https://schema.bco-dmo.org/v1.0/conversionDescription
:conversionDescription rdf:type owl:DatatypeProperty ;
                       rdfs:domain :DatasetParameter ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Describes how the values can be converted." ;
                       rdfs:label "conversionDescription" .


###  https://schema.bco-dmo.org/v1.0/dataManagementProcessingDescription
:dataManagementProcessingDescription rdf:type owl:DatatypeProperty ;
                                     rdfs:domain :Dataset ;
                                     rdfs:range xsd:string ;
                                     rdfs:comment "A description of data management and processing applied by BCO-DMO." ;
                                     rdfs:label "dataManagementProcessingDescription" .


###  https://schema.bco-dmo.org/v1.0/description
:description rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "A description of a resource." ;
             rdfs:label "description" .


###  https://schema.bco-dmo.org/v1.0/eastBoundary
:eastBoundary rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :BoundingBoxGeometry ;
              rdfs:range xsd:float ;
              rdfs:comment "The eastern longitude boundary of a bounding box (decimal degrees)." ;
              rdfs:label "eastBoundary" .


###  https://schema.bco-dmo.org/v1.0/encoding
:encoding rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:string ;
          rdfs:comment "The character encoding of a file (e.g. utf-8)." ;
          rdfs:label "encoding" .


###  https://schema.bco-dmo.org/v1.0/expirationDate
:expirationDate rdf:type owl:DatatypeProperty ;
                rdfs:domain :EmbargoPolicy ;
                rdfs:range xsd:date ;
                rdfs:comment "The date on which an embargo expires and the dataset becomes publicly accessible." ;
                rdfs:label "expirationDate" .


###  https://schema.bco-dmo.org/v1.0/externalWebsite
:externalWebsite rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:anyURI ;
                 rdfs:comment "The external project or program website URL." ;
                 rdfs:label "externalWebsite" .


###  https://schema.bco-dmo.org/v1.0/familyName
:familyName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Person ;
            rdfs:range xsd:string ;
            rdfs:comment "The family (last) name of a person." ;
            rdfs:label "familyName" .


###  https://schema.bco-dmo.org/v1.0/filename
:filename rdf:type owl:DatatypeProperty ;
          rdfs:domain :File ;
          rdfs:range xsd:token ;
          rdfs:comment "The file name including extension." ;
          rdfs:label "filename" .


###  https://schema.bco-dmo.org/v1.0/givenName
:givenName rdf:type owl:DatatypeProperty ;
           rdfs:domain :Person ;
           rdfs:range xsd:string ;
           rdfs:comment "The given (first) name of a person." ;
           rdfs:label "givenName" .


###  https://schema.bco-dmo.org/v1.0/hasReportURL
:hasReportURL rdf:type owl:DatatypeProperty ;
              rdfs:domain :Deployment ;
              rdfs:range xsd:anyURI ;
              rdfs:comment "A URL linking to the cruise/deployment report." ;
              rdfs:label "hasReportURL" .


###  https://schema.bco-dmo.org/v1.0/honorific
:honorific rdf:type owl:DatatypeProperty ;
           rdfs:domain :Person ;
           rdfs:range xsd:string ;
           rdfs:comment "Honorific for a Person." ;
           rdfs:label "honorific" .


###  https://schema.bco-dmo.org/v1.0/identifierValue
:identifierValue rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Identifier ;
                 rdfs:range xsd:token ;
                 rdfs:comment "The raw identifier string value (e.g. the DOI suffix, the ROR ID)." ;
                 rdfs:label "identifierValue" .


###  https://schema.bco-dmo.org/v1.0/isPrimaryDataFile
:isPrimaryDataFile rdf:type owl:DatatypeProperty ;
                   rdfs:domain :DataFile ;
                   rdfs:range xsd:boolean ;
                   rdfs:comment "Indicates whether this is the primary data file of a dataset (true/false)." ;
                   rdfs:label "isPrimaryDataFile" .


###  https://schema.bco-dmo.org/v1.0/label
:label rdf:type owl:DatatypeProperty ;
       owl:equivalentProperty :name ;
       rdfs:range xsd:string ;
       rdfs:comment "A human-readable label for any BCO-DMO resource." ;
       rdfs:label "label" .


###  https://schema.bco-dmo.org/v1.0/middleName
:middleName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Person ;
            rdfs:range xsd:string ;
            rdfs:comment "The middle name or initial of a person." ;
            rdfs:label "middleName" .


###  https://schema.bco-dmo.org/v1.0/mimeType
:mimeType rdf:type owl:DatatypeProperty ;
          rdfs:domain :FileType ;
          rdfs:range xsd:token ;
          rdfs:comment "The MIME type associated with a file type." ;
          rdfs:label "mimeType" .


###  https://schema.bco-dmo.org/v1.0/name
:name rdf:type owl:DatatypeProperty ;
      rdfs:range xsd:string ;
      rdfs:comment "The name of the item. Synonymous with the label property." ;
      rdfs:label "name" .


###  https://schema.bco-dmo.org/v1.0/nickname
:nickname rdf:type owl:DatatypeProperty ;
          rdfs:domain :Person ;
          rdfs:range xsd:string ;
          rdfs:comment "Nickname, or preferred name, of a Person" ;
          rdfs:label "nickname" .


###  https://schema.bco-dmo.org/v1.0/noDataValue
:noDataValue rdf:type owl:DatatypeProperty ;
             rdfs:domain :DatasetParameter ;
             rdfs:range xsd:token ;
             rdfs:comment "The value to expect in a DatasetParameter when there was no data for the given record." ;
             rdfs:label "noDataValue" .


###  https://schema.bco-dmo.org/v1.0/northBoundary
:northBoundary rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :BoundingBoxGeometry ;
               rdfs:range xsd:float ;
               rdfs:comment "The northern latitude boundary of a bounding box (decimal degrees)." ;
               rdfs:label "northBoundary" .


###  https://schema.bco-dmo.org/v1.0/officialName
:officialName rdf:type owl:DatatypeProperty ;
              rdfs:domain :Parameter ;
              rdfs:range xsd:string ;
              rdfs:comment "The official name for a master parameter." ;
              rdfs:label "officialName" .


###  https://schema.bco-dmo.org/v1.0/problemDescription
:problemDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Dataset ;
                    rdfs:range xsd:string ;
                    rdfs:comment "A description of known problems or caveats with the dataset." ;
                    rdfs:label "problemDescription" .


###  https://schema.bco-dmo.org/v1.0/processingDescription
:processingDescription rdf:type owl:DatatypeProperty ;
                       rdfs:domain [ rdf:type owl:Class ;
                                     owl:unionOf ( :Dataset
                                                   :DatasetDeployment
                                                   :Deployment
                                                 )
                                   ] ;
                       rdfs:range rdf:HTML ;
                       rdfs:comment "An HTML description of data processing steps." ;
                       rdfs:label "processingDescription" .


###  https://schema.bco-dmo.org/v1.0/requiresConversion
:requiresConversion rdf:type owl:DatatypeProperty ;
                    rdfs:domain :DatasetParameter ;
                    rdfs:range xsd:boolean ;
                    rdfs:comment "The values in the dataset for this property need to be converted." ;
                    rdfs:label "requiresConversion" .


###  https://schema.bco-dmo.org/v1.0/resolvableUrl
:resolvableUrl rdf:type owl:DatatypeProperty ;
               rdfs:domain :Identifier ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "A resolvable URL that dereferences the identifier." ;
               rdfs:label "resolvableUrl" .


###  https://schema.bco-dmo.org/v1.0/restricted
:restricted rdf:type owl:DatatypeProperty ;
            rdfs:domain :Dataset ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Is the dataset restricted for access by the public." ;
            rdfs:label "restricted" .


###  https://schema.bco-dmo.org/v1.0/roleWeight
:roleWeight rdf:type owl:DatatypeProperty ;
            rdfs:domain :Role ;
            rdfs:range xsd:int ;
            rdfs:comment "Sort ordering of role types" ;
            rdfs:label "roleWeight" .


###  https://schema.bco-dmo.org/v1.0/shortDescription
:shortDescription rdf:type owl:DatatypeProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :Dataset
                                              :Parameter
                                            )
                              ] ;
                  rdfs:range rdf:HTML ;
                  rdfs:comment "A brief HTML description of the dataset." ;
                  rdfs:label "shortDescription" .


###  https://schema.bco-dmo.org/v1.0/shortName
:shortName rdf:type owl:DatatypeProperty ;
           rdfs:domain :Parameter ;
           rdfs:range xsd:string ;
           rdfs:comment "A short name for a master parameter." ;
           rdfs:label "shortName" .


###  https://schema.bco-dmo.org/v1.0/southBoundary
:southBoundary rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :BoundingBoxGeometry ;
               rdfs:range xsd:float ;
               rdfs:comment "The southern latitude boundary of a bounding box (decimal degrees)." ;
               rdfs:label "southBoundary" .


###  https://schema.bco-dmo.org/v1.0/title
:title rdf:type owl:DatatypeProperty ;
       rdfs:domain :Dataset ;
       rdfs:range xsd:string ;
       rdfs:comment "The full title of the dataset." ;
       rdfs:label "title" .


###  https://schema.bco-dmo.org/v1.0/url
:url rdf:type owl:DatatypeProperty ;
     rdfs:range xsd:anyURI ;
     rdfs:comment "A URL for a resource, such as its landing page." ;
     rdfs:label "url" .


###  https://schema.bco-dmo.org/v1.0/validated
:validated rdf:type owl:DatatypeProperty ;
           rdfs:domain :Dataset ;
           rdfs:range xsd:boolean ;
           rdfs:comment "Has the dataset been validated by the PI." ;
           rdfs:label "validated" .


###  https://schema.bco-dmo.org/v1.0/valueFormat
:valueFormat rdf:type owl:DatatypeProperty ;
             rdfs:domain :DatasetParameter ;
             rdfs:range xsd:token ;
             rdfs:comment "The format string used to encode parameter values in the data file." ;
             rdfs:label "valueFormat" .


###  https://schema.bco-dmo.org/v1.0/version
:version rdf:type owl:DatatypeProperty ;
         rdfs:domain :Dataset ;
         rdfs:range xsd:token ;
         rdfs:comment "The version label of the dataset (numeric or numeric + single lowercase letter)." ;
         rdfs:label "version" .


###  https://schema.bco-dmo.org/v1.0/westBoundary
:westBoundary rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :BoundingBoxGeometry ;
              rdfs:range xsd:float ;
              rdfs:comment "The western longitude boundary of a bounding box (decimal degrees)." ;
              rdfs:label "westBoundary" .


#################################################################
#    Classes
#################################################################

###  http://www.opengis.net/ont/geosparql#Geometry
<http://www.opengis.net/ont/geosparql#Geometry> rdf:type owl:Class .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement
rdf:Statement rdf:type owl:Class .


###  http://www.w3.org/2006/time#Instant
<http://www.w3.org/2006/time#Instant> rdf:type owl:Class .


###  http://www.w3.org/2006/time#Interval
<http://www.w3.org/2006/time#Interval> rdf:type owl:Class .


###  https://schema.bco-dmo.org/v1.0/Action
:Action rdf:type owl:Class ;
        rdfs:subClassOf :Category ;
        rdfs:comment "Some action that can be taken on an Entity. A Policy can restrict and allow actions" ;
        rdfs:label "Action" .


###  https://schema.bco-dmo.org/v1.0/Affiliation
:Affiliation rdf:type owl:Class ;
             rdfs:subClassOf [ owl:intersectionOf ( :Organization
                                                    [ rdf:type owl:Class ;
                                                      owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                      owl:onProperty [ owl:inverseOf :affiliation
                                                                                     ] ;
                                                                      owl:someValuesFrom :Person
                                                                    ]
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty [ owl:inverseOf :performedAt
                                                                                     ] ;
                                                                      owl:someValuesFrom :AgentRole
                                                                    ]
                                                                  )
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             rdfs:comment "An institutional affiliation of a person (university, research institute, etc.)." ;
             rdfs:label "Affiliation" .


###  https://schema.bco-dmo.org/v1.0/Agent
:Agent rdf:type owl:Class ;
       rdfs:subClassOf :Entity ;
       rdfs:comment "An entity (person or organisation) that can perform roles." ;
       rdfs:label "Agent" .


###  https://schema.bco-dmo.org/v1.0/AgentRole
:AgentRole rdf:type owl:Class ;
           rdfs:subClassOf [ owl:intersectionOf ( :Situation
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :performedBy ;
                                                    owl:someValuesFrom :Agent
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :role ;
                                                    owl:someValuesFrom :Role
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty [ owl:inverseOf :hasAgentWithRole
                                                                   ] ;
                                                    owl:someValuesFrom :Entity
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
           rdfs:comment "A qualified association that links an Agent to a role and optionally an affiliation context." ;
           rdfs:label "Agent Role" .


###  https://schema.bco-dmo.org/v1.0/ArchiveFileType
:ArchiveFileType rdf:type owl:Class ;
                 rdfs:subClassOf :FileType ;
                 rdfs:comment "A file format  used to bundle multiple files and folders into a single file for easier storage or transfer." ;
                 rdfs:label "ArchiveFileType" .


###  https://schema.bco-dmo.org/v1.0/Award
:Award rdf:type owl:Class ;
       rdfs:subClassOf [ owl:intersectionOf ( :Entity
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :provider ;
                                                owl:someValuesFrom :FundingAgency
                                              ]
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty [ owl:inverseOf :fundedByAward
                                                               ] ;
                                                owl:someValuesFrom :CreativeWork
                                              ]
                                            ) ;
                         rdf:type owl:Class
                       ] ;
       rdfs:comment "A funding award (grant) from a funder that supports data collection." ;
       rdfs:label "Award" .


###  https://schema.bco-dmo.org/v1.0/BCODMOIdentifier
:BCODMOIdentifier rdf:type owl:Class ;
                  rdfs:subClassOf :Identifier ;
                  rdfs:comment "An internal BCO-DMO identifier (version 2 scheme)." ;
                  rdfs:label "BCO-DMO Identifier" .


###  https://schema.bco-dmo.org/v1.0/BoundingBoxGeometry
:BoundingBoxGeometry rdf:type owl:Class ;
                     rdfs:subClassOf [ owl:intersectionOf ( :Geometry
                                                            [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty :eastBoundary ;
                                                                                     owl:someValuesFrom xsd:float
                                                                                   ]
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty :northBoundary ;
                                                                                     owl:someValuesFrom xsd:float
                                                                                   ]
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty :southBoundary ;
                                                                                     owl:someValuesFrom xsd:float
                                                                                   ]
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty :westBoundary ;
                                                                                     owl:someValuesFrom xsd:float
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                     rdfs:comment "An axis-aligned bounding box geometry defined by west/south/east/north boundaries." ;
                     rdfs:label "Bounding Box Geometry" .


###  https://schema.bco-dmo.org/v1.0/Category
:Category rdf:type owl:Class ;
          rdfs:subClassOf :Entity ;
          rdfs:comment "A set of taxonomy" ;
          rdfs:label "Category" .


###  https://schema.bco-dmo.org/v1.0/CentroidGeometry
:CentroidGeometry rdf:type owl:Class ;
                  rdfs:subClassOf :Geometry ;
                  rdfs:comment "A point geometry representing the centroid of a spatial extent." ;
                  rdfs:label "Centroid Geometry" .


###  https://schema.bco-dmo.org/v1.0/ComputerLanguage
:ComputerLanguage rdf:type owl:Class ;
                  rdfs:subClassOf :Language ;
                  owl:disjointWith :NaturalLanguage ;
                  rdfs:comment "Programming languages such as Python, Go, Rust and Java." ;
                  rdfs:label "ComputerLanguage" .


###  https://schema.bco-dmo.org/v1.0/ConsumeAction
:ConsumeAction rdf:type owl:Class ;
               rdfs:subClassOf :Action ;
               rdfs:comment "The act of consuming an Entity." ;
               rdfs:label "ConsumeAction" ;
               rdfs:seeAlso "https://schema.org/ConsumeAction" .


###  https://schema.bco-dmo.org/v1.0/CreativeWork
:CreativeWork rdf:type owl:Class ;
              rdfs:subClassOf :Entity ;
              rdfs:comment "Any work that can be created by some Agent" ;
              rdfs:label "Creative Work" .


###  https://schema.bco-dmo.org/v1.0/CreativeWorkStatus
:CreativeWorkStatus rdf:type owl:Class ;
                    rdfs:subClassOf :Category ;
                    rdfs:comment "A state of for some createive work." ;
                    rdfs:label "CreativeWorkStatus" .


###  https://schema.bco-dmo.org/v1.0/Cruise
:Cruise rdf:type owl:Class ;
        rdfs:subClassOf [ owl:intersectionOf ( :Deployment
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :onPlatform ;
                                                 owl:someValuesFrom :Vessel
                                               ]
                                             ) ;
                          rdf:type owl:Class
                        ] ;
        rdfs:comment "A research vessel cruise, a specialisation of Platform for vessel-type platforms." ;
        rdfs:label "Cruise" .


###  https://schema.bco-dmo.org/v1.0/CryptographicHash
:CryptographicHash rdf:type owl:Class ;
                   rdfs:subClassOf [ owl:intersectionOf ( :Identifier
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :identifierScheme ;
                                                            owl:someValuesFrom :CryptographicHashAlgorithm
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
                   rdfs:comment "A cryptographic hash (e.g. MD5) used as a file integrity checksum." ;
                   rdfs:label "Cryptographic Hash" .


###  https://schema.bco-dmo.org/v1.0/CryptographicHashAlgorithm
:CryptographicHashAlgorithm rdf:type owl:Class ;
                            rdfs:subClassOf :IdentifierScheme ;
                            rdfs:comment "A mathematical function that transforms any arbitrary amount of input data into a fixed-length string of characters (identifierValue), acting as a secure \"digital fingerprint\" or \"digest\"" ;
                            rdfs:label "Cryptographic Hash Algorithm" .


###  https://schema.bco-dmo.org/v1.0/CurrentState
:CurrentState rdf:type owl:Class ;
              rdfs:subClassOf :Category ;
              rdfs:comment "The current editorial/curation state of a CreativeWork" ;
              rdfs:label "Current State" .


###  https://schema.bco-dmo.org/v1.0/DOIDataset
:DOIDataset rdf:type owl:Class ;
            rdfs:subClassOf [ owl:intersectionOf ( :Dataset
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :identifier ;
                                                     owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                          owl:onProperty :identifierScheme ;
                                                                          owl:hasValue :IdentifierScheme_DOI
                                                                        ]
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
            rdfs:comment "A versioned BCO-DMO dataset that has been assigned a DOI." ;
            rdfs:label "DOI Dataset" .


###  https://schema.bco-dmo.org/v1.0/DOIIdentifier
:DOIIdentifier rdf:type owl:Class ;
               rdfs:subClassOf [ owl:intersectionOf ( :Identifier
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :identifierScheme ;
                                                        owl:hasValue :IdentifierScheme_DOI
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
               rdfs:comment "A Digital Object Identifier." ;
               rdfs:label "DOI Identifier" .


###  https://schema.bco-dmo.org/v1.0/DOIStatus
:DOIStatus rdf:type owl:Class ;
           rdfs:subClassOf [ owl:intersectionOf ( :CreativeWorkStatus
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty [ owl:inverseOf :status
                                                                   ] ;
                                                    owl:someValuesFrom :DOIDataset
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
           rdfs:comment "The lifecycle status of a DOI Dataset (Draft, Reserved, Published, etc.)." ;
           rdfs:label "DOI Status" .


###  https://schema.bco-dmo.org/v1.0/DataFile
:DataFile rdf:type owl:Class ;
          rdfs:subClassOf [ owl:intersectionOf ( :FileDescriptor
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty [ owl:inverseOf :dataFile
                                                                  ] ;
                                                   owl:someValuesFrom :CreativeWork
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
          rdfs:comment "A primary or supplemental data file distributed as part of a dataset." ;
          rdfs:label "Data File" .


###  https://schema.bco-dmo.org/v1.0/DataManagementPlan
:DataManagementPlan rdf:type owl:Class ;
                    rdfs:subClassOf [ owl:intersectionOf ( :FileDescriptor
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty [ owl:inverseOf :dataManagementPlan
                                                                            ] ;
                                                             owl:someValuesFrom :CreativeWork
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                    rdfs:comment "A plan describing how a research activity will manage and archive data products produced." ;
                    rdfs:label "DataManagementPlan" .


###  https://schema.bco-dmo.org/v1.0/Dataset
:Dataset rdf:type owl:Class ;
         rdfs:subClassOf :CreativeWork ;
         rdfs:comment "A dataset which may be internal or external to BCO-DMO." ;
         rdfs:label "Dataset" .


###  https://schema.bco-dmo.org/v1.0/DatasetAward
:DatasetAward rdf:type owl:Class ;
              rdfs:subClassOf :Situation ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                       owl:onProperty :fundedByAward ;
                                                       owl:someValuesFrom :Award
                                                     ]
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf :forDataset
                                                                      ] ;
                                                       owl:someValuesFrom :Dataset
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
              rdfs:comment "The connection between a dataset and the award the funded its generation" ;
              rdfs:label "DatasetAward" .


###  https://schema.bco-dmo.org/v1.0/DatasetDeployment
:DatasetDeployment rdf:type owl:Class ;
                   rdfs:subClassOf :Situation ,
                                   [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                            owl:onProperty :forDataset ;
                                                            owl:someValuesFrom :Dataset
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :fromDeployment ;
                                                            owl:someValuesFrom :Deployment
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
                   rdfs:comment "A deployment as referenced within a specific dataset, with dataset-specific properties." ;
                   rdfs:label "Dataset Deployment" .


###  https://schema.bco-dmo.org/v1.0/DatasetInstrument
:DatasetInstrument rdf:type owl:Class ;
                   rdfs:subClassOf :Situation ,
                                   [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                            owl:onProperty :forDataset ;
                                                            owl:someValuesFrom :Dataset
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :isDefinedAs ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass :Instrument
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
                   rdfs:comment "An instrument as referenced within a specific dataset, with dataset-specific properties." ;
                   rdfs:label "Dataset Instrument" .


###  https://schema.bco-dmo.org/v1.0/DatasetParameter
:DatasetParameter rdf:type owl:Class ;
                  rdfs:subClassOf :Situation ,
                                  [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                           owl:onProperty :forDataset ;
                                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                           owl:onClass :Dataset
                                                         ]
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :isDefinedAs ;
                                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                           owl:onClass :Parameter
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
                  rdfs:comment "A parameter as instantiated within a specific dataset column, with dataset-level name, description, units, and format." ;
                  rdfs:label "Dataset Parameter" .


###  https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute
:DatasetParameterAttribute rdf:type owl:Class ;
                           rdfs:subClassOf :Category ;
                           rdfs:comment "An attribute of a dataset parameter that provides more context as to how it could be used." ;
                           rdfs:label "DatasetParameterAttribute" .


###  https://schema.bco-dmo.org/v1.0/DatasetType
:DatasetType rdf:type owl:Class ;
             rdfs:subClassOf [ owl:intersectionOf ( :DefinedType
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty [ owl:inverseOf :datasetType
                                                                     ] ;
                                                      owl:someValuesFrom :Dataset
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             rdfs:comment "A category describing the type of dataset (e.g. Cruise Data, Model Output)." ;
             rdfs:label "Dataset Type" .


###  https://schema.bco-dmo.org/v1.0/Datatype
:Datatype rdf:type owl:Class ;
          rdfs:subClassOf [ owl:intersectionOf ( :DefinedType
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty [ owl:inverseOf :dataType
                                                                  ] ;
                                                   owl:someValuesFrom :DatasetParameter
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
          rdfs:comment "The data type of a dataset parameter column (e.g. string, integer, float)." ;
          rdfs:label "Datatype" .


###  https://schema.bco-dmo.org/v1.0/DefinedType
:DefinedType rdf:type owl:Class ;
             rdfs:subClassOf :Category ;
             rdfs:comment "A type of something" ;
             rdfs:label "DefinedType" .


###  https://schema.bco-dmo.org/v1.0/Deployment
:Deployment rdf:type owl:Class ;
            rdfs:subClassOf [ owl:intersectionOf ( :Event
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :onPlatform ;
                                                     owl:someValuesFrom :Platform
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
            rdfs:comment "A scientific deployment (cruise, expedition, mooring deployment) during which data were collected." ;
            rdfs:label "Deployment" .


###  https://schema.bco-dmo.org/v1.0/DeploymentEntityMatch
:DeploymentEntityMatch rdf:type owl:Class ;
                       rdfs:subClassOf [ owl:intersectionOf ( :EntityMatch
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty rdf:object ;
                                                                owl:cardinality "1"^^xsd:nonNegativeInteger
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty rdf:subject ;
                                                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                owl:onClass :Deployment
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] .


###  https://schema.bco-dmo.org/v1.0/EmailAddress
:EmailAddress rdf:type owl:Class ;
              rdfs:subClassOf :IdentifierString ;
              rdfs:isDefinedBy :Datatype_EmailAddress ;
              rdfs:label "Email Address" .


###  https://schema.bco-dmo.org/v1.0/EmbargoPolicy
:EmbargoPolicy rdf:type owl:Class ;
               rdfs:subClassOf [ owl:intersectionOf ( :Policy
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :modifiesAction ;
                                                        owl:someValuesFrom :ConsumeAction
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :target ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass :CreativeWork
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :expirationDate ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onDataRange xsd:date
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
               rdfs:comment "A policy that restricts access to a dataset until an expiration date." ;
               rdfs:label "Embargo Policy" .


###  https://schema.bco-dmo.org/v1.0/EmbargoReleasePolicy
:EmbargoReleasePolicy rdf:type owl:Class ;
                      rdfs:subClassOf :Policy ;
                      rdfs:comment "A policy that allows access to a FileDescriptor when its overarching Dataset is under an embargo." ;
                      rdfs:label "EmbargoReleasePolicy" .


###  https://schema.bco-dmo.org/v1.0/Entity
:Entity rdf:type owl:Class ;
        rdfs:comment "A BCO-DMO specific concept" ;
        rdfs:label "Entity" .


###  https://schema.bco-dmo.org/v1.0/EntityMatch
:EntityMatch rdf:type owl:Class ;
             rdfs:subClassOf rdf:Statement ,
                             [ owl:intersectionOf ( :Situation
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty rdf:object ;
                                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty rdf:subject ;
                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass :Entity
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
             rdfs:comment "A link between two entities that are related in some way as defined by rdf:predicate. This entity allows for annotating details of the match." ;
             rdfs:label "EntityMatch" .


###  https://schema.bco-dmo.org/v1.0/Event
:Event rdf:type owl:Class ;
       rdfs:subClassOf [ owl:intersectionOf ( :Situation
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :hasTime ;
                                                owl:someValuesFrom :TemporalEntity
                                              ]
                                            ) ;
                         rdf:type owl:Class
                       ] ;
       rdfs:comment "A dynamic situation in which something unique or impotant happened." ;
       rdfs:label "Event" .


###  https://schema.bco-dmo.org/v1.0/File
:File rdf:type owl:Class ;
      rdfs:subClassOf :CreativeWork ;
      rdfs:comment "A physical file (byte stream) associated with a dataset or package." ;
      rdfs:label "File" .


###  https://schema.bco-dmo.org/v1.0/FileDescriptor
:FileDescriptor rdf:type owl:Class ;
                rdfs:subClassOf [ owl:intersectionOf ( :Situation
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :describesFile ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass :File
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
                rdfs:comment "A context-specific description of a file. The context could be data, metadata or supplemental documentation." ;
                rdfs:label "File Descriptor" .


###  https://schema.bco-dmo.org/v1.0/FileType
:FileType rdf:type owl:Class ;
          rdfs:subClassOf [ owl:intersectionOf ( :DefinedType
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty [ owl:inverseOf :fileType
                                                                  ] ;
                                                   owl:someValuesFrom :File
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
          rdfs:comment "A file format type, characterised by a label and MIME type (e.g. CSV, XML, PDF)." ;
          rdfs:label "File Type" .


###  https://schema.bco-dmo.org/v1.0/FundingAgency
:FundingAgency rdf:type owl:Class ;
               rdfs:subClassOf [ owl:intersectionOf ( :Organization
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :grantedAward ;
                                                        owl:someValuesFrom :Award
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
               rdfs:comment "An Organization that has provided some funding award" ;
               rdfs:label "Funding Agency" .


###  https://schema.bco-dmo.org/v1.0/GeographicalLocation
:GeographicalLocation rdf:type owl:Class ;
                      rdfs:subClassOf :Entity ;
                      rdfs:comment "A spatial extent or named location associated with a dataset, deployment, project, or program." ;
                      rdfs:label "Geographical Location" .


###  https://schema.bco-dmo.org/v1.0/Geometry
:Geometry rdf:type owl:Class ;
          rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Geometry> ,
                          :Entity ;
          rdfs:comment "An abstract spatial geometry." ;
          rdfs:label "Geometry" .


###  https://schema.bco-dmo.org/v1.0/Identifier
:Identifier rdf:type owl:Class ;
            rdfs:subClassOf :Entity ;
            rdfs:comment "An identifier assigned to a resource by some scheme." ;
            rdfs:label "Identifier" .


###  https://schema.bco-dmo.org/v1.0/IdentifierScheme
:IdentifierScheme rdf:type owl:Class ;
                  rdfs:subClassOf :Category ;
                  rdfs:comment "A named scheme or authority that mints identifiers (DOI, ROR, ORCID, etc.)." ;
                  rdfs:label "Identifier Scheme" .


###  https://schema.bco-dmo.org/v1.0/IdentifierString
:IdentifierString rdf:type owl:Class ;
                  rdfs:subClassOf :String ;
                  rdfs:isDefinedBy :Datatype_Identifier ;
                  rdfs:label "IdentifierString"@en .


###  https://schema.bco-dmo.org/v1.0/Image
:Image rdf:type owl:Class ;
       rdfs:subClassOf [ owl:intersectionOf ( :File
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty :fileType ;
                                                owl:someValuesFrom :ImageFileType
                                              ]
                                            ) ;
                         rdf:type owl:Class
                       ] ;
       rdfs:comment "An image file." ;
       rdfs:label "Image" .


###  https://schema.bco-dmo.org/v1.0/ImageFileType
:ImageFileType rdf:type owl:Class ;
               rdfs:subClassOf :FileType ;
               rdfs:comment "Representative of a type of image file." ;
               rdfs:label "ImageFileType" .


###  https://schema.bco-dmo.org/v1.0/Instrument
:Instrument rdf:type owl:Class ;
            rdfs:subClassOf [ owl:intersectionOf ( :DefinedType
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty [ owl:inverseOf :isDefinedAs
                                                                    ] ;
                                                     owl:someValuesFrom :DatasetInstrument
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
            rdfs:comment "A master (community-level) scientific instrument definition." ;
            rdfs:label "Instrument" .


###  https://schema.bco-dmo.org/v1.0/Keyword
:Keyword rdf:type owl:Class ;
         rdfs:subClassOf :Category ;
         rdfs:comment "A subject keyword associated with a dataset." ;
         rdfs:label "Keyword" .


###  https://schema.bco-dmo.org/v1.0/Language
:Language rdf:type owl:Class ;
          rdfs:subClassOf :Category ;
          rdfs:comment "A natural language used in the dataset metadata." ;
          rdfs:label "Language" .


###  https://schema.bco-dmo.org/v1.0/License
:License rdf:type owl:Class ;
         rdfs:subClassOf [ owl:intersectionOf ( :CreativeWork
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty [ owl:inverseOf :license
                                                                 ] ;
                                                  owl:someValuesFrom :CreativeWork
                                                ]
                                              ) ;
                           rdf:type owl:Class
                         ] ;
         rdfs:comment "A  license applied to some creative work." ;
         rdfs:label "License" .


###  https://schema.bco-dmo.org/v1.0/Logo
:Logo rdf:type owl:Class ;
      rdfs:subClassOf :Image ;
      rdfs:comment "An image that is representative of some thing" ;
      rdfs:label "Logo" .


###  https://schema.bco-dmo.org/v1.0/MetadataFile
:MetadataFile rdf:type owl:Class ;
              rdfs:subClassOf [ owl:intersectionOf ( :FileDescriptor
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf :metadataFile
                                                                      ] ;
                                                       owl:someValuesFrom :CreativeWork
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
              rdfs:comment "A metadata file (e.g. ISO 19115-2 XML, dataset description PDF) describing a dataset." ;
              rdfs:label "Metadata File" .


###  https://schema.bco-dmo.org/v1.0/MetadataProfile
:MetadataProfile rdf:type owl:Class ;
                 rdfs:subClassOf :CreativeWork ;
                 rdfs:comment "A formal metadata profile specification to which the datapackage conforms." ;
                 rdfs:label "Metadata Profile" .


###  https://schema.bco-dmo.org/v1.0/NaturalLanguage
:NaturalLanguage rdf:type owl:Class ;
                 rdfs:subClassOf :Language ;
                 rdfs:comment "Natural languages such as Spanish, Tamil, Hindi, English, etc." ;
                 rdfs:label "NaturalLanguage" ;
                 rdfs:seeAlso <https://schema.org/Language> .


###  https://schema.bco-dmo.org/v1.0/ORCIDIdentifier
:ORCIDIdentifier rdf:type owl:Class ;
                 rdfs:subClassOf [ owl:intersectionOf ( :Identifier
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :identifierScheme ;
                                                          owl:hasValue :IdentifierScheme_ROR
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
                 rdfs:comment "An Open Researcher and Contributor ID" ;
                 rdfs:label "ORCID Identifier" .


###  https://schema.bco-dmo.org/v1.0/Organization
:Organization rdf:type owl:Class ;
              rdfs:subClassOf :Agent ;
              owl:disjointWith :Person ;
              rdfs:comment "An organisational body such as a publisher, funder, or identifier authority." ;
              rdfs:label "Organization" .


###  https://schema.bco-dmo.org/v1.0/Parameter
:Parameter rdf:type owl:Class ;
           rdfs:subClassOf [ owl:intersectionOf ( :DefinedType
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty [ owl:inverseOf :isDefinedAs
                                                                   ] ;
                                                    owl:someValuesFrom :DatasetParameter
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
           rdfs:comment "A master (community-level) scientific parameter definition." ;
           rdfs:label "Parameter" .


###  https://schema.bco-dmo.org/v1.0/Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf :Agent ;
        rdfs:comment "A human individual associated with some entity." ;
        rdfs:label "Person" .


###  https://schema.bco-dmo.org/v1.0/Platform
:Platform rdf:type owl:Class ;
          rdfs:subClassOf :Entity ;
          rdfs:comment "A platform (vessel, buoy, glider, etc.) used for data collection." ;
          rdfs:label "Platform" .


###  https://schema.bco-dmo.org/v1.0/PlatformTitle
:PlatformTitle rdf:type owl:Class ;
               rdfs:subClassOf [ owl:intersectionOf ( :Category
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty [ owl:inverseOf :platformTitle
                                                                       ] ;
                                                        owl:someValuesFrom :Platform
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
               rdfs:comment "A named title/designation for a platform (e.g. the full name of a research vessel)." ;
               rdfs:label "Platform Title" .


###  https://schema.bco-dmo.org/v1.0/PlatformType
:PlatformType rdf:type owl:Class ;
              rdfs:subClassOf [ owl:intersectionOf ( :DefinedType
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty [ owl:inverseOf :platformType
                                                                      ] ;
                                                       owl:someValuesFrom :Platform
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
              rdfs:comment "A category of platform (e.g. vessel, mooring, glider)." ;
              rdfs:label "Platform Type" .


###  https://schema.bco-dmo.org/v1.0/Policy
:Policy rdf:type owl:Class ;
        rdfs:subClassOf [ owl:intersectionOf ( :Entity
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :modifiesAction ;
                                                 owl:someValuesFrom :ConsumeAction
                                               ]
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :target ;
                                                 owl:someValuesFrom :Entity
                                               ]
                                             ) ;
                          rdf:type owl:Class
                        ] ;
        rdfs:comment "An access or governance policy applied to a resource." ;
        rdfs:label "Policy" .


###  https://schema.bco-dmo.org/v1.0/Program
:Program rdf:type owl:Class ;
         rdfs:subClassOf [ owl:intersectionOf ( :ResearchActivity
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty [ owl:inverseOf :hasParentProgram
                                                                 ] ;
                                                  owl:someValuesFrom :Project
                                                ]
                                              ) ;
                           rdf:type owl:Class
                         ] ;
         rdfs:comment "A scientific program (typically a grouping of related projects) associated with a dataset." ;
         rdfs:label "Program" .


###  https://schema.bco-dmo.org/v1.0/Project
:Project rdf:type owl:Class ;
         rdfs:subClassOf :ResearchActivity ;
         rdfs:comment "A funded scientific project under which data were collected." ;
         rdfs:label "Project" .


###  https://schema.bco-dmo.org/v1.0/Publication
:Publication rdf:type owl:Class ;
             rdfs:subClassOf :CreativeWork ;
             rdfs:comment "A scholarly publication related to a dataset (journal article, report, etc.)." ;
             rdfs:label "Publication" .


###  https://schema.bco-dmo.org/v1.0/RORIdentifier
:RORIdentifier rdf:type owl:Class ;
               rdfs:subClassOf [ owl:intersectionOf ( :Identifier
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :identifierScheme ;
                                                        owl:hasValue :IdentifierScheme_ROR
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
               rdfs:comment "A Research Organization Registry identifier." ;
               rdfs:label "ROR Identifier" .


###  https://schema.bco-dmo.org/v1.0/ResearchActivity
:ResearchActivity rdf:type owl:Class ;
                  rdfs:subClassOf [ owl:intersectionOf ( :Event
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :situationInvolves ;
                                                           owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                           owl:onClass :Agent
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
                  rdfs:comment "An activity that enables research. The research typically produces datasets." ;
                  rdfs:label "Research Activity" .


###  https://schema.bco-dmo.org/v1.0/ResourceRelation
:ResourceRelation rdf:type owl:Class ;
                  rdfs:subClassOf :Category ;
                  rdfs:comment "A controlled-vocabulary term describing the relationship between two resources (aligned to Crossref and DataCite relation types)." ;
                  rdfs:label "Resource Relation" .


###  https://schema.bco-dmo.org/v1.0/ResourceRelationGroup
:ResourceRelationGroup rdf:type owl:Class ;
                       rdfs:subClassOf [ owl:intersectionOf ( :Category
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty [ owl:inverseOf :inGroup
                                                                               ] ;
                                                                owl:someValuesFrom :ResourceRelation
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                       rdfs:comment "A grouping category for resource relation types." ;
                       rdfs:label "Resource Relation Group" .


###  https://schema.bco-dmo.org/v1.0/Role
:Role rdf:type owl:Class ;
      rdfs:subClassOf [ owl:intersectionOf ( :DefinedType
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :roleWeight ;
                                               owl:someValuesFrom xsd:int
                                             ]
                                           ) ;
                        rdf:type owl:Class
                      ] ;
      rdfs:comment "A functional role performed by an agent (e.g. Principal Investigator, Co-Investigator)." ;
      rdfs:label "Role" .


###  https://schema.bco-dmo.org/v1.0/Situation
:Situation rdf:type owl:Class ;
           rdfs:subClassOf [ owl:intersectionOf ( :Entity
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :situationInvolves ;
                                                    owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
           rdfs:comment "A static or dynamic scenario. A state of affairs that describes some configuration of the world. Most often a situation describes the interaction of 2 or more entities. In some cases these interactions are time bounded and can be labeled as significant events." ;
           rdfs:label "Situation" .


###  https://schema.bco-dmo.org/v1.0/String
:String rdf:type owl:Class ;
        rdfs:subClassOf :Datatype ;
        rdfs:isDefinedBy :Datatype_String ;
        rdfs:label "String"@en ;
        rdfs:seeAlso <https://schema.org/Text> .


###  https://schema.bco-dmo.org/v1.0/SupplementalDocument
:SupplementalDocument rdf:type owl:Class ;
                      rdfs:subClassOf [ owl:intersectionOf ( :FileDescriptor
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty [ owl:inverseOf :supplementalDocument
                                                                              ] ;
                                                               owl:someValuesFrom :CreativeWork
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                      rdfs:comment "A supplemental (non-primary) document file associated with a dataset." ;
                      rdfs:label "Supplemental Document" .


###  https://schema.bco-dmo.org/v1.0/Synonym
:Synonym rdf:type owl:Class ;
         rdfs:subClassOf :Entity ;
         rdfs:comment "An alternative name or synonym, e.g. for a deployment." ;
         rdfs:label "Synonym" .


###  https://schema.bco-dmo.org/v1.0/TemporalEntity
:TemporalEntity rdf:type owl:Class ;
                rdfs:subClassOf :Entity ;
                rdfs:comment "A frame of reference for when something existed or occupied time — it is either a durationless point (an instant) or a thing with some extent in time (an interval)." ;
                rdfs:label "TemporalEntity" .


###  https://schema.bco-dmo.org/v1.0/TemporalInstant
:TemporalInstant rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/2006/time#Instant> ,
                                 :TemporalEntity ;
                 rdfs:comment "A single point in time associated with a dataset extent or event date." ;
                 rdfs:label "Temporal Instant" .


###  https://schema.bco-dmo.org/v1.0/TemporalInterval
:TemporalInterval rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.w3.org/2006/time#Interval> ,
                                  :TemporalEntity ;
                  rdfs:comment "A time period with a beginning and an end, used to describe dataset temporal coverage." ;
                  rdfs:label "Temporal Interval" .


###  https://schema.bco-dmo.org/v1.0/URL
:URL rdf:type owl:Class ;
     rdfs:subClassOf :IdentifierString ;
     rdfs:isDefinedBy :Datatype_URL ;
     rdfs:label "URL"@en ;
     rdfs:seeAlso <https://schema.org/URL> .


