                                             rdfs:label "middleName" ;
                                             <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://schema.org/additionalName> .


###  https://schema.bco-dmo.org/v0.1/mimeType
<https://schema.bco-dmo.org/v0.1/mimeType> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain <https://schema.bco-dmo.org/v0.1/FileType> ;
                                           rdfs:range xsd:token ;
                                           rdfs:comment "The MIME type associated with a file type." ;
                                           rdfs:label "mimeType" ;
                                           <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/encodingFormat> .


###  https://schema.bco-dmo.org/v0.1/name
<https://schema.bco-dmo.org/v0.1/name> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <https://schema.bco-dmo.org/v0.1/Entity> ;
                                       rdfs:range xsd:string ;
                                       rdfs:comment "The name of the item. Synonymous with the label property." ;
                                       rdfs:label "name" ;
                                       <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/name> .


###  https://schema.bco-dmo.org/v0.1/nickname
<https://schema.bco-dmo.org/v0.1/nickname> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain <https://schema.bco-dmo.org/v0.1/Person> ;
                                           rdfs:range xsd:string ;
                                           rdfs:comment "Nickname, or preferred name, of a Person" ;
                                           rdfs:label "nickname" ;
                                           <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/additionalName> .


###  https://schema.bco-dmo.org/v0.1/noDataValue
<https://schema.bco-dmo.org/v0.1/noDataValue> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <https://schema.bco-dmo.org/v0.1/DatasetParameter> ;
                                              rdfs:range xsd:token ;
                                              rdfs:comment "The value to expect in a DatasetParameter when there was no data for the given record." ;
                                              rdfs:label "noDataValue" .


###  https://schema.bco-dmo.org/v0.1/northBoundary
<https://schema.bco-dmo.org/v0.1/northBoundary> rdf:type owl:DatatypeProperty ,
                                                         owl:FunctionalProperty ;
                                                rdfs:domain <https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry> ;
                                                rdfs:range xsd:float ;
                                                rdfs:comment "The northern latitude boundary of a bounding box (decimal degrees)." ;
                                                rdfs:label "northBoundary" .


###  https://schema.bco-dmo.org/v0.1/officialName
<https://schema.bco-dmo.org/v0.1/officialName> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <https://schema.bco-dmo.org/v0.1/Parameter> ;
                                               rdfs:range xsd:string ;
                                               rdfs:comment "The official name for a master parameter." ;
                                               rdfs:label "officialName" ;
                                               <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://schema.org/name> .


###  https://schema.bco-dmo.org/v0.1/problemDescription
<https://schema.bco-dmo.org/v0.1/problemDescription> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <https://schema.bco-dmo.org/v0.1/Dataset> ;
                                                     rdfs:range xsd:string ;
                                                     rdfs:comment "A description of known problems or caveats with the dataset." ;
                                                     rdfs:label "problemDescription" .


###  https://schema.bco-dmo.org/v0.1/processingDescription
<https://schema.bco-dmo.org/v0.1/processingDescription> rdf:type owl:DatatypeProperty ;
                                                        rdfs:domain [ rdf:type owl:Class ;
                                                                      owl:unionOf ( <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                                    <https://schema.bco-dmo.org/v0.1/DatasetDeployment>
                                                                                    <https://schema.bco-dmo.org/v0.1/Deployment>
                                                                                  )
                                                                    ] ;
                                                        rdfs:range rdf:HTML ;
                                                        rdfs:comment "An HTML description of data processing steps." ;
                                                        rdfs:label "processingDescription" .


###  https://schema.bco-dmo.org/v0.1/requiresConversion
<https://schema.bco-dmo.org/v0.1/requiresConversion> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <https://schema.bco-dmo.org/v0.1/DatasetParameter> ;
                                                     rdfs:range xsd:boolean ;
                                                     rdfs:comment "The values in the dataset for this property need to be converted." ;
                                                     rdfs:label "requiresConversion" .


###  https://schema.bco-dmo.org/v0.1/resolvableUrl
<https://schema.bco-dmo.org/v0.1/resolvableUrl> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <https://schema.bco-dmo.org/v0.1/Identifier> ;
                                                rdfs:range xsd:anyURI ;
                                                rdfs:comment "A resolvable URL that dereferences the identifier." ;
                                                rdfs:label "resolvableUrl" ;
                                                <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/url> .


###  https://schema.bco-dmo.org/v0.1/restricted
<https://schema.bco-dmo.org/v0.1/restricted> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <https://schema.bco-dmo.org/v0.1/Dataset> ;
                                             rdfs:range xsd:boolean ;
                                             rdfs:comment "Is the dataset restricted for access by the public." ;
                                             rdfs:label "restricted" .


###  https://schema.bco-dmo.org/v0.1/roleWeight
<https://schema.bco-dmo.org/v0.1/roleWeight> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <https://schema.bco-dmo.org/v0.1/Role> ;
                                             rdfs:range xsd:int ;
                                             rdfs:comment "Sort ordering of role types" ;
                                             rdfs:label "roleWeight" .


###  https://schema.bco-dmo.org/v0.1/shortDescription
<https://schema.bco-dmo.org/v0.1/shortDescription> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain [ rdf:type owl:Class ;
                                                                 owl:unionOf ( <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                               <https://schema.bco-dmo.org/v0.1/Parameter>
                                                                             )
                                                               ] ;
                                                   rdfs:range rdf:HTML ;
                                                   rdfs:comment "A brief HTML description of the dataset." ;
                                                   rdfs:label "shortDescription" ;
                                                   <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/disambiguatingDescription> .


###  https://schema.bco-dmo.org/v0.1/shortName
<https://schema.bco-dmo.org/v0.1/shortName> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <https://schema.bco-dmo.org/v0.1/Parameter> ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment "A short name for a master parameter." ;
                                            rdfs:label "shortName" ;
                                            <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://schema.org/name> .


###  https://schema.bco-dmo.org/v0.1/southBoundary
<https://schema.bco-dmo.org/v0.1/southBoundary> rdf:type owl:DatatypeProperty ,
                                                         owl:FunctionalProperty ;
                                                rdfs:domain <https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry> ;
                                                rdfs:range xsd:float ;
                                                rdfs:comment "The southern latitude boundary of a bounding box (decimal degrees)." ;
                                                rdfs:label "southBoundary" .


###  https://schema.bco-dmo.org/v0.1/title
<https://schema.bco-dmo.org/v0.1/title> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain <https://schema.bco-dmo.org/v0.1/Dataset> ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "The full title of the dataset." ;
                                        rdfs:label "title" ;
                                        <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/name> .


###  https://schema.bco-dmo.org/v0.1/url
<https://schema.bco-dmo.org/v0.1/url> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <https://schema.bco-dmo.org/v0.1/Entity> ;
                                      rdfs:range xsd:anyURI ;
                                      rdfs:comment "A URL for a resource, such as its landing page." ;
                                      rdfs:label "url" ;
                                      <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/url> .


###  https://schema.bco-dmo.org/v0.1/validated
<https://schema.bco-dmo.org/v0.1/validated> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <https://schema.bco-dmo.org/v0.1/Dataset> ;
                                            rdfs:range xsd:boolean ;
                                            rdfs:comment "Has the dataset been validated by the PI." ;
                                            rdfs:label "validated" .


###  https://schema.bco-dmo.org/v0.1/valueFormat
<https://schema.bco-dmo.org/v0.1/valueFormat> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <https://schema.bco-dmo.org/v0.1/DatasetParameter> ;
                                              rdfs:range xsd:token ;
                                              rdfs:comment "The format string used to encode parameter values in the data file." ;
                                              rdfs:label "valueFormat" .


###  https://schema.bco-dmo.org/v0.1/version
<https://schema.bco-dmo.org/v0.1/version> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <https://schema.bco-dmo.org/v0.1/Dataset> ;
                                          rdfs:range xsd:token ;
                                          rdfs:comment "The version label of the dataset (numeric or numeric + single lowercase letter)." ;
                                          rdfs:label "version" ;
                                          <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/version> .


###  https://schema.bco-dmo.org/v0.1/westBoundary
<https://schema.bco-dmo.org/v0.1/westBoundary> rdf:type owl:DatatypeProperty ,
                                                        owl:FunctionalProperty ;
                                               rdfs:domain <https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry> ;
                                               rdfs:range xsd:float ;
                                               rdfs:comment "The western longitude boundary of a bounding box (decimal degrees)." ;
                                               rdfs:label "westBoundary" .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement
rdf:Statement rdf:type owl:Class .


###  http://www.w3.org/2006/time#TemporalUnit
<http://www.w3.org/2006/time#TemporalUnit> rdf:type owl:Class .


###  https://schema.bco-dmo.org/v0.1/Action
<https://schema.bco-dmo.org/v0.1/Action> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                         rdfs:comment "Some action that can be taken on an Entity. A Policy can restrict and allow actions" ;
                                         rdfs:label "Action" ;
                                         <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Action> .


###  https://schema.bco-dmo.org/v0.1/Affiliation
<https://schema.bco-dmo.org/v0.1/Affiliation> rdf:type owl:Class ;
                                              rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Organization>
                                                                                     [ rdf:type owl:Class ;
                                                                                       owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                       owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/affiliation>
                                                                                                                      ] ;
                                                                                                       owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Person>
                                                                                                     ]
                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                       owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/performedAt>
                                                                                                                      ] ;
                                                                                                       owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/AgentRole>
                                                                                                     ]
                                                                                                   )
                                                                                     ]
                                                                                   ) ;
                                                                rdf:type owl:Class
                                                              ] ;
                                              rdfs:comment "An institutional affiliation of a person (university, research institute, etc.)." ;
                                              rdfs:label "Affiliation" .


###  https://schema.bco-dmo.org/v0.1/Agent
<https://schema.bco-dmo.org/v0.1/Agent> rdf:type owl:Class ;
                                        rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                        rdfs:comment "An entity (person or organisation) that can perform roles." ;
                                        rdfs:label "Agent" .


###  https://schema.bco-dmo.org/v0.1/AgentRole
<https://schema.bco-dmo.org/v0.1/AgentRole> rdf:type owl:Class ;
                                            rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Situation>
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <https://schema.bco-dmo.org/v0.1/performedBy> ;
                                                                                     owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Agent>
                                                                                   ]
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <https://schema.bco-dmo.org/v0.1/role> ;
                                                                                     owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Role>
                                                                                   ]
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/hasAgentWithRole>
                                                                                                    ] ;
                                                                                     owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Entity>
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ] ;
                                            rdfs:comment "A qualified association that links an Agent to a role and optionally an affiliation context." ;
                                            rdfs:label "Agent Role" ;
                                            <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Role> .


###  https://schema.bco-dmo.org/v0.1/ArchiveFileType
<https://schema.bco-dmo.org/v0.1/ArchiveFileType> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/FileType> ;
                                                  rdfs:comment "A file format  used to bundle multiple files and folders into a single file for easier storage or transfer." ;
                                                  rdfs:label "ArchiveFileType" .


###  https://schema.bco-dmo.org/v0.1/Award
<https://schema.bco-dmo.org/v0.1/Award> rdf:type owl:Class ;
                                        rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Entity>
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://schema.bco-dmo.org/v0.1/provider> ;
                                                                                 owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/FundingAgency>
                                                                               ]
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/fundedByAward>
                                                                                                ] ;
                                                                                 owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                        rdfs:comment "A funding award (grant) from a funder that supports data collection." ;
                                        rdfs:label "Award" ;
                                        <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Grant> .


###  https://schema.bco-dmo.org/v0.1/BCODMOIdentifier
<https://schema.bco-dmo.org/v0.1/BCODMOIdentifier> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Identifier> ;
                                                   rdfs:comment "An internal BCO-DMO identifier (version 2 scheme)." ;
                                                   rdfs:label "BCO-DMO Identifier" .


###  https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry
<https://schema.bco-dmo.org/v0.1/BoundingBoxGeometry> rdf:type owl:Class ;
                                                      rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Geometry>
                                                                                             [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty <https://schema.bco-dmo.org/v0.1/eastBoundary> ;
                                                                                                                      owl:someValuesFrom xsd:float
                                                                                                                    ]
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty <https://schema.bco-dmo.org/v0.1/northBoundary> ;
                                                                                                                      owl:someValuesFrom xsd:float
                                                                                                                    ]
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty <https://schema.bco-dmo.org/v0.1/southBoundary> ;
                                                                                                                      owl:someValuesFrom xsd:float
                                                                                                                    ]
                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                      owl:onProperty <https://schema.bco-dmo.org/v0.1/westBoundary> ;
                                                                                                                      owl:someValuesFrom xsd:float
                                                                                                                    ]
                                                                                                                  ) ;
                                                                                               rdf:type owl:Class
                                                                                             ]
                                                                                           ) ;
                                                                        rdf:type owl:Class
                                                                      ] ;
                                                      rdfs:comment "An axis-aligned bounding box geometry defined by west/south/east/north boundaries." ;
                                                      rdfs:label "Bounding Box Geometry" ;
                                                      <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#Envelope> .


###  https://schema.bco-dmo.org/v0.1/Category
<https://schema.bco-dmo.org/v0.1/Category> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                           rdfs:comment "A set of taxonomy" ;
                                           rdfs:label "Category" ;
                                           <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/DefinedTerm> .


###  https://schema.bco-dmo.org/v0.1/CentroidGeometry
<https://schema.bco-dmo.org/v0.1/CentroidGeometry> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Geometry> ;
                                                   rdfs:comment "A point geometry representing the centroid of a spatial extent." ;
                                                   rdfs:label "Centroid Geometry" ;
                                                   <http://www.w3.org/2004/02/skos/core#closeMatch> <http://www.opengis.net/ont/sf#Point> .


###  https://schema.bco-dmo.org/v0.1/ComputerLanguage
<https://schema.bco-dmo.org/v0.1/ComputerLanguage> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Language> ;
                                                   owl:disjointWith <https://schema.bco-dmo.org/v0.1/NaturalLanguage> ;
                                                   rdfs:comment "Programming languages such as Python, Go, Rust and Java." ;
                                                   rdfs:label "ComputerLanguage" ;
                                                   <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/ComputerLanguage> .


###  https://schema.bco-dmo.org/v0.1/ConsumeAction
<https://schema.bco-dmo.org/v0.1/ConsumeAction> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Action> ;
                                                rdfs:comment "The act of consuming an Entity." ;
                                                rdfs:label "ConsumeAction" ;
                                                <http://www.w3.org/2004/02/skos/core#closeMatch> "https://schema.org/ConsumeAction" .


###  https://schema.bco-dmo.org/v0.1/CreativeWork
<https://schema.bco-dmo.org/v0.1/CreativeWork> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                               rdfs:comment "Any work that can be created by some Agent" ;
                                               rdfs:label "Creative Work" ;
                                               <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/CreativeWork> .


###  https://schema.bco-dmo.org/v0.1/CreativeWorkStatus
<https://schema.bco-dmo.org/v0.1/CreativeWorkStatus> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                                     rdfs:comment "A state of for some createive work." ;
                                                     rdfs:label "CreativeWorkStatus" .


###  https://schema.bco-dmo.org/v0.1/Cruise
<https://schema.bco-dmo.org/v0.1/Cruise> rdf:type owl:Class ;
                                         rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Deployment>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://schema.bco-dmo.org/v0.1/onPlatform> ;
                                                                                  owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Vessel>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                         rdfs:comment "A research vessel cruise, a specialisation of Platform for vessel-type platforms." ;
                                         rdfs:label "Cruise" .


###  https://schema.bco-dmo.org/v0.1/CryptographicHash
<https://schema.bco-dmo.org/v0.1/CryptographicHash> rdf:type owl:Class ;
                                                    rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Identifier>
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://schema.bco-dmo.org/v0.1/identifierScheme> ;
                                                                                             owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm>
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                    rdfs:comment "A cryptographic hash (e.g. MD5) used as a file integrity checksum." ;
                                                    rdfs:label "Cryptographic Hash" .


###  https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm
<https://schema.bco-dmo.org/v0.1/CryptographicHashAlgorithm> rdf:type owl:Class ;
                                                             rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/IdentifierScheme> ;
                                                             rdfs:comment "A mathematical function that transforms any arbitrary amount of input data into a fixed-length string of characters (identifierValue), acting as a secure \"digital fingerprint\" or \"digest\"" ;
                                                             rdfs:label "Cryptographic Hash Algorithm" .


###  https://schema.bco-dmo.org/v0.1/CurrentState
<https://schema.bco-dmo.org/v0.1/CurrentState> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                               rdfs:comment "The current editorial/curation state of a CreativeWork" ;
                                               rdfs:label "Current State" .


###  https://schema.bco-dmo.org/v0.1/DOIDataset
<https://schema.bco-dmo.org/v0.1/DOIDataset> rdf:type owl:Class ;
                                             rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <https://schema.bco-dmo.org/v0.1/identifier> ;
                                                                                      owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <https://schema.bco-dmo.org/v0.1/identifierScheme> ;
                                                                                                           owl:hasValue <https://schema.bco-dmo.org/v0.1/IdentifierScheme_DOI>
                                                                                                         ]
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                             rdfs:comment "A versioned BCO-DMO dataset that has been assigned a DOI." ;
                                             rdfs:label "DOI Dataset" .


###  https://schema.bco-dmo.org/v0.1/DOIIdentifier
<https://schema.bco-dmo.org/v0.1/DOIIdentifier> rdf:type owl:Class ;
                                                rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Identifier>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://schema.bco-dmo.org/v0.1/identifierScheme> ;
                                                                                         owl:hasValue <https://schema.bco-dmo.org/v0.1/IdentifierScheme_DOI>
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                                rdfs:comment "A Digital Object Identifier." ;
                                                rdfs:label "DOI Identifier" .


###  https://schema.bco-dmo.org/v0.1/DOIStatus
<https://schema.bco-dmo.org/v0.1/DOIStatus> rdf:type owl:Class ;
                                            rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/CreativeWorkStatus>
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/status>
                                                                                                    ] ;
                                                                                     owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/DOIDataset>
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ] ;
                                            rdfs:comment "The lifecycle status of a DOI Dataset (Draft, Reserved, Published, etc.)." ;
                                            rdfs:label "DOI Status" .


###  https://schema.bco-dmo.org/v0.1/DataFile
<https://schema.bco-dmo.org/v0.1/DataFile> rdf:type owl:Class ;
                                           rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/FileDescriptor>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/dataFile>
                                                                                                   ] ;
                                                                                    owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                           rdfs:comment "A primary or supplemental data file distributed as part of a dataset." ;
                                           rdfs:label "Data File" .


###  https://schema.bco-dmo.org/v0.1/DataManagementPlan
<https://schema.bco-dmo.org/v0.1/DataManagementPlan> rdf:type owl:Class ;
                                                     rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/FileDescriptor>
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/dataManagementPlan>
                                                                                                             ] ;
                                                                                              owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ] ;
                                                     rdfs:comment "A plan describing how a research activity will manage and archive data products produced." ;
                                                     rdfs:label "DataManagementPlan" .


###  https://schema.bco-dmo.org/v0.1/Dataset
<https://schema.bco-dmo.org/v0.1/Dataset> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/CreativeWork> ;
                                          rdfs:comment "A dataset which may be internal or external to BCO-DMO." ;
                                          rdfs:label "Dataset" ;
                                          <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Dataset> .


###  https://schema.bco-dmo.org/v0.1/DatasetAward
<https://schema.bco-dmo.org/v0.1/DatasetAward> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Situation> ,
                                                               [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <https://schema.bco-dmo.org/v0.1/fundedByAward> ;
                                                                                        owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Award>
                                                                                      ]
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/forDataset>
                                                                                                       ] ;
                                                                                        owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ] ;
                                               rdfs:comment "The connection between a dataset and the award the funded its generation" ;
                                               rdfs:label "DatasetAward" .


###  https://schema.bco-dmo.org/v0.1/DatasetDeployment
<https://schema.bco-dmo.org/v0.1/DatasetDeployment> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Situation> ,
                                                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://schema.bco-dmo.org/v0.1/forDataset> ;
                                                                                             owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                                           ]
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://schema.bco-dmo.org/v0.1/fromDeployment> ;
                                                                                             owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Deployment>
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                    rdfs:comment "A deployment as referenced within a specific dataset, with dataset-specific properties." ;
                                                    rdfs:label "Dataset Deployment" .


###  https://schema.bco-dmo.org/v0.1/DatasetInstrument
<https://schema.bco-dmo.org/v0.1/DatasetInstrument> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Situation> ,
                                                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://schema.bco-dmo.org/v0.1/forDataset> ;
                                                                                             owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                                           ]
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://schema.bco-dmo.org/v0.1/isDefinedAs> ;
                                                                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                             owl:onClass <https://schema.bco-dmo.org/v0.1/Instrument>
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ] ;
                                                    rdfs:comment "An instrument as referenced within a specific dataset, with dataset-specific properties." ;
                                                    rdfs:label "Dataset Instrument" .


###  https://schema.bco-dmo.org/v0.1/DatasetParameter
<https://schema.bco-dmo.org/v0.1/DatasetParameter> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Situation> ,
                                                                   [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <https://schema.bco-dmo.org/v0.1/forDataset> ;
                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                            owl:onClass <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                                          ]
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <https://schema.bco-dmo.org/v0.1/isDefinedAs> ;
                                                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                            owl:onClass <https://schema.bco-dmo.org/v0.1/Parameter>
                                                                                          ]
                                                                                        ) ;
                                                                     rdf:type owl:Class
                                                                   ] ;
                                                   rdfs:comment "A parameter as instantiated within a specific dataset column, with dataset-level name, description, units, and format." ;
                                                   rdfs:label "Dataset Parameter" .


###  https://schema.bco-dmo.org/v0.1/DatasetParameterAttribute
<https://schema.bco-dmo.org/v0.1/DatasetParameterAttribute> rdf:type owl:Class ;
                                                            rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                                            rdfs:comment "An attribute of a dataset parameter that provides more context as to how it could be used." ;
                                                            rdfs:label "DatasetParameterAttribute" .


###  https://schema.bco-dmo.org/v0.1/DatasetType
<https://schema.bco-dmo.org/v0.1/DatasetType> rdf:type owl:Class ;
                                              rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/DefinedType>
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/datasetType>
                                                                                                      ] ;
                                                                                       owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Dataset>
                                                                                     ]
                                                                                   ) ;
                                                                rdf:type owl:Class
                                                              ] ;
                                              rdfs:comment "A category describing the type of dataset (e.g. Cruise Data, Model Output)." ;
                                              rdfs:label "Dataset Type" .


###  https://schema.bco-dmo.org/v0.1/Datatype
<https://schema.bco-dmo.org/v0.1/Datatype> rdf:type owl:Class ;
                                           rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/DefinedType>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/dataType>
                                                                                                   ] ;
                                                                                    owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/DatasetParameter>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                           rdfs:comment "The data type of a dataset parameter column (e.g. string, integer, float)." ;
                                           rdfs:label "Datatype" ;
                                           <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/DataType> .


###  https://schema.bco-dmo.org/v0.1/DefinedType
<https://schema.bco-dmo.org/v0.1/DefinedType> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                              rdfs:comment "A type of something" ;
                                              rdfs:label "DefinedType" .


###  https://schema.bco-dmo.org/v0.1/Deployment
<https://schema.bco-dmo.org/v0.1/Deployment> rdf:type owl:Class ;
                                             rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Event>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <https://schema.bco-dmo.org/v0.1/onPlatform> ;
                                                                                      owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Platform>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                             rdfs:comment "A scientific deployment (cruise, expedition, mooring deployment) during which data were collected." ;
                                             rdfs:label "Deployment" ;
                                             <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://schema.org/Event> .


###  https://schema.bco-dmo.org/v0.1/DeploymentEntityMatch
<https://schema.bco-dmo.org/v0.1/DeploymentEntityMatch> rdf:type owl:Class ;
                                                        rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/EntityMatch>
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty rdf:object ;
                                                                                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                                               ]
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty rdf:subject ;
                                                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                                 owl:onClass <https://schema.bco-dmo.org/v0.1/Deployment>
                                                                                               ]
                                                                                             ) ;
                                                                          rdf:type owl:Class
                                                                        ] ;
                                                        rdfs:label "DeploymentEntityMatch" .


###  https://schema.bco-dmo.org/v0.1/EmailAddress
<https://schema.bco-dmo.org/v0.1/EmailAddress> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/IdentifierString> ;
                                               rdfs:isDefinedBy <https://schema.bco-dmo.org/v0.1/Datatype_EmailAddress> ;
                                               rdfs:label "Email Address" .


###  https://schema.bco-dmo.org/v0.1/EmbargoPolicy
<https://schema.bco-dmo.org/v0.1/EmbargoPolicy> rdf:type owl:Class ;
                                                rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Policy>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://schema.bco-dmo.org/v0.1/modifiesAction> ;
                                                                                         owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/ConsumeAction>
                                                                                       ]
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://schema.bco-dmo.org/v0.1/target> ;
                                                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                         owl:onClass <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                                       ]
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://schema.bco-dmo.org/v0.1/expirationDate> ;
                                                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                         owl:onDataRange xsd:date
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                                rdfs:comment "A policy that restricts access to a dataset until an expiration date." ;
                                                rdfs:label "Embargo Policy" .


###  https://schema.bco-dmo.org/v0.1/EmbargoReleasePolicy
<https://schema.bco-dmo.org/v0.1/EmbargoReleasePolicy> rdf:type owl:Class ;
                                                       rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Policy> ;
                                                       rdfs:comment "A policy that allows access to a FileDescriptor when its overarching Dataset is under an embargo." ;
                                                       rdfs:label "EmbargoReleasePolicy" .


###  https://schema.bco-dmo.org/v0.1/Entity
<https://schema.bco-dmo.org/v0.1/Entity> rdf:type owl:Class ;
                                         rdfs:comment "A BCO-DMO specific concept" ;
                                         rdfs:label "Entity" .


###  https://schema.bco-dmo.org/v0.1/EntityMatch
<https://schema.bco-dmo.org/v0.1/EntityMatch> rdf:type owl:Class ;
                                              rdfs:subClassOf rdf:Statement ,
                                                              [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Situation>
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty rdf:object ;
                                                                                       owl:cardinality "1"^^xsd:nonNegativeInteger
                                                                                     ]
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty rdf:subject ;
                                                                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                       owl:onClass <https://schema.bco-dmo.org/v0.1/Entity>
                                                                                     ]
                                                                                   ) ;
                                                                rdf:type owl:Class
                                                              ] ;
                                              rdfs:comment "A link between two entities that are related in some way as defined by rdf:predicate. This entity allows for annotating details of the match." ;
                                              rdfs:label "EntityMatch" .


###  https://schema.bco-dmo.org/v0.1/Event
<https://schema.bco-dmo.org/v0.1/Event> rdf:type owl:Class ;
                                        rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Situation>
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://schema.bco-dmo.org/v0.1/hasTime> ;
                                                                                 owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/TemporalEntity>
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                        rdfs:comment "A dynamic situation in which something unique or impotant happened." ;
                                        rdfs:label "Event" ;
                                        <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Event> .


###  https://schema.bco-dmo.org/v0.1/File
<https://schema.bco-dmo.org/v0.1/File> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/CreativeWork> ;
                                       rdfs:comment "A physical file (byte stream) associated with a dataset or package." ;
                                       rdfs:label "File" ;
                                       <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/DigitalDocument> .


###  https://schema.bco-dmo.org/v0.1/FileDescriptor
<https://schema.bco-dmo.org/v0.1/FileDescriptor> rdf:type owl:Class ;
                                                 rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Situation>
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty <https://schema.bco-dmo.org/v0.1/describesFile> ;
                                                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                          owl:onClass <https://schema.bco-dmo.org/v0.1/File>
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ] ;
                                                 rdfs:comment "A context-specific description of a file. The context could be data, metadata or supplemental documentation." ;
                                                 rdfs:label "File Descriptor" .


###  https://schema.bco-dmo.org/v0.1/FileType
<https://schema.bco-dmo.org/v0.1/FileType> rdf:type owl:Class ;
                                           rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/DefinedType>
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/fileType>
                                                                                                   ] ;
                                                                                    owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/File>
                                                                                  ]
                                                                                ) ;
                                                             rdf:type owl:Class
                                                           ] ;
                                           rdfs:comment "A file format type, characterised by a label and MIME type (e.g. CSV, XML, PDF)." ;
                                           rdfs:label "File Type" .


###  https://schema.bco-dmo.org/v0.1/FundingAgency
<https://schema.bco-dmo.org/v0.1/FundingAgency> rdf:type owl:Class ;
                                                rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Organization>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://schema.bco-dmo.org/v0.1/grantedAward> ;
                                                                                         owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Award>
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                                rdfs:comment "An Organization that has provided some funding award" ;
                                                rdfs:label "Funding Agency" .


###  https://schema.bco-dmo.org/v0.1/GeographicalLocation
<https://schema.bco-dmo.org/v0.1/GeographicalLocation> rdf:type owl:Class ;
                                                       rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                                       rdfs:comment "A spatial extent or named location associated with a dataset, deployment, project, or program." ;
                                                       rdfs:label "Geographical Location" ;
                                                       <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Place> .


###  https://schema.bco-dmo.org/v0.1/Geometry
<https://schema.bco-dmo.org/v0.1/Geometry> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                           rdfs:comment "An abstract spatial geometry." ;
                                           rdfs:label "Geometry" ;
                                           <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/GeospatialGeometry> ;
                                           <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.opengis.net/ont/sf#Geometry> .


###  https://schema.bco-dmo.org/v0.1/Identifier
<https://schema.bco-dmo.org/v0.1/Identifier> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                             rdfs:comment "An identifier assigned to a resource by some scheme." ;
                                             rdfs:label "Identifier" .


###  https://schema.bco-dmo.org/v0.1/IdentifierScheme
<https://schema.bco-dmo.org/v0.1/IdentifierScheme> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                                   rdfs:comment "A named scheme or authority that mints identifiers (DOI, ROR, ORCID, etc.)." ;
                                                   rdfs:label "Identifier Scheme" .


###  https://schema.bco-dmo.org/v0.1/IdentifierString
<https://schema.bco-dmo.org/v0.1/IdentifierString> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/String> ;
                                                   rdfs:isDefinedBy <https://schema.bco-dmo.org/v0.1/Datatype_Identifier> ;
                                                   rdfs:label "IdentifierString"@en .


###  https://schema.bco-dmo.org/v0.1/Image
<https://schema.bco-dmo.org/v0.1/Image> rdf:type owl:Class ;
                                        rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/File>
                                                                               [ rdf:type owl:Restriction ;
                                                                                 owl:onProperty <https://schema.bco-dmo.org/v0.1/fileType> ;
                                                                                 owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/ImageFileType>
                                                                               ]
                                                                             ) ;
                                                          rdf:type owl:Class
                                                        ] ;
                                        rdfs:comment "An image file." ;
                                        rdfs:label "Image" ;
                                        <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/ImageObject> .


###  https://schema.bco-dmo.org/v0.1/ImageFileType
<https://schema.bco-dmo.org/v0.1/ImageFileType> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/FileType> ;
                                                rdfs:comment "Representative of a type of image file." ;
                                                rdfs:label "ImageFileType" .


###  https://schema.bco-dmo.org/v0.1/Instrument
<https://schema.bco-dmo.org/v0.1/Instrument> rdf:type owl:Class ;
                                             rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/DefinedType>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/isDefinedAs>
                                                                                                     ] ;
                                                                                      owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/DatasetInstrument>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                             rdfs:comment "A master (community-level) scientific instrument definition." ;
                                             rdfs:label "Instrument" .


###  https://schema.bco-dmo.org/v0.1/Keyword
<https://schema.bco-dmo.org/v0.1/Keyword> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                          rdfs:comment "A subject keyword associated with a dataset." ;
                                          rdfs:label "Keyword" .


###  https://schema.bco-dmo.org/v0.1/Language
<https://schema.bco-dmo.org/v0.1/Language> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                           rdfs:comment "A natural language used in the dataset metadata." ;
                                           rdfs:label "Language" .


###  https://schema.bco-dmo.org/v0.1/License
<https://schema.bco-dmo.org/v0.1/License> rdf:type owl:Class ;
                                          rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/license>
                                                                                                  ] ;
                                                                                   owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ] ;
                                          rdfs:comment "A  license applied to some creative work." ;
                                          rdfs:label "License" .


###  https://schema.bco-dmo.org/v0.1/Logo
<https://schema.bco-dmo.org/v0.1/Logo> rdf:type owl:Class ;
                                       rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Image> ;
                                       rdfs:comment "An image that is representative of some thing" ;
                                       rdfs:label "Logo" .


###  https://schema.bco-dmo.org/v0.1/MetadataFile
<https://schema.bco-dmo.org/v0.1/MetadataFile> rdf:type owl:Class ;
                                               rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/FileDescriptor>
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/metadataFile>
                                                                                                       ] ;
                                                                                        owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ] ;
                                               rdfs:comment "A metadata file (e.g. ISO 19115-2 XML, dataset description PDF) describing a dataset." ;
                                               rdfs:label "Metadata File" .


###  https://schema.bco-dmo.org/v0.1/MetadataProfile
<https://schema.bco-dmo.org/v0.1/MetadataProfile> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/CreativeWork> ;
                                                  rdfs:comment "A formal metadata profile specification to which the datapackage conforms." ;
                                                  rdfs:label "Metadata Profile" .


###  https://schema.bco-dmo.org/v0.1/NaturalLanguage
<https://schema.bco-dmo.org/v0.1/NaturalLanguage> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Language> ;
                                                  rdfs:comment "Natural languages such as Spanish, Tamil, Hindi, English, etc." ;
                                                  rdfs:label "NaturalLanguage" ;
                                                  <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Language> .


###  https://schema.bco-dmo.org/v0.1/ORCIDIdentifier
<https://schema.bco-dmo.org/v0.1/ORCIDIdentifier> rdf:type owl:Class ;
                                                  rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Identifier>
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <https://schema.bco-dmo.org/v0.1/identifierScheme> ;
                                                                                           owl:hasValue <https://schema.bco-dmo.org/v0.1/IdentifierScheme_ROR>
                                                                                         ]
                                                                                       ) ;
                                                                    rdf:type owl:Class
                                                                  ] ;
                                                  rdfs:comment "An Open Researcher and Contributor ID" ;
                                                  rdfs:label "ORCID Identifier" .


###  https://schema.bco-dmo.org/v0.1/Organization
<https://schema.bco-dmo.org/v0.1/Organization> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Agent> ;
                                               owl:disjointWith <https://schema.bco-dmo.org/v0.1/Person> ;
                                               rdfs:comment "An organisational body such as a publisher, funder, or identifier authority." ;
                                               rdfs:label "Organization" ;
                                               <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Organization> .


###  https://schema.bco-dmo.org/v0.1/Parameter
<https://schema.bco-dmo.org/v0.1/Parameter> rdf:type owl:Class ;
                                            rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/DefinedType>
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/isDefinedAs>
                                                                                                    ] ;
                                                                                     owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/DatasetParameter>
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ] ;
                                            rdfs:comment "A master (community-level) scientific parameter definition." ;
                                            rdfs:label "Parameter" .


###  https://schema.bco-dmo.org/v0.1/Person
<https://schema.bco-dmo.org/v0.1/Person> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Agent> ;
                                         rdfs:comment "A human individual associated with some entity." ;
                                         rdfs:label "Person" ;
                                         <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/Person> .


###  https://schema.bco-dmo.org/v0.1/Platform
<https://schema.bco-dmo.org/v0.1/Platform> rdf:type owl:Class ;
                                           rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                           rdfs:comment "A platform (vessel, buoy, glider, etc.) used for data collection." ;
                                           rdfs:label "Platform" .


###  https://schema.bco-dmo.org/v0.1/PlatformTitle
<https://schema.bco-dmo.org/v0.1/PlatformTitle> rdf:type owl:Class ;
                                                rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Category>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/platformTitle>
                                                                                                        ] ;
                                                                                         owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Platform>
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                                rdfs:comment "A named title/designation for a platform (e.g. the full name of a research vessel)." ;
                                                rdfs:label "Platform Title" .


###  https://schema.bco-dmo.org/v0.1/PlatformType
<https://schema.bco-dmo.org/v0.1/PlatformType> rdf:type owl:Class ;
                                               rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/DefinedType>
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/platformType>
                                                                                                       ] ;
                                                                                        owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Platform>
                                                                                      ]
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ] ;
                                               rdfs:comment "A category of platform (e.g. vessel, mooring, glider)." ;
                                               rdfs:label "Platform Type" .


###  https://schema.bco-dmo.org/v0.1/Policy
<https://schema.bco-dmo.org/v0.1/Policy> rdf:type owl:Class ;
                                         rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Entity>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://schema.bco-dmo.org/v0.1/modifiesAction> ;
                                                                                  owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/ConsumeAction>
                                                                                ]
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <https://schema.bco-dmo.org/v0.1/target> ;
                                                                                  owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Entity>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                         rdfs:comment "An access or governance policy applied to a resource." ;
                                         rdfs:label "Policy" .


###  https://schema.bco-dmo.org/v0.1/Program
<https://schema.bco-dmo.org/v0.1/Program> rdf:type owl:Class ;
                                          rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/ResearchActivity>
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/hasParentProgram>
                                                                                                  ] ;
                                                                                   owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Project>
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ] ;
                                          rdfs:comment "A scientific program (typically a grouping of related projects) associated with a dataset." ;
                                          rdfs:label "Program" .


###  https://schema.bco-dmo.org/v0.1/Project
<https://schema.bco-dmo.org/v0.1/Project> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/ResearchActivity> ;
                                          rdfs:comment "A funded scientific project under which data were collected." ;
                                          rdfs:label "Project" .


###  https://schema.bco-dmo.org/v0.1/Publication
<https://schema.bco-dmo.org/v0.1/Publication> rdf:type owl:Class ;
                                              rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/CreativeWork> ;
                                              rdfs:comment "A scholarly publication related to a dataset (journal article, report, etc.)." ;
                                              rdfs:label "Publication" ;
                                              <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Article> .


###  https://schema.bco-dmo.org/v0.1/RORIdentifier
<https://schema.bco-dmo.org/v0.1/RORIdentifier> rdf:type owl:Class ;
                                                rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Identifier>
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <https://schema.bco-dmo.org/v0.1/identifierScheme> ;
                                                                                         owl:hasValue <https://schema.bco-dmo.org/v0.1/IdentifierScheme_ROR>
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ] ;
                                                rdfs:comment "A Research Organization Registry identifier." ;
                                                rdfs:label "ROR Identifier" .


###  https://schema.bco-dmo.org/v0.1/ResearchActivity
<https://schema.bco-dmo.org/v0.1/ResearchActivity> rdf:type owl:Class ;
                                                   rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Event>
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <https://schema.bco-dmo.org/v0.1/situationInvolves> ;
                                                                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                            owl:onClass <https://schema.bco-dmo.org/v0.1/Agent>
                                                                                          ]
                                                                                        ) ;
                                                                     rdf:type owl:Class
                                                                   ] ;
                                                   rdfs:comment "An activity that enables research. The research typically produces datasets." ;
                                                   rdfs:label "Research Activity" ;
                                                   <http://www.w3.org/2004/02/skos/core#relatedMatch> <https://schema.org/ResearchProject> .


###  https://schema.bco-dmo.org/v0.1/ResourceRelation
<https://schema.bco-dmo.org/v0.1/ResourceRelation> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Category> ;
                                                   rdfs:comment "A controlled-vocabulary term describing the relationship between two resources (aligned to Crossref and DataCite relation types)." ;
                                                   rdfs:label "Resource Relation" .


###  https://schema.bco-dmo.org/v0.1/ResourceRelationGroup
<https://schema.bco-dmo.org/v0.1/ResourceRelationGroup> rdf:type owl:Class ;
                                                        rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Category>
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/inGroup>
                                                                                                                ] ;
                                                                                                 owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/ResourceRelation>
                                                                                               ]
                                                                                             ) ;
                                                                          rdf:type owl:Class
                                                                        ] ;
                                                        rdfs:comment "A grouping category for resource relation types." ;
                                                        rdfs:label "Resource Relation Group" .


###  https://schema.bco-dmo.org/v0.1/Role
<https://schema.bco-dmo.org/v0.1/Role> rdf:type owl:Class ;
                                       rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/DefinedType>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <https://schema.bco-dmo.org/v0.1/roleWeight> ;
                                                                                owl:someValuesFrom xsd:int
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ] ;
                                       rdfs:comment "A functional role performed by an agent (e.g. Principal Investigator, Co-Investigator)." ;
                                       rdfs:label "Role" .


###  https://schema.bco-dmo.org/v0.1/Situation
<https://schema.bco-dmo.org/v0.1/Situation> rdf:type owl:Class ;
                                            rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Entity>
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <https://schema.bco-dmo.org/v0.1/situationInvolves> ;
                                                                                     owl:minCardinality "1"^^xsd:nonNegativeInteger
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ] ;
                                            rdfs:comment "A static or dynamic scenario. A state of affairs that describes some configuration of the world. Most often a situation describes the interaction of 2 or more entities. In some cases these interactions are time bounded and can be labeled as significant events." ;
                                            rdfs:label "Situation" .


###  https://schema.bco-dmo.org/v0.1/String
<https://schema.bco-dmo.org/v0.1/String> rdf:type owl:Class ;
                                         rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Datatype> ;
                                         rdfs:isDefinedBy <https://schema.bco-dmo.org/v0.1/Datatype_String> ;
                                         rdfs:label "String"@en ;
                                         <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/Text> .


###  https://schema.bco-dmo.org/v0.1/SupplementalDocument
<https://schema.bco-dmo.org/v0.1/SupplementalDocument> rdf:type owl:Class ;
                                                       rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/FileDescriptor>
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty [ owl:inverseOf <https://schema.bco-dmo.org/v0.1/supplementalDocument>
                                                                                                               ] ;
                                                                                                owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/CreativeWork>
                                                                                              ]
                                                                                            ) ;
                                                                         rdf:type owl:Class
                                                                       ] ;
                                                       rdfs:comment "A supplemental (non-primary) document file associated with a dataset." ;
                                                       rdfs:label "Supplemental Document" .


###  https://schema.bco-dmo.org/v0.1/Synonym
<https://schema.bco-dmo.org/v0.1/Synonym> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                          rdfs:comment "An alternative name or synonym, e.g. for a deployment." ;
                                          rdfs:label "Synonym" .


###  https://schema.bco-dmo.org/v0.1/TemporalEntity
<https://schema.bco-dmo.org/v0.1/TemporalEntity> rdf:type owl:Class ;
                                                 rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/Entity> ;
                                                 rdfs:comment "A frame of reference for when something existed or occupied time — it is either a durationless point (an instant) or a thing with some extent in time (an interval)." ;
                                                 rdfs:label "TemporalEntity" ;
                                                 <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.w3.org/2006/time#TemporalEntity> .


###  https://schema.bco-dmo.org/v0.1/TemporalInstant
<https://schema.bco-dmo.org/v0.1/TemporalInstant> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/TemporalEntity> ;
                                                  rdfs:comment "A single point in time associated with a dataset extent or event date." ;
                                                  rdfs:label "Temporal Instant" ;
                                                  <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.w3.org/2006/time#Instant> .


###  https://schema.bco-dmo.org/v0.1/TemporalInterval
<https://schema.bco-dmo.org/v0.1/TemporalInterval> rdf:type owl:Class ;
                                                   rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/TemporalEntity> ;
                                                   rdfs:comment "A time period with a beginning and an end, used to describe dataset temporal coverage." ;
                                                   rdfs:label "Temporal Interval" ;
                                                   <http://www.w3.org/2004/02/skos/core#exactMatch> <http://www.w3.org/2006/time#Interval> .


###  https://schema.bco-dmo.org/v0.1/TimeSeries
<https://schema.bco-dmo.org/v0.1/TimeSeries> rdf:type owl:Class ;
                                             rdfs:subClassOf [ owl:intersectionOf ( <https://schema.bco-dmo.org/v0.1/Event>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <https://schema.bco-dmo.org/v0.1/hasDeployment> ;
                                                                                      owl:someValuesFrom <https://schema.bco-dmo.org/v0.1/Deployment>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                             rdfs:comment "an ordered collection of observations indexed by time, representing the temporal evolution of one or more properties of a feature, system, or phenomenon." ;
                                             rdfs:label "Time Series" ;
                                             <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/EventSeries> .


###  https://schema.bco-dmo.org/v0.1/URL
<https://schema.bco-dmo.org/v0.1/URL> rdf:type owl:Class ;
                                      rdfs:subClassOf <https://schema.bco-dmo.org/v0.1/IdentifierString> ;
                                      rdfs:isDefinedBy <https://schema.bco-dmo.org/v0.1/Datatype_URL> ;
