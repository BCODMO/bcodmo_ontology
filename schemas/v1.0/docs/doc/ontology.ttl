:DOIStatus_Draft rdf:type owl:NamedIndividual ,
                          :DOIStatus ;
                 :label "Draft" ;
                 rdfs:comment "The DOI record has been created locally but not yet registered." .


###  https://schema.bco-dmo.org/v1.0/DOIStatus_PublishFailed
:DOIStatus_PublishFailed rdf:type owl:NamedIndividual ,
                                  :DOIStatus ;
                         :label "Publish Failed" ;
                         rdfs:comment "DOI metadata publication failed after initiation." .


###  https://schema.bco-dmo.org/v1.0/DOIStatus_PublishInProgress
:DOIStatus_PublishInProgress rdf:type owl:NamedIndividual ,
                                      :DOIStatus ;
                             :label "Publish in Progress" ;
                             rdfs:comment "DOI metadata submission to the minter is in progress." .


###  https://schema.bco-dmo.org/v1.0/DOIStatus_PublishInitiateFailed
:DOIStatus_PublishInitiateFailed rdf:type owl:NamedIndividual ,
                                          :DOIStatus ;
                                 :label "Publish Initiate Failed" ;
                                 rdfs:comment "Initiating the DOI metadata publication failed." .


###  https://schema.bco-dmo.org/v1.0/DOIStatus_Published
:DOIStatus_Published rdf:type owl:NamedIndividual ,
                              :DOIStatus ;
                     :label "Published" ;
                     rdfs:comment "The DOI is registered and publicly resolvable (Registered with DataCite)." .


###  https://schema.bco-dmo.org/v1.0/DOIStatus_Reserved
:DOIStatus_Reserved rdf:type owl:NamedIndividual ,
                             :DOIStatus ;
                    :label "Reserved" ;
                    rdfs:comment "The DOI has been reserved/registered as Findable with DataCite." .


