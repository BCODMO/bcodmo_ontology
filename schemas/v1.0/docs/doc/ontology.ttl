                                                 rdfs:range xsd:date ;
                                                 rdfs:comment "The date on which an embargo expires and the dataset becomes publicly accessible." ;
                                                 rdfs:label "expirationDate" ;
                                                 <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/expires> .


###  https://schema.bco-dmo.org/v0.1/externalWebsite
<https://schema.bco-dmo.org/v0.1/externalWebsite> rdf:type owl:DatatypeProperty ;
                                                  rdfs:domain <https://schema.bco-dmo.org/v0.1/Entity> ;
