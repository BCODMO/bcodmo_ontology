:DatasetParameterAttribute_PrimaryDepthVariable rdf:type owl:NamedIndividual ,
                                                         :DatasetParameterAttribute ;
                                                :label "Primary Depth Variable" ;
                                                rdfs:label "Dataset Parameter Attribute: Primary Depth Variable" .


