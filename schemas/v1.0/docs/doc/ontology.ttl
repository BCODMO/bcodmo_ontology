:DatasetParameterAttribute_PrimaryLatitudeVariable rdf:type owl:NamedIndividual ,
                                                            :DatasetParameterAttribute ;
                                                   :label "Primary Latitude Variable" ;
                                                   rdfs:label "Dataset Parameter Attribute: Primary Latitude Variable" .


###  https://schema.bco-dmo.org/v1.0/DatasetParameterAttribute_PrimaryLongitudeVariable
:DatasetParameterAttribute_PrimaryLongitudeVariable rdf:type owl:NamedIndividual ,
                                                             :DatasetParameterAttribute ;
                                                    :label "Primary Longitude Variable" ;
                                                    rdfs:label "Dataset Parameter Attribute: Primary Longtiude Variable" .


###  https://schema.bco-dmo.org/v1.0/DatasetType_Code
:DatasetType_Code rdf:type owl:NamedIndividual ,
                           :DatasetType ;
                  :label "Code" ;
                  rdfs:comment "Software/code as a product of some research project" ;
                  rdfs:label "Dataset Type: Code" .


###  https://schema.bco-dmo.org/v1.0/DatasetType_CruiseReport
:DatasetType_CruiseReport rdf:type owl:NamedIndividual ,
                                   :DatasetType ;
                          :label "Cruise Report" ;
