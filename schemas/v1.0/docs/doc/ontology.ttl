                                            rdfs:comment "The given (first) name of a person." ;
                                            rdfs:label "givenName" ;
                                            <http://www.w3.org/2004/02/skos/core#exactMatch> <https://schema.org/givenName> .


###  https://schema.bco-dmo.org/v0.1/hasReportURL
<https://schema.bco-dmo.org/v0.1/hasReportURL> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <https://schema.bco-dmo.org/v0.1/Deployment> ;
                                               rdfs:range xsd:anyURI ;
                                               rdfs:comment "A URL linking to the cruise/deployment report." ;
                                               rdfs:label "hasReportURL" .


###  https://schema.bco-dmo.org/v0.1/honorific
<https://schema.bco-dmo.org/v0.1/honorific> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <https://schema.bco-dmo.org/v0.1/Person> ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment "An honorific prefix preceding a Person's name such as Dr/Mrs/Mr." ;
                                            rdfs:label "honorific" ;
                                            <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/honorificPrefix> .


###  https://schema.bco-dmo.org/v0.1/honorificSuffix
<https://schema.bco-dmo.org/v0.1/honorificSuffix> rdf:type owl:DatatypeProperty ;
                                                  rdfs:domain <https://schema.bco-dmo.org/v0.1/Person> ;
                                                  rdfs:range xsd:string ;
                                                  rdfs:comment "An honorific suffix following a Person's name such as M.D./PhD/MSCSW." ;
                                                  rdfs:label "honorificSuffix" ;
                                                  <http://www.w3.org/2004/02/skos/core#exactMatch> "https://schema.org/honorificSuffix" .


###  https://schema.bco-dmo.org/v0.1/identifierValue
<https://schema.bco-dmo.org/v0.1/identifierValue> rdf:type owl:DatatypeProperty ;
                                                  rdfs:domain <https://schema.bco-dmo.org/v0.1/Identifier> ;
                                                  rdfs:range xsd:token ;
                                                  rdfs:comment "The raw identifier string value (e.g. the DOI suffix, the ROR ID)." ;
                                                  rdfs:label "identifierValue" ;
                                                  <http://www.w3.org/2004/02/skos/core#closeMatch> "https://schema.org/identifier" .


###  https://schema.bco-dmo.org/v0.1/isPrimaryDataFile
<https://schema.bco-dmo.org/v0.1/isPrimaryDataFile> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <https://schema.bco-dmo.org/v0.1/DataFile> ;
                                                    rdfs:range xsd:boolean ;
                                                    rdfs:comment "Indicates whether this is the primary data file of a dataset (true/false)." ;
                                                    rdfs:label "isPrimaryDataFile" .


###  https://schema.bco-dmo.org/v0.1/label
<https://schema.bco-dmo.org/v0.1/label> rdf:type owl:DatatypeProperty ;
                                        owl:equivalentProperty <https://schema.bco-dmo.org/v0.1/name> ;
                                        rdfs:domain <https://schema.bco-dmo.org/v0.1/Entity> ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "A human-readable label for any BCO-DMO resource." ;
                                        rdfs:label "label" ;
                                        <http://www.w3.org/2004/02/skos/core#closeMatch> <https://schema.org/name> .


###  https://schema.bco-dmo.org/v0.1/middleName
<https://schema.bco-dmo.org/v0.1/middleName> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <https://schema.bco-dmo.org/v0.1/Person> ;
