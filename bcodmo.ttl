:EntryPointGroup_DatasetMetadata rdf:type owl:NamedIndividual ,
                                          :EntryPointGroup ;
                                 :label "Metadata" ;
                                 rdfs:label "Entry Point Group: Dataset Metadata" .


###  http://schema.bco-dmo.org/ontology/FileType_AudioMPEG
:FileType_AudioMPEG rdf:type owl:NamedIndividual ,
                             :AudioFileType ;
                    :commonFileTypeExtension "m4a"^^xsd:token ,
                                             "mp2"^^xsd:token ,
                                             "mp3"^^xsd:token ,
                                             "mpeg"^^xsd:token ,
                                             "mpega"^^xsd:token ;
                    :mimetype "audio/mpeg"^^xsd:token ;
                    :label "Audio MPEG" ;
                    rdfs:label "File Type: Audio MPEG" .


