:DatasetParameterType_ProfileDiscrete rdf:type owl:NamedIndividual ,
                                               :ProfileDatasetParameterType ;
                                      :isRankable "true"^^xsd:boolean ;
                                      :label "profile discrete" ;
                                      rdfs:label "Dataset Parameter Type: Profile Discrete" .


